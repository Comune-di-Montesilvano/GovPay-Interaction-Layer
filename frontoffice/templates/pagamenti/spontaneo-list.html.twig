{% extends 'base.html.twig' %}

{% block title %}{{ 'Seleziona il servizio da pagare'|trans }} - {{ app_entity.name }}{% endblock %}

{% block content %}

{# ── Page header ── #}
<div class="page-head">
  <div class="container">
    <div class="crumbs">
      <a href="/">{{ 'Home'|trans }}</a>
      <span class="sep">/</span>
      <span class="current">{{ 'Pagamento spontaneo'|trans }}</span>
    </div>
    <h1>{{ 'Genera un pagamento spontaneo'|trans }}</h1>
    <p class="page-sub">{{ 'Seleziona la tipologia di pagamento per continuare. Alcuni servizi ti porteranno su un portale esterno indicato dall\'Ente.'|trans }}</p>
  </div>
</div>

<section class="block">
  <div class="container">

    {# ── Stepper ── #}
    <div class="steps" style="margin-bottom:var(--sp-5);">
      <div class="step active">
        <span class="n">1</span>
        <span>{{ 'Scegli il servizio'|trans }}</span>
      </div>
      <div class="bar"></div>
      <div class="step">
        <span class="n">2</span>
        <span>{{ 'Compila il modulo'|trans }}</span>
      </div>
      <div class="bar"></div>
      <div class="step">
        <span class="n">3</span>
        <span>{{ 'Avviso generato'|trans }}</span>
      </div>
    </div>

    {% if selection_error %}
      <div class="alert alert-warning" style="margin-bottom:var(--sp-4);" role="alert">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="alert-icon" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <div>{{ selection_error }}</div>
      </div>
    {% endif %}

    {# ── Search ── #}
    <div class="field" style="max-width:480px;margin-bottom:var(--sp-5);">
      <div style="position:relative;">
        <input
          id="serviceSearch"
          type="search"
          class="input"
          placeholder="{{ 'Cerca per tipologia o descrizione'|trans }}"
          autocomplete="off"
          style="padding-left:38px;"
        >
        <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--fg-3);pointer-events:none;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </div>
    </div>

    {# ── Marca da Bollo card (gold, separata dalla griglia) ── #}
    {% if bollot_attivo %}
      <div class="bollo-spontaneo-wrap" style="margin-bottom:var(--sp-5);">
        <div class="bollo-card bollo-card--inline">
          <div class="bollo-card-badge">
            <span class="badge-gold">
              <span class="badge-dot"></span>
              {{ 'Disponibile'|trans }}
            </span>
          </div>
          <div class="bollo-card-header">
            <div class="bollo-icon-circle">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2" stroke-dasharray="2 2"/>
                <circle cx="12" cy="12" r="3.5" fill="var(--ms-gold-100)" stroke="var(--ms-gold-600)"/>
                <path d="M12 9v6M9 12h6"/>
              </svg>
            </div>
            <h3>{{ 'Marca da Bollo Digitale'|trans }}</h3>
          </div>
          <p class="bollo-card-body">
            {{ 'Acquista ed emetti online una marca da bollo digitale (tassa di bollo telematica) per le tue istanze amministrative.'|trans }}
          </p>
          <div class="bollo-card-footer">
            <a href="/pagamento-bollo" class="btn-gold">
              <span>{{ 'Paga Marca da Bollo'|trans }}</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    {% endif %}

    {# ── Services grid ── #}
    {% set all_services = (internal_services|default([]))|merge(external_services|default([])) %}
    {% if all_services %}
      <div class="svc-grid" id="svc-grid">
        {% for service in all_services %}
          {% set isExternal = (service.type|default('internal')) == 'external' %}
          <a
            class="svc-tile{{ isExternal ? ' svc-tile--external' : '' }}"
            href="/pagamento-spontaneo?tipologia={{ (service.slug|default(service.id))|url_encode }}"
            data-service-id="{{ service.id|default('')|e('html_attr') }}"
            data-service-label="{{ service.label|default('')|e('html_attr') }}"
            data-service-desc="{{ service.descrizione_estesa|default('')|e('html_attr') }}"
          >
            <div class="icon-wrap">
              {% if isExternal %}
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              {% else %}
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              {% endif %}
            </div>
            <h3>{{ service.label }}</h3>
            <p>
              {% if service.descrizione_estesa is defined and service.descrizione_estesa is not empty %}
                {{ service.descrizione_estesa }}
              {% elseif isExternal %}
                {{ 'Verrai reindirizzato al portale esterno dell\'Ente.'|trans }}
              {% else %}
                {{ 'Richiedi l\'emissione dell\'avviso e completa il pagamento su questo portale.'|trans }}
              {% endif %}
            </p>
            <span class="arrow">
              {{ isExternal ? 'Vai al servizio'|trans : 'Seleziona'|trans }}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        {% endfor %}
      </div>
      <p id="svc-empty" style="display:none;color:var(--fg-3);margin-top:var(--sp-4);">{{ 'Nessun servizio trovato per la ricerca effettuata.'|trans }}</p>
    {% else %}
      <p style="color:var(--fg-3);">{{ 'Al momento non sono disponibili tipologie.'|trans }}</p>
    {% endif %}

  </div>
</section>

{% endblock %}

{% block head %}
<style>
.bollo-card--inline {
  display: flex; flex-direction: row; align-items: center; gap: var(--sp-4);
  max-width: 100%; padding: var(--sp-4) var(--sp-5);
  background: #FFFDF5 !important;
  border: 1.5px solid #F1E2B3 !important;
  box-shadow: 0 4px 12px rgba(228, 189, 86, 0.08) !important;
}
.bollo-card--inline::before {
  background: radial-gradient(circle, rgba(228, 189, 86, 0.03) 0%, transparent 60%) !important;
}
.bollo-card--inline:hover {
  border-color: var(--ms-gold-400) !important;
  box-shadow: 0 6px 16px rgba(228, 189, 86, 0.15) !important;
}
.bollo-card--inline .bollo-card-header h3 {
  color: var(--bi-navy) !important;
}
.bollo-card--inline .bollo-card-body {
  color: var(--fg-2) !important;
}
.bollo-card--inline .bollo-icon-circle {
  background: rgba(228, 189, 86, 0.15) !important;
  border-color: rgba(228, 189, 86, 0.35) !important;
  color: #B38600 !important;
}
.bollo-card--inline .badge-gold {
  background: #FDF8E7 !important;
  border-color: rgba(228, 189, 86, 0.4) !important;
  color: #B38600 !important;
}
.bollo-card--inline .badge-dot {
  background-color: #B38600 !important;
  box-shadow: 0 0 8px #B38600 !important;
}
.bollo-card--inline .bollo-card-header { flex: 0 0 auto; flex-direction: row; align-items: center; gap: var(--sp-3); margin: 0; }
.bollo-card--inline .bollo-card-body  { flex: 1 1 0; margin: 0; font-size: 14px; }
.bollo-card--inline .bollo-card-footer { flex: 0 0 auto; margin: 0; }
.bollo-card--inline .bollo-card-badge  { position: absolute; top: -12px; right: var(--sp-4); }
.bollo-spontaneo-wrap { position: relative; }
@media (max-width: 640px) {
  .bollo-card--inline { flex-direction: column; align-items: flex-start; }
  .bollo-card--inline .bollo-card-footer { align-self: stretch; }
  .bollo-card--inline .bollo-card-footer .btn-gold { width: 100%; justify-content: center; }
  .bollo-card--inline .bollo-card-badge { position: static; margin-bottom: var(--sp-2); }
}
</style>
{% endblock %}

{% block scripts %}
{{ parent() }}
<script>
(function(){
  function initServiceSearch(){
    var input = document.getElementById('serviceSearch');
    if (!input) return;

    function safeLower(s){ return (s || '').toString().toLowerCase(); }
    function foldAccents(s){
      try { return s.normalize('NFD').replace(/[̀-ͯ]/g, ''); } catch(e){ return s; }
    }
    function tokenize(s){
      var x = foldAccents(safeLower(s)).trim().replace(/[^a-z0-9]+/g, ' ').trim();
      if (!x) return [];
      return x.split(/\s+/).filter(Boolean);
    }
    function bestScore(qt, idT, lblT, descT){
      var best = 0;
      lblT.forEach(function(t){ if(t===qt) best=Math.max(best,60); else if(t.indexOf(qt)===0) best=Math.max(best,50); });
      idT.forEach(function(t){ if(t===qt) best=Math.max(best,40); else if(t.indexOf(qt)===0) best=Math.max(best,30); });
      descT.forEach(function(t){ if(t===qt) best=Math.max(best,10); else if(t.indexOf(qt)===0) best=Math.max(best,8); });
      return best;
    }

    var tiles = Array.prototype.slice.call(document.querySelectorAll('#svc-grid [data-service-label]'));
    var emptyMsg = document.getElementById('svc-empty');
    var entries = tiles.map(function(tile, i){
      return {
        el: tile,
        origIdx: i,
        idT: tokenize(tile.getAttribute('data-service-id') || ''),
        lblT: tokenize(tile.getAttribute('data-service-label') || ''),
        descT: tokenize(tile.getAttribute('data-service-desc') || ''),
        lblSort: foldAccents(safeLower(tile.getAttribute('data-service-label') || '')).trim()
      };
    });

    function applyFilter(){
      var qT = tokenize(input.value || '');
      var grid = document.getElementById('svc-grid');
      if (!grid) return;
      var visibleCount = 0;

      entries.forEach(function(e){
        var score = 0, matched = 0;
        if (qT.length > 0) {
          qT.forEach(function(qt){
            if (qt.length < 2) return;
            var s = bestScore(qt, e.idT, e.lblT, e.descT);
            if (s > 0){ matched++; score += s; }
          });
          score = matched > 0 ? matched * 1000 + score : 0;
        }
        e._score = score;
        e._matched = matched;
      });

      if (qT.length === 0) {
        entries.sort(function(a,b){ return a.origIdx - b.origIdx; });
        entries.forEach(function(e){ e.el.style.display = ''; grid.appendChild(e.el); visibleCount++; });
      } else {
        var visible = entries.filter(function(e){ return e._score > 0; });
        var hidden = entries.filter(function(e){ return e._score === 0; });
        visible.sort(function(a,b){
          if (b._matched !== a._matched) return b._matched - a._matched;
          if (b._score !== a._score) return b._score - a._score;
          return a.lblSort < b.lblSort ? -1 : a.lblSort > b.lblSort ? 1 : a.origIdx - b.origIdx;
        });
        visible.forEach(function(e){ e.el.style.display = ''; grid.appendChild(e.el); });
        hidden.forEach(function(e){ e.el.style.display = 'none'; });
        visibleCount = visible.length;
      }

      if (emptyMsg) emptyMsg.style.display = visibleCount === 0 ? '' : 'none';
    }

    input.addEventListener('input', applyFilter);
    applyFilter();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initServiceSearch);
  } else {
    initServiceSearch();
  }
})();
</script>
{% endblock %}
