{% extends 'base.html.twig' %}

{% block title %}{{ 'Troppi tentativi'|trans }} – {{ app_entity.name }}{% endblock %}

{% block content %}
<section class="block">
  <div class="container">
    <div style="max-width:480px;margin:0 auto;">
      <div class="card card-pad" style="text-align:center;padding:var(--sp-7) var(--sp-5);">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--ms-warning,#f59e0b);margin:0 auto var(--sp-4);" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5"/><path d="M12 16h.01"/></svg>
        <h1 style="font-size:20px;margin:0 0 var(--sp-3);">{{ 'Troppi tentativi'|trans }}</h1>
        <p style="margin:0 0 var(--sp-3);color:var(--fg-1);">{{ 'Per la tua sicurezza abbiamo temporaneamente limitato le richieste da questa connessione.'|trans }}</p>
        <p style="margin:0 0 var(--sp-5);color:var(--fg-2);">{{ 'Riprova tra qualche minuto.'|trans }}</p>
        <a class="btn btn-outline" href="/">{{ 'Torna alla home'|trans }}</a>
      </div>
    </div>
  </div>
</section>
{% endblock %}
