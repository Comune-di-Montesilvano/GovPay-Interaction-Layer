{% extends 'base.html.twig' %}

{% block title %}{{ 'Troppi tentativi'|trans }} – {{ app_entity.name }}{% endblock %}

{% block content %}
  <section class="container py-5">
    <div class="row justify-content-center">
      <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-warning shadow-sm">
          <div class="card-body p-4 p-md-5 text-center">
            <div class="mb-3">
              <i class="fa-solid fa-hourglass-half text-warning" style="font-size:3rem"></i>
            </div>
            <h1 class="h4 mb-3">{{ 'Troppi tentativi'|trans }}</h1>
            <p class="mb-3">{{ 'Per la tua sicurezza abbiamo temporaneamente limitato le richieste da questa connessione.'|trans }}</p>
            <p class="text-muted mb-4">{{ 'Riprova tra qualche minuto.'|trans }}</p>
            <a class="btn btn-outline-primary" href="/">{{ 'Torna alla home'|trans }}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
{% endblock %}
