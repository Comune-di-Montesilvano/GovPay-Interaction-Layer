{% extends 'base.html.twig' %}

{% block title %}{{ 'Paga un avviso o scarica la ricevuta'|trans }} - {{ app_entity.name }}{% endblock %}

{% set old = form_data|default({}) %}

{% block content %}
{# ── Page header ── #}
<section class="fo-page-header">
  <div class="fo-page-header-inner">
    <nav class="fo-breadcrumb" aria-label="{{ 'Percorso'|trans }}">
      <a href="/">{{ 'Home'|trans }}</a>
      <span class="fo-breadcrumb-sep" aria-hidden="true">›</span>
      <span aria-current="page">{{ 'Paga un avviso'|trans }}</span>
    </nav>
    <div class="fo-ph-badge">{{ 'Pagamenti pagoPA'|trans }}</div>
    <h1>{{ 'Paga un avviso o scarica la ricevuta'|trans }}</h1>
    <p>{{ 'Inserisci codice avviso e codice fiscale: verifichiamo lo stato e — se già pagato — puoi scaricare subito la ricevuta digitale. Nessun login necessario.'|trans }}</p>
  </div>
</section>

{# ── Form section ── #}
<section class="fo-form-section">
  <div class="container-xxl">
    <div class="row g-4">

      {# ── Main form ── #}
      <div class="col-lg-8">
        <form class="fo-form-card" method="post" action="/pagamento-avviso">
          <div class="fo-form-card-body">
            <div class="d-flex flex-column flex-md-row justify-content-between gap-2 mb-4">
              <div>
                <p class="fo-field-section mb-1">{{ 'Verifica avviso'|trans }}</p>
                <h2 class="h3 mb-0">{{ 'Dati richiesti'|trans }}</h2>
              </div>
              <div class="text-md-end small" style="color:var(--fo-fg-3);">{{ 'Solo due campi obbligatori'|trans }}</div>
            </div>

            {% if form_feedback %}
              <div class="alert alert-{{ form_feedback.type|default('info') }}" role="status">
                <h3 class="h6 mb-1">{{ form_feedback.title|trans }}</h3>
                <p class="mb-0">{{ form_feedback.message|trans }}</p>
              </div>
              {% if form_feedback.type == 'danger' %}
                <div class="mb-3">
                  <p class="small mb-1" style="color:var(--fo-fg-3);">{{ 'Se l\'avviso è stato emesso da un altro ente, puoi provare direttamente sul portale pagoPA:'|trans }}</p>
                  <a href="{{ pay_portal_url|default('https://checkout.pagopa.it/') }}" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary btn-sm">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1" aria-hidden="true">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                    {{ 'Prova su pagoPA Checkout'|trans }}
                  </a>
                </div>
              {% endif %}
            {% endif %}

            <div class="row g-4">
              <div class="col-12">
                <label for="codiceAvviso" class="form-label">{{ 'Codice avviso / IUV *'|trans }}</label>
                <input type="text" class="form-control form-control-lg" id="codiceAvviso" name="codiceAvviso" value="{{ old.codiceAvviso|default('') }}" maxlength="35" required placeholder="0123 4567 8901 2345">
                <div class="form-text">{{ 'Lo trovi sul bollettino o sulla comunicazione inviata dall\'ente.'|trans }}</div>
              </div>
              <div class="col-12">
                <label for="codiceFiscale" class="form-label">{{ 'Codice fiscale / Partita IVA del soggetto pagatore *'|trans }}</label>
                <input type="text" class="form-control" id="codiceFiscale" name="codiceFiscale" value="{{ old.codiceFiscale|default('') }}" maxlength="16" required placeholder="RSSMRA00A01H501Z oppure 01234567890">
                <div class="form-text">{{ 'Inserisci il codice fiscale (16 caratteri) oppure la partita IVA (11 cifre) del soggetto pagatore.'|trans }}</div>
              </div>
            </div>

            <script>
              (function(){
                const cf = document.getElementById('codiceFiscale');
                if(!cf) return;
                const up = function(){ cf.value = (cf.value || '').toUpperCase(); };
                cf.addEventListener('input', up);
                cf.addEventListener('blur', up);
              })();
            </script>

            <div class="alert alert-info mt-4" role="note">
              <p class="mb-1 fw-semibold">{{ 'Cosa succede dopo'|trans }}</p>
              <ol class="ps-3 mb-0">
                <li>{{ 'Verifichiamo lo stato dell\'avviso e l\'importo aggiornato;'|trans }}</li>
                <li>{{ 'se ancora da pagare: scegli il canale e completa su pagoPA — ricevi ricevuta via email;'|trans }}</li>
                <li>{{ 'se già pagato: scarica subito la ricevuta digitale, senza login.'|trans }}</li>
              </ol>
            </div>

            <div class="d-flex gap-3 flex-wrap mt-4">
              <button type="submit" class="btn btn-primary btn-lg px-4">{{ 'Cerca avviso'|trans }}</button>
              <a class="btn btn-outline-secondary btn-lg" href="/">{{ 'Annulla'|trans }}</a>
            </div>
          </div>
        </form>
      </div>

      {# ── Sidebar ── #}
      <div class="col-lg-4">
        <div class="fo-sidebar-card mb-4">
          <div class="fo-sidebar-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 4v12"/><path d="m7 11 5 5 5-5"/><path d="M5 20h14"/>
            </svg>
          </div>
          <h3>{{ 'Già pagato?'|trans }}</h3>
          <p>{{ 'Puoi scaricare la ricevuta digitale inserendo gli stessi dati: codice avviso e codice fiscale. Nessun accesso richiesto.'|trans }}</p>
          <p style="font-size:13px; color:var(--fo-fg-3);">{{ 'Se hai smarrito il codice avviso, contatta l\'ente oppure accedi con SPID/CIE per consultare lo storico delle pendenze.'|trans }}</p>
        </div>
        <div class="fo-sidebar-card mb-4">
          <div class="fo-sidebar-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 20h4l10-10-4-4L4 16z"/><path d="M14 6l4 4"/>
            </svg>
          </div>
          <h3>{{ 'Non hai un avviso?'|trans }}</h3>
          <p>{{ 'Puoi generare un nuovo avviso pagoPA scegliendo il servizio e inserendo i dati del pagatore.'|trans }}</p>
          <a class="btn btn-outline-primary w-100" href="/pagamento-spontaneo">{{ 'Pagamento spontaneo'|trans }}</a>
        </div>
        {% if support_email or support_phone or support_location %}
        <div class="fo-sidebar-card">
          <h3>{{ 'Supporto'|trans }}</h3>
          {% if support_email %}
            <p>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:4px;color:var(--fo-primary);" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 7 9-7"/>
              </svg>
              <a href="mailto:{{ support_email }}" style="color:var(--fo-primary);">{{ support_email }}</a>
            </p>
          {% endif %}
          {% if support_phone %}
            <p>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:4px;color:var(--fo-primary);" aria-hidden="true">
                <path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 6 6L15 14l5 2v3a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2"/>
              </svg>
              {{ support_phone }}{% if support_hours %} <span style="color:var(--fo-fg-3);">({{ support_hours }})</span>{% endif %}
            </p>
          {% endif %}
          {% if support_location %}
            <p style="font-size:13px; color:var(--fo-fg-3);">{{ support_location|raw }}</p>
          {% endif %}
        </div>
        {% endif %}
      </div>

    </div>
  </div>
</section>
{% endblock %}
