{% extends 'base.html.twig' %}

{% block title %}{{ 'Paga un avviso o scarica la ricevuta'|trans }} - {{ app_entity.name }}{% endblock %}

{% set old = form_data|default({}) %}

{% block content %}
{# ── Page header ── #}
<div class="page-head">
  <div class="container">
    <div class="crumbs">
      <a href="/">{{ 'Home'|trans }}</a>
      <span class="sep">/</span>
      <span class="current">{{ 'Paga un avviso'|trans }}</span>
    </div>
    <h1>{{ 'Paga un avviso o scarica la ricevuta'|trans }}</h1>
    <p class="page-sub">{{ 'Inserisci codice avviso e codice fiscale: verifichiamo lo stato e (se già pagato) puoi scaricare subito la ricevuta digitale. Nessun login necessario.'|trans }}</p>
  </div>
</div>

{# ── Content block ── #}
<section class="block">
  <div class="container">
    <div class="split">
      
      {# ── Main form card ── #}
      <div>
        <div class="card card-pad-lg">
          <form method="post" action="/pagamento-avviso">
            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--sp-4);gap:var(--sp-3);flex-wrap:wrap;">
              <h2 style="margin:0;font-size:22px;">{{ 'Dati richiesti'|trans }}</h2>
              <span style="color:var(--fg-3);font-size:13px;">{{ 'Solo due campi obbligatori'|trans }}</span>
            </div>

            {% if form_feedback %}
              <div class="alert alert-{{ form_feedback.type|default('info') }}" style="margin-bottom:var(--sp-4);" role="status">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="alert-icon" aria-hidden="true">
                  {% if form_feedback.type == 'danger' %}
                    <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                  {% else %}
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
                  {% endif %}
                </svg>
                <div>
                  <strong>{{ form_feedback.title|trans }}</strong>
                  <p style="margin:4px 0 0;">{{ form_feedback.message|trans }}</p>
                </div>
              </div>
              {% if form_feedback.type == 'danger' %}
                <div style="margin-bottom:var(--sp-4);">
                  <p style="font-size:13px;color:var(--fg-3);margin-bottom:8px;">{{ 'Se l\'avviso è stato emesso da un altro ente, puoi provare direttamente sul portale pagoPA:'|trans }}</p>
                  <a href="{{ pay_portal_url|default('https://checkout.pagopa.it/') }}" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px; vertical-align: middle;" aria-hidden="true">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                    {{ 'Prova su pagoPA Checkout'|trans }}
                  </a>
                </div>
              {% endif %}
            {% endif %}

            <div class="field">
              <label for="codiceAvviso">{{ 'Codice avviso / IUV'|trans }} <span class="required">*</span></label>
              <input type="text" class="input mono" id="codiceAvviso" name="codiceAvviso" value="{{ old.codiceAvviso|default('') }}" maxlength="35" required placeholder="0123 4567 8901 2345" autocomplete="off">
              <p class="hint">{{ 'Lo trovi sul bollettino o sulla comunicazione inviata dall\'ente.'|trans }}</p>
            </div>

            <div class="field">
              <label for="codiceFiscale">{{ 'Codice fiscale / Partita IVA del soggetto pagatore'|trans }} <span class="required">*</span></label>
              <input type="text" class="input mono" id="codiceFiscale" name="codiceFiscale" value="{{ old.codiceFiscale|default('') }}" maxlength="16" required placeholder="RSSMRA00A01H501Z oppure 01234567890" autocomplete="off">
              <p class="hint">{{ 'Inserisci il codice fiscale (16 caratteri) oppure la partita IVA (11 cifre) del soggetto pagatore.'|trans }}</p>
            </div>

            <div class="alert alert-info" style="margin-top:var(--sp-4);" role="note">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="alert-icon" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
              <div>
                <strong style="display:block;margin-bottom:4px;">{{ 'Cosa succede dopo'|trans }}</strong>
                <ol style="margin:0;padding-left:16px;font-size:13px;line-height:1.6;color:var(--fg-2);">
                  <li>{{ 'Verifichiamo lo stato dell\'avviso e l\'importo aggiornato;'|trans }}</li>
                  <li>{{ 'se ancora da pagare: scegli il canale e completa su pagoPA — ricevi ricevuta via email;'|trans }}</li>
                  <li>{{ 'se già pagato: scarica subito la ricevuta digitale, senza login.'|trans }}</li>
                </ol>
              </div>
            </div>

            <div style="display:flex;gap:var(--sp-3);flex-wrap:wrap;margin-top:var(--sp-5);">
              <a class="btn btn-ghost" href="/">{{ 'Annulla'|trans }}</a>
              <button type="submit" class="btn btn-primary btn-lg">{{ 'Cerca avviso'|trans }}</button>
            </div>
          </form>
        </div>
      </div>

      {# ── Sidebar cards ── #}
      <aside class="aside">
        <div class="card card-pad">
          <div class="fo-sidebar-icon" style="margin-bottom:var(--sp-2);color:var(--fo-primary);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 4v12"/><path d="m7 11 5 5 5-5"/><path d="M5 20h14"/>
            </svg>
          </div>
          <h3>{{ 'Già pagato?'|trans }}</h3>
          <p style="font-size:14px;color:var(--fg-2);line-height:1.6;margin-bottom:8px;">{{ 'Puoi scaricare la ricevuta digitale inserendo gli stessi dati: codice avviso e codice fiscale. Nessun accesso richiesto.'|trans }}</p>
          <p style="font-size:12px;color:var(--fg-3);line-height:1.5;">{{ 'Se hai smarrito il codice avviso, contatta l\'ente oppure accedi con SPID/CIE per consultare lo storico delle pendenze.'|trans }}</p>
        </div>
        
        <div class="card card-pad">
          <div class="fo-sidebar-icon" style="margin-bottom:var(--sp-2);color:var(--fo-primary);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 20h4l10-10-4-4L4 16z"/><path d="M14 6l4 4"/>
            </svg>
          </div>
          <h3>{{ 'Non hai un avviso?'|trans }}</h3>
          <p style="font-size:14px;color:var(--fg-2);line-height:1.6;margin-bottom:14px;">{{ 'Puoi generare un nuovo avviso pagoPA scegliendo il servizio e inserendo i dati del pagatore.'|trans }}</p>
          <a class="btn btn-outline w-100" href="/pagamento-spontaneo">{{ 'Pagamento spontaneo'|trans }}</a>
        </div>

        {% if support_email or support_phone or support_location %}
        <div class="card card-pad">
          <h3>{{ 'Supporto'|trans }}</h3>
          <ul style="margin:0;padding:0;list-style:none;font-size:14px;color:var(--fg-2);display:flex;gap:8px;flex-direction:column;">
            {% if support_email %}
              <li style="display:flex;align-items:center;gap:6px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="color:var(--fo-primary);" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 7 9-7"/>
                </svg>
                <a href="mailto:{{ support_email }}" style="color:var(--fo-primary);text-decoration:none;">{{ support_email }}</a>
              </li>
            {% endif %}
            {% if support_phone %}
              <li style="display:flex;align-items:center;gap:6px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="color:var(--fo-primary);" aria-hidden="true">
                  <path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 6 6L15 14l5 2v3a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2"/>
                </svg>
                <span>{{ support_phone }}</span>{% if support_hours %} <span style="color:var(--fg-3);font-size:12px;">({{ support_hours }})</span>{% endif %}
              </li>
            {% endif %}
            {% if support_location %}
              <li style="font-size:13px;color:var(--fg-3);line-height:1.5;margin-top:4px;">
                {{ support_location|raw }}
              </li>
            {% endif %}
          </ul>
        </div>
        {% endif %}
      </aside>

    </div>
  </div>
</section>
{% endblock %}

{% block scripts %}
{{ parent() }}
<script>
  (function(){
    const cf = document.getElementById('codiceFiscale');
    if(!cf) return;
    const up = function(){ cf.value = (cf.value || '').toUpperCase(); };
    cf.addEventListener('input', up);
    cf.addEventListener('blur', up);
  })();
</script>
{% endblock %}
