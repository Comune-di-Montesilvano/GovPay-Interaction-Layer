{% extends 'base.html.twig' %}

{% block title %}{{ 'Paga un avviso o scarica la ricevuta'|trans }} - {{ app_entity.name }}{% endblock %}

{% set old = form_data|default({}) %}

{% block content %}

{# ── Page header ── #}
<div class="page-head">
  <div class="container">
    <div class="crumbs">
      <a href="/">{{ 'Home'|trans }}</a>
      <span class="sep">/</span>
      <span class="current">{{ 'Paga un avviso'|trans }}</span>
    </div>
    <h1>{{ 'Paga un avviso o scarica la ricevuta'|trans }}</h1>
    <p class="page-sub">{{ 'Inserisci codice avviso e codice fiscale: verifichiamo lo stato e — se già pagato — puoi scaricare subito la ricevuta digitale. Nessun login necessario.'|trans }}</p>
  </div>
</div>

{# ── Content ── #}
<section class="block">
  <div class="container">
    <div class="split">

      {# ── Main form ── #}
      <div>
        <div class="card card-pad-lg">
          <h2 style="margin:0 0 var(--sp-2);font-size:20px;">{{ 'Inserisci codice avviso'|trans }}</h2>
          <p style="margin:0 0 var(--sp-5);font-size:14px;color:var(--fg-2);">{{ 'Solo due campi obbligatori. Il sistema verificherà lo stato e l\'importo aggiornato.'|trans }}</p>

          {% if form_feedback is defined and form_feedback %}
            <div class="alert alert-{{ form_feedback.type|default('info') }}" style="margin-bottom:var(--sp-4);" role="status">
              <div>
                <strong>{{ form_feedback.title|trans }}</strong>
                <p style="margin:4px 0 0;">{{ form_feedback.message|trans }}</p>
              </div>
            </div>
            {% if form_feedback.type == 'danger' %}
              <div style="margin-bottom:var(--sp-4);">
                <p style="font-size:13px;color:var(--fg-3);margin:0 0 var(--sp-2);">{{ 'Se l\'avviso è stato emesso da un altro ente, puoi provare direttamente sul portale pagoPA:'|trans }}</p>
                <a href="{{ pay_portal_url|default('https://checkout.pagopa.it/') }}" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  {{ 'Prova su pagoPA Checkout'|trans }}
                </a>
              </div>
            {% endif %}
          {% endif %}

          <form method="post" action="/pagamento-avviso">
            <div class="field">
              <label for="codiceAvviso">{{ 'Codice avviso / IUV'|trans }}<span class="required">*</span></label>
              <input type="text" class="input mono" id="codiceAvviso" name="codiceAvviso" value="{{ old.codiceAvviso|default('') }}" maxlength="35" required placeholder="0000 0000 0000 0000 00">
              <p class="hint">{{ 'Lo trovi sul bollettino o sulla comunicazione inviata dall\'ente. 18 cifre.'|trans }}</p>
            </div>
            <div class="field">
              <label for="codiceFiscale">{{ 'Codice fiscale / Partita IVA del soggetto pagatore'|trans }}<span class="required">*</span></label>
              <input type="text" class="input mono" id="codiceFiscale" name="codiceFiscale" value="{{ old.codiceFiscale|default('') }}" maxlength="16" required placeholder="RSSMRA85A01F646X">
              <p class="hint">{{ '16 caratteri (codice fiscale) o 11 cifre (partita IVA) dell\'intestatario.'|trans }}</p>
            </div>

            <div class="alert alert-info" style="margin-bottom:var(--sp-5);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="alert-icon" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 8h.01"/></svg>
              <div>
                <strong>{{ 'Cosa succede dopo'|trans }}</strong>
                <ol style="margin:4px 0 0;padding-left:18px;">
                  <li>{{ 'Verifichiamo lo stato dell\'avviso e l\'importo aggiornato;'|trans }}</li>
                  <li>{{ 'se ancora da pagare: scegli il canale e completa su pagoPA;'|trans }}</li>
                  <li>{{ 'se già pagato: scarica subito la ricevuta digitale, senza login.'|trans }}</li>
                </ol>
              </div>
            </div>

            <div style="display:flex;gap:var(--sp-3);flex-wrap:wrap;">
              <button type="submit" class="btn btn-primary btn-lg">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                {{ 'Cerca avviso'|trans }}
              </button>
              <a class="btn btn-ghost" href="/">{{ 'Annulla'|trans }}</a>
            </div>
          </form>
        </div>
      </div>

      {# ── Sidebar ── #}
      <aside class="aside">
        <div class="card card-pad">
          <h3>{{ 'Cosa ti serve'|trans }}</h3>
          <ul>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3h12v18l-3-2-3 2-3-2-3 2z"/></svg>
              <span>Il <strong>codice avviso/IUV</strong> riportato sul documento ricevuto</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span>Il <strong>codice fiscale o P.IVA</strong> del soggetto debitore</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m13 3-7 11h5l-1 7 7-11h-5z"/></svg>
              <span>Un <strong>metodo di pagamento</strong> pagoPA (carta, conto, app)</span>
            </li>
          </ul>
        </div>
        <div class="card card-pad">
          <h3>{{ 'Già pagato?'|trans }}</h3>
          <p style="margin:0;font-size:13px;color:var(--fg-2);line-height:1.55;">{{ 'Inserisci numero avviso e codice fiscale per scaricare la ricevuta senza bisogno di SPID/CIE.'|trans }}</p>
        </div>
        <div class="card card-pad" style="background:var(--bi-primary-a4);border-color:rgba(0,102,204,.2);">
          <h3 style="color:var(--bi-primary);">{{ 'Non hai un avviso?'|trans }}</h3>
          <p style="margin:0 0 var(--sp-3);font-size:13px;color:var(--fg-2);">{{ 'Genera un nuovo pagamento spontaneo selezionando il servizio.'|trans }}</p>
          <a class="btn btn-outline btn-sm" style="width:100%;justify-content:center;" href="/pagamento-spontaneo">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 20h4l10-10-4-4L4 16z"/></svg>
            {{ 'Pagamento spontaneo'|trans }}
          </a>
        </div>
        {% if support_email or support_phone %}
        <div class="card card-pad">
          <h3>{{ 'Supporto'|trans }}</h3>
          <ul>
            {% if support_email %}
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 7 9-7"/></svg>
              <a href="mailto:{{ support_email }}">{{ support_email }}</a>
            </li>
            {% endif %}
            {% if support_phone %}
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 6 6L15 14l5 2v3a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2"/></svg>
              <span class="mono">{{ support_phone }}</span>{% if support_hours %} <span style="font-size:12px;color:var(--fg-3);">({{ support_hours }})</span>{% endif %}
            </li>
            {% endif %}
          </ul>
        </div>
        {% endif %}
      </aside>

    </div>
  </div>
</section>

{% endblock %}

{% block scripts %}
{{ parent() }}
<script>
(function(){
  var cf = document.getElementById('codiceFiscale');
  if (!cf) return;
  var up = function(){ cf.value = (cf.value || '').toUpperCase(); };
  cf.addEventListener('input', up);
  cf.addEventListener('blur', up);
})();
</script>
{% endblock %}
