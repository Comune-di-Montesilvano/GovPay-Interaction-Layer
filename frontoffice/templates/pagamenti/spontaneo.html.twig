{% extends 'base.html.twig' %}

{% block title %}{{ 'Pagamento spontaneo'|trans }} - {{ app_entity.name }}{% endblock %}

{% set old = form_data|default({}) %}
{% set payer = old.soggettoPagatore|default({}) %}
{% set selected = selected_service|default(null) %}

{% block content %}
{# ── Page header ── #}
<section class="fo-page-header">
  <div class="fo-page-header-inner">
    <nav class="fo-breadcrumb" aria-label="{{ 'Percorso'|trans }}">
      <a href="/">{{ 'Home'|trans }}</a>
      <span class="fo-breadcrumb-sep" aria-hidden="true">›</span>
      <span aria-current="page">{{ 'Pagamento spontaneo'|trans }}</span>
    </nav>
    <div class="fo-ph-badge">{{ 'Servizi pagoPA'|trans }}</div>
    <h1>{{ 'Genera un avviso pagoPA'|trans }}</h1>
    <p>{{ 'Compila il modulo con i dati del servizio e del soggetto pagatore. Al termine verrà creato subito l\'avviso pagoPA e potrai scaricarlo in PDF.'|trans }}</p>
    {% if selected %}
      <p style="margin-top:var(--fo-sp-2); color:rgba(255,255,255,.75); font-size:14px;">
        {{ 'Servizio'|trans }}: <strong style="color:#fff;">{{ selected.label }}</strong>
      </p>
    {% endif %}
  </div>
</section>

{# ── Form section ── #}
<section class="fo-form-section">
  <div class="container-xxl">
    <div class="row g-4">

      {# ── Main form column ── #}
      <div class="col-lg-8">
        <form class="fo-form-card" method="post" action="/pagamento-spontaneo">
          <div class="fo-form-card-body">
            <div class="d-flex flex-column flex-md-row justify-content-between gap-2 mb-4">
              <div>
                <p class="fo-field-section mb-1">{{ 'Modulo di generazione'|trans }}</p>
                <h2 class="h3 mb-0">{{ 'Dati del pagamento'|trans }}</h2>
              </div>
              <div class="text-md-end small" style="color:var(--fo-fg-3);">
                <span>{{ 'Campi contrassegnati da * sono obbligatori'|trans }}</span>
              </div>
            </div>

            {% if form_errors is defined and form_errors %}
              <div class="alert alert-danger" role="status">
                <h3 class="h6 mb-2">{{ 'Controlla i dati inseriti'|trans }}</h3>
                <ul class="mb-0 ps-3">
                  {% for error in form_errors %}
                    <li>{{ error|trans }}</li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}

            {% if form_feedback %}
              <div class="alert alert-{{ form_feedback.type|default('info') }}" role="status">
                <h3 class="h6 mb-1">{{ form_feedback.title|trans }}</h3>
                <p class="mb-0">{{ form_feedback.message|trans }}</p>
              </div>
            {% endif %}

            {% if pendenza_result is defined and pendenza_result %}
              {% set codice_avviso = pendenza_result.numeroAvviso|default('—') %}
              <div class="fo-result-card">
                <div class="fo-result-row">
                  <div>
                    <div class="fo-result-label">{{ 'Codice avviso / IUV'|trans }}</div>
                    <div class="fo-result-val">{{ codice_avviso }}</div>
                  </div>
                  <div>
                    <div class="fo-result-label">{{ 'Importo'|trans }}</div>
                    <div class="fo-result-val">€ {{ pendenza_result.importo|number_format(2, ',', '.') }}</div>
                  </div>
                  <div>
                    <div class="fo-result-label">{{ 'Causale'|trans }}</div>
                    <div class="fo-result-val">{{ pendenza_result.causale|default('—') }}</div>
                  </div>
                  {% if pendenza_result.data_scadenza %}
                    <div>
                      <div class="fo-result-label">{{ 'Scadenza'|trans }}</div>
                      <div class="fo-result-val">{{ pendenza_result.data_scadenza|date('d/m/Y') }}</div>
                    </div>
                  {% endif %}
                </div>
                <p style="font-size:13px; color:var(--fo-fg-3); margin-bottom:var(--fo-sp-4);">
                  {{ 'Per pagare online usa il pulsante dedicato e inserisci il codice avviso quando richiesto.'|trans }}
                </p>
                <div class="d-flex flex-wrap gap-3">
                  {% if pendenza_result.checkout_url %}
                    <button
                      type="button"
                      class="btn btn-primary"
                      id="btn-cart-add"
                      data-id="{{ pendenza_result.idPendenza|default('') }}"
                      aria-label="{{ 'Aggiungi al carrello'|trans }}"
                    >
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1" aria-hidden="true">
                        <circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/>
                        <path d="M3 4h2l3 12h11l2-8H7"/>
                      </svg>
                      <span id="btn-cart-label">{{ 'Aggiungi al carrello'|trans }}</span>
                    </button>
                  {% endif %}
                  <a class="btn btn-outline-primary" href="{{ pendenza_result.checkout_url|default(pay_portal_url|default('https://checkout.pagopa.it/')) }}" target="_blank" rel="noopener">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1" aria-hidden="true">
                      <path d="m13 3-7 11h5l-1 7 7-11h-5z"/>
                    </svg>
                    {{ 'Paga subito'|trans }}
                  </a>
                  {% if pendenza_result.download_url %}
                    <a class="btn btn-outline-primary" href="{{ pendenza_result.download_url }}" target="_blank" rel="noopener">
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1" aria-hidden="true">
                        <path d="M12 4v12"/><path d="m7 11 5 5 5-5"/><path d="M5 20h14"/>
                      </svg>
                      {{ 'Stampa / Scarica PDF'|trans }}
                    </a>
                  {% else %}
                    <button class="btn btn-outline-primary" type="button" disabled>{{ 'PDF disponibile a breve'|trans }}</button>
                  {% endif %}
                  <a class="btn btn-outline-secondary" href="/pagamento-spontaneo">{{ 'Genera un altro avviso'|trans }}</a>
                </div>
              </div>
            {% endif %}

            {% if pendenza_result is not defined or not pendenza_result %}
            <div class="row g-3">
              {% if selected %}
                <div class="col-12">
                  <label class="form-label">{{ 'Servizio da pagare *'|trans }}</label>
                  <div style="border:1px solid var(--fo-border-2); border-radius:var(--fo-r-md); padding:var(--fo-sp-3) var(--fo-sp-4); background:var(--fo-bg-1); display:flex; align-items:center; justify-content:space-between; gap:var(--fo-sp-4); flex-wrap:wrap;">
                    <div>
                      <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--fo-fg-3);">{{ 'Tipologia selezionata'|trans }}</div>
                      <div style="font-weight:600; color:var(--fo-fg-1);">{{ selected.label }}</div>
                    </div>
                    <a class="btn btn-outline-secondary btn-sm" href="/pagamento-spontaneo">{{ 'Cambia servizio'|trans }}</a>
                  </div>
                  <input type="hidden" id="idTipoPendenza" name="idTipoPendenza" value="{{ selected.id }}">
                </div>
              {% else %}
                <div class="col-md-6">
                  <label for="idTipoPendenza" class="form-label">{{ 'Servizio da pagare *'|trans }}</label>
                  <select class="form-select" id="idTipoPendenza" name="idTipoPendenza" required>
                    <option value="">{{ 'Seleziona'|trans }}</option>
                    {% for option in service_options %}
                      <option value="{{ option.id }}" {% if old.idTipoPendenza|default('') == option.id %}selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                  </select>
                  <div class="form-text">{{ 'Scegli la voce corrispondente al pagamento che vuoi generare.'|trans }}</div>
                </div>
              {% endif %}
              <div class="col-md-3">
                {% set selected_year = old.annoRiferimento|default(default_year|default('now'|date('Y'))) %}
                {% set start_year = (default_year|default('now'|date('Y'))) + 1 %}
                {% set end_year = (default_year|default('now'|date('Y'))) - 5 %}
                <label for="annoRiferimento" class="form-label">{{ 'Anno di riferimento *'|trans }}</label>
                <select id="annoRiferimento" name="annoRiferimento" class="form-select" required>
                  {% if selected_year is defined and selected_year not in range(start_year, end_year) %}
                    <option value="{{ selected_year }}" selected>{{ selected_year }}</option>
                  {% endif %}
                  {% for y in range(start_year, end_year) %}
                    <option value="{{ y }}" {% if selected_year == y %}selected{% endif %}>{{ y }}</option>
                  {% endfor %}
                </select>
              </div>
              <div class="col-md-3">
                <label for="importo" class="form-label">{{ 'Importo (&euro;) *'|trans|raw }}</label>
                <div class="input-group">
                  <span class="input-group-text">&euro;</span>
                  <input type="number" step="0.01" min="0.01" class="form-control" id="importo" name="importo" value="{{ old.importo|default('') }}" required placeholder="0.00">
                </div>
                <div class="form-text">{{ 'Inserisci l\'importo in euro (esempio 125,50).'|trans }}</div>
              </div>
            </div>

            <div class="row g-3 mt-1">
              <div class="col-12">
                <label for="causale" class="form-label">{{ 'Causale / descrizione *'|trans }}</label>
                <input type="text" class="form-control" id="causale" name="causale" value="{{ old.causale|default('') }}" maxlength="140" required placeholder="{{ 'Descrivi il motivo del pagamento'|trans }}">
                <div class="d-flex justify-content-between small mt-1" style="color:var(--fo-fg-3);">
                  <span>{{ 'Max 140 caratteri.'|trans }}</span>
                  <span id="causaleCounter">0/140</span>
                </div>
              </div>
            </div>

            <hr class="fo-field-divider">
            <p class="fo-field-section mb-2">{{ 'Soggetto pagatore'|trans }}</p>

            <div class="row g-3 align-items-end">
              <div class="col-12">
                {% set tipo = payer.tipo|default('F') %}
                <div class="form-check form-check-inline">
                  <input class="form-check-input" type="radio" name="soggettoPagatore[tipo]" id="soggettoPF" value="F" {% if tipo != 'G' %}checked{% endif %}>
                  <label class="form-check-label" for="soggettoPF">{{ 'Persona fisica'|trans }}</label>
                </div>
                <div class="form-check form-check-inline">
                  <input class="form-check-input" type="radio" name="soggettoPagatore[tipo]" id="soggettoPJ" value="G" {% if tipo == 'G' %}checked{% endif %}>
                  <label class="form-check-label" for="soggettoPJ">{{ 'Persona giuridica'|trans }}</label>
                </div>
              </div>
              <div class="col-md-4">
                <label for="identificativo" class="form-label" id="identificativoLabel">{{ tipo == 'G' ? 'Partita IVA *'|trans : 'Codice fiscale *'|trans }}</label>
                <input type="text" class="form-control" id="identificativo" name="soggettoPagatore[identificativo]" value="{{ payer.identificativo|default('') }}" required placeholder="{{ tipo == 'G' ? 'IT00000000000' : 'RSSMRA00A01H501Z' }}" autocomplete="off">
              </div>
              <div class="col-md-4">
                <label for="anagrafica" class="form-label" id="anagraficaLabel">{{ tipo == 'G' ? 'Ragione sociale *'|trans : 'Cognome *'|trans }}</label>
                <input type="text" class="form-control" id="anagrafica" name="soggettoPagatore[anagrafica]" value="{{ payer.anagrafica|default('') }}" required autocomplete="off">
              </div>
              <div class="col-md-4" id="nomeWrapper" style="{{ tipo == 'G' ? 'display:none;' : '' }}">
                <label for="nome" class="form-label">{{ 'Nome'|trans }}</label>
                <input type="text" class="form-control" id="nome" name="soggettoPagatore[nome]" value="{{ payer.nome|default('') }}" autocomplete="off">
              </div>
            </div>

            <div class="row g-3 mt-1">
              <div class="col-md-6">
                <label for="email" class="form-label">{{ 'Email di contatto *'|trans }}</label>
                <input type="email" class="form-control" id="email" name="soggettoPagatore[email]" value="{{ payer.email|default('') }}" required placeholder="esempio@dominio.it">
              </div>
              <div class="col-md-6">
                <label for="telefono" class="form-label">{{ 'Telefono (opzionale)'|trans }}</label>
                <input type="tel" class="form-control" id="telefono" name="soggettoPagatore[telefono]" value="{{ payer.telefono|default('') }}" placeholder="333 1234567">
              </div>
            </div>

            <div class="alert alert-info mt-4" role="note">
              <p class="mb-1 fw-semibold">{{ 'Come funziona'|trans }}</p>
              <ul class="mb-0 ps-3">
                <li>{{ 'compila i dati e genera subito l\'avviso pagoPA;'|trans }}</li>
                <li>{{ 'scarica il PDF oppure paga online con il codice avviso.'|trans }}</li>
              </ul>
            </div>

            <div class="form-check mt-4">
              <input class="form-check-input" type="checkbox" value="1" id="privacy" required name="privacy">
              <label class="form-check-label" for="privacy">
                {{ 'Dichiaro di aver letto l\'informativa privacy dell\'Ente e autorizzo il trattamento dei dati per finalita\' connesse al presente pagamento.'|trans }}
              </label>
            </div>

            <div class="d-flex gap-3 flex-wrap mt-4">
              <button type="submit" class="btn btn-primary btn-lg px-4">{{ 'Genera avviso'|trans }}</button>
              <a class="btn btn-outline-secondary btn-lg" href="/">{{ 'Annulla'|trans }}</a>
            </div>
            {% endif %}
          </div>
        </form>
      </div>

      {# ── Sidebar ── #}
      <div class="col-lg-4">
        <div class="fo-sidebar-card mb-4">
          <div class="fo-sidebar-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 8h.01"/>
            </svg>
          </div>
          <h3>{{ 'Documenti utili'|trans }}</h3>
          <p>{{ 'Tienili a portata di mano per velocizzare la compilazione:'|trans }}</p>
          <ul>
            <li>{{ 'Codice fiscale o partita IVA del pagatore'|trans }}</li>
            <li>{{ 'Dettagli del servizio (numero pratica, periodo, ecc.)'|trans }}</li>
            <li>{{ 'Indirizzo email per ricevere l\'avviso pagoPA'|trans }}</li>
          </ul>
        </div>
        {% if support_email or support_phone or support_location %}
        <div class="fo-sidebar-card">
          <h3>{{ 'Serve supporto?'|trans }}</h3>
          {% if support_email %}
            <p>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:4px;color:var(--fo-primary);" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 7 9-7"/>
              </svg>
              <a href="mailto:{{ support_email }}" style="color:var(--fo-primary);">{{ support_email }}</a>
            </p>
          {% endif %}
          {% if support_phone %}
            <p>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:4px;color:var(--fo-primary);" aria-hidden="true">
                <path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 6 6L15 14l5 2v3a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2"/>
              </svg>
              {{ support_phone }}{% if support_hours %} <span style="color:var(--fo-fg-3);">({{ support_hours }})</span>{% endif %}
            </p>
          {% endif %}
          {% if support_location %}
            <p style="font-size:13px; color:var(--fo-fg-3);">{{ support_location|raw }}</p>
          {% endif %}
        </div>
        {% endif %}
      </div>

    </div>
  </div>
</section>
{% endblock %}

{% block scripts %}
  {{ parent() }}
  <script>
    (function(){
      const pf = document.getElementById('soggettoPF');
      const pj = document.getElementById('soggettoPJ');
      const identificativoLabel = document.getElementById('identificativoLabel');
      const identificativoInput = document.getElementById('identificativo');
      const anagraficaLabel = document.getElementById('anagraficaLabel');
      const anagraficaInput = document.getElementById('anagrafica');
      const nomeInput = document.getElementById('nome');
      const nomeWrapper = document.getElementById('nomeWrapper');
      const causale = document.getElementById('causale');
      const counter = document.getElementById('causaleCounter');

      function upcaseInput(el){
        if(!el) return;
        el.value = (el.value || '').toUpperCase();
      }

      function updatePersona(type){
        if(!identificativoLabel || !anagraficaLabel) return;
        if(type === 'G'){
          identificativoLabel.textContent = '{{ "Partita IVA *"|trans|escape("js") }}';
          identificativoInput.placeholder = 'IT00000000000';
          anagraficaLabel.textContent = '{{ "Ragione sociale *"|trans|escape("js") }}';
          if(nomeWrapper) nomeWrapper.style.display = 'none';
        } else {
          identificativoLabel.textContent = '{{ "Codice fiscale *"|trans|escape("js") }}';
          identificativoInput.placeholder = 'RSSMRA00A01H501Z';
          anagraficaLabel.textContent = '{{ "Cognome *"|trans|escape("js") }}';
          if(nomeWrapper) nomeWrapper.style.display = '';
        }
      }

      [identificativoInput, anagraficaInput, nomeInput].forEach(function(input){
        if(!input) return;
        input.addEventListener('input', function(){ upcaseInput(input); });
        input.addEventListener('blur', function(){ upcaseInput(input); });
      });

      [pf,pj].forEach(function(radio){
        if(!radio) return;
        radio.addEventListener('change', function(){
          if(this.checked) updatePersona(this.value);
        });
      });

      updatePersona(pf && pf.checked ? 'F' : 'G');

      if(causale && counter){
        const syncCounter = function(){
          const value = causale.value || '';
          counter.textContent = value.length + '/140';
        };
        causale.addEventListener('input', syncCounter);
        syncCounter();
      }
    })();
  </script>
{% endblock %}
