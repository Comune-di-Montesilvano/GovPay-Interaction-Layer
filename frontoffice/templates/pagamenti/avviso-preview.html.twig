{% extends 'base.html.twig' %}

{% block title %}{{ 'Anteprima avviso'|trans }} - {{ app_entity.name }}{% endblock %}

{% set avviso = avviso_preview|default({}) %}
{% set pagatore = avviso.soggetto_pagatore|default({}) %}
{% set voci = avviso.voci|default([]) %}
{% set is_bollo = avviso.is_bollo|default(false)
    or (voci|length > 0
        and voci[0].tipoBollo is defined
        and voci[0].tipoBollo is not null
        and voci[0].tipoBollo != '') %}
{% set status_cls = avviso.is_paid
    ? 'status-paid'
    : (avviso.is_payable
        ? 'status-pay'
        : (avviso.stato.code|default('') == 'ANNULLATA'
            ? 'status-cancel'
            : 'status-due')) %}

{% block content %}

{# ── Page header ── #}
<div class="page-head">
  <div class="container">
    <div class="crumbs">
      <a href="/">{{ 'Home'|trans }}</a>
      <span class="sep">/</span>
      <a href="/pagamento-avviso">{{ 'Paga un avviso'|trans }}</a>
      <span class="sep">/</span>
      <span class="current">{{ 'Anteprima avviso'|trans }}</span>
    </div>
    <div style="display:flex;flex-wrap:wrap;align-items:center;gap:var(--sp-3);">
      <div>
        <h1>{{ 'Avviso'|trans }} {{ avviso.numero_avviso|default('—') }}</h1>
        <p class="page-sub">{{ 'Visualizza i dettagli prima di procedere con la stampa o il pagamento.'|trans }}</p>
      </div>
      <span class="status {{ status_cls }}">
        <span class="dot"></span>
        {{ avviso.stato.label|default('Stato sconosciuto'|trans) }}
      </span>
    </div>
  </div>
</div>

{# ── Content ── #}
<section class="block">
  <div class="container">
    <div class="split">

      {# ── Main ── #}
      <div>

        {# avviso-card #}
        <div class="avviso-card" style="margin-bottom:var(--sp-4);">
          <div class="avviso-header">
            <div class="from">
              {{ 'Ente creditore'|trans }}
              <strong>{{ app_entity.name }}</strong>
            </div>
            <span class="status {{ status_cls }}">
              <span class="dot"></span>
              {{ avviso.stato.label|default('—') }}
            </span>
          </div>

          <div class="avviso-body">
            <div class="avviso-row">
              <span class="k">{{ 'Causale'|trans }}</span>
              <span class="v">{{ avviso.causale|default('—') }}</span>
            </div>
            <div class="avviso-row">
              <span class="k">{{ 'Codice avviso'|trans }}</span>
              <span class="v mono">{{ avviso.numero_avviso|default('—') }}</span>
            </div>
            <div class="avviso-row">
              <span class="k">{{ 'Intestatario'|trans }}</span>
              <span class="v">
                {{ pagatore.anagrafica|default('—') }}
                {% if pagatore.identificativo %}
                  <span style="color:var(--fg-3);font-size:13px;">({{ pagatore.identificativo }})</span>
                {% endif %}
              </span>
            </div>
            <div class="avviso-row">
              <span class="k">{{ 'Scadenza'|trans }}</span>
              <span class="v">
                {% if avviso.data_scadenza %}
                  {{ avviso.data_scadenza|date('d/m/Y') }}
                {% else %}
                  {{ 'Non prevista'|trans }}
                {% endif %}
              </span>
            </div>
            <div class="avviso-row">
              <span class="k" style="font-weight:700;color:var(--fg-1);">{{ 'Importo dovuto'|trans }}</span>
              <span class="v amount">
                {% if avviso.importo is not null %}
                  € {{ avviso.importo|number_format(2, ',', '.') }}
                {% else %}—{% endif %}
              </span>
            </div>

            {% if avviso.is_paid %}
              <div class="alert alert-success" style="margin-top:var(--sp-4);" role="status">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="alert-icon" aria-hidden="true"><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg>
                <div>{{ 'La ricevuta del pagamento è disponibile per il download.'|trans }}</div>
              </div>
            {% elseif not avviso.is_payable %}
              <div class="alert alert-warning" style="margin-top:var(--sp-4);" role="status">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="alert-icon" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                <div>{{ 'Questo avviso risulta'|trans }} {{ avviso.stato.label|lower }}. {{ 'Non sarà possibile avviare il pagamento online, ma puoi comunque scaricare la copia dell\'avviso.'|trans }}</div>
              </div>
            {% endif %}
          </div>

          <div class="avviso-actions">
            {% if is_bollo %}
              {# Usa download_url già calcolato lato PHP (punta a /avviso-bollo con tutti i params) #}
              {% set _burl = avviso.download_url is defined and avviso.download_url starts with '/avviso-bollo'
                  ? avviso.download_url
                  : ('/avviso-bollo?iuv=' ~ (avviso.numero_avviso ?? '')|url_encode
                      ~ '&ente=' ~ (avviso.id_dominio ?? id_dominio ?? '')|url_encode
                      ~ '&importo=' ~ ((avviso.importo ?? 0) * 100)|round
                      ~ '&causale=' ~ (avviso.causale ?? '')|url_encode
                      ~ '&cf=' ~ (pagatore.identificativo ?? pagatore.codice_fiscale ?? '')|url_encode
                      ~ '&scadenza=' ~ (avviso.data_scadenza ?? '')|url_encode) %}
              {% if not (avviso.download_url starts with '/avviso-bollo') %}
                {% for v in voci %}
                  {% set _burl = _burl ~ '&desc[]=' ~ (v.descrizione ?? '')|url_encode %}
                {% endfor %}
              {% endif %}
            {% endif %}

            {# — Aggiungi al carrello — #}
            {% if avviso.is_payable and avviso.id_pendenza and not is_bollo %}
                <button
                  type="button"
                  class="btn btn-primary"
                  id="btn-cart-add"
                  data-id="{{ avviso.id_pendenza }}"
                  data-added="{{ (cart_items_ids is defined and avviso.id_pendenza in cart_items_ids) ? '1' : '0' }}"
                  aria-label="{{ 'Aggiungi al carrello'|trans }}"
                >
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/><path d="M3 4h2l3 12h11l2-8H7"/></svg>
                  <span id="btn-cart-label">
                    {% if cart_items_ids is defined and avviso.id_pendenza in cart_items_ids %}
                      {{ 'Nel carrello ✓'|trans }}
                    {% else %}
                      {{ 'Aggiungi al carrello'|trans }}
                    {% endif %}
                  </span>
                </button>
            {% endif %}

            {# — Paga subito — #}
            {% if avviso.is_payable and avviso.checkout_url %}
              <a class="btn btn-outline" href="{{ avviso.checkout_url }}">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m13 3-7 11h5l-1 7 7-11h-5z"/></svg>
                {{ 'Paga subito'|trans }}
              </a>
            {% endif %}

            {# — Stampa / Scarica PDF — #}
            {% if is_bollo %}
              <a class="btn btn-outline" href="{{ _burl }}" target="_blank" rel="noopener">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                {{ 'Bollettino MBT'|trans }}
              </a>
            {% elseif avviso.download_url %}
              <a class="btn btn-outline" href="{{ avviso.download_url }}" target="_blank" rel="noopener">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                {{ 'Stampa / Scarica PDF'|trans }}
              </a>
            {% else %}
              <button class="btn btn-outline" type="button" disabled>{{ 'PDF non disponibile'|trans }}</button>
            {% endif %}

            {# — Scarica ricevuta — #}
            {% if avviso.is_paid and avviso.receipt_download_url and not is_bollo %}
              <a class="btn btn-primary" href="{{ avviso.receipt_download_url }}" rel="noopener">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                {{ 'Scarica la ricevuta'|trans }}
              </a>
            {% endif %}

            {# — Storico ricevute — #}
            {% if avviso.is_paid and spid_enabled and current_user %}
              <a class="btn btn-ghost" href="/pendenze?stato=ESEGUITA">{{ 'Vai alle ricevute'|trans }}</a>
            {% endif %}

            {# — Cerca altro avviso — #}
            {% if back_url|default('') %}
              <a class="btn btn-ghost" href="{{ back_url }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m19 12H5"/><path d="m12 5-7 7 7 7"/></svg>
                {{ 'Cerca un altro avviso'|trans }}
              </a>
            {% endif %}
          </div>
        </div>

        {# Dettaglio voci #}
        {% if voci %}
          <div class="card card-pad">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--sp-3);">
              <h2 style="margin:0;font-size:16px;">{{ 'Dettaglio voci'|trans }}</h2>
              <span style="font-size:13px;color:var(--fg-3);">{{ voci|length }} {{ voci|length > 1 ? 'voci'|trans : 'voce'|trans }}</span>
            </div>
            <div class="table-wrap">
              <table class="table">
                <thead>
                  <tr>
                    <th>{{ 'Descrizione'|trans }}</th>
                    <th style="text-align:right;">{{ 'Importo'|trans }}</th>
                  </tr>
                </thead>
                <tbody>
                  {% for voce in voci %}
                    <tr style="cursor:default;">
                      <td>{{ voce.descrizione|default('—') }}</td>
                      <td style="text-align:right;" class="amount">
                        {% if voce.importo is defined %}
                          € {{ voce.importo|number_format(2, ',', '.') }}
                        {% else %}—{% endif %}
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
        {% endif %}

      </div>

      {# ── Aside ── #}
      <aside class="aside">
        <div class="card card-pad">
          <h3>{{ 'Prossimi passaggi'|trans }}</h3>
          <div class="timeline">
            <div class="timeline-item">
              <div class="dot"></div>
              <div class="title">{{ '1. Stampa o salva il PDF'|trans }}</div>
              <div class="meta">{{ 'L\'avviso contiene tutti i dati necessari per il pagamento presso un PSP.'|trans }}</div>
            </div>
            <div class="timeline-item">
              <div class="dot"></div>
              <div class="title">{{ '2. Avvia il pagamento online'|trans }}</div>
              <div class="meta">{{ 'Verrai portato sul portale pagoPA per inserire il codice avviso e scegliere il canale preferito.'|trans }}</div>
            </div>
            <div class="timeline-item">
              <div class="dot"></div>
              <div class="title">{{ '3. Conserva la ricevuta'|trans }}</div>
              <div class="meta">{{ 'Riceverai la ricevuta digitale all\'indirizzo email associato all\'avviso.'|trans }}</div>
            </div>
          </div>
        </div>

        {% if support_email or support_phone %}
          <div class="card card-pad" style="background:var(--bi-navy);color:#e2ecff !important;">
            <h3 style="color:#fff !important;margin-bottom:var(--sp-2);">{{ 'Serve assistenza?'|trans }}</h3>
            <p style="margin:0 0 var(--sp-3);font-size:13px;opacity:.75;color:#e2ecff !important;">{{ 'Contatta'|trans }} {{ app_entity.name }}</p>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:var(--sp-2);font-size:13px;color:#e2ecff !important;">
              {% if support_email %}
                <li style="display:flex;gap:8px;align-items:center;color:#e2ecff !important;">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;opacity:.7;color:#7bdcff !important;" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 7 9-7"/></svg>
                  <a href="mailto:{{ support_email }}" style="color:#7bdcff !important;">{{ support_email }}</a>
                </li>
              {% endif %}
              {% if support_phone %}
                <li style="display:flex;gap:8px;align-items:center;color:#e2ecff !important;">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;opacity:.7;color:#7bdcff !important;" aria-hidden="true"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 6 6L15 14l5 2v3a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2"/></svg>
                  <span style="color:#e2ecff !important;">{{ support_phone }}{% if support_hours %} <span style="opacity:.65;color:#e2ecff !important;">({{ support_hours }})</span>{% endif %}</span>
                </li>
              {% endif %}
              {% if support_location %}
                <li style="opacity:.55;font-size:12px;color:#e2ecff !important;">{{ support_location|nl2br }}</li>
              {% endif %}
            </ul>
          </div>
        {% endif %}
      </aside>

    </div>
  </div>
</section>

{% endblock %}
