{% extends 'base.html.twig' %}

{% block title %}{{ 'Le mie pendenze'|trans }} - {{ app_entity.name }}{% endblock %}

{% set items = pendenze|default([]) %}
{% set stato = filters.stato|default('') %}
{% set selected_tipologia = filters.tipologia|default('') %}
{% set pagina = pagination.pagina|default(1) %}
{% set per_pagina = pagination.risultati_per_pagina|default(25) %}

{% block content %}

{# ── Page header ── #}
<div class="page-head">
  <div class="container">
    <div class="crumbs">
      <a href="/">{{ 'Home'|trans }}</a>
      <span class="sep">/</span>
      <span class="current">{{ 'Le mie pendenze'|trans }}</span>
    </div>
    <h1>{{ 'Le mie pendenze'|trans }}</h1>
    <p class="page-sub">{{ 'Consulta lo stato, scarica l\'avviso e (quando disponibile) la ricevuta di pagamento.'|trans }}</p>
  </div>
</div>

<section class="block">
  <div class="container">

    {# ── Profile bar ── #}
    <div class="profile-bar" style="margin-bottom:var(--sp-5);">
      <div class="avatar">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </div>
      <div>
        <div class="name">{{ codice_fiscale|default('') }}</div>
        <div class="meta">{{ 'Area personale'|trans }}</div>
      </div>
      <div style="margin-left:auto;display:flex;gap:var(--sp-2);flex-wrap:wrap;">
        <a class="btn btn-sm" style="background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.4);color:#fff;" href="/pagamento-avviso">{{ 'Paga un avviso'|trans }}</a>
        <a class="btn btn-sm" style="background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.4);color:#fff;" href="/pagamento-spontaneo">{{ 'Pagamento spontaneo'|trans }}</a>
        <a class="btn btn-sm" style="background:transparent;border-color:rgba(255,255,255,.3);color:rgba(255,255,255,.75);" href="/logout">{{ 'Logout'|trans }}</a>
      </div>
    </div>

    {# ── Filters ── #}
    <div class="card card-pad" style="margin-bottom:var(--sp-4);">
      <form style="display:flex;flex-wrap:wrap;gap:var(--sp-3);align-items:flex-end;" method="get" action="/pendenze">
        <div class="field" style="min-width:200px;flex:1;margin:0;">
          <label for="stato">{{ 'Stato'|trans }}</label>
          <select class="select" id="stato" name="stato">
            <option value="" {{ stato == '' ? 'selected' : '' }}>{{ 'Tutti'|trans }}</option>
            <option value="NON_ESEGUITA" {{ stato == 'NON_ESEGUITA' ? 'selected' : '' }}>{{ 'Da pagare'|trans }}</option>
            <option value="ESEGUITA_PARZIALE" {{ stato == 'ESEGUITA_PARZIALE' ? 'selected' : '' }}>{{ 'Pagata parzialmente'|trans }}</option>
            <option value="ESEGUITA" {{ stato == 'ESEGUITA' ? 'selected' : '' }}>{{ 'Pagata'|trans }}</option>
            <option value="SCADUTA" {{ stato == 'SCADUTA' ? 'selected' : '' }}>{{ 'Scaduta'|trans }}</option>
            <option value="ANNULLATA" {{ stato == 'ANNULLATA' ? 'selected' : '' }}>{{ 'Annullata'|trans }}</option>
            <option value="ANOMALA" {{ stato == 'ANOMALA' ? 'selected' : '' }}>{{ 'In verifica'|trans }}</option>
          </select>
        </div>
        <div class="field" style="min-width:200px;flex:1;margin:0;">
          <label for="tipologia">{{ 'Tipologia'|trans }}</label>
          <select class="select" id="tipologia" name="tipologia">
            <option value="" {{ selected_tipologia == '' ? 'selected' : '' }}>{{ 'Tutte'|trans }}</option>
            {% for t in tipologie|default([]) %}
              <option value="{{ t.id_entrata }}" {{ selected_tipologia == t.id_entrata ? 'selected' : '' }}>
                {{ t.descrizione_effettiva|default(t.descrizione|default(t.id_entrata)) }}
              </option>
            {% endfor %}
          </select>
        </div>
        <div class="field" style="min-width:140px;flex:0 0 auto;margin:0;">
          <label for="per_page">{{ 'Per pagina'|trans }}</label>
          <select class="select" id="per_page" name="per_page">
            {% for n in [10,25,50,100] %}
              <option value="{{ n }}" {{ per_pagina == n ? 'selected' : '' }}>{{ n }}</option>
            {% endfor %}
          </select>
        </div>
        <div style="display:flex;gap:var(--sp-2);">
          <button class="btn btn-primary" type="submit">{{ 'Aggiorna'|trans }}</button>
          <a class="btn btn-ghost" href="/pendenze">{{ 'Reset'|trans }}</a>
        </div>
      </form>
    </div>

    {# ── Table ── #}
    {% if items is empty %}
      <div class="alert alert-info" role="status">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="alert-icon" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 8h.01"/></svg>
        <div>{{ 'Nessuna pendenza trovata.'|trans }}</div>
      </div>
    {% else %}

      {# Hidden form for cart POST #}
      <form id="carrello-form" method="post" action="/carrello/checkout" style="display:none">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">
        <input type="hidden" name="csrf_token" id="csrf_token_field" value="">
      </form>

      <div class="table-wrap">
        <div class="table-toolbar">
          <div class="left">
            <span style="font-size:13px;color:var(--fg-3);">{{ 'Elenco pendenze'|trans }}</span>
            <span id="carrello-hint" style="display:none;font-size:13px;color:var(--fg-3);display:flex;align-items:center;gap:6px;">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/><path d="M3 4h2l3 12h11l2-8H7"/></svg>
              {{ 'Seleziona fino a 5 pendenze pagabili e aggiungile al carrello'|trans }}
            </span>
          </div>
        </div>

        <table class="table" id="cart-table">
          <thead>
            <tr>
              <th class="col-sel"><span class="sr-only">{{ 'Seleziona'|trans }}</span></th>
              <th>{{ 'Causale'|trans }}</th>
              <th style="text-align:right;">{{ 'Importo'|trans }}</th>
              <th>{{ 'Scadenza'|trans }}</th>
              <th>{{ 'Stato'|trans }}</th>
              <th style="text-align:right;">{{ 'Azioni'|trans }}</th>
            </tr>
          </thead>
          <tbody>
            {% for p in items %}
              {% set is_payable = p.stato.code in ['NON_ESEGUITA', 'ESEGUITA_PARZIALE'] %}
              {% set status_cls = p.stato.code == 'ESEGUITA'
                  ? 'status-paid'
                  : (is_payable ? 'status-pay'
                    : (p.stato.code in ['SCADUTA','ANOMALA'] ? 'status-due' : 'status-cancel')) %}
              <tr class="{{ is_payable ? 'fo-row-payable' : '' }}">
                <td class="col-sel" style="text-align:center;">
                  {% if is_payable and p.id_pendenza and not p.is_bollo|default(false) %}
                    <input
                      class="pendenza-checkbox"
                      type="checkbox"
                      name="pendenze[]"
                      value="{{ p.id_pendenza }}"
                      data-importo="{{ p.importo is not null ? (p.importo * 100)|round(0, 'floor') : 0 }}"
                      aria-label="{{ 'Seleziona pendenza'|trans }} {{ p.numero_avviso|default(p.id_pendenza) }}"
                      form="carrello-form"
                    >
                  {% endif %}
                </td>
                <td>
                  <div style="font-weight:600;">{{ p.causale|default('—') }}</div>
                  {% if p.numero_avviso %}
                    <div class="mono" style="font-size:12px;color:var(--fg-3);">{{ p.numero_avviso }}</div>
                  {% endif %}
                  {% if p.tipologia and p.tipologia.descrizione %}
                    <div style="font-size:12px;color:var(--fg-3);margin-top:2px;display:flex;align-items:center;gap:4px;">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:var(--c-primary);flex-shrink:0;"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7" cy="7" r=".01"/></svg>
                      <span>{{ p.tipologia.descrizione }}</span>
                    </div>
                  {% endif %}
                </td>
                <td class="amount" style="text-align:right;white-space:nowrap;">
                  {% if p.importo is not null %}
                    € {{ p.importo|number_format(2, ',', '.') }}
                  {% else %}—{% endif %}
                </td>
                <td>
                  {% if p.data_scadenza %}
                    {{ p.data_scadenza|date('d/m/Y') }}
                  {% else %}
                    <span style="color:var(--fg-3);">—</span>
                  {% endif %}
                </td>
                <td>
                  <span class="status {{ status_cls }}">
                    <span class="dot"></span>
                    {{ p.stato.label|default('—') }}
                  </span>
                </td>
                <td style="text-align:right;">
                  <div style="display:flex;gap:4px;justify-content:flex-end;">
                    {% if is_payable and p.id_pendenza and not p.is_bollo|default(false) %}
                      {% if p.id_pendenza in cart_items_ids|default([]) %}
                        {# Item già nel carrello — mostra checkmark + bottone rimuovi #}
                        <button
                          type="button"
                          class="btn btn-sm btn-outline btn-cart-row"
                          data-id="{{ p.id_pendenza }}"
                          title="{{ 'Nel carrello'|trans }}"
                          disabled
                        >
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 13 4 4L19 7"/></svg>
                          <span class="sr-only">{{ 'Nel carrello ✓'|trans }}</span>
                        </button>
                        <button
                          type="button"
                          class="btn btn-sm btn-ghost btn-cart-remove"
                          data-id="{{ p.id_pendenza }}"
                          title="{{ 'Rimuovi dal carrello'|trans }}"
                          aria-label="{{ 'Rimuovi dal carrello'|trans }}"
                          style="color:var(--c-danger);"
                        >
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                          <span class="sr-only">{{ 'Rimuovi'|trans }}</span>
                        </button>
                      {% else %}
                        <button
                          type="button"
                          class="btn btn-sm btn-primary btn-cart-row"
                          data-id="{{ p.id_pendenza }}"
                          title="{{ 'Aggiungi al carrello'|trans }}"
                          aria-label="{{ 'Aggiungi al carrello'|trans }}"
                          {{ cart_count|default(0) >= 5 ? 'disabled' : '' }}
                        >
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/><path d="M3 4h2l3 12h11l2-8H7"/></svg>
                          <span class="sr-only">{{ 'Aggiungi al carrello'|trans }}</span>
                        </button>
                      {% endif %}
                    {% endif %}
                    {% if p.detail_url %}
                      <a class="btn btn-sm btn-outline" href="{{ p.detail_url }}" title="{{ 'Dettaglio'|trans }}">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 8h.01"/></svg>
                        <span class="sr-only">{{ 'Dettaglio'|trans }}</span>
                      </a>
                    {% endif %}
                    {% if p.download_url %}
                      <a class="btn btn-sm btn-ghost" href="{{ p.download_url }}" target="_blank" rel="noopener" title="{{ 'Scarica PDF avviso'|trans }}">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3h12v18l-3-2-3 2-3-2-3 2z"/><path d="M9 8h6M9 12h4"/></svg>
                        <span class="sr-only">{{ 'Scarica PDF avviso'|trans }}</span>
                      </a>
                    {% endif %}
                    {% if p.receipt_url and not p.is_bollo|default(false) %}
                      <a class="btn btn-sm btn-outline" href="{{ p.receipt_url }}" title="{{ 'Scarica ricevuta'|trans }}">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 4v12"/><path d="m7 11 5 5 5-5"/><path d="M5 20h14"/></svg>
                        <span class="sr-only">{{ 'Scarica ricevuta'|trans }}</span>
                      </a>
                    {% endif %}
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>

        <div class="table-toolbar">
          <div style="font-size:13px;color:var(--fg-3);">
            {{ 'Pagina'|trans }} {{ pagination.pagina }} {{ 'di'|trans }} {{ pagination.total_pages|default(1) }}
          </div>
          <div style="display:flex;gap:var(--sp-2);">
            <a
              class="btn btn-sm btn-ghost {% if pagination.pagina <= 1 %}disabled{% endif %}"
              href="?page={{ pagination.pagina - 1 }}&per_page={{ pagination.risultati_per_pagina }}{% if filters.stato %}&stato={{ filters.stato }}{% endif %}{% if filters.tipologia %}&tipologia={{ filters.tipologia }}{% endif %}"
              {% if pagination.pagina <= 1 %}aria-disabled="true" tabindex="-1"{% endif %}
            >{{ 'Precedente'|trans }}</a>
            <a
              class="btn btn-sm btn-ghost {% if pagination.pagina >= (pagination.total_pages|default(1)) %}disabled{% endif %}"
              href="?page={{ pagination.pagina + 1 }}&per_page={{ pagination.risultati_per_pagina }}{% if filters.stato %}&stato={{ filters.stato }}{% endif %}{% if filters.tipologia %}&tipologia={{ filters.tipologia }}{% endif %}"
              {% if pagination.pagina >= (pagination.total_pages|default(1)) %}aria-disabled="true" tabindex="-1"{% endif %}
            >{{ 'Successiva'|trans }}</a>
          </div>
        </div>
      </div>

    {% endif %}

  </div>
</section>

{# ── Sticky Cart Bar ── #}
<div id="carrello-bar" role="status" aria-live="polite">
  <div class="fo-bar-info">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink:0;"><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/><path d="M3 4h2l3 12h11l2-8H7"/></svg>
    <strong id="bar-count">0</strong>
    <span id="bar-text-singular" style="display:none;">{{ 'pendenza selezionata'|trans }}</span>
    <span id="bar-text-plural" style="display:none;">{{ 'pendenze selezionate'|trans }}</span>
    <span id="bar-text-display"></span>
    &nbsp;·&nbsp;
    {{ 'Totale'|trans }}: <strong id="bar-total">€ 0,00</strong>
  </div>
  <div class="fo-bar-actions">
    <button type="button" class="fo-bar-btn" id="deseleziona-btn">{{ 'Deseleziona tutto'|trans }}</button>
    <button type="submit" form="carrello-form" formaction="/carrello/aggiungi-multiplo" class="fo-bar-btn primary" id="aggiungi-btn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/><path d="M3 4h2l3 12h11l2-8H7"/></svg>
      {{ 'Aggiungi al carrello'|trans }}
    </button>
    <button type="submit" form="carrello-form" formaction="/carrello/checkout" class="fo-bar-btn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m13 3-7 11h5l-1 7 7-11h-5z"/></svg>
      {{ 'Paga selezionate'|trans }}
    </button>
  </div>
</div>

{% endblock %}

{% block scripts %}
{{ parent() }}
<script>
(function () {
  var MAX_SEL = 5;
  var bar = document.getElementById('carrello-bar');
  var hint = document.getElementById('carrello-hint');
  var countEl = document.getElementById('bar-count');
  var totalEl = document.getElementById('bar-total');
  var deselBtn = document.getElementById('deseleziona-btn');
  var checkboxes = Array.from(document.querySelectorAll('.pendenza-checkbox'));

  function formatEuro(cents) {
    var euros = cents / 100;
    return '€ ' + euros.toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.');
  }

  function update() {
    var selected = checkboxes.filter(function(cb) { return cb.checked; });
    var count = selected.length;
    var totalCents = selected.reduce(function(s, cb) { return s + parseInt(cb.dataset.importo || '0', 10); }, 0);

    countEl.textContent = count;
    totalEl.textContent = formatEuro(totalCents);

    var displayEl = document.getElementById('bar-text-display');
    if (displayEl) {
      displayEl.textContent = count === 1
        ? document.getElementById('bar-text-singular').textContent
        : document.getElementById('bar-text-plural').textContent;
    }

    if (count > 0) {
      bar.classList.add('visible');
      if (hint) hint.style.display = 'flex';
      document.body.style.paddingBottom = '80px';
    } else {
      bar.classList.remove('visible');
      document.body.style.paddingBottom = '';
    }

    checkboxes.forEach(function(cb) {
      if (!cb.checked) cb.disabled = count >= MAX_SEL;
    });
  }

  checkboxes.forEach(function(cb) { cb.addEventListener('change', update); });

  if (deselBtn) deselBtn.addEventListener('click', function() {
    checkboxes.forEach(function(cb) { cb.checked = false; cb.disabled = false; });
    update();
  });

  if (checkboxes.length > 0 && hint) hint.style.display = 'flex';

  update();
})();

(function () {
  var svgCheck = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 13 4 4L19 7"/></svg>';
  var svgCart = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/><path d="M3 4h2l3 12h11l2-8H7"/></svg>';
  var svgTrash = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>';

  function updateBadges(count) {
    document.querySelectorAll('.cart-badge').forEach(function (el) {
      el.textContent = count;
      el.style.display = count > 0 ? '' : 'none';
    });
    // Disabilita tutti i bottoni aggiungi se carrello pieno
    var full = count >= 5;
    document.querySelectorAll('.btn-cart-row:not([disabled])').forEach(function (b) {
      if (!b.classList.contains('btn-outline')) { // non è già "nel carrello"
        b.disabled = full;
      }
    });
  }

  // Aggiungi al carrello
  document.querySelectorAll('.btn-cart-row').forEach(function (btn) {
    if (btn.classList.contains('btn-outline')) return; // già nel carrello, skip
    btn.addEventListener('click', function () {
      var id = btn.dataset.id;
      if (!id || btn.disabled) return;
      btn.disabled = true;
      fetch('/carrello/aggiungi', {
        method: 'POST',
        body: new URLSearchParams({ idPendenza: id, _csrf: '{{ csrf_token }}' }),
        headers: { 'X-Requested-With': 'XMLHttpRequest', 'X-CSRF-Token': '{{ csrf_token }}' }
      })
      .then(function (r) { return window.GovPayUi.parseJsonSafely(r); })
      .then(function (data) {
        if (data.error) { btn.disabled = false; alert(data.error); return; }
        // Trasforma in bottone "nel carrello"
        btn.classList.remove('btn-primary');
        btn.classList.add('btn-outline');
        btn.innerHTML = svgCheck + '<span class="sr-only">{{ "Nel carrello ✓"|trans }}</span>';
        btn.title = '{{ "Nel carrello"|trans }}';
        // Inserisci bottone rimuovi accanto
        var rm = document.createElement('button');
        rm.type = 'button';
        rm.className = 'btn btn-sm btn-ghost btn-cart-remove';
        rm.dataset.id = id;
        rm.title = '{{ "Rimuovi dal carrello"|trans }}';
        rm.style.color = 'var(--c-danger)';
        rm.innerHTML = svgTrash + '<span class="sr-only">{{ "Rimuovi"|trans }}</span>';
        btn.insertAdjacentElement('afterend', rm);
        attachRemove(rm);
        updateBadges(data.count || 0);
      })
      .catch(function (err) {
        btn.disabled = false;
        alert(err && err.message ? err.message : '{{ "Servizio temporaneamente non disponibile. Riprova tra poco."|trans|escape("js") }}');
      });
    });
  });

  function attachRemove(btn) {
    btn.addEventListener('click', function () {
      var id = btn.dataset.id;
      if (!id || btn.disabled) return;
      btn.disabled = true;
      fetch('/carrello/rimuovi', {
        method: 'POST',
        body: new URLSearchParams({ idPendenza: id, _csrf: '{{ csrf_token }}' }),
        headers: { 'X-Requested-With': 'XMLHttpRequest', 'X-CSRF-Token': '{{ csrf_token }}' }
      })
      .then(function (r) { return window.GovPayUi.parseJsonSafely(r); })
      .then(function (data) {
        if (data.error) { btn.disabled = false; alert(data.error); return; }
        // Ripristina bottone aggiungi
        var addBtn = document.querySelector('.btn-cart-row[data-id="' + id + '"]');
        if (addBtn) {
          addBtn.classList.remove('btn-outline');
          addBtn.classList.add('btn-primary');
          addBtn.innerHTML = svgCart + '<span class="sr-only">{{ "Aggiungi al carrello"|trans }}</span>';
          addBtn.title = '{{ "Aggiungi al carrello"|trans }}';
          addBtn.disabled = false;
        }
        btn.remove();
        updateBadges(data.count || 0);
      })
      .catch(function (err) {
        btn.disabled = false;
        alert(err && err.message ? err.message : '{{ "Servizio temporaneamente non disponibile. Riprova tra poco."|trans|escape("js") }}');
      });
    });
  }

  // Attacca remove ai bottoni già presenti (item già in carrello al caricamento pagina)
  document.querySelectorAll('.btn-cart-remove').forEach(attachRemove);
})();
</script>
