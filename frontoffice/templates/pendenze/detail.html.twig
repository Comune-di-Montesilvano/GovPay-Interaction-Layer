{% extends 'base.html.twig' %}

{% block title %}{{ 'Dettaglio pendenza'|trans }} - {{ app_entity.name }}{% endblock %}

{% set p = pendenza_preview|default({}) %}
{% set raw = pendenza|default({}) %}
{% set pagatore = p.soggetto_pagatore|default({}) %}
{% set voci = p.voci|default([]) %}
{% set iuv_display = p.iuv|default(raw.iuv|default(raw.iuvAvviso|default(raw.iuv_avviso|default(raw.iuvPagamento|default(''))))) %}
{% set status_cls = p.stato.code|default('') == 'ESEGUITA'
    ? 'status-paid'
    : (p.stato.code|default('') in ['NON_ESEGUITA','ESEGUITA_PARZIALE'] ? 'status-pay'
        : (p.stato.code|default('') in ['SCADUTA','ANOMALA'] ? 'status-due' : 'status-cancel')) %}
{% set is_bollo = p.is_bollo|default(false)
    or (voci|length > 0
        and voci[0].tipoBollo is defined
        and voci[0].tipoBollo is not null
        and voci[0].tipoBollo != '') %}
{% set bolloXmlTesto = '' %}
{% set bolloXmlIuv   = '' %}
{% if voci is iterable %}
  {% for voce in voci %}
    {% if voce.riscossioni is defined and voce.riscossioni is iterable %}
      {% for risc in voce.riscossioni %}
        {% if bolloXmlTesto == ''
            and risc.tipo is defined and risc.tipo == 'MBT'
            and risc.allegato is defined
            and risc.allegato.testo is defined
            and risc.allegato.testo %}
          {% set bolloXmlTesto = risc.allegato.testo %}
          {% set bolloXmlIuv   = risc.iuv|default('bollo') %}
        {% endif %}
      {% endfor %}
    {% endif %}
  {% endfor %}
{% endif %}

{% block content %}

{# ── Page header ── #}
<div class="page-head">
  <div class="container">
    <div class="crumbs">
      <a href="/">{{ 'Home'|trans }}</a>
      <span class="sep">/</span>
      <a href="/pendenze">{{ 'Le mie pendenze'|trans }}</a>
      <span class="sep">/</span>
      <span class="current">{{ 'Dettaglio'|trans }}</span>
    </div>
    <div style="display:flex;flex-wrap:wrap;align-items:center;gap:var(--sp-3);">
      <h1>{{ 'Dettaglio pendenza'|trans }}</h1>
      <span class="status {{ status_cls }}"><span class="dot"></span>{{ p.stato.label|default('—') }}</span>
    </div>
  </div>
</div>

{# ── Content ── #}
<section class="block">
  <div class="container">
    <div class="split">

      {# ── Main ── #}
      <div>

        {% if is_bollo %}
          <div class="alert alert-info" role="status" style="margin-bottom:var(--sp-4); display: flex; gap: var(--sp-2); align-items: start;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="alert-icon" style="flex-shrink: 0; margin-top: 2px;" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>
            </svg>
            <div>
              <strong>{{ 'Marca da Bollo Telematica'|trans }}</strong> — {{ voci|length }} {{ (voci|length > 1 ? 'voci'|trans : 'voce'|trans) }} {{ 'da € 16,00 ciascuna'|trans }}.
              {% set _prov = (voci|length > 0 and voci[0].provinciaResidenza is defined) ? voci[0].provinciaResidenza : '' %}
              {% if _prov %}{{ 'Provincia di residenza'|trans }}: <strong>{{ _prov }}</strong>.{% endif %}
              {{ 'Avviso PDF e rateizzazione non applicabili.'|trans }}
            </div>
          </div>
        {% endif %}

        {# ── avviso-card ── #}
        <div class="avviso-card" style="margin-bottom:var(--sp-4);">
          <div class="avviso-header">
            <div class="from">
              {{ 'Pendenza'|trans }}
              <strong>{{ p.causale|default('—') }}</strong>
            </div>
            <span class="status {{ status_cls }}"><span class="dot"></span>{{ p.stato.label|default('—') }}</span>
          </div>
          <div class="avviso-body">
            {% if p.numero_avviso %}
              <div class="avviso-row">
                <span class="k">{{ 'Numero avviso'|trans }}</span>
                <span class="v mono">{{ p.numero_avviso }}</span>
              </div>
            {% endif %}
            {% if iuv_display %}
              <div class="avviso-row">
                <span class="k">{{ 'IUV'|trans }}</span>
                <span class="v mono">{{ iuv_display }}</span>
              </div>
            {% endif %}
            <div class="avviso-row">
              <span class="k">{{ 'Causale'|trans }}</span>
              <span class="v">{{ p.causale|default('—') }}</span>
            </div>
            <div class="avviso-row">
              <span class="k">{{ 'Pagatore'|trans }}</span>
              <span class="v">
                <strong>{{ pagatore.anagrafica|default('—') }}</strong>
                {% if pagatore.identificativo %}
                  <span style="color:var(--fg-3);font-family:var(--font-mono);font-size:12px;">({{ pagatore.identificativo }})</span>
                {% endif %}
              </span>
            </div>
            <div class="avviso-row">
              <span class="k">{{ 'Data scadenza'|trans }}</span>
              <span class="v">{{ p.data_scadenza ? p.data_scadenza|date('d/m/Y') : '—' }}</span>
            </div>
            <div class="avviso-row">
              <span class="k" style="font-weight:700;color:var(--fg-1);">{{ 'Importo'|trans }}</span>
              <span class="v amount">
                {% if p.importo is not null %}€ {{ p.importo|number_format(2, ',', '.') }}{% else %}—{% endif %}
              </span>
            </div>
          </div>

          <div class="avviso-actions">
            {% if is_bollo %}
              {% set _burl = '/avviso-bollo?iuv=' ~ (p.numero_avviso ?? '')|url_encode
                  ~ '&ente=' ~ (p.id_dominio ?? '')|url_encode
                  ~ '&importo=' ~ ((p.importo ?? 0) * 100)|round
                  ~ '&causale=' ~ (p.causale ?? '')|url_encode
                  ~ '&cf=' ~ (pagatore.identificativo ?? pagatore.codice_fiscale ?? '')|url_encode
                  ~ '&scadenza=' ~ (p.data_scadenza ?? '')|url_encode %}
              {% for v in voci %}
                {% set _burl = _burl ~ '&desc[]=' ~ (v.descrizione ?? '')|url_encode %}
              {% endfor %}
              <a class="btn btn-outline" href="{{ _burl }}" target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3h12v18l-3-2-3 2-3-2-3 2z"/><path d="M9 8h6M9 12h4"/></svg>
                {{ 'Bollettino MBT'|trans }}
              </a>
            {% elseif p.download_url %}
              <a class="btn btn-outline" href="{{ p.download_url }}" target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3h12v18l-3-2-3 2-3-2-3 2z"/><path d="M9 8h6M9 12h4"/></svg>
                {{ 'Scarica PDF avviso'|trans }}
              </a>
            {% endif %}
            {% if p.receipt_url and not is_bollo %}
              <a class="btn btn-outline" href="{{ p.receipt_url }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 4v12"/><path d="m7 11 5 5 5-5"/><path d="M5 20h14"/></svg>
                {{ 'Scarica ricevuta'|trans }}
              </a>
            {% endif %}
            {% if p.is_payable and p.id_pendenza and not is_bollo %}
                <button
                  type="button"
                  class="btn btn-primary"
                  id="btn-cart-add"
                  data-id="{{ p.id_pendenza }}"
                  data-added="{{ p.id_pendenza in cart_items_ids|default([]) ? '1' : '0' }}"
                  aria-label="{{ 'Aggiungi al carrello'|trans }}"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/><path d="M3 4h2l3 12h11l2-8H7"/></svg>
                  <span id="btn-cart-label">
                    {% if p.id_pendenza in cart_items_ids|default([]) %}
                      {{ 'Nel carrello ✓'|trans }}
                    {% else %}
                      {{ 'Aggiungi al carrello'|trans }}
                    {% endif %}
                  </span>
                </button>
            {% endif %}
            {% if p.is_payable and p.id_pendenza and is_bollo %}
              <a class="btn btn-primary" href="/pendenze/{{ p.id_pendenza|url_encode }}/checkout" style="color:#fff!important;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m13 3-7 11h5l-1 7 7-11h-5z"/></svg>
                {{ 'Paga Marca da Bollo'|trans }}
              </a>
            {% elseif p.is_payable and p.checkout_url and not is_bollo %}
              <a class="btn btn-ghost" href="{{ p.checkout_url }}" target="_blank" rel="noopener">{{ 'Paga su pagoPA'|trans }}</a>
            {% endif %}
          </div>
        </div>

        {# ── Dettaglio voci ── #}
        {% if voci %}
          <div class="card card-pad">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--sp-3);">
              <h2 style="margin:0;font-size:16px;">{{ 'Dettaglio voci'|trans }}</h2>
              <span style="font-size:13px;color:var(--fg-3);">{{ voci|length }} {{ voci|length > 1 ? 'voci'|trans : 'voce'|trans }}</span>
            </div>
            <div class="table-wrap">
              <table class="table">
                <thead>
                  <tr>
                    <th>{{ 'Descrizione'|trans }}</th>
                    {% if is_bollo %}
                      <th>{{ 'IUBD'|trans }}</th>
                      <th>{{ 'Tipo bollo'|trans }}</th>
                      <th>{{ 'Provincia'|trans }}</th>
                      <th>{{ 'Impronta documento'|trans }}</th>
                      <th style="text-align:center;">{{ 'Azioni'|trans }}</th>
                    {% endif %}
                    <th style="text-align:right;">{{ 'Importo'|trans }}</th>
                  </tr>
                </thead>
                <tbody>
                  {% for voce in voci %}
                    <tr style="cursor:default;">
                      <td>{{ voce.descrizione|default('—') }}</td>
                      {% if is_bollo %}
                        <td>
                          {% set voceBolloIubd = '' %}
                          {% if voce.riscossioni is defined and voce.riscossioni is iterable %}
                            {% for risc in voce.riscossioni %}
                              {% if voceBolloIubd == ''
                                  and risc.tipo is defined and risc.tipo == 'MBT'
                                  and risc.allegato is defined
                                  and risc.allegato.contenuto is defined
                                  and risc.allegato.contenuto.IUBD is defined
                                  and risc.allegato.contenuto.IUBD %}
                                {% set voceBolloIubd = risc.allegato.contenuto.IUBD %}
                              {% endif %}
                            {% endfor %}
                          {% endif %}
                          {{ voceBolloIubd|default('—') }}
                        </td>
                        <td>{{ voce.tipoBollo|default('—') }}</td>
                        <td>{{ voce.provinciaResidenza|default('—') }}</td>
                        <td>
                          {% if voce.hashDocumento is defined and voce.hashDocumento %}
                            <code class="small user-select-all" style="font-family:var(--font-mono);font-size:12px;" title="{{ voce.hashDocumento }}">{{ voce.hashDocumento|slice(0,24) }}&hellip;</code>
                          {% else %}—{% endif %}
                        </td>
                        <td style="text-align:center;">
                          {% set voceBolloXmlTesto = '' %}
                          {% set voceBolloXmlIuv = '' %}
                          {% if voce.riscossioni is defined and voce.riscossioni is iterable %}
                            {% for risc in voce.riscossioni %}
                              {% if voceBolloXmlTesto == ''
                                  and risc.tipo is defined and risc.tipo == 'MBT'
                                  and risc.allegato is defined
                                  and risc.allegato.testo is defined
                                  and risc.allegato.testo %}
                                {% set voceBolloXmlTesto = risc.allegato.testo %}
                                {% set voceBolloXmlIuv = risc.iuv|default('bollo') %}
                              {% endif %}
                            {% endfor %}
                          {% endif %}
                          {% if voceBolloXmlTesto %}
                            <button type="button"
                              class="btn btn-outline btn-sm download-voce-bollo-xml-btn"
                              style="padding: 2px 8px; font-size: 12px; height: auto; min-height: 0; display: inline-flex; align-items: center; justify-content: center; cursor: pointer;"
                              data-testo="{{ voceBolloXmlTesto }}"
                              data-iuv="{{ voceBolloXmlIuv }}"
                              title="Scarica XML Marca da Bollo Telematica">
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 4v12"/><path d="m7 11 5 5 5-5"/><path d="M5 20h14"/></svg>
                            </button>
                          {% else %}
                            <span style="color:var(--fg-3);">—</span>
                          {% endif %}
                        </td>
                      {% endif %}
                      <td class="amount" style="text-align:right;">
                        {% if voce.importo is defined %}
                          € {{ voce.importo|number_format(2, ',', '.') }}
                        {% else %}—{% endif %}
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
        {% endif %}

      </div>

      {# ── Aside ── #}
      <aside class="aside">
        <div class="card card-pad">
          <h3>{{ 'Intestatario sessione'|trans }}</h3>
          <p style="font-size:14px;color:var(--fg-2);margin:0 0 var(--sp-3);">
            {{ 'Codice fiscale'|trans }}: <strong>{{ codice_fiscale|default('') }}</strong>
          </p>
          <a class="btn btn-outline" style="width:100%;justify-content:center;" href="/pendenze">{{ 'Vai all\'elenco'|trans }}</a>
        </div>
        {% if back_url|default('') %}
          <div class="card card-pad">
            <a class="btn btn-ghost" style="width:100%;justify-content:center;" href="{{ back_url }}">{{ 'Torna all\'elenco'|trans }}</a>
          </div>
        {% endif %}
      </aside>

    </div>
  </div>
</section>

{% block scripts %}
  {% if is_bollo %}
    <script>
    (function(){
      document.addEventListener('click', function(e) {
        const btn = e.target.closest('.download-voce-bollo-xml-btn');
        if (!btn) return;
        const b64      = btn.dataset.testo;
        const iuv      = btn.dataset.iuv || 'bollo';
        const filename = 'marca-da-bollo-' + iuv + '.xml';
        try {
          const binary = atob(b64);
          const bytes  = new Uint8Array(binary.length);
          for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
          const blob = new Blob([bytes], { type: 'application/xml' });
          const url  = URL.createObjectURL(blob);
          const a    = document.createElement('a');
          a.href = url; a.download = filename;
          document.body.appendChild(a); a.click();
          document.body.removeChild(a);
          URL.revokeObjectURL(url);
        } catch(err) {
          alert('Errore download marca da bollo: ' + err.message);
        }
      });
    })();
    </script>
  {% endif %}
{% endblock %}

{% endblock %}
