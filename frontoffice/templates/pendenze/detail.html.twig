{% extends 'base.html.twig' %}

{% block title %}{{ 'Dettaglio pendenza'|trans }} - {{ app_entity.name }}{% endblock %}

{% set p = pendenza_preview|default({}) %}
{% set raw = pendenza|default({}) %}
{% set pagatore = p.soggetto_pagatore|default({}) %}
{% set voci = p.voci|default([]) %}
{% set iuv_display = p.iuv|default(raw.iuv|default(raw.iuvAvviso|default(raw.iuv_avviso|default(raw.iuvPagamento|default(''))))) %}

{% block content %}

{# ── Page Header ── #}
<section class="fo-page-header">
  <div class="fo-page-header-inner">
    <nav class="fo-breadcrumb" aria-label="{{ 'Percorso'|trans }}">
      <a href="/">{{ 'Home'|trans }}</a>
      <span class="fo-breadcrumb-sep" aria-hidden="true">›</span>
      <a href="/pendenze">{{ 'Le mie pendenze'|trans }}</a>
      <span class="fo-breadcrumb-sep" aria-hidden="true">›</span>
      <span aria-current="page">{{ 'Dettaglio'|trans }}</span>
    </nav>
    <div class="fo-ph-badge">{{ 'Area personale'|trans }}</div>
    <h1>{{ 'Dettaglio pendenza'|trans }}</h1>
  </div>
</section>

{# ── Content ── #}
<section class="fo-form-section">
  <div class="container-xxl">
    <div class="row g-4">

      {# ── Main ── #}
      <div class="col-12 col-lg-8">

        <div class="fo-form-card mb-4">
          <div class="fo-form-card-body">
            <p class="fo-field-section">{{ 'Dati pendenza'|trans }}</p>

            {% set badge_cls = p.stato.code in ['NON_ESEGUITA','ESEGUITA_PARZIALE'] ? 'fo-status-open' : (p.stato.code in ['SCADUTA','ANOMALA'] ? 'fo-status-warn' : (p.stato.code == 'ESEGUITA' ? 'fo-status-done' : 'fo-status-neutral')) %}
            <div class="d-flex flex-wrap gap-2 align-items-center mb-4">
              <span class="fo-status-badge {{ badge_cls }}">{{ p.stato.label|default('—') }}</span>
              {% if p.numero_avviso %}
                <span class="text-muted small">{{ 'N. avviso'|trans }}: <span class="font-monospace">{{ p.numero_avviso }}</span></span>
              {% endif %}
              {% if iuv_display %}
                <span class="text-muted small">{{ 'IUV'|trans }}: <span class="font-monospace">{{ iuv_display }}</span></span>
              {% endif %}
            </div>

            <dl class="fo-dl">
              <div class="fo-dl-row">
                <dt>{{ 'Causale'|trans }}</dt>
                <dd>{{ p.causale|default('—') }}</dd>
              </div>
              {% if p.numero_avviso %}
                <div class="fo-dl-row">
                  <dt>{{ 'Numero avviso'|trans }}</dt>
                  <dd><span class="font-monospace">{{ p.numero_avviso }}</span></dd>
                </div>
              {% endif %}
              {% if iuv_display %}
                <div class="fo-dl-row">
                  <dt>{{ 'IUV'|trans }}</dt>
                  <dd><span class="font-monospace">{{ iuv_display }}</span></dd>
                </div>
              {% endif %}
              <div class="fo-dl-row">
                <dt>{{ 'Importo'|trans }}</dt>
                <dd>
                  {% if p.importo is not null %}
                    <strong>€ {{ p.importo|number_format(2, ',', '.') }}</strong>
                  {% else %}
                    —
                  {% endif %}
                </dd>
              </div>
              <div class="fo-dl-row">
                <dt>{{ 'Data scadenza'|trans }}</dt>
                <dd>{{ p.data_scadenza ? p.data_scadenza|date('d/m/Y') : '—' }}</dd>
              </div>
              <div class="fo-dl-row">
                <dt>{{ 'Pagatore'|trans }}</dt>
                <dd>
                  <strong>{{ pagatore.anagrafica|default('—') }}</strong>
                  {% if pagatore.identificativo %}
                    <br><span class="text-muted small font-monospace">{{ pagatore.identificativo }}</span>
                  {% endif %}
                </dd>
              </div>
            </dl>
          </div>

          <div style="padding: var(--fo-sp-4) var(--fo-sp-6); border-top: 1px solid var(--fo-border-1); display:flex; flex-wrap:wrap; gap: var(--fo-sp-3); align-items:center;">
            {% if p.download_url %}
              <a class="btn btn-outline-primary" href="{{ p.download_url }}" target="_blank" rel="noopener">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1" aria-hidden="true"><path d="M6 3h12v18l-3-2-3 2-3-2-3 2z"/><path d="M9 8h6M9 12h4"/></svg>
                {{ 'Scarica PDF avviso'|trans }}
              </a>
            {% endif %}
            {% if p.receipt_url %}
              <a class="btn btn-outline-success" href="{{ p.receipt_url }}">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1" aria-hidden="true"><path d="M12 4v12"/><path d="m7 11 5 5 5-5"/><path d="M5 20h14"/></svg>
                {{ 'Scarica ricevuta'|trans }}
              </a>
            {% endif %}
            {% if p.is_payable and p.id_pendenza %}
              <button
                type="button"
                class="btn btn-primary"
                id="btn-cart-add"
                data-id="{{ p.id_pendenza }}"
                data-added="{{ p.id_pendenza in cart_items_ids|default([]) ? '1' : '0' }}"
                aria-label="{{ 'Aggiungi al carrello'|trans }}"
              >
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1" aria-hidden="true"><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/><path d="M3 4h2l3 12h11l2-8H7"/></svg>
                <span id="btn-cart-label">
                  {% if p.id_pendenza in cart_items_ids|default([]) %}
                    {{ 'Nel carrello ✓'|trans }}
                  {% else %}
                    {{ 'Aggiungi al carrello'|trans }}
                  {% endif %}
                </span>
              </button>
            {% endif %}
            {% if p.is_payable and p.checkout_url %}
              <a class="btn btn-outline-secondary" href="{{ p.checkout_url }}" target="_blank" rel="noopener">{{ 'Paga su pagoPA'|trans }}</a>
            {% endif %}
          </div>
        </div>

        {% if voci %}
          <div class="fo-form-card">
            <div class="fo-form-card-body" style="padding-bottom:0;">
              <div class="d-flex justify-content-between align-items-center">
                <p class="fo-field-section mb-0">{{ 'Dettaglio voci'|trans }}</p>
                <span class="text-muted small">{{ voci|length }} {{ voci|length > 1 ? 'voci'|trans : 'voce'|trans }}</span>
              </div>
            </div>
            <div class="table-responsive">
              <table class="table mb-0 align-middle">
                <thead>
                  <tr>
                    <th>{{ 'Descrizione'|trans }}</th>
                    <th class="text-end">{{ 'Importo'|trans }}</th>
                  </tr>
                </thead>
                <tbody>
                  {% for voce in voci %}
                    <tr>
                      <td>{{ voce.descrizione|default('—') }}</td>
                      <td class="text-end">
                        {% if voce.importo is defined %}
                          € {{ voce.importo|number_format(2, ',', '.') }}
                        {% else %}
                          —
                        {% endif %}
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
        {% endif %}

      </div>

      {# ── Sidebar ── #}
      <div class="col-12 col-lg-4">
        <div class="fo-sidebar-card mb-4">
          <h3>{{ 'Intestatario sessione'|trans }}</h3>
          <p>{{ 'Codice fiscale'|trans }}: <strong style="color:var(--fo-fg-1);">{{ codice_fiscale|default('') }}</strong></p>
          <a class="btn btn-outline-primary w-100" href="/pendenze">{{ 'Vai all\'elenco'|trans }}</a>
        </div>
        {% if back_url|default('') %}
          <div class="fo-sidebar-card">
            <a class="btn btn-outline-secondary w-100" href="{{ back_url }}">{{ 'Torna all\'elenco'|trans }}</a>
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

{% endblock %}
