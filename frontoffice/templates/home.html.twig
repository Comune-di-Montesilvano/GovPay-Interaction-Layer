{% extends 'base.html.twig' %}

{% block head %}
<style>
  body { background: #f6f8fb; }
  .page-hero {
    padding: 3.5rem 0 2.5rem;
    background: linear-gradient(135deg, #0b1431 0%, #0a2c5f 50%, #005fcc 100%);
    color: #fff;
  }
  .page-hero .btn { font-weight: 600; border-radius: 999px; }
</style>
{% endblock %}

{% block content %}
<section class="page-hero">
  <div class="container-xxl">
    <div class="row">
      <div class="col-lg-9 col-xl-8">
        <h1 class="display-6 fw-semibold mb-3">{{ 'Gestisci i pagamenti PagoPA con pochi clic'|trans }}</h1>
        <p class="lead mb-4" style="color:rgba(255,255,255,.8)">{{ 'Cerca un avviso, generalo spontaneamente, aggiungilo al carrello e paga fino a 5 pendenze insieme — tutto senza fare code.'|trans }}</p>
        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-warning text-dark" href="/pagamento-avviso">{{ 'Paga un avviso'|trans }}</a>
          <a class="btn btn-outline-light" href="/pagamento-spontaneo">{{ 'Pagamento spontaneo'|trans }}</a>
          <a class="btn btn-outline-light" href="/carrello">
            <i class="fa-solid fa-cart-shopping me-1"></i>{{ 'Carrello'|trans }}
            {% if cart_count|default(0) > 0 %}
              <span class="badge bg-warning text-dark ms-1 cart-badge">{{ cart_count }}</span>
            {% else %}
              <span class="badge bg-warning text-dark ms-1 cart-badge" style="display:none;">0</span>
            {% endif %}
          </a>
          {% if spid_enabled %}
            <a class="btn btn-outline-light" href="/pendenze">{{ 'Le mie pendenze'|trans }}</a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

<div class="container-xxl py-4">
  <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="row g-0">

      <div class="col-md-7 p-4 p-lg-5">
        <h2 class="h5 fw-semibold mb-3">{{ 'Come funziona'|trans }}</h2>
        <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
          <li class="d-flex gap-3 align-items-start">
            <span class="badge rounded-pill bg-primary mt-1 flex-shrink-0">1</span>
            <span>{{ 'Inserisci il <strong>codice avviso</strong> ricevuto (o genera un pagamento spontaneo) per trovare la tua pendenza.'|trans|raw }}</span>
          </li>
          <li class="d-flex gap-3 align-items-start">
            <span class="badge rounded-pill bg-primary mt-1 flex-shrink-0">2</span>
            <span>{{ 'Puoi <strong>pagare subito</strong>, aggiungere al <strong>carrello</strong> (fino a 5 avvisi) o <strong>stampare il PDF</strong> per pagare in banca o tabaccheria.'|trans|raw }}</span>
          </li>
          <li class="d-flex gap-3 align-items-start">
            <span class="badge rounded-pill bg-primary mt-1 flex-shrink-0">3</span>
            <span>{{ 'Il pagamento avviene sul portale ufficiale <strong>PagoPA</strong>: sicuro, tracciato, con ricevuta digitale immediata.'|trans|raw }}</span>
          </li>
        </ul>
        <a href="/guida" class="btn btn-link px-0 mt-3 small">
          <i class="fas fa-question-circle me-1"></i>{{ 'Guida completa'|trans }}
        </a>
      </div>

      <div class="col-md-5 p-4 p-lg-5 bg-light border-start d-flex flex-column justify-content-center">
        <h2 class="h5 fw-semibold mb-3">{{ 'Assistenza'|trans }}</h2>
        {% if support_email %}
        <p class="mb-2 small">
          <i class="fas fa-envelope text-primary me-2"></i>
          <a href="mailto:{{ support_email }}">{{ support_email }}</a>
        </p>
        {% endif %}
        {% if support_phone %}
        <p class="mb-2 small">
          <i class="fas fa-phone text-primary me-2"></i>
          {{ support_phone }}
          {% if support_hours %}<span class="text-muted ms-1">({{ support_hours }})</span>{% endif %}
        </p>
        {% endif %}
        {% if support_location %}
        <p class="mb-0 small text-muted">{{ support_location|raw }}</p>
        {% endif %}
      </div>

    </div>
  </div>
</div>
{% endblock %}
