{% extends 'base.html.twig' %}

{% block title %}{{ 'Operazione completata'|trans }} – {{ app_entity.name }}{% endblock %}

{% block content %}
<section class="block">
  <div class="container">
    <div style="max-width:640px;margin:0 auto;">

      <div class="alert alert-success" role="alert" style="margin-bottom:var(--sp-4);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="alert-icon" aria-hidden="true"><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg>
        <div>
          <strong style="font-size:16px;">{{ 'Pagamento completato'|trans }}</strong>
          <p style="margin:4px 0 0;">
            {% if numero_avvisi is defined and numero_avvisi > 1 %}
              {{ 'Hai pagato'|trans }} <strong>{{ numero_avvisi }} {{ 'avvisi'|trans }}</strong> {{ 'tramite il Checkout pagoPA. Lo stato potrebbe aggiornarsi entro qualche minuto.'|trans }}
            {% else %}
              {{ 'Il pagamento è stato confermato dal Checkout pagoPA. Lo stato potrebbe aggiornarsi entro qualche minuto.'|trans }}
            {% endif %}
          </p>
        </div>
      </div>

      {% if numero_avviso %}
        <p style="font-size:14px;color:var(--fg-2);margin-bottom:var(--sp-4);">{{ 'Numero avviso'|trans }}: <strong>{{ numero_avviso }}</strong></p>
      {% endif %}

      <div style="display:flex;flex-wrap:wrap;gap:var(--sp-3);margin-bottom:var(--sp-5);">
        {% if numero_avvisi is defined and numero_avvisi > 1 %}
          <a class="btn btn-primary" href="/pendenze">{{ 'Le mie pendenze'|trans }}</a>
          {% for item in receipt_items|default([]) %}
            <a class="btn btn-outline" href="{{ item.receipt_url }}" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              {% if (receipt_items|default([]))|length > 1 %}
                {{ 'Scarica ricevuta'|trans }} {{ item.numero_avviso }}
              {% else %}
                {{ 'Scarica ricevuta'|trans }}
              {% endif %}
            </a>
          {% endfor %}
        {% else %}
          {% if spid_enabled and (not is_logged_in) %}
            <a class="btn btn-primary" href="{{ login_path }}">{{ 'Accedi per vedere lo stato'|trans }}</a>
          {% else %}
            <a class="btn btn-primary" href="{{ detail_path }}">{{ 'Vai alla pendenza'|trans }}</a>
          {% endif %}
          {% if receipt_url is defined and receipt_url %}
            <a class="btn btn-outline" href="{{ receipt_url }}" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              {{ 'Scarica ricevuta'|trans }}
            </a>
          {% endif %}
          <a class="btn btn-ghost" href="/pendenze">{{ 'Le mie pendenze'|trans }}</a>
        {% endif %}
        <a class="btn btn-ghost" href="/">{{ 'Torna alla home'|trans }}</a>
      </div>

      <div style="font-size:13px;color:var(--fg-3);">
        {% if receipt_items|default([])|length > 0 or (receipt_url is defined and receipt_url) %}
          <p style="margin:0 0 4px;">{{ 'La ricevuta potrebbe non essere disponibile immediatamente dopo il pagamento.'|trans }}</p>
        {% endif %}
        <p style="margin:0;">{{ 'Se riscontri anomalie puoi contattarci a'|trans }} <a href="mailto:{{ support_email }}">{{ support_email }}</a>.</p>
      </div>

    </div>
  </div>
</section>
{% endblock %}
