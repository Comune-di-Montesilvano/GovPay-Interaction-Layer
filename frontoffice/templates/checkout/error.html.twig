{% extends 'base.html.twig' %}

{% block title %}{{ 'Errore pagamento'|trans }} – {{ app_entity.name }}{% endblock %}

{% block content %}
<section class="block">
  <div class="container">
    <div style="max-width:640px;margin:0 auto;">

      <div class="alert alert-danger" role="alert" style="margin-bottom:var(--sp-4);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="alert-icon" aria-hidden="true"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <div>
          <strong style="font-size:16px;">{{ 'Si è verificato un errore'|trans }}</strong>
          <p style="margin:4px 0 0;">{{ 'Non è stato possibile completare l\'operazione nel Checkout pagoPA. Puoi riprovare tra qualche minuto.'|trans }}</p>
        </div>
      </div>

      {% if numero_avviso %}
        <p style="font-size:14px;color:var(--fg-2);margin-bottom:var(--sp-4);">{{ 'Numero avviso'|trans }}: <strong>{{ numero_avviso }}</strong></p>
      {% endif %}

      <div style="display:flex;flex-wrap:wrap;gap:var(--sp-3);margin-bottom:var(--sp-5);">
        {% if spid_enabled and (not is_logged_in) %}
          <a class="btn btn-primary" href="{{ login_path }}">{{ 'Accedi e riprova'|trans }}</a>
        {% else %}
          <a class="btn btn-primary" href="{{ detail_path }}">{{ 'Torna alla pendenza'|trans }}</a>
        {% endif %}
        {% for item in pdf_items|default([]) %}
          <a class="btn btn-outline" href="{{ item.pdf_url }}" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            {% if (pdf_items|default([]))|length > 1 %}
              {{ 'Scarica PDF avviso'|trans }} {{ item.numero_avviso }}
            {% else %}
              {{ 'Scarica PDF avviso'|trans }}
            {% endif %}
          </a>
        {% endfor %}
        <a class="btn btn-ghost" href="/pendenze">{{ 'Le mie pendenze'|trans }}</a>
        <a class="btn btn-ghost" href="/">{{ 'Torna alla home'|trans }}</a>
      </div>

      <div style="font-size:13px;color:var(--fg-3);">
        <p style="margin:0;">{{ 'Se l\'errore persiste, contattaci a'|trans }} <a href="mailto:{{ support_email }}">{{ support_email }}</a>.</p>
      </div>

    </div>
  </div>
</section>
{% endblock %}
