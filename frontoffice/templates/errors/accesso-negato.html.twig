{% extends 'base.html.twig' %}

{% block title %}{{ 'Accesso negato'|trans }} - {{ app_entity.name }}{% endblock %}

{% block content %}
<section class="block">
  <div class="container">
    <div style="max-width:560px;margin:0 auto;text-align:center;padding:var(--sp-8) 0;">
      <p style="font-size:12px;text-transform:uppercase;letter-spacing:.1em;color:var(--fg-3);margin:0 0 var(--sp-3);">{{ 'Errore di autenticazione'|trans }}</p>
      <h1 style="font-size:32px;margin:0 0 var(--sp-3);">{{ 'Accesso negato'|trans }}</h1>
      <p style="font-size:16px;color:var(--fg-2);margin:0 0 var(--sp-5);">{{ 'Si è verificato un errore durante il processo di autenticazione. Il tuo accesso non ha potuto essere completato.'|trans }}</p>
      <div style="display:flex;gap:var(--sp-3);justify-content:center;flex-wrap:wrap;">
        <a class="btn btn-primary" href="/">{{ 'Torna alla home'|trans }}</a>
        <a class="btn btn-outline" href="/login">{{ 'Riprova accesso'|trans }}</a>
      </div>
      {% if error_message is defined and error_message %}
        <p style="font-size:13px;color:var(--fg-3);margin:var(--sp-5) 0 0;">{{ error_message }}</p>
      {% endif %}
    </div>
  </div>
</section>
{% endblock %}
