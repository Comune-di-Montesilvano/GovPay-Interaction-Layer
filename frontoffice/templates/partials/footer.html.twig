{# ============================================================
   Frontoffice Footer — Design 2026
   pagoPA strip + dark institutional footer
   ============================================================ #}

{# ── pagoPA strip ── #}
<section class="pagopa-strip">
  <div class="container">
    <div class="text">
      <img src="/img/logo-pagopa-bianco.svg" alt="pagoPA" class="logo-pago" />
      <p>{{ 'I pagamenti vengono completati sul portale ufficiale <strong style="color:#fff">pagoPA</strong>: sicuro, tracciato, con ricevuta digitale immediata.'|trans|raw }}</p>
    </div>
    <a class="btn" href="https://www.pagopa.gov.it" target="_blank" rel="noopener noreferrer" style="background:transparent;color:#fff;border-color:rgba(255,255,255,.6);">
      {{ "Cos'è pagoPA"|trans }}
    </a>
  </div>
</section>

{# ── Site footer ── #}
<footer class="site-footer">
  <div class="container">
    <div class="f-top">
      <div class="f-ident">
        {% if app_logo.type == 'img' %}
          <img src="{{ app_logo.src }}" alt="{{ app_entity.name }}" class="stemma" />
        {% else %}
          <svg class="stemma" style="width:44px;height:44px;flex-shrink:0;filter:drop-shadow(0 2px 6px rgba(0,0,0,.3));" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        {% endif %}
        <div>
          <div class="title">{{ app_entity.name }}</div>
          <div class="sub">
            {{ app_entity.full|default(app_entity.name) }}
            {% if app_entity.suffix %}<br/>{{ app_entity.suffix }}{% endif %}
          </div>
        </div>
      </div>

      {% if support_email or support_phone %}
      <div class="f-help">
        <span class="f-help-lbl">{{ 'Assistenza pagamenti'|trans }}</span>
        {% if support_phone %}
          <a href="tel:{{ support_phone|replace({' ':''}) }}">{{ support_phone }}</a>
          {% if support_hours %}<span class="dot-sep">·</span><span class="muted-li">{{ support_hours }}</span>{% endif %}
        {% endif %}
        {% if support_email %}
          {% if support_phone %}<span class="dot-sep">·</span>{% endif %}
          <a href="mailto:{{ support_email }}">{{ support_email }}</a>
        {% endif %}
      </div>
      {% endif %}
    </div>
  </div>

  <div class="f-bottom">
    <div class="container">
      <div>
        © {{ "now"|date("Y") }} {{ app_entity.name }} —
        {% if app_repo_url %}
          <a href="{{ app_repo_url }}" target="_blank" rel="noopener noreferrer">{{ 'Sportello pagamenti pagoPA'|trans }}{% if app_version_label %} (GIL {{ app_version_label }}){% endif %}</a>
        {% else %}
          {{ 'Sportello pagamenti pagoPA'|trans }}{% if app_version_label %} (GIL {{ app_version_label }}){% endif %}
        {% endif %}
      </div>
      <div class="f-legal">
        <a href="/guida">{{ 'Guida'|trans }}</a>
        <a href="/privacy">{{ 'Privacy'|trans }}</a>
        <a href="/accessibilita">{{ 'Accessibilità'|trans }}</a>
      </div>
    </div>
  </div>
</footer>
