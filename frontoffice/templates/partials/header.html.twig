{# ============================================================
   Frontoffice Header — Design 2026
   1. Slim institutional bar (navy)
   2. Institutional header (white: logo + entity + login)
   3. Sticky main nav (Home, Paga avviso, Spontaneo, Pendenze, Guida + Cart)
   ============================================================ #}

{# ── 1. Slim bar ── #}
<div class="slim-header">
  <div class="container">
    <div class="left">
      <span><span class="gov-dot"></span>{{ 'Sito ufficiale della Pubblica Amministrazione'|trans }}</span>
    </div>
    <div class="right">
      <div class="lang-switch lang-switch-desktop">
        <a href="?lang=it" class="{{ current_locale == 'it' ? 'active' : '' }}">IT</a>
        <a href="?lang=en" class="{{ current_locale == 'en' ? 'active' : '' }}">EN</a>
        <a href="?lang=fr" class="{{ current_locale == 'fr' ? 'active' : '' }}">FR</a>
        <a href="?lang=es" class="{{ current_locale == 'es' ? 'active' : '' }}">ES</a>
        <a href="?lang=de" class="{{ current_locale == 'de' ? 'active' : '' }}">DE</a>
      </div>
      <div class="lang-switch-mobile" style="display:none;">
        <select class="lang-select-input" onchange="location = this.value;" aria-label="{{ 'Seleziona lingua'|trans }}">
          <option value="?lang=it" {{ current_locale == 'it' ? 'selected' : '' }}>IT</option>
          <option value="?lang=en" {{ current_locale == 'en' ? 'selected' : '' }}>EN</option>
          <option value="?lang=fr" {{ current_locale == 'fr' ? 'selected' : '' }}>FR</option>
          <option value="?lang=es" {{ current_locale == 'es' ? 'selected' : '' }}>ES</option>
          <option value="?lang=de" {{ current_locale == 'de' ? 'selected' : '' }}>DE</option>
        </select>
      </div>
    </div>
  </div>
</div>

{# ── 2. Institutional header ── #}
<header class="inst-header">
  <div class="container" style="padding-top:var(--sp-4);padding-bottom:var(--sp-4);display:flex;align-items:center;justify-content:space-between;gap:var(--sp-5);">
    <a class="inst-brand" href="/">
      {% if app_logo.type == 'img' %}
        <img src="{{ app_logo.src }}" alt="{{ app_entity.name }}" class="stemma" style="width:48px;height:auto;flex-shrink:0;" />
      {% else %}
        <svg class="stemma" style="width:48px;height:48px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
      {% endif %}
      <div>
        <div class="eyebrow">{{ 'Ente'|trans }}</div>
        <div class="title">{{ app_entity.name }}</div>
        {% if app_entity.suffix %}<div class="sub">{{ app_entity.suffix }}</div>{% endif %}
      </div>
    </a>

    <div class="inst-actions">
      {% if current_user %}
        {% set first = current_user.first_name|default('') %}
        {% set last  = current_user.last_name|default('') %}
        {% set display_name = first ~ (last != '' ? ' ' ~ last|upper : '') %}
        {% set initials = (first|slice(0,1)) ~ (last|slice(0,1)) %}
        <div class="fo-user-menu" id="fo-user-menu">
          <button class="btn btn-outline" id="fo-user-btn" aria-haspopup="true" aria-expanded="false">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
            {{ display_name != '' ? display_name : current_user.email }}
          </button>
          <div class="fo-user-dropdown" id="fo-user-dropdown" aria-hidden="true">
            <a href="/pendenze">{{ 'Le mie pendenze'|trans }}</a>
            <a href="/profile">{{ 'Profilo'|trans }}</a>
            <a href="/logout" style="color:var(--ms-danger);">{{ 'Logout'|trans }}</a>
          </div>
        </div>
      {% else %}
        {% if login_enabled %}
          <a class="btn btn-ghost" href="/guida" style="display:none;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="9"/><path d="M12 17v-5M12 8h.01"/>
            </svg>
            {{ 'Guida'|trans }}
          </a>
          <a class="btn btn-primary" href="/login" style="color:#ffffff !important;">
            {{ 'Accedi'|trans }}
          </a>
        {% endif %}
      {% endif %}
    </div>
  </div>
</header>

{# ── 3. Sticky main nav ── #}
<nav class="main-nav" aria-label="{{ 'Navigazione principale'|trans }}">
  <div class="container main-nav-container">
    <button class="nav-toggle-btn" id="nav-toggle-btn" aria-label="{{ 'Apri menu'|trans }}" aria-expanded="false" aria-controls="fo-nav-menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display: block;">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <div class="nav-menu" id="fo-nav-menu">
      <a class="nav-item{{ current_path == '/' ? ' active' : '' }}" href="/">{{ 'Home'|trans }}</a>
      <a class="nav-item{{ current_path starts with '/pagamento-avviso' ? ' active' : '' }}" href="/pagamento-avviso">{{ 'Paga un avviso'|trans }}</a>
      <a class="nav-item{{ current_path starts with '/pagamento-spontaneo' ? ' active' : '' }}" href="/pagamento-spontaneo">{{ 'Pagamento spontaneo'|trans }}</a>
      {% if bollot_attivo %}
        <a class="nav-item nav-item--bollo{{ current_path starts with '/pagamento-bollo' ? ' active' : '' }}" href="/pagamento-bollo">{{ 'Marca da Bollo'|trans }}</a>
      {% endif %}
      {% if login_enabled %}
        <a class="nav-item{{ current_path starts with '/pendenze' ? ' active' : '' }}" href="/pendenze">{{ 'Le mie pendenze'|trans }}</a>
      {% endif %}
      <a class="nav-item{{ current_path starts with '/guida' ? ' active' : '' }}" href="/guida">{{ 'Guida'|trans }}</a>
    </div>

    <div class="spacer"></div>

    <a class="cart-btn" href="/carrello" aria-label="{{ 'Carrello'|trans }}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/>
        <path d="M3 4h2l3 12h11l2-8H7"/>
      </svg>
      <span class="cart-btn-text">{{ 'Carrello'|trans }}</span>
      <span class="badge cart-badge"{% if cart_count|default(0) == 0 %} style="display:none;"{% endif %}>{{ cart_count|default(0) }}</span>
    </a>
  </div>
</nav>

{% if govpay_down %}
<div class="govpay-alert-banner" style="background: #fff1f2; border-bottom: 1px solid #fecdd3; padding: 12px 0; color: #9f1239; font-size: 14px; font-weight: 500;">
  <div class="container" style="display: flex; align-items: center; gap: 10px;">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink: 0; color: #e11d48;">
      <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
    </svg>
    <span>{{ 'Attenzione: Il collegamento con il sistema di pagamento pagoPA è temporaneamente interrotto. Alcune operazioni di pagamento o download delle ricevute potrebbero non essere disponibili.'|trans }}</span>
  </div>
</div>
{% endif %}

<style>
.nav-item--bollo { color: var(--ms-gold-400, #D4AD4A) !important; font-weight: 600; }
.nav-item--bollo:hover, .nav-item--bollo.active { color: var(--ms-gold-300, #E4BD56) !important; }
.fo-user-menu { position: relative; }
.fo-user-dropdown {
  display: none; position: absolute; right: 0; top: calc(100% + 6px); min-width: 180px;
  background: #fff; border: 1px solid var(--border-1); border-radius: var(--r-md);
  box-shadow: var(--shadow-3); z-index: 50; overflow: hidden;
}
.fo-user-dropdown.open { display: block; }
.fo-user-dropdown a {
  display: block; padding: 10px 16px; font-size: 14px; color: var(--fg-1);
  text-decoration: none; font-weight: 500;
}
.fo-user-dropdown a:hover { background: var(--bg-2); }
.lang-switch a { padding: 2px 6px; border-radius: 2px; text-decoration: none; color: rgba(255,255,255,.85); }
.lang-switch a.active { background: rgba(255,255,255,.18); font-weight: 700; color: #fff; }
.lang-switch a:hover { color: #fff; }
</style>
<script>
(function(){
  var btn = document.getElementById('fo-user-btn');
  var menu = document.getElementById('fo-user-dropdown');
  if (btn && menu) {
    btn.addEventListener('click', function(e){
      e.stopPropagation();
      var open = menu.classList.toggle('open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      menu.setAttribute('aria-hidden', open ? 'false' : 'true');
    });
    document.addEventListener('click', function(){
      menu.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    });
  }

  // Hamburger menu toggle for mobile
  var navBtn = document.getElementById('nav-toggle-btn');
  var navMenu = document.getElementById('fo-nav-menu');
  if (navBtn && navMenu) {
    navBtn.addEventListener('click', function(e){
      e.stopPropagation();
      var open = navMenu.classList.toggle('open');
      navBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
      navBtn.classList.toggle('active');
    });
    document.addEventListener('click', function(e){
      if (!navMenu.contains(e.target) && e.target !== navBtn && !navBtn.contains(e.target)) {
        navMenu.classList.remove('open');
        navBtn.classList.remove('active');
        navBtn.setAttribute('aria-expanded', 'false');
      }
    });
  }
})();
</script>
