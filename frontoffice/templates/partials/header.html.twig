{# ============================================================
   Frontoffice Header — New design (2026)
   Three tiers:
   1. Slim institutional bar (navy)
   2. Institutional header (white: logo + entity + login)
   3. Sticky main nav (Home, Paga avviso, Spontaneo, Pendenze, Guida + Cart)
   ============================================================ #}

{# ── 1. Slim bar ── #}
<div class="fo-slim-header">
  <div class="container-xxl">
    <div class="fo-slim-left">
      <span><span class="fo-gov-dot"></span>{{ 'Sito ufficiale della Pubblica Amministrazione'|trans }}</span>
    </div>
    <div class="fo-slim-right">
      {# Language dropdown — keep original BS5 dropdown markup, restyled via CSS #}
      <div class="nav-item dropdown">
        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="font-size:12px; color:rgba(255,255,255,.9); padding:0; font-weight:600; font-family:inherit;">
          <span>{{ current_locale|upper }}</span>
        </a>
        <div class="dropdown-menu dropdown-menu-end">
          <div class="row">
            <div class="col-12">
              <div class="link-list-wrapper">
                <ul class="link-list">
                  <li><a class="dropdown-item list-item {{ current_locale == 'it' ? 'active' : '' }}" href="?lang=it"><span>ITA</span></a></li>
                  <li><a class="dropdown-item list-item {{ current_locale == 'en' ? 'active' : '' }}" href="?lang=en"><span>ENG</span></a></li>
                  <li><a class="dropdown-item list-item {{ current_locale == 'es' ? 'active' : '' }}" href="?lang=es"><span>ESP</span></a></li>
                  <li><a class="dropdown-item list-item {{ current_locale == 'fr' ? 'active' : '' }}" href="?lang=fr"><span>FRA</span></a></li>
                  <li><a class="dropdown-item list-item {{ current_locale == 'de' ? 'active' : '' }}" href="?lang=de"><span>DEU</span></a></li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{# ── 2. Institutional header ── #}
<header class="fo-inst-header">
  <div class="fo-inst-inner container-xxl">
    <a class="fo-inst-brand" href="/">
      {% if app_logo.type == 'img' %}
        <img src="{{ app_logo.src }}" alt="{{ app_entity.name }}" class="fo-inst-logo" />
      {% else %}
        <svg class="fo-inst-logo-svg" viewBox="0 0 24 24" aria-hidden="true">
          <use xlink:href="{{ app_logo.src ?: '/assets/bootstrap-italia/svg/sprites.svg#it-pa' }}"></use>
        </svg>
      {% endif %}
      <div>
        <div class="fo-inst-eyebrow">{{ 'Ente'|trans }}</div>
        <div class="fo-inst-title">{{ app_entity.name }}</div>
        {% if app_entity.suffix %}<div class="fo-inst-sub">{{ app_entity.suffix }}</div>{% endif %}
      </div>
    </a>

    <div class="fo-inst-actions">
      {# ── Login / user area — keep EXACTLY as original ── #}
      {% if current_user %}
        <div class="it-user-wrapper nav-item dropdown show">
          <a aria-expanded="false" class="btn btn-primary btn-icon btn-full" data-bs-toggle="dropdown" href="#" id="fo-userDropdown">
            {% set first = current_user.first_name|default('') %}
            {% set last  = current_user.last_name|default('') %}
            {% set show_name = (first != '') or (last != '') %}
            {% set display_name = first ~ (last != '' ? ' ' ~ last|upper : '') %}
            {% set initials = (first|slice(0,1)) ~ (last|slice(0,1)) %}
            {% if show_name %}
              <span class="d-none d-md-inline">{{ display_name }}</span>
            {% else %}
              <span class="d-none d-md-inline">{{ current_user.email }}</span>
            {% endif %}
            <span class="badge bg-light text-dark ms-2 d-none d-md-inline">{{ initials|upper }}</span>
            <span class="d-inline d-md-none user-initials-avatar ms-2 d-flex align-items-center justify-content-center">{{ initials|upper }}</span>
            <svg class="icon icon-white d-none d-lg-block ms-2" style="width:18px;height:18px;">
              <use xlink:href="/assets/bootstrap-italia/svg/sprites.svg#it-expand"></use>
            </svg>
          </a>
          <div class="dropdown-menu dropdown-menu-end" aria-labelledby="fo-userDropdown">
            <div class="row">
              <div class="col-12">
                <div class="link-list-wrapper px-3 py-2">
                  <ul class="link-list list-unstyled mb-0">
                    <li>
                      <a class="list-item d-block text-dark py-1 {{ current_path == '/profile' ? 'active' : '' }}" href="/profile">{{ 'Profilo'|trans }}</a>
                    </li>
                    <li>
                      <a class="list-item d-block text-dark py-1 {{ current_path == '/pendenze' ? 'active' : '' }}" href="/pendenze">{{ 'Le mie pendenze'|trans }}</a>
                    </li>
                    <li>
                      <a class="list-item d-block text-danger py-1" href="/logout">{{ 'Logout'|trans }}</a>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      {% else %}
        {% if spid_enabled %}
          <a class="btn btn-primary btn-sm" href="/login">{{ 'Accedi'|trans }}</a>
        {% endif %}
      {% endif %}
    </div>
  </div>
</header>

{# ── 3. Sticky main nav ── #}
<nav class="fo-main-nav" aria-label="{{ 'Navigazione principale'|trans }}">
  <div class="fo-nav-inner container-xxl">
    {# Hamburger (mobile only) #}
    <button class="fo-hamburger" id="fo-nav-toggle" aria-label="{{ 'Menu'|trans }}" aria-expanded="false" aria-controls="fo-nav-links">
      <svg class="fo-icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 6h18M3 12h18M3 18h18"/>
      </svg>
      <svg class="fo-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>

    {# Nav links — desktop: display:contents (flex items inline); mobile: dropdown #}
    <div class="fo-nav-links" id="fo-nav-links">
      <a class="fo-nav-item{{ current_path == '/' ? ' active' : '' }}" href="/">
        {{ 'Home'|trans }}
      </a>
      <a class="fo-nav-item{{ current_path starts with '/pagamento-avviso' ? ' active' : '' }}" href="/pagamento-avviso">
        {{ 'Paga un avviso'|trans }}
      </a>
      <a class="fo-nav-item{{ current_path starts with '/pagamento-spontaneo' ? ' active' : '' }}" href="/pagamento-spontaneo">
        {{ 'Pagamento spontaneo'|trans }}
      </a>
      {% if spid_enabled %}
        <a class="fo-nav-item{{ current_path starts with '/pendenze' ? ' active' : '' }}" href="/pendenze">
          {{ 'Le mie pendenze'|trans }}
        </a>
      {% endif %}
      <a class="fo-nav-item{{ current_path starts with '/guida' ? ' active' : '' }}" href="/guida">
        {{ 'Guida'|trans }}
      </a>
    </div>

    <div class="fo-nav-spacer"></div>

    <a class="fo-cart-btn" href="/carrello" aria-label="{{ 'Carrello'|trans }} ({{ cart_count|default(0) }} avvisi)">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/>
        <path d="M3 4h2l3 12h11l2-8H7"/>
      </svg>
      {{ 'Carrello'|trans }}
      <span class="fo-cart-badge cart-badge" {% if cart_count|default(0) == 0 %}style="display:none;"{% endif %}>{{ cart_count|default(0) }}</span>
    </a>
  </div>
</nav>
<script>
(function(){
  var toggle = document.getElementById('fo-nav-toggle');
  var nav = toggle && toggle.closest('.fo-main-nav');
  if (!toggle || !nav) return;
  toggle.addEventListener('click', function(){
    var open = nav.classList.toggle('fo-nav-open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  document.addEventListener('click', function(e){
    if (!nav.contains(e.target)) {
      nav.classList.remove('fo-nav-open');
      toggle.setAttribute('aria-expanded', 'false');
    }
  });
})();
</script>
