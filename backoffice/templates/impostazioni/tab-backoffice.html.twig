<div class="card border-0 shadow-sm">
  <div class="card-header bg-white py-3">
    <h2 class="h5 mb-0"><i class="fas fa-cogs me-2 text-primary"></i>Backoffice</h2>
  </div>
  <div class="card-body">
    <form id="form-backoffice" onsubmit="return false;">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

      <h6 class="text-muted text-uppercase small fw-semibold mb-3">
        <i class="fas fa-link me-1"></i>URL pubblici
      </h6>
      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <label class="form-label">URL pubblico backoffice</label>
          <input type="url" class="form-control" name="public_base_url"
            value="{{ backoffice.public_base_url|default('') }}" placeholder="https://backoffice.comune.example.it"
            {{ not is_superadmin ? 'readonly' : '' }}>
        </div>
        <div class="col-md-6">
          <label class="form-label">Apache ServerName</label>
          <input type="text" class="form-control font-monospace" name="apache_server_name"
            value="{{ backoffice.apache_server_name|default('') }}" placeholder="backoffice.comune.example.it"
            {{ not is_superadmin ? 'readonly' : '' }}>
          <div class="form-text">Hostname nella configurazione Apache o Nginx.</div>
        </div>
      </div>

      <div class="alert alert-light border mb-4" role="alert">
        <i class="fas fa-envelope me-1 text-primary"></i>
        La configurazione email si trova nella scheda <a href="/impostazioni?tab=smtp" class="alert-link">Generale → SMTP</a>.
      </div>

      <div class="alert alert-light border mb-4" role="alert">
        <i class="fas fa-bug me-1 text-warning"></i>
        I flag di debug sono disponibili nella scheda
        <a href="/impostazioni?tab=debug" class="alert-link">Sistema → Debug</a>.
      </div>

      {% if is_superadmin %}
      <div class="d-flex justify-content-end border-top pt-3">
        <button type="button" class="btn btn-primary" onclick="impSaveForm('form-backoffice', '/impostazioni/backoffice/save', this)">
          <i class="fas fa-save me-1"></i>Salva
        </button>
      </div>
      {% endif %}
    </form>
  </div>
</div>
