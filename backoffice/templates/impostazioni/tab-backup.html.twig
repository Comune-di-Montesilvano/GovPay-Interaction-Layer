<div id="backup-wrap">
  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

  {# ─── AVVISO CHIAVE CIFRATURA ────────────────────────────────────────────── #}
  {% if is_superadmin %}
  <div class="alert alert-warning small py-2 mb-3">
    <i class="fas fa-exclamation-triangle me-1"></i>
    Il backup ZIP include il dump del database con i valori cifrati. Senza la <strong>APP_ENCRYPTION_KEY originale</strong>, i dati cifrati nel backup sono inutilizzabili.
    Conserva la chiave separatamente — usa la card <strong>"Visualizza APP_ENCRYPTION_KEY"</strong> in fondo a questa pagina.
  </div>
  {% endif %}

  {# ─── Backup completo di sistema ─────────────────────────────────────────── #}
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
      <h2 class="h6 mb-0"><i class="fas fa-database me-2 text-primary"></i>Crea backup ZIP</h2>
    </div>
    <div class="card-body">
      <p class="text-muted small mb-3">
        Crea un archivio ZIP per disaster recovery e migrazione. Il backup include sempre impostazioni DB e dump database.
      </p>

      <div class="alert alert-info small py-2 mb-3">
        <strong>Nota:</strong> logo e favicon vengono salvati in questo backup.
        Certificati e metadata SPID/CIE restano separati nella scheda
        <a href="/impostazioni?tab=login-proxy" class="alert-link">Login Proxy</a>.
      </div>

      <form id="form-backup-sistema" onsubmit="return false;">
        <div class="mb-3">
          <label class="form-label small fw-semibold mb-2">Dati di sistema (volumi)</label>
          <div class="row g-2">
            <div class="col-sm-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="volumes[]" value="gil_certs" id="vol-gil-certs" checked>
                <label class="form-check-label" for="vol-gil-certs">Certificati GovPay</label>
              </div>
            </div>
            <div class="col-sm-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="volumes[]" value="gil_images" id="vol-gil-images" checked>
                <label class="form-check-label" for="vol-gil-images">Immagini branding (logo e favicon)</label>
              </div>
            </div>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label small fw-semibold mb-2">Dati applicativi (GovPay)</label>
          <div class="row g-2">
            <div class="col-sm-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="govpay_sections[]" value="tipologie" id="gp-tipologie" checked>
                <label class="form-check-label" for="gp-tipologie">Tipologie pagamento</label>
              </div>
            </div>
            <div class="col-sm-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="govpay_sections[]" value="tipologie_esterne" id="gp-tipologie-esterne" checked>
                <label class="form-check-label" for="gp-tipologie-esterne">Tipologie esterne</label>
              </div>
            </div>
            <div class="col-sm-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="govpay_sections[]" value="templates" id="gp-templates" checked>
                <label class="form-check-label" for="gp-templates">Template pendenze</label>
              </div>
            </div>
            <div class="col-sm-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="govpay_sections[]" value="io_services" id="gp-io" checked>
                <label class="form-check-label" for="gp-io">Servizi App IO</label>
              </div>
            </div>
            <div class="col-sm-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="govpay_sections[]" value="utenti" id="gp-utenti">
                <label class="form-check-label" for="gp-utenti">Utenti backoffice</label>
              </div>
            </div>
            <div class="col-sm-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="govpay_sections[]" value="gruppi-utenti" id="gp-gruppi-utenti">
                <label class="form-check-label" for="gp-gruppi-utenti">Gruppi utenti</label>
              </div>
            </div>
            <div class="col-sm-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="govpay_sections[]" value="mapping_tipologie_custom" id="gp-mapping-custom" checked>
                <label class="form-check-label" for="gp-mapping-custom">Mapping tipologie custom</label>
              </div>
            </div>
            <div class="col-sm-6 col-md-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="govpay_sections[]" value="mapping_pendenze" id="gp-mapping-pendenze" checked>
                <label class="form-check-label" for="gp-mapping-pendenze">Regole mapping pendenze (L1/L2)</label>
              </div>
            </div>
          </div>
        </div>
      </form>

      {% if is_superadmin %}
      <button class="btn btn-primary btn-sm me-2"
              onclick="backupCreateSistema(this)">
        <i class="fas fa-plus me-1"></i>Crea backup
      </button>
      {% endif %}

      <button class="btn btn-outline-secondary btn-sm"
              onclick="backupListSistema(this)">
        <i class="fas fa-list me-1"></i>Aggiorna lista
      </button>

      <div id="backup-sistema-list" class="mt-3"></div>
    </div>
  </div>

  {# ─── Ripristina da ZIP ──────────────────────────────────────────────────── #}
  {% if is_superadmin %}
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
      <h2 class="h6 mb-0"><i class="fas fa-upload me-2 text-danger"></i>Ripristina da ZIP</h2>
    </div>
    <div class="card-body">
      <p class="text-muted small mb-3">
        Carica un archivio ZIP prodotto da questa sezione backup.
        Il ripristino reimposta sistema e configurazione applicativa in modo equivalente al setup iniziale,
        limitatamente ai dati presenti nell'archivio.
        <strong class="text-danger">I dati esistenti saranno sovrascritti.</strong>
      </p>
      <div id="restore-result" class="mb-3" style="display:none;"></div>
      <div id="restore-progress" class="mb-3" style="display:none;">
        <div class="progress" style="height:6px;">
          <div id="restore-progress-bar" class="progress-bar bg-danger" style="width:0%;transition:width .2s;"></div>
        </div>
        <div id="restore-progress-label" class="text-muted small mt-1"></div>
      </div>
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <input type="file" id="restore-zip-file" class="form-control form-control-sm" accept=".zip" style="max-width:340px;">
        <button class="btn btn-danger btn-sm" onclick="backupRipristina(this)">
          <i class="fas fa-upload me-1"></i>Ripristina
        </button>
      </div>
    </div>
  </div>
  {% endif %}

  {# ─── Backup/Ripristino configurazione JSON ──────────────────────────────── #}
  {% if is_superadmin %}
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
      <h2 class="h6 mb-0"><i class="fas fa-file-code me-2 text-success"></i>Backup configurazione JSON</h2>
    </div>
    <div class="card-body">
      <p class="text-muted small mb-3">
        Esporta o importa le sole sezioni di configurazione applicativa in formato JSON,
        senza dump database. Utile per copiare la configurazione tra istanze.
      </p>
      <div class="row g-4">
        <div class="col-lg-6">
          <h3 class="h6 fw-semibold mb-2"><i class="fas fa-download me-1 text-success"></i>Esporta JSON</h3>
          <form method="post" action="/configurazione/backup/export">
            <div class="row g-2 mb-3">
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="tipologie" id="jex-tipologie" checked><label class="form-check-label small" for="jex-tipologie">Tipologie</label></div></div>
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="tipologie_esterne" id="jex-tipologie-esterne" checked><label class="form-check-label small" for="jex-tipologie-esterne">Tipologie esterne</label></div></div>
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="templates" id="jex-templates" checked><label class="form-check-label small" for="jex-templates">Template pendenze</label></div></div>
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="io_services" id="jex-io" checked><label class="form-check-label small" for="jex-io">Servizi App IO</label></div></div>
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="gruppi-utenti" id="jex-gruppi" checked><label class="form-check-label small" for="jex-gruppi">Gruppi utenti</label></div></div>
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="mapping_tipologie_custom" id="jex-mapping" checked><label class="form-check-label small" for="jex-mapping">Mapping tipologie custom</label></div></div>
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="mapping_pendenze" id="jex-mapping-pendenze" checked><label class="form-check-label small" for="jex-mapping-pendenze">Regole mapping (L1/L2)</label></div></div>
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="utenti" id="jex-utenti"><label class="form-check-label small" for="jex-utenti">Utenti <span class="badge bg-warning text-dark ms-1 py-0">sensibile</span></label></div></div>
            </div>
            <button type="submit" class="btn btn-sm btn-success"><i class="fas fa-download me-1"></i>Scarica JSON</button>
          </form>
        </div>
        <div class="col-lg-6">
          <h3 class="h6 fw-semibold mb-2"><i class="fas fa-upload me-1 text-danger"></i>Importa JSON</h3>
          <div class="alert alert-warning py-2 small mb-3">
            <strong>Attenzione:</strong> i dati delle sezioni selezionate verranno <strong>sostituiti</strong>.
          </div>
          <form method="post" action="/configurazione/backup/import" enctype="multipart/form-data">
            <div class="mb-3">
              <input class="form-control form-control-sm" type="file" name="backup_file" accept=".json" required>
            </div>
            <div class="row g-2 mb-3">
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="tipologie" id="jim-tipologie" checked><label class="form-check-label small" for="jim-tipologie">Tipologie</label></div></div>
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="tipologie_esterne" id="jim-tipologie-esterne" checked><label class="form-check-label small" for="jim-tipologie-esterne">Tipologie esterne</label></div></div>
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="templates" id="jim-templates" checked><label class="form-check-label small" for="jim-templates">Template pendenze</label></div></div>
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="io_services" id="jim-io" checked><label class="form-check-label small" for="jim-io">Servizi App IO</label></div></div>
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="gruppi-utenti" id="jim-gruppi" checked><label class="form-check-label small" for="jim-gruppi">Gruppi utenti</label></div></div>
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="mapping_tipologie_custom" id="jim-mapping" checked><label class="form-check-label small" for="jim-mapping">Mapping tipologie custom</label></div></div>
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="mapping_pendenze" id="jim-mapping-pendenze" checked><label class="form-check-label small" for="jim-mapping-pendenze">Regole mapping (L1/L2)</label></div></div>
              <div class="col-6"><div class="form-check"><input class="form-check-input" type="checkbox" name="sections[]" value="utenti" id="jim-utenti"><label class="form-check-label small" for="jim-utenti">Utenti <span class="badge bg-warning text-dark ms-1 py-0">sensibile</span></label></div></div>
            </div>
            <button type="submit" class="btn btn-sm btn-danger"
                    onclick="return confirm('Confermi l\'importazione? I dati delle sezioni selezionate verranno sostituiti.')">
              <i class="fas fa-upload me-1"></i>Importa
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  {% if is_superadmin %}
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
      <h2 class="h6 mb-0"><i class="fas fa-lock me-2 text-primary"></i>Chiavi cifrate nel DB</h2>
      <button class="btn btn-outline-secondary btn-sm" type="button" onclick="loadEncryptedKeys(this)">
        <i class="fas fa-sync-alt me-1"></i>Aggiorna
      </button>
    </div>
    <div class="card-body">
      <p class="text-muted small mb-2">
        Elenco reale delle chiavi marcate come cifrate nella tabella settings.
      </p>
      <div id="encrypted-keys-list" class="small text-muted">Caricamento...</div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
      <h2 class="h6 mb-0"><i class="fas fa-key me-2 text-warning"></i>Rotazione chiave cifratura (APP_ENCRYPTION_KEY)</h2>
    </div>
    <div class="card-body">
      <p class="text-muted small mb-3">
        Re-cifra tutti i valori con <code>encrypted=1</code> usando una nuova chiave.
        Esegui questa operazione solo in finestra di manutenzione.
      </p>
      <div class="alert alert-warning small py-2 mb-3">
        <strong>Attenzione:</strong> se la nuova chiave non è già attiva su tutte le istanze,
        potresti avere errori di decifratura finché non completi rollout e riavvio.
      </div>

      <div class="alert alert-info small py-2 mb-3">
        <strong>Procedura consigliata (qui dove la usi):</strong>
        <ol class="mb-0 ps-3 mt-2">
          <li>Backup DB completo.</li>
          <li>Aggiorna APP_ENCRYPTION_KEY su tutte le istanze e riavvia.</li>
          <li>Verifica l'elenco "Chiavi cifrate nel DB" in questa pagina.</li>
          <li>Esegui prima dry-run con old/new key.</li>
          <li>Se dry-run OK, togli dry-run e avvia rotazione reale.</li>
          <li>Verifica log e funzionalità; per rollback ripristina DB + vecchia chiave.</li>
        </ol>
      </div>

      <div id="rotate-key-result" class="mb-3" style="display:none;"></div>

      <form id="form-rotate-key" onsubmit="return false;">
        <div class="row g-2">
          <div class="col-md-4">
            <label class="form-label small fw-semibold">Old key</label>
            <input type="password" class="form-control form-control-sm" name="old_key" autocomplete="off" required>
          </div>
          <div class="col-md-4">
            <label class="form-label small fw-semibold">New key (32 caratteri)</label>
            <input type="password" class="form-control form-control-sm" name="new_key" minlength="32" maxlength="32" autocomplete="off" required>
          </div>
          <div class="col-md-4">
            <label class="form-label small fw-semibold">Conferma new key</label>
            <input type="password" class="form-control form-control-sm" name="confirm_new_key" minlength="32" maxlength="32" autocomplete="off" required>
          </div>
        </div>

        <div class="form-check mt-3">
          <input class="form-check-input" type="checkbox" value="true" id="force-runtime-mismatch" name="force_runtime_mismatch">
          <label class="form-check-label small" for="force-runtime-mismatch">
            Confermo che sto forzando la rotazione anche se la chiave runtime attuale non coincide con la nuova.
          </label>
        </div>

        <div class="form-check mt-2">
          <input class="form-check-input" type="checkbox" value="true" id="rotate-key-dry-run" name="dry_run" checked>
          <label class="form-check-label small" for="rotate-key-dry-run">
            Esegui prima una simulazione (dry-run, nessuna scrittura su DB).
          </label>
        </div>
      </form>

      <div class="mt-3">
        <button class="btn btn-warning btn-sm" onclick="rotateEncryptionKey(this)">
          <i class="fas fa-key me-1"></i>Ruota chiave
        </button>
      </div>
    </div>
  </div>


  {# ─── Visualizza APP_ENCRYPTION_KEY ──────────────────────────────────────── #}
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
      <h2 class="h6 mb-0"><i class="fas fa-eye me-2 text-secondary"></i>Visualizza APP_ENCRYPTION_KEY attiva</h2>
    </div>
    <div class="card-body">
      <p class="text-muted small mb-3">
        Mostra la chiave di cifratura correntemente in uso dall'applicazione.
        <strong>Conserva questa chiave in un archivio sicuro separato dal backup</strong> — senza di essa i dati cifrati nel backup sono inutilizzabili.
      </p>
      <div id="show-key-result" class="mb-3" style="display:none;"></div>
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <input type="password" id="show-key-password" class="form-control form-control-sm" placeholder="Inserisci la tua password per visualizzare la chiave" style="max-width:320px;" autocomplete="current-password">
        <button class="btn btn-outline-secondary btn-sm" onclick="showEncryptionKey(this)">
          <i class="fas fa-eye me-1"></i>Mostra chiave
        </button>
      </div>
    </div>
  </div>

  {% endif %}
</div>

<script>
(function () {
  function fmtSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / 1048576).toFixed(1) + ' MB';
  }

  function renderBackupList(items) {
    const el = document.getElementById('backup-sistema-list');
    if (!items || items.length === 0) {
      el.innerHTML = '<p class="text-muted small mb-0">Nessun archivio trovato.</p>';
      return;
    }
    let html = '<div class="table-responsive"><table class="table table-sm table-hover mb-0"><thead><tr>'
      + '<th>File</th><th>Dimensione</th><th>Data</th><th></th></tr></thead><tbody>';
    for (const f of items) {
      html += `<tr>
        <td class="font-monospace small">${f.name}</td>
        <td class="small">${fmtSize(f.size)}</td>
        <td class="small">${f.created}</td>
        <td class="text-nowrap">
          <a href="/backup/sistema/download?file=${encodeURIComponent(f.name)}" class="btn btn-xs btn-outline-secondary btn-sm py-0 px-2 me-1" tabindex="0" data-bs-toggle="popover" data-bs-trigger="hover focus" data-bs-placement="top" data-bs-content="Scarica backup">
            <i class="fas fa-download me-1"></i>
          </a>
          <button class="btn btn-xs btn-outline-primary btn-sm py-0 px-2 me-1" onclick="backupRipristinaFile(this, '${f.name.replace(/'/g,"\\'")}')" tabindex="0" data-bs-toggle="popover" data-bs-trigger="hover focus" data-bs-placement="top" data-bs-content="Ripristina backup">
            <i class="fas fa-undo me-1"></i>
          </button>
          <button class="btn btn-xs btn-outline-danger btn-sm py-0 px-2" onclick="backupEliminaFile(this, '${f.name.replace(/'/g,"\\'")}')" tabindex="0" data-bs-toggle="popover" data-bs-trigger="hover focus" data-bs-placement="top" data-bs-content="Elimina backup">
            <i class="fas fa-trash-alt me-1"></i>
          </button>
        </td></tr>`;
    }
    html += '</tbody></table></div>';
    el.innerHTML = html;
    // Attiva popover Bootstrap
    setTimeout(() => {
      const popoverTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="popover"]'));
      popoverTriggerList.forEach(function (popoverTriggerEl) {
        if (!popoverTriggerEl._popoverInstance) {
          new bootstrap.Popover(popoverTriggerEl);
        }
      });
    }, 0);
  }

  async function parseJsonOrThrow(res) {
    const ct = (res.headers.get('content-type') || '').toLowerCase();
    if (ct.includes('application/json')) {
      return await res.json();
    }
    const raw = await res.text();
    const preview = raw.replace(/\s+/g, ' ').slice(0, 180);
    throw new Error(`Risposta non JSON (HTTP ${res.status}). ${preview}`);
  }

  window.backupCreateSistema = async function (btn) {
    btn.disabled = true;
    const orig = btn.innerHTML;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Creazione…';
    const csrf = document.querySelector('#backup-wrap input[name="csrf_token"]')?.value || '';
    const form = document.getElementById('form-backup-sistema');
    const volumes = [...form.querySelectorAll('input[name="volumes[]"]:checked')].map(c => c.value);
    const govpaySections = [...form.querySelectorAll('input[name="govpay_sections[]"]:checked')].map(c => c.value);
    const fd = new FormData();
    fd.append('csrf_token', csrf);
    for (const v of volumes) fd.append('volumes[]', v);
    for (const s of govpaySections) fd.append('govpay_sections[]', s);
    try {
      const res = await fetch('/backup/sistema/crea', {
        method: 'POST',
        body: fd,
      });
      const json = await parseJsonOrThrow(res);
      if (!res.ok) {
        throw new Error(json.message || `Errore HTTP ${res.status}`);
      }
      impToast(json.message || (json.success ? 'Backup creato.' : 'Errore.'), !!json.success);
      if (json.success) backupListSistema(null);
    } catch (e) {
      impToast('Errore di rete: ' + e.message, false);
    } finally {
      btn.disabled = false;
      btn.innerHTML = orig;
    }
  };

  window.backupListSistema = async function (btn) {
    if (btn) { btn.disabled = true; }
    try {
      const res = await fetch('/backup/sistema/lista');
      const json = await parseJsonOrThrow(res);
      renderBackupList(json.files || []);
    } catch (e) {
      document.getElementById('backup-sistema-list').innerHTML =
        '<p class="text-danger small">Errore nel caricamento della lista.</p>';
    } finally {
      if (btn) { btn.disabled = false; }
    }
  };

  function showRestoreResult(ok, msg, detail) {
    const el = document.getElementById('restore-result');
    if (!el) return;
    let html = `<div class="alert alert-${ok ? 'success' : 'danger'} py-2 mb-0 small">${msg}`;
    if (detail && ok) {
      html += `<br><span class="text-muted">Sezioni DB: ${detail.settings_sections ?? 0} &nbsp;|&nbsp; File volumi: ${detail.volume_files ?? 0}`;
      if ((detail.govpay_sections ?? 0) > 0) html += ` &nbsp;|&nbsp; Sezioni GovPay: ${detail.govpay_sections}`;
      html += '</span>';
    }
    html += '</div>';

    const failures = detail?.decrypt_failures ?? [];
    if (ok && failures.length > 0) {
      html += '<div class="alert alert-danger py-2 mt-2 mb-0 small">'
        + '<strong><i class="fas fa-exclamation-triangle me-1"></i>Errore decifratura — le seguenti chiavi non sono decifrabili con la APP_ENCRYPTION_KEY attiva:</strong>'
        + '<ul class="mb-0 mt-1 ps-3">';
      for (const f of failures) {
        html += `<li class="font-monospace">${f.section}.${f.key_name}</li>`;
      }
      html += '</ul>'
        + '<div class="mt-1">Ripristina la chiave corretta nel <code>.env</code> e riavvia il container, oppure esegui la rotazione chiave.</div>'
        + '</div>';
    }

    el.innerHTML = html;
    el.style.display = '';
  }

  function showRotateKeyResult(ok, msg, detail) {
    const el = document.getElementById('rotate-key-result');
    if (!el) return;
    let extra = '';
    if (detail && ok) {
      const rotated = Number(detail.rotated || 0);
      const normalized = Number(detail.legacy_plaintext_normalized || 0);
      extra = `<br><span class="text-muted">Valori ruotati: ${rotated} | Valori legacy normalizzati: ${normalized}</span>`;
    }
    el.innerHTML = `<div class="alert alert-${ok ? 'success' : 'danger'} py-2 mb-0 small">${msg}${extra}</div>`;
    el.style.display = '';
  }

  function renderEncryptedKeys(items) {
    const el = document.getElementById('encrypted-keys-list');
    if (!el) return;
    if (!Array.isArray(items) || items.length === 0) {
      el.innerHTML = '<span class="text-muted">Nessuna chiave marcata come cifrata.</span>';
      return;
    }

    const statusBadge = (s) => {
      switch (s) {
        case 'ok':        return '<span class="badge bg-success">Decifrata correttamente</span>';
        case 'empty':     return '<span class="badge bg-secondary">Vuoto</span>';
        case 'plaintext': return '<span class="badge bg-warning text-dark">In chiaro (non cifrata)</span>';
        case 'no_key':    return '<span class="badge bg-danger">APP_ENCRYPTION_KEY assente</span>';
        case 'error':     return '<span class="badge bg-danger">Errore decifratura</span>';
        default:          return '<span class="badge bg-light text-dark">Sconosciuto</span>';
      }
    };

    let html = '<div class="table-responsive"><table class="table table-sm table-striped mb-0">'
      + '<thead><tr><th>Sezione</th><th>Chiave</th><th>Stato</th></tr></thead><tbody>';
    for (const row of items) {
      html += `<tr><td class="font-monospace">${row.section || ''}</td>`
           + `<td class="font-monospace">${row.key_name || ''}</td>`
           + `<td>${statusBadge(row.status)}</td></tr>`;
    }
    html += '</tbody></table></div>';
    el.innerHTML = html;
  }

  async function doRestoreChunked(file, btn) {
    const CHUNK_SIZE = 512 * 1024;
    const totalChunks = Math.ceil(file.size / CHUNK_SIZE);
    const uploadId = crypto.randomUUID();
    const csrf = document.querySelector('#backup-wrap input[name="csrf_token"]')?.value || '';

    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Caricamento…';

    const progress = document.getElementById('restore-progress');
    const bar      = document.getElementById('restore-progress-bar');
    const label    = document.getElementById('restore-progress-label');
    if (progress) progress.style.display = '';

    const setProgress = (n, total, msg) => {
      if (bar)   bar.style.width = Math.round((n / total) * 100) + '%';
      if (label) label.textContent = msg;
    };

    try {
      let lastJson = null;
      for (let i = 0; i < totalChunks; i++) {
        const start = i * CHUNK_SIZE;
        const end   = Math.min(start + CHUNK_SIZE, file.size);
        const fd    = new FormData();
        fd.append('upload_id',    uploadId);
        fd.append('chunk_index',  i);
        fd.append('total_chunks', totalChunks);
        fd.append('csrf_token',   csrf);
        fd.append('chunk', file.slice(start, end), 'chunk.bin');

        setProgress(i, totalChunks, `Caricamento ${i + 1}/${totalChunks}…`);
        const res  = await fetch('/backup/sistema/ripristina/chunk', { method: 'POST', body: fd });
        lastJson   = await parseJsonOrThrow(res);
        if (!lastJson.success) throw new Error(lastJson.message || 'Chunk rifiutato dal server.');
      }

      setProgress(totalChunks, totalChunks, 'Completato.');
      showRestoreResult(!!lastJson.success, lastJson.message || 'Ripristino completato.', lastJson.detail ?? null);
      impToast(lastJson.message || 'Ripristino completato.', !!lastJson.success);
    } catch (e) {
      showRestoreResult(false, 'Errore di rete: ' + e.message, null);
    } finally {
      btn.disabled = false;
      btn.innerHTML = orig;
      if (progress) setTimeout(() => { progress.style.display = 'none'; if (bar) bar.style.width = '0%'; }, 1500);
    }
  }

  window.backupRipristina = async function (btn) {
    const fileInput = document.getElementById('restore-zip-file');
    if (!fileInput?.files?.length) {
      impToast('Seleziona un file ZIP.', false);
      return;
    }
    if (!confirm('Ripristinare il backup? I dati correnti verranno sovrascritti con quelli presenti nel file ZIP.')) return;
    await doRestoreChunked(fileInput.files[0], btn);
    fileInput.value = '';
  };

  window.backupRipristinaFile = async function (btn, filename) {
    if (!confirm(`Ripristinare "${filename}"? I dati correnti verranno sovrascritti con quelli presenti nel file ZIP.`)) return;
    btn.disabled = true;
    const origHtml = btn.innerHTML;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>';
    try {
      const dlRes = await fetch(`/backup/sistema/download?file=${encodeURIComponent(filename)}`);
      if (!dlRes.ok) throw new Error('Download fallito');
      const blob = await dlRes.blob();
      await doRestoreChunked(new File([blob], filename, { type: 'application/zip' }), btn);
    } catch (e) {
      impToast('Errore: ' + e.message, false);
      btn.disabled = false;
      btn.innerHTML = origHtml;
    }
  };

  window.backupEliminaFile = async function (btn, filename) {
    if (!confirm(`Eliminare definitivamente "${filename}"?`)) return;
    const csrf = document.querySelector('#backup-wrap input[name="csrf_token"]')?.value || '';
    const origHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>';
    try {
      const fd = new FormData();
      fd.append('csrf_token', csrf);
      fd.append('file', filename);
      const res = await fetch('/backup/sistema/elimina', { method: 'POST', body: fd });
      const json = await parseJsonOrThrow(res);
      if (!res.ok) {
        throw new Error(json.message || `Errore HTTP ${res.status}`);
      }
      impToast(json.message || 'Backup eliminato.', true);
      await backupListSistema(null);
    } catch (e) {
      impToast('Errore: ' + e.message, false);
    } finally {
      btn.disabled = false;
      btn.innerHTML = origHtml;
    }
  };

  window.rotateEncryptionKey = async function (btn) {
    const form = document.getElementById('form-rotate-key');
    if (!form) return;

    const oldKey = form.querySelector('input[name="old_key"]')?.value || '';
    const newKey = form.querySelector('input[name="new_key"]')?.value || '';
    const confirmNewKey = form.querySelector('input[name="confirm_new_key"]')?.value || '';
    const forceRuntimeMismatch = !!form.querySelector('input[name="force_runtime_mismatch"]')?.checked;
    const dryRun = !!form.querySelector('input[name="dry_run"]')?.checked;
    const csrf = document.querySelector('#backup-wrap input[name="csrf_token"]')?.value || '';

    if (!oldKey || !newKey || !confirmNewKey) {
      impToast('Compila tutti i campi della rotazione chiave.', false);
      return;
    }

    if (newKey.length !== 32) {
      impToast('La nuova chiave deve essere di 32 caratteri.', false);
      return;
    }

    if (newKey !== confirmNewKey) {
      impToast('La conferma della nuova chiave non coincide.', false);
      return;
    }

    if (!confirm('Confermi la rotazione di APP_ENCRYPTION_KEY? Esegui l\'operazione solo in manutenzione.')) {
      return;
    }

    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Rotazione…';

    try {
      const payload = {
        csrf_token: csrf,
        old_key: oldKey,
        new_key: newKey,
        confirm_new_key: confirmNewKey,
        force_runtime_mismatch: forceRuntimeMismatch,
        dry_run: dryRun,
      };

      const res = await fetch('/impostazioni/sicurezza/rotate-encryption-key', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const json = await parseJsonOrThrow(res);
      showRotateKeyResult(!!json.success, json.message || (json.success ? 'Rotazione completata.' : 'Errore.'), json);
      impToast(json.message || (json.success ? 'Rotazione completata.' : 'Errore rotazione.'), !!json.success);
    } catch (e) {
      showRotateKeyResult(false, 'Errore di rete: ' + e.message, null);
      impToast('Errore di rete: ' + e.message, false);
    } finally {
      btn.disabled = false;
      btn.innerHTML = orig;
    }
  };

  window.loadEncryptedKeys = async function (btn) {
    if (btn) btn.disabled = true;
    try {
      const res = await fetch('/impostazioni/sicurezza/encrypted-keys');
      const json = await parseJsonOrThrow(res);
      if (!json.success) {
        throw new Error(json.message || 'Errore nel caricamento chiavi cifrate');
      }
      renderEncryptedKeys(json.items || []);
    } catch (e) {
      const el = document.getElementById('encrypted-keys-list');
      if (el) {
        el.innerHTML = `<span class="text-danger">Errore: ${e.message}</span>`;
      }
    } finally {
      if (btn) btn.disabled = false;
    }
  };

  window.showEncryptionKey = async function (btn) {
    const password = document.getElementById('show-key-password')?.value || '';
    if (!password) {
      impToast('Inserisci la password per visualizzare la chiave.', false);
      return;
    }
    const csrf = document.querySelector('#backup-wrap input[name="csrf_token"]')?.value || '';
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>';
    const el = document.getElementById('show-key-result');
    try {
      const res = await fetch('/impostazioni/sicurezza/show-encryption-key', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password, csrf_token: csrf }),
      });
      const json = await parseJsonOrThrow(res);
      if (!json.success) throw new Error(json.message || 'Errore');
      const key = json.key || '';
      el.innerHTML = `<div class="alert alert-success py-2 mb-0 small">
        <div class="mb-1 fw-semibold">APP_ENCRYPTION_KEY attiva:</div>
        <code id="enc-key-value" class="user-select-all fs-6">${key}</code>
        <button type="button" class="btn btn-xs btn-outline-secondary btn-sm py-0 px-2 ms-2"
          onclick="navigator.clipboard.writeText(document.getElementById('enc-key-value').textContent).then(()=>impToast('Chiave copiata.',true))">
          <i class="fas fa-copy"></i>
        </button>
        <div class="mt-1 text-muted">Lunghezza: ${key.length} caratteri. Conservala in un archivio sicuro offline separato dal backup.</div>
      </div>`;
      el.style.display = '';
      document.getElementById('show-key-password').value = '';
    } catch (e) {
      el.innerHTML = `<div class="alert alert-danger py-2 mb-0 small">${e.message}</div>`;
      el.style.display = '';
    } finally {
      btn.disabled = false;
      btn.innerHTML = orig;
    }
  };

  // Carica automaticamente la lista all'apertura del tab
  backupListSistema(null);
  loadEncryptedKeys(null);
})();
</script>
