// ── Generazione cert SPID ─────────────────────────────────────────────────────
async function doGeneraSpidCerts(btn) {
  const payload = {
    common_name:   document.getElementById('spid-cert-cn')?.value?.trim()        || '',
    locality_name: document.getElementById('spid-cert-locality')?.value?.trim()  || '',
    org_id:        document.getElementById('spid-cert-org-id')?.value?.trim()    || '',
    org_name:      document.getElementById('spid-cert-org-name')?.value?.trim()  || '',
    entity_id:     document.getElementById('spid-cert-entity-id')?.value?.trim() || '',
    days:          parseInt(document.getElementById('spid-cert-days')?.value) || 730,
    key_size:      parseInt(document.getElementById('spid-cert-keysize')?.value) || 3072,
  };
  const resultEl = document.getElementById('spid-cert-result');
  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Generazione…';
  resultEl.style.display = 'none';
  try {
    const res  = await fetch('/impostazioni/login-proxy/spid-certs/genera', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const json = await res.json();
    const ok   = !!json.success;
    resultEl.className = 'mt-3 alert ' + (ok ? 'alert-success' : 'alert-danger');
    let html = (ok ? '<i class="fas fa-check-circle me-1"></i>' : '<i class="fas fa-times-circle me-1"></i>') + escHtml(json.message || '');
    if (ok && json.cert) {
      html += '<dl class="row small mt-2 mb-0">'
        + metaRow('Soggetto', escHtml(json.cert.subject || '—'))
        + metaRow('Valido dal', escHtml(json.cert.valid_from || '—'))
        + metaRow('Valido al',  escHtml(json.cert.valid_to  || '—'))
        + '</dl>';
    }
    resultEl.innerHTML = html;
    resultEl.style.display = '';
    if (ok) { impToast('Certificati SPID generati.', true); loadSpidCertInfo(null); }
  } catch (e) {
    resultEl.className = 'mt-3 alert alert-danger';
    resultEl.innerHTML = '<i class="fas fa-times-circle me-1"></i>Errore: ' + escHtml(e.message);
    resultEl.style.display = '';
  } finally {
    btn.disabled = false;
    btn.innerHTML = orig;
  }
}

