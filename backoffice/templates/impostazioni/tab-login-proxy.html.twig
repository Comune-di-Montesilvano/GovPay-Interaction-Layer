                    value="{{ iam_proxy.satosa_org_name_en|default('') }}"
                    placeholder="{{ entity.name|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Organization URL (EN)</label>
                  <input type="url" class="form-control" name="satosa_org_url_en"
                    value="{{ iam_proxy.satosa_org_url_en|default(entity.url|default('')) }}"
                    placeholder="{{ entity.url|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
              </div>
            </details>

            {# UI IDP — testi e logo mostrati al cittadino sulla pagina di login SATOSA #}
            <details class="mt-2">
              <summary class="text-muted small fw-semibold" style="cursor:pointer">
                <i class="fas fa-caret-right me-1"></i>UI IDP — testi e logo pagina di login (avanzati)
              </summary>
              <div class="alert alert-info py-2 small mt-2 mb-0">
                <i class="fas fa-info-circle me-1"></i>
                Testi e URL mostrati nella schermata di scelta IdP (disco.html) e nei metadata SAML2.
                Se lasciati vuoti vengono usate stringhe vuote (SATOSA accetta ma l'interfaccia potrebbe risultare incompleta).
              </div>
              <div class="row g-3 mt-1">
                <div class="col-md-6">
                  <label class="form-label">Display Name (IT)</label>
                  <input type="text" class="form-control" name="satosa_ui_display_name_it"
                    value="{{ iam_proxy.satosa_ui_display_name_it|default('') }}"
                    placeholder="{{ entity.name|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Display Name (EN)</label>
                  <input type="text" class="form-control" name="satosa_ui_display_name_en"
                    value="{{ iam_proxy.satosa_ui_display_name_en|default('') }}"
                    placeholder="{{ entity.name|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Descrizione (IT)</label>
                  <input type="text" class="form-control" name="satosa_ui_description_it"
                    value="{{ iam_proxy.satosa_ui_description_it|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Descrizione (EN)</label>
                  <input type="text" class="form-control" name="satosa_ui_description_en"
                    value="{{ iam_proxy.satosa_ui_description_en|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-6">
                  <label class="form-label">URL Informazioni (IT)</label>
                  <input type="url" class="form-control" name="satosa_ui_information_url_it"
                    value="{{ iam_proxy.satosa_ui_information_url_it|default(entity.url|default('')) }}"
                    placeholder="{{ entity.url|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-6">
                  <label class="form-label">URL Informazioni (EN)</label>
                  <input type="url" class="form-control" name="satosa_ui_information_url_en"
                    value="{{ iam_proxy.satosa_ui_information_url_en|default(entity.url|default('')) }}"
                    placeholder="{{ entity.url|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-6">
                  <label class="form-label">URL Privacy (IT)</label>
                  <input type="url" class="form-control" name="satosa_ui_privacy_url_it"
                    value="{{ iam_proxy.satosa_ui_privacy_url_it|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-6">
                  <label class="form-label">URL Privacy (EN)</label>
                  <input type="url" class="form-control" name="satosa_ui_privacy_url_en"
                    value="{{ iam_proxy.satosa_ui_privacy_url_en|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-6">
                  <label class="form-label">URL Note legali (IT)</label>
                  <input type="url" class="form-control" name="satosa_ui_legal_url_it"
                    value="{{ iam_proxy.satosa_ui_legal_url_it|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-6">
                  <label class="form-label">URL Note legali (EN)</label>
                  <input type="url" class="form-control" name="satosa_ui_legal_url_en"
                    value="{{ iam_proxy.satosa_ui_legal_url_en|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-6">
                  <label class="form-label">URL Accessibilità (IT)</label>
                  <input type="url" class="form-control" name="satosa_ui_accessibility_url_it"
                    value="{{ iam_proxy.satosa_ui_accessibility_url_it|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-6">
                  <label class="form-label">URL Accessibilità (EN)</label>
                  <input type="url" class="form-control" name="satosa_ui_accessibility_url_en"
                    value="{{ iam_proxy.satosa_ui_accessibility_url_en|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-8">
                  <label class="form-label">URL Logo</label>
                  <input type="url" class="form-control" name="satosa_ui_logo_url"
                    value="{{ iam_proxy.satosa_ui_logo_url|default('') }}"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-2">
                  <label class="form-label">Larghezza logo (px)</label>
                  <input type="number" class="form-control" name="satosa_ui_logo_width"
                    value="{{ iam_proxy.satosa_ui_logo_width|default('200') }}"
                    min="1" max="9999"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
                <div class="col-md-2">
                  <label class="form-label">Altezza logo (px)</label>
                  <input type="number" class="form-control" name="satosa_ui_logo_height"
                    value="{{ iam_proxy.satosa_ui_logo_height|default('60') }}"
                    min="1" max="9999"
                    {{ not is_superadmin ? 'readonly' : '' }}>
                </div>
              </div>
            </details>
          </div>
        </div>
      </div>

      {# ─── Chiavi crittografiche (solo superadmin) ───────────────────────── #}
      {% if is_superadmin %}
      <div class="accordion-item border shadow-sm mb-2">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#lp-satosa-keys">
            <i class="fas fa-key me-2 text-danger"></i>Chiavi crittografiche SATOSA
            <span class="badge bg-danger-subtle text-danger border border-danger-subtle ms-2 fw-normal small">Segreti</span>
          </button>
        </h2>
        <div id="lp-satosa-keys" class="accordion-collapse collapse" data-bs-parent="#acc-lp">
          <div class="accordion-body">
            <div class="alert alert-warning py-2 small mb-3">
              <i class="fas fa-exclamation-triangle me-1"></i>
              Chiavi per firma/cifratura sessioni SATOSA. Almeno <strong>32 caratteri</strong>.
              Genera con: <code>openssl rand -hex 24</code>.
              Lasciare vuoto per non modificare il valore esistente.
            </div>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Salt</label>
                <div class="input-group">
                  <input type="password" class="form-control font-monospace" name="satosa_salt"
                    id="satosa-salt" placeholder="Lascia vuoto per non modificare" autocomplete="new-password">
                  <button class="btn btn-outline-secondary" type="button" onclick="togglePwd('satosa-salt', this)"><i class="fas fa-eye"></i></button>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label">State Encryption Key</label>
                <div class="input-group">
                  <input type="password" class="form-control font-monospace" name="satosa_state_encryption_key"
                    id="satosa-state-key" placeholder="Lascia vuoto per non modificare" autocomplete="new-password">
                  <button class="btn btn-outline-secondary" type="button" onclick="togglePwd('satosa-state-key', this)"><i class="fas fa-eye"></i></button>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label">Encryption Key</label>
                <div class="input-group">
                  <input type="password" class="form-control font-monospace" name="satosa_encryption_key"
                    id="satosa-enc-key" placeholder="Lascia vuoto per non modificare" autocomplete="new-password">
                  <button class="btn btn-outline-secondary" type="button" onclick="togglePwd('satosa-enc-key', this)"><i class="fas fa-eye"></i></button>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label">User ID Hash Salt</label>
                <div class="input-group">
                  <input type="password" class="form-control font-monospace" name="satosa_user_id_hash_salt"
                    id="satosa-id-salt" placeholder="Lascia vuoto per non modificare" autocomplete="new-password">
                  <button class="btn btn-outline-secondary" type="button" onclick="togglePwd('satosa-id-salt', this)"><i class="fas fa-eye"></i></button>
                </div>
              </div>
            </div>

            <hr class="my-3">
            <p class="small text-muted mb-2">Toggle avanzati:</p>
            <div class="d-flex gap-4 flex-wrap">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="enable_idem" id="en-idem" value="true"
                  {{ iam_proxy.enable_idem|default('false') == 'true' ? 'checked' : '' }}>
                <label class="form-check-label" for="en-idem">IDEM</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="enable_eidas" id="en-eidas" value="true"
                  {{ iam_proxy.enable_eidas|default('false') == 'true' ? 'checked' : '' }}>
                <label class="form-check-label" for="en-eidas">eIDAS</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="satosa_use_demo_spid_idp" id="demo-spid" value="true"
                  {{ iam_proxy.satosa_use_demo_spid_idp|default('false') == 'true' ? 'checked' : '' }}>
                <label class="form-check-label" for="demo-spid">Demo SPID IdP</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="satosa_use_spid_validator" id="spid-validator" value="true"
                  {{ iam_proxy.satosa_use_spid_validator|default('false') == 'true' ? 'checked' : '' }}>
                <label class="form-check-label" for="spid-validator">SPID Validator</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="satosa_disable_cieoidc_backend" id="dis-cie" value="true"
                  {{ iam_proxy.satosa_disable_cieoidc_backend|default('false') == 'true' ? 'checked' : '' }}>
                <label class="form-check-label" for="dis-cie">Disabilita backend CIE OIDC</label>
              </div>
            </div>
          </div>
        </div>
      </div>
      {% endif %}

    </div>{# /accordion #}

    {% if is_superadmin %}
    <div class="d-flex justify-content-end">
      <button type="button" class="btn btn-primary"
        onclick="impSaveForm('form-login-proxy', '/impostazioni/login-proxy/save', this)">
        <i class="fas fa-save me-1"></i>Salva configurazione
      </button>
    </div>
    {% endif %}
  </form>

  {# ─── Fase 2: Chiavi e Certificati ────────────────────────────────────────── #}
  <div class="d-flex align-items-center gap-2 mt-4 mb-2">
    <span class="badge rounded-pill bg-success fs-6 fw-bold px-3 py-2">2</span>
    <h5 class="mb-0">Chiavi e Certificati</h5>
  </div>
  <p class="text-muted small mb-3">
    Genera il certificato SPID e/o le chiavi JWK CIE OIDC.
    {% if is_superadmin %}Completa questo passo prima di rigenerare i metadata (passo 3).{% endif %}
  </p>
  <div class="row g-3 mb-2">
    {# Card SPID certs #}
    <div class="col-md-6" id="lp-cert-spid-card"
      style="{{ iam_proxy.enable_spid|default('false') != 'true' ? 'display:none' : '' }}">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white d-flex align-items-center justify-content-between py-2">
          <h6 class="mb-0"><i class="fas fa-certificate me-2 text-success"></i>Certificato SPID</h6>
          <span class="badge bg-success-subtle text-success border border-success-subtle">SPID</span>
        </div>
        <div class="card-body" id="spid-cert-info-body">
          <p class="text-muted small mb-0">Clicca <strong>Stato</strong> per verificare il certificato attuale.</p>
        </div>
        <div class="card-footer bg-white d-flex align-items-center justify-content-between gap-2 flex-wrap">
          <button class="btn btn-sm btn-outline-secondary" onclick="loadSpidCertInfo(this)" title="Aggiorna info">
            <i class="fas fa-sync-alt me-1"></i>Stato
          </button>
          {% if is_superadmin %}
          <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-sm btn-outline-warning" type="button"
              data-bs-toggle="modal" data-bs-target="#spidCertRestoreModal">
              <i class="fas fa-upload me-1"></i>Ripristina
            </button>
            <button class="btn btn-sm btn-outline-success" type="button"
              data-bs-toggle="modal" data-bs-target="#spidCertGeneraModal">
              <i class="fas fa-certificate me-1"></i>Genera
            </button>
          </div>
          {% endif %}
        </div>
      </div>
    </div>
    {# Card CIE OIDC keys #}
    <div class="col-md-6" id="lp-cert-cie-card"
      style="{{ iam_proxy.enable_cie_oidc|default('false') != 'true' ? 'display:none' : '' }}">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white d-flex align-items-center justify-content-between py-2">
          <h6 class="mb-0"><i class="fas fa-key me-2 text-info"></i>Chiavi JWK CIE OIDC</h6>
          <span class="badge bg-info-subtle text-info border border-info-subtle">CIE OIDC</span>
        </div>
        <div class="card-body" id="cie-keys-info-body">
          <p class="text-muted small mb-0">Clicca <strong>Stato</strong> per verificare le chiavi attuali.</p>
        </div>
        <div class="card-footer bg-white d-flex align-items-center justify-content-between gap-2 flex-wrap">
          <button class="btn btn-sm btn-outline-secondary" onclick="loadCieKeysInfo(this)" title="Aggiorna info">
            <i class="fas fa-sync-alt me-1"></i>Stato
          </button>
          {% if is_superadmin %}
          <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-sm btn-outline-warning" type="button"
              data-bs-toggle="modal" data-bs-target="#cieKeysRestoreModal">
              <i class="fas fa-upload me-1"></i>Ripristina
            </button>
            <button class="btn btn-sm btn-outline-info" type="button" onclick="generaCieKeys(this)">
              <i class="fas fa-key me-1"></i>Genera
            </button>
          </div>
          {% endif %}
        </div>
      </div>
    </div>
    {# Placeholder: nessun metodo abilitato #}
    <div class="col-12" id="lp-fase2-empty" style="display:none;">
      <div class="alert alert-secondary mb-0">
        <i class="fas fa-info-circle me-1"></i>
        Abilita SPID e/o CIE OIDC nella <strong>Fase 1 → Generale</strong> per accedere alla generazione di chiavi e certificati.
      </div>
    </div>
  </div>

  {# ─── Fase 3: Metadata ────────────────────────────────────────────────────── #}
  <div class="d-flex align-items-center gap-2 mt-4 mb-2">
    <span class="badge rounded-pill bg-warning text-dark fs-6 fw-bold px-3 py-2">3</span>
    <h5 class="mb-0">Metadata</h5>
  </div>
  <p class="text-muted small mb-3">
    La UI gestisce solo gli artifact pubblici federabili. Il metadata interno frontoffice↔iam-proxy si autogenera e si riallinea da solo.
  </p>
  <div class="row g-3 mb-2">
    <div class="col-md-6" id="lp-meta-spid-card"
      style="{{ iam_proxy.enable_spid|default('false') != 'true' ? 'display:none' : '' }}">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white d-flex align-items-center justify-content-between py-2">
          <h6 class="mb-0"><i class="fas fa-id-card me-2 text-success"></i>Metadata pubblico SPID (AgID)</h6>
          <button class="btn btn-sm btn-outline-secondary" onclick="loadMetadataInfo('spid', this)" title="Aggiorna info">
            <i class="fas fa-sync-alt"></i>
          </button>
        </div>
        <div class="card-body" id="spid-metadata-body">
          <p class="text-muted small mb-0">Esporta il file da inviare ad AgID e usa <i class="fas fa-sync-alt"></i> per verificarne lo stato.</p>
        </div>
        {% if is_superadmin %}
        <div class="card-footer bg-white d-flex justify-content-end gap-2 flex-wrap">
          <button class="btn btn-sm btn-outline-secondary" type="button" onclick="downloadSpidMetadata(this)">
            <i class="fas fa-download me-1"></i>Scarica XML
          </button>
          <button class="btn btn-sm btn-outline-warning" type="button"
            data-bs-toggle="modal" data-bs-target="#spidMetaRestoreModal">
            <i class="fas fa-upload me-1"></i>Ripristina XML
          </button>
          <button class="btn btn-sm btn-outline-success" type="button"
                  data-bs-toggle="modal" data-bs-target="#spidMetaGeneraModal">
            <i class="fas fa-file-export me-1"></i>Genera da SATOSA
          </button>
        </div>
        {% endif %}
      </div>
    </div>
    <div class="col-md-6" id="lp-meta-cie-card"
      style="{{ iam_proxy.enable_cie_oidc|default('false') != 'true' ? 'display:none' : '' }}">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white d-flex align-items-center justify-content-between py-2">
          <h6 class="mb-0"><i class="fas fa-address-card me-2 text-info"></i>Metadata SP CIE OIDC</h6>
          <button class="btn btn-sm btn-outline-secondary" onclick="loadMetadataInfo('cie', this)" title="Aggiorna info">
            <i class="fas fa-sync-alt"></i>
          </button>
        </div>
        <div class="card-body" id="cie-metadata-body">
          <p class="text-muted small mb-0">Clicca <i class="fas fa-sync-alt"></i> per caricare le informazioni.</p>
        </div>
        {% if is_superadmin %}
        <div class="card-footer bg-white d-flex justify-content-end gap-2 flex-wrap">
          <button class="btn btn-sm btn-outline-info" type="button" onclick="exportCieOidc(this)">
            <i class="fas fa-file-export me-1"></i>Esporta artefatti CIE
          </button>
        </div>
        {% endif %}
      </div>
    </div>
    <div class="col-12" id="lp-fase3-empty" style="display:none;">
      <div class="alert alert-secondary mb-0">
        <i class="fas fa-info-circle me-1"></i>
        Abilita SPID e/o CIE OIDC nella <strong>Fase 1 → Generale</strong> per accedere alla gestione dei metadata.
      </div>
    </div>
  </div>

  {# ─── Fase 4: Backup e Ripristino ─────────────────────────────────────────── #}
  {% if is_superadmin %}
  <div class="d-flex align-items-center gap-2 mt-4 mb-2">
    <span class="badge rounded-pill bg-secondary fs-6 fw-bold px-3 py-2">4</span>
    <h5 class="mb-0">Backup e Ripristino</h5>
  </div>
  <p class="text-muted small mb-3">
    Esporta in un unico archivio ZIP la configurazione e/o i file di chiavi e metadata.
    Il ripristino sostituisce i file esistenti sul volume.
  </p>
  <div class="row g-3 mb-2">
    {# Export ZIP #}
    <div class="col-md-7">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white py-2">
