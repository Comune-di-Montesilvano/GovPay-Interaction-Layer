// ── Info certificato SPID (Fase 2) ────────────────────────────────────────────
async function loadSpidCertInfo(btn) {
  const bodyEl = document.getElementById('spid-cert-info-body');
  if (!bodyEl) return;
  const orig = btn ? btn.innerHTML : '';
  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>'; }
  try {
    const res = await fetch('/impostazioni/login-proxy/spid-certs/info');
    const json = await res.json();
    const d = json.data || json;
    if (!d.exists) {
      bodyEl.innerHTML = '<span class="badge bg-warning-subtle text-warning border border-warning-subtle"><i class="fas fa-exclamation-circle me-1"></i>Certificato non presente</span><p class="text-muted small mt-2 mb-0">' + escHtml(d.message || 'Genera o ripristina il certificato SPID.') + '</p>';
      return;
    }
    let html = '<dl class="row small mb-0">';
    html += metaRow('CN', '<code class="small">' + escHtml(d.subject_cn || '—') + '</code>');
    if (d.subject_o) html += metaRow('Organizzazione', escHtml(d.subject_o));
    if (d.subject_l) html += metaRow('Locality', escHtml(d.subject_l));
    if (d.key_bits)  html += metaRow('Chiave', escHtml(d.key_type || 'RSA') + ' ' + d.key_bits + ' bit');
    if (d.valid_to) {
      const daysLeft = d.days_left ?? 0;
      const expiredFlag = d.expired;
      const cls = expiredFlag ? 'bg-danger-subtle text-danger border-danger-subtle' : (daysLeft < 30 ? 'bg-warning-subtle text-warning border-warning-subtle' : 'bg-success-subtle text-success border-success-subtle');
      const icon = expiredFlag ? 'fa-times-circle' : (daysLeft < 30 ? 'fa-exclamation-circle' : 'fa-check-circle');
      const label = expiredFlag ? 'SCADUTO' : (daysLeft + ' giorni');
      html += metaRow('Scadenza', '<span class="badge ' + cls + ' border"><i class="fas ' + icon + ' me-1"></i>' + escHtml(d.valid_to) + ' (' + label + ')</span>');
    }
    if (d.fingerprint_sha256) html += metaRow('SHA-256', '<code class="small text-break">' + escHtml(d.fingerprint_sha256) + '</code>');
    html += metaRow('Chiave privata', d.has_key ? '<span class="badge bg-success-subtle text-success border border-success-subtle"><i class="fas fa-check-circle me-1"></i>Presente</span>' : '<span class="badge bg-danger-subtle text-danger border border-danger-subtle"><i class="fas fa-times-circle me-1"></i>Mancante</span>');
    html += '</dl>';
    bodyEl.innerHTML = html;
  } catch (e) {
    bodyEl.innerHTML = '<div class="text-danger small">Errore: ' + escHtml(e.message) + '</div>';
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = orig; }
  }
}

