    const res  = await fetch('/impostazioni/login-proxy/spid-certs/restore', { method: 'POST', body: fd });
    const json = await res.json();
    resultEl.className = 'mt-2 alert ' + (json.success ? 'alert-success' : 'alert-danger') + ' small';
    resultEl.innerHTML = (json.success ? '<i class="fas fa-check-circle me-1"></i>' : '<i class="fas fa-times-circle me-1"></i>') + escHtml(json.message || '');
    if (json.success && json.subject_cn) resultEl.innerHTML += '<br><strong>CN:</strong> ' + escHtml(json.subject_cn) + (json.valid_to ? ', scade: ' + escHtml(json.valid_to) : '');
    resultEl.style.display = '';
    if (json.success) { impToast('Certificato SPID ripristinato.', true); loadSpidCertInfo(null); }
  } catch (e) {
    resultEl.className = 'mt-2 alert alert-danger small';
    resultEl.innerHTML = '<i class="fas fa-times-circle me-1"></i>Errore: ' + escHtml(e.message);
    resultEl.style.display = '';
  } finally {
    btn.disabled = false;
    btn.innerHTML = orig;
  }
}

// ── Ripristino chiavi JWK CIE OIDC da file ───────────────────────────────────
async function doRestoreCieKeys(btn) {
  const fedFile = document.getElementById('cie-restore-fed')?.files[0];
  const sigFile = document.getElementById('cie-restore-sig')?.files[0];
  const encFile = document.getElementById('cie-restore-enc')?.files[0];
  if (!fedFile && !sigFile && !encFile) { impToast('Seleziona almeno un file JWK da ripristinare.', false); return; }
  const fd = new FormData();
  if (fedFile) fd.append('jwk-federation.json', fedFile);
  if (sigFile) fd.append('jwk-core-sig.json', sigFile);
  if (encFile) fd.append('jwk-core-enc.json', encFile);
  const resultEl = document.getElementById('cie-keys-restore-result');
  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Caricamento…';
  resultEl.style.display = 'none';
  try {
    const res  = await fetch('/impostazioni/login-proxy/cie-keys/restore', { method: 'POST', body: fd });
    const json = await res.json();
    resultEl.className = 'mt-2 alert ' + (json.success ? 'alert-success' : 'alert-danger') + ' small';
    resultEl.innerHTML = (json.success ? '<i class="fas fa-check-circle me-1"></i>' : '<i class="fas fa-times-circle me-1"></i>') + escHtml(json.message || '');
    if (json.success && json.restored) resultEl.innerHTML += '<br>Ripristinati: ' + json.restored.map(f => '<code>' + escHtml(f) + '</code>').join(', ');
    resultEl.style.display = '';
    if (json.success) { impToast('Chiavi JWK CIE OIDC ripristinate.', true); loadCieKeysInfo(null); }
  } catch (e) {
    resultEl.className = 'mt-2 alert alert-danger small';
    resultEl.innerHTML = '<i class="fas fa-times-circle me-1"></i>Errore: ' + escHtml(e.message);
    resultEl.style.display = '';
  } finally {
    btn.disabled = false;
    btn.innerHTML = orig;
  }
}

// ── Ripristino da backup ZIP completo ─────────────────────────────────────────
async function lpRestoreBackupZip(btn) {
  const fileEl = document.getElementById('bk-restore-zip');
  if (!fileEl || !fileEl.files[0]) { impToast('Seleziona un file ZIP di backup.', false); return; }
  if (!confirm('Ripristinare dal file ZIP?\n\nI file esistenti (cert.pem, privkey.pem, chiavi JWK, metadata) saranno sovrascritti con il contenuto del backup.')) return;
  const fd = new FormData();
  fd.append('backup_zip', fileEl.files[0]);
  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Ripristino…';
  try {
    const res  = await fetch('/impostazioni/login-proxy/backup/restore', { method: 'POST', body: fd });
    const json = await res.json();
    if (!json.success && !json.results) {
      impToast(json.message || 'Ripristino fallito.', false);
      return;
    }
    const results = json.results || {};
    const parts = Object.entries(results).map(([k, v]) => (v.success ? '✓ ' : '✗ ') + v.message);
    if (parts.length) {
      impToast(json.message + '\n' + parts.join('\n'), Object.values(results).some(v => v.success));
    } else {
      impToast('Nessun elemento trovato nel ZIP.', false);
    }
    // Refresh cards
    loadSpidCertInfo(null);
    loadCieKeysInfo(null);
    loadMetadataInfo('spid', null);
    loadMetadataInfo('cie', null);
  } catch (e) {
    impToast('Errore: ' + e.message, false);
  } finally {
    btn.disabled = false;
    btn.innerHTML = orig;
  }
}
</script>
