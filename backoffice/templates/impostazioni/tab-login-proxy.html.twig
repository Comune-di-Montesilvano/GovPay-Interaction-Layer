<script>
// ── Costanti CIE ────────────────────────────────────────────────────────────
const CIE_PROD_URL    = 'https://oidc.idserver.servizicie.interno.gov.it';
const CIE_PREPROD_URL = 'https://preproduzione.cie.interno.gov.it/idp/oidc/op';
const CIE_TRUST_PROD    = 'https://oidc.registry.servizicie.interno.gov.it';
const CIE_TRUST_PREPROD = 'https://preprod.registry.servizicie.interno.gov.it';

// ── Derivazione campi da URL pubblico ────────────────────────────────────────
function lpDeriveFromUrl() {
  const pub = (document.getElementById('lp-public-url')?.value || '').replace(/\/$/, '');
  const host = document.getElementById('lp-hostname')?.value || '';

  // SATOSA metadata URLs
  lpSetDerived('lp-saml2-meta-pub', pub ? pub + '/Saml2IDP/metadata' : '');
  lpSetHint('lp-saml2-meta-pub-hint', pub ? pub + '/Saml2IDP/metadata' : '—');
  const _intScheme = {{ ssl_on is defined and ssl_on ? 'true' : 'false' }} ? 'https' : 'http';
  lpSetDerived('lp-saml2-meta-int', host ? _intScheme + '://' + host + '/Saml2IDP/metadata' : '');

  // SPID cert fields
  lpSetDerived('lp-spid-cn', host);
  const fo = '{{ frontoffice.public_url|default('') }}';
  const entityId = fo ? fo.replace(/\/$/, '') + '/saml/sp' : (pub ? pub + '/saml/sp' : '');
  lpSetDerived('lp-spid-entity-id', entityId);
  lpSetHint('lp-spid-entity-id-hint', entityId || '—');

  // SPID org ID
  const ipa = '{{ entity.ipa_code|default('') }}';
  const orgId = ipa ? 'PA:IT-' + ipa : '';
  lpSetDerived('lp-spid-org-id', orgId);

  // CIE fields
  const rp = pub ? pub + '/CieOidcRp' : '';
  lpSetDerived('lp-cie-client-id', rp);
  lpSetHint('lp-cie-client-id-hint', rp || '—');
  lpSetDerived('lp-cie-redirect', rp ? rp + '/oidc/callback' : '');
  lpSetHint('lp-cie-redirect-hint', rp ? rp + '/oidc/callback' : '—');
  lpSetDerived('lp-cie-jwks', rp ? rp + '/openid_relying_party/jwks.json' : '');
  lpSetHint('lp-cie-jwks-hint', rp ? rp + '/openid_relying_party/jwks.json' : '—');
  lpSetDerived('lp-cie-signed-jwks', rp ? rp + '/openid_relying_party/jwks.jose' : '');
  lpSetHint('lp-cie-signed-jwks-hint', rp ? rp + '/openid_relying_party/jwks.jose' : '—');
  lpSetDerived('lp-cie-homepage', rp);
  lpSetHint('lp-cie-homepage-hint', rp || '—');
  // Fed endpoints (avanzati)
  lpSetDerived('lp-cie-fed-resolve', rp ? rp + '/resolve' : '');
  lpSetDerived('lp-cie-fed-fetch', rp ? rp + '/fetch' : '');
  lpSetDerived('lp-cie-fed-tm', rp ? rp + '/trust_mark_status' : '');
  lpSetDerived('lp-cie-fed-list', rp ? rp + '/list' : '');
  lpSetDerived('lp-cie-policy', rp ? rp + '/en/website/legal-information' : '');
  lpSetDerived('lp-cie-logo', pub ? pub + '/static/cie/sample-cie-logo.png' : '');

  // CIE trust anchor aggiornato dall'ambiente già selezionato
  lpUpdateCieEnv(false);
}

function lpSetDerived(id, val) {
  const el = document.getElementById(id);
  if (!el || !el.dataset.derived) return; // non sovrascrivere se sbloccato
  if (val) el.value = val;
}

function lpSetHint(id, val) {
  const el = document.getElementById(id);
  if (el) el.textContent = val;
}

function lpUnlock(id, btn) {
  const el = document.getElementById(id);
  if (!el) return;
  el.removeAttribute('readonly');
  delete el.dataset.derived;
  el.classList.add('border-warning');
  btn.innerHTML = '<i class="fas fa-lock-open text-warning"></i>';
  btn.disabled = true;
  el.focus();
}

// ── CIE ambiente select ───────────────────────────────────────────────────────
function lpUpdateCieEnv(updateFields = true) {
  const sel = document.getElementById('lp-cie-env');
  const wrap = document.getElementById('lp-cie-custom-wrap');
  const hidden = document.getElementById('lp-cie-provider-url-hidden');
  if (!sel) return;
  const env = sel.value;
  wrap.style.display = env === 'custom' ? '' : 'none';

  let providerUrl = '';
  let trustUrl = '';
  if (env === 'prod') {
    providerUrl = CIE_PROD_URL;
    trustUrl = CIE_TRUST_PROD;
  } else if (env === 'preprod') {
    providerUrl = CIE_PREPROD_URL;
    trustUrl = CIE_TRUST_PREPROD;
  } else {
    providerUrl = document.getElementById('lp-cie-custom-url')?.value || '';
    trustUrl = '';
  }
  if (hidden) hidden.value = providerUrl;

  if (updateFields) {
    // Aggiorna trust anchor se il campo è ancora in modalità derivata
    const taEl = document.getElementById('lp-cie-trust-anchor');
    if (taEl && taEl.dataset.derived && trustUrl) {
      taEl.value = trustUrl;
      lpSetHint('lp-cie-trust-anchor-hint', trustUrl);
    }
    const ahEl = document.getElementById('lp-cie-auth-hint');
    if (ahEl && ahEl.dataset.derived && trustUrl) {
      ahEl.value = trustUrl;
      lpSetHint('lp-cie-auth-hint-hint', trustUrl);
    }
  }
}

// ── Utility ───────────────────────────────────────────────────────────────────
function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function togglePwd(id, btn) {
  const el = document.getElementById(id);
  if (!el) return;
  el.type = el.type === 'password' ? 'text' : 'password';
  btn.querySelector('i').className = el.type === 'password' ? 'fas fa-eye' : 'fas fa-eye-slash';
}

function toggleRestoreForm(id) {
  const el = document.getElementById(id);
  if (el) el.style.display = el.style.display === 'none' ? '' : 'none';
}

async function loadMetadataInfo(type, btn) {
  const bodyEl = document.getElementById(type + '-metadata-body');
  if (!bodyEl) return;
  const origIcon = btn ? btn.innerHTML : '';
  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>'; }
  try {
    const res = await fetch('/impostazioni/login-proxy/' + type + '-metadata/info');
    const json = await res.json();
    const d = json.data || json;
    if (!d.exists) {
      bodyEl.innerHTML = '<span class="badge bg-warning-subtle text-warning border border-warning-subtle"><i class="fas fa-exclamation-circle me-1"></i>File non trovato</span>';
      return;
    }
    if (d.parse_error) {
      bodyEl.innerHTML = '<div class="text-danger small"><i class="fas fa-times-circle me-1"></i>Errore parsing: ' + escHtml(d.parse_error) + '</div>';
      return;
    }
    let html = '<dl class="row small mb-0">';
    if (type === 'spid') {
      html += metaRow('Entity ID', escHtml(d.entity_id || '—'));
      if (d.acs_urls && d.acs_urls.length) {
        html += metaRow('ACS URL', d.acs_urls.map(u => '<code class="small">' + escHtml(u) + '</code>').join('<br>'));
      }
      html += metaRow('Scadenza metadata', expiryBadge(d.valid_until, d.valid_until_expired));
      html += metaRow('Scadenza certificato', expiryBadge(d.cert_expiry, d.cert_expired));
    } else {
      html += metaRow('Issuer', '<code class="small">' + escHtml(d.iss || '—') + '</code>');
      html += metaRow('Subject', '<code class="small">' + escHtml(d.sub || '—') + '</code>');
      if (d.exp) {
        const daysLeft = d.exp_days_left ?? 0;
        const expired = d.exp_expired;
        const cls = expired ? 'bg-danger-subtle text-danger border-danger-subtle' : (daysLeft < 30 ? 'bg-warning-subtle text-warning border-warning-subtle' : 'bg-success-subtle text-success border-success-subtle');
        const icon = expired ? 'fa-times-circle' : (daysLeft < 30 ? 'fa-exclamation-circle' : 'fa-check-circle');
        const lbl = expired ? 'SCADUTO' : (daysLeft + ' giorni');
        html += metaRow('Scadenza (exp)', '<span class="badge ' + cls + ' border"><i class="fas ' + icon + ' me-1"></i>' + escHtml(d.exp) + ' (' + lbl + ')</span>');
      }
      if (d.iat) html += metaRow('Emesso (iat)', '<span class="text-muted">' + escHtml(d.iat) + '</span>');
      html += metaRow('Chiavi federazione', '<span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">' + (d.federation_jwk_count || 0) + ' JWK</span>');
      if (d.client_name) html += metaRow('Client name', escHtml(d.client_name));
    }
    html += metaRow('Aggiornato', '<span class="text-muted">' + escHtml(d.file_mtime || '—') + '</span>');
    html += '</dl>';
    bodyEl.innerHTML = html;
  } catch (e) {
    bodyEl.innerHTML = '<div class="text-danger small">Errore: ' + escHtml(e.message) + '</div>';
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = origIcon; }
  }
}

function metaRow(label, value) {
  return '<dt class="col-5 text-muted fw-normal">' + label + '</dt><dd class="col-7 mb-1">' + value + '</dd>';
}
function expiryBadge(date, expired) {
  if (!date) return '<span class="text-muted">—</span>';
  const cls = expired ? 'bg-danger-subtle text-danger border-danger-subtle' : 'bg-success-subtle text-success border-success-subtle';
  const icon = expired ? 'fa-times-circle' : 'fa-check-circle';
  return '<span class="badge ' + cls + ' border"><i class="fas ' + icon + ' me-1"></i>' + escHtml(date) + '</span>';
}
async function restoreMetadata(type, fileInputId, btn) {
  const fileEl = document.getElementById(fileInputId);
  if (!fileEl || !fileEl.files[0]) { impToast('Seleziona un file.', false); return; }
  const fd = new FormData();
  fd.append('metadata_file', fileEl.files[0]);
  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Caricamento…';
  try {
    const res = await fetch('/impostazioni/login-proxy/' + type + '-metadata/restore', { method: 'POST', body: fd });
    const json = await res.json();
    impToast(json.message || (json.success ? 'Ripristinato.' : 'Fallito.'), !!json.success);
    if (json.success) { toggleRestoreForm(type + '-restore-form'); loadMetadataInfo(type, null); }
  } catch (e) { impToast('Errore: ' + e.message, false); }
  finally { btn.disabled = false; btn.innerHTML = orig; }
}

