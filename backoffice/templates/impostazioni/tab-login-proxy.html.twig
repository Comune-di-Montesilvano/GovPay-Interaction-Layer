// ── Export backup ZIP (Fase 4) ────────────────────────────────────────────────
async function lpExportBackupZip(btn) {
  const items = [];
  document.querySelectorAll('#lp-backup-checks input[type=checkbox]:checked:not(:disabled)').forEach(cb => items.push(cb.value));
  if (!items.length) { impToast('Seleziona almeno un elemento da esportare.', false); return; }
  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Preparazione…';
  try {
    const res = await fetch('/impostazioni/login-proxy/backup/export', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items }),
    });
    if (!res.ok) {
      const errJson = await res.json().catch(() => ({}));
      impToast(errJson.message || 'Errore durante l\'export.', false);
      return;
    }
    const blob = await res.blob();
    const cd   = res.headers.get('Content-Disposition') || '';
    const match = cd.match(/filename="([^"]+)"/);
    const filename = match ? match[1] : 'backup-iam-proxy.zip';
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = filename; a.click();
    URL.revokeObjectURL(url);
    impToast('Backup esportato: ' + escHtml(filename), true);
  } catch (e) {
    impToast('Errore: ' + e.message, false);
  } finally {
    btn.disabled = false;
    btn.innerHTML = orig;
  }
}

