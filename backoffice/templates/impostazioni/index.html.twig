<script>
(function () {
  'use strict';

  // ── Toast helper ──────────────────────────────────────────────────────────
  window.impToast = function (msg, ok) {
    const el = document.getElementById('imp-toast');
    const body = document.getElementById('imp-toast-body');
    el.className = 'toast align-items-center position-fixed bottom-0 end-0 m-3 text-bg-' + (ok ? 'success' : 'danger');
    body.textContent = msg;
    bootstrap.Toast.getOrCreateInstance(el, { delay: 4000 }).show();
  };

  // ── Generic AJAX form submit ───────────────────────────────────────────────
  window.impSaveForm = async function (formId, url, btn) {
    const form = document.getElementById(formId);
    if (!form) return;

    // Evita trailing slash negli URL base per non generare endpoint con doppio '/'.
    form.querySelectorAll('input[name="public_base_url"]').forEach((el) => {
      const value = (el.value || '').trim();
      if (value && /^https?:\/\//i.test(value)) {
        el.value = value.replace(/\/+$/, '');
      } else {
        el.value = value;
      }
    });

    const data = new FormData(form);
    const body = new URLSearchParams(data).toString();
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Salvataggio…';
    try {
      const res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body,
      });
      const json = await res.json();
      impToast(json.message || (json.success ? 'Salvato.' : 'Errore.'), !!json.success);
    } catch (e) {
      impToast('Errore di rete: ' + e.message, false);
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-save me-1"></i>Salva';
    }
  };

  // ── Generic action button ─────────────────────────────────────────────────
  window.impAction = async function (url, btn, label) {
    btn.disabled = true;
    const orig = btn.innerHTML;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>' + (label || 'Attendere…');
    try {
      const csrf = document.querySelector('input[name="csrf_token"]')?.value || '';
      const res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ csrf_token: csrf }),
      });
      const json = await res.json();
      impToast(json.message || (json.success ? 'OK.' : 'Errore.'), !!json.success);
    } catch (e) {
      impToast('Errore di rete: ' + e.message, false);
    } finally {
      btn.disabled = false;
      btn.innerHTML = orig;
    }
  };

