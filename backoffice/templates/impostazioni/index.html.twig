{% extends 'base.html.twig' %}

{% block title %}Impostazioni - GovPay{% endblock %}

{% block head %}
<style>
  .imp-nav .nav-link { border-radius: 0; border-left: 3px solid transparent; }
  .imp-nav .nav-link.active { border-left-color: var(--bs-primary); background: rgba(var(--bs-primary-rgb), .06); }
  .imp-nav .nav-link:hover:not(.active) { background: rgba(0,0,0,.04); }
  .imp-section-title { font-size: .7rem; text-transform: uppercase; letter-spacing: .08em; color: #6c757d; font-weight: 600; padding: .5rem 1rem .25rem; }
  .form-save-bar { display: none; position: sticky; bottom: 0; background: rgba(255,255,255,.95); backdrop-filter: blur(4px); border-top: 1px solid #dee2e6; padding: .75rem 1rem; z-index: 10; }
  .form-save-bar.visible { display: flex; }
  .master-status-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
  /* Bootstrap Italia aggiunge icone via background-image 32x32px su .alert.
     Riduce l'icona e il padding-left per gli alert compatti (py-2 / small). */
  .alert.py-2 {
    background-size: 18px 18px;
    background-position: 10px center;
    padding-left: 2.2rem;
  }
  .alert.py-2.small, .alert.py-2 .small { font-size: .875rem; }
  .imp-search-results { display: none; }
  .imp-search-results.visible { display: block; }
  .imp-search-result { display: block; text-decoration: none; color: inherit; border: 1px solid #dee2e6; border-radius: .5rem; padding: .625rem .75rem; background: #fff; }
  .imp-search-result:hover { border-color: var(--bs-primary); background: rgba(var(--bs-primary-rgb), .03); }
  .imp-search-result-title { font-size: .92rem; font-weight: 600; }
  .imp-search-result-meta { font-size: .78rem; color: #6c757d; }
  mark.imp-mark { background: rgba(255, 193, 7, .35); padding: 0; }
</style>
{% endblock %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-3">
  <h1 class="h4 mb-0"><i class="fas fa-sliders-h me-2 text-primary"></i>Impostazioni di sistema</h1>
  <a class="btn btn-sm btn-outline-secondary" href="/"><i class="fas fa-arrow-left me-1"></i>Home</a>
</div>

{% if not is_superadmin %}
  <div class="alert alert-info py-2 mb-3" role="alert">
    Sei autenticato come <strong>admin</strong>: le impostazioni sono in sola lettura. Per apportare modifiche è necessario un superadmin.
  </div>
{% endif %}

{% set debug_app_active = app.debug|default('false') == 'true' %}
{% set debug_iam_active = iam_proxy.debug|default('false') == 'true' %}
{% if debug_app_active or debug_iam_active %}
  <div class="alert alert-warning d-flex align-items-center justify-content-between py-2 mb-3" role="alert">
    <div>
      <i class="fas fa-bug me-2"></i>
      <strong>Modalità debug attiva.</strong>
      {% if debug_app_active and debug_iam_active %}
        Sono abilitati Debug applicativo e Debug Auth Proxy.
      {% elseif debug_app_active %}
        È abilitato il Debug applicativo.
      {% else %}
        È abilitato il Debug Auth Proxy.
      {% endif %}
    </div>
    <a class="btn btn-sm btn-outline-dark" href="/impostazioni?tab=debug">Vai al tab Debug</a>
  </div>
{% endif %}

