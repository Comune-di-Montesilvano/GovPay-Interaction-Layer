    function updateSearchIndex() { /* no-op, indice statico */ }

    // Hook su click nav impostazioni
    document.querySelectorAll('.imp-nav .nav-link').forEach(link => {
      link.addEventListener('click', () => {
        setTimeout(updateSearchIndex, 300);
      });
    });

    function escapeHtml(value) {
      return value.replace(/[&<>"']/g, function (ch) {
        return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[ch];
      });
    }

    function highlight(value, query) {
      const safe = escapeHtml(value);
      const idx = value.toLowerCase().indexOf(query.toLowerCase());
      if (idx < 0) return safe;
      const before = escapeHtml(value.slice(0, idx));
      const match = escapeHtml(value.slice(idx, idx + query.length));
      const after = escapeHtml(value.slice(idx + query.length));
      return before + '<mark class="imp-mark">' + match + '</mark>' + after;
    }

    function renderResults(query) {
      if (!query) {
        resultsEl.classList.remove('visible');
        resultsEl.innerHTML = '';
        return;
      }

      const q = query.toLowerCase();
      const matches = searchIndex
        .map((item) => {
          const haystack = [item.section, item.label, item.text].join(' ').toLowerCase();
          const score = haystack.includes(q)
            ? (item.label.toLowerCase().includes(q) ? 3 : (item.section.toLowerCase().includes(q) ? 2 : 1))
            : 0;
          return { item, score };
        })
        .filter((entry) => entry.score > 0)
        .sort((a, b) => b.score - a.score || a.item.section.localeCompare(b.item.section) || a.item.label.localeCompare(b.item.label))
        .slice(0, 8);

      if (matches.length === 0) {
        resultsEl.classList.add('visible');
        resultsEl.innerHTML = '<div class="small text-muted px-1 py-2">Nessun risultato trovato.</div>';
        return;
      }

      resultsEl.classList.add('visible');
      resultsEl.innerHTML = matches.map(({ item }) => (
        '<a class="imp-search-result mb-2" href="/impostazioni?tab=' + encodeURIComponent(item.tab) + '">' +
          '<div class="imp-search-result-title">' + highlight(item.label, query) + '</div>' +
          '<div class="imp-search-result-meta">' + escapeHtml(item.section) + ' · tab ' + escapeHtml(item.tab) + '</div>' +
        '</a>'
      )).join('');
    }

    navSearch.addEventListener('input', function () {
      renderResults(this.value.trim());
    });

    navSearch.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') {
        this.value = '';
        renderResults('');
      }
    });
  }
})();
</script>
