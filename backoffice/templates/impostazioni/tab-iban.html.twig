{# Tab Conti di Accredito (IBAN) — dati letti/scritti su GovPay via EntiCreditoriApi #}

{# ── Lista IBAN ──────────────────────────────────────────────────────────── #}
<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white d-flex align-items-center justify-content-between py-3">
    <h2 class="h5 mb-0"><i class="fas fa-university me-2 text-primary"></i>Conti di Accredito</h2>
    <button class="btn btn-sm btn-outline-secondary" type="button" onclick="ibanReload(this)">
      <i class="fas fa-sync-alt me-1"></i>Aggiorna
    </button>
  </div>
  <div class="card-body p-0">

    {% if iban_error %}
      <div class="alert alert-danger mx-3 my-3 mb-0">
        <i class="fas fa-exclamation-triangle me-2"></i>{{ iban_error }}
      </div>
    {% elseif iban_list|length == 0 %}
      <div id="iban-list-area">
        <p class="text-muted small px-3 py-3 mb-0">Nessun conto di accredito configurato.</p>
      </div>
    {% else %}
      <div id="iban-list-area">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0 small" id="iban-table">
            <thead class="table-light">
              <tr>
                <th>IBAN</th>
                <th>BIC</th>
                <th>Intestatario</th>
                <th>Descrizione</th>
                <th>Tipologie Associate</th>
                <th class="text-center">Postale</th>
                <th class="text-center">MyBank</th>
                <th class="text-center">Stato</th>
                {% if is_superadmin %}<th class="text-end">Azioni</th>{% endif %}
              </tr>
            </thead>
            <tbody>
              {% for row in iban_list %}
                <tr id="iban-row-{{ row.iban|default('')|url_encode }}">
                  <td class="font-monospace fw-semibold">{{ row.iban|default('—') }}</td>
                  <td class="font-monospace">{{ row.bic|default('—') }}</td>
                  <td>{{ row.intestatario|default('—') }}</td>
                  <td>{{ row.descrizione|default('—') }}</td>
                  <td class="text-nowrap">
                    {% if row.num_primarie|default(0) > 0 %}
                      <span class="badge bg-success-subtle text-success border border-success-subtle me-1" title="Utilizzato come IBAN primario di accredito">
                        {{ row.num_primarie }} {{ row.num_primarie == 1 ? 'Primaria' : 'Primarie' }}
                      </span>
                    {% endif %}
                    {% if row.num_secondarie|default(0) > 0 %}
                      <span class="badge bg-info-subtle text-info border border-info-subtle me-1" title="Utilizzato come IBAN secondario di appoggio">
                        {{ row.num_secondarie }} {{ row.num_secondarie == 1 ? 'Secondaria' : 'Secondarie' }}
                      </span>
                    {% endif %}
                    {% if row.num_primarie|default(0) == 0 and row.num_secondarie|default(0) == 0 %}
                      <span class="text-muted small">—</span>
                    {% endif %}
                  </td>
                  <td class="text-center">
                    {% if row.postale is defined and row.postale %}
                      <span class="badge text-bg-success">Sì</span>
                    {% else %}
                      <span class="badge bg-light text-muted border">No</span>
                    {% endif %}
                  </td>
                  <td class="text-center">
                    {% if row.mybank is defined and row.mybank %}
                      <span class="badge text-bg-success">Sì</span>
                    {% else %}
                      <span class="badge bg-light text-muted border">No</span>
                    {% endif %}
                  </td>
                  <td class="text-center" id="iban-stato-{{ row.iban|default('')|url_encode }}">
                    {% if row.abilitato is defined and row.abilitato %}
                      <span class="badge text-bg-success">Abilitato</span>
                    {% else %}
                      <span class="badge text-bg-danger">Disabilitato</span>
                    {% endif %}
                  </td>
                  {% if is_superadmin %}
                  <td class="text-end text-nowrap">
                    <button class="btn btn-xs btn-outline-primary me-1" title="Modifica"
                      onclick='ibanFillForm({{ row|json_encode }})'>
                      <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn btn-xs {{ row.abilitato is defined and row.abilitato ? 'btn-outline-warning' : 'btn-outline-success' }}"
                      title="{{ row.abilitato is defined and row.abilitato ? 'Disabilita' : 'Abilita' }}"
                      id="btn-toggle-{{ row.iban|default('')|url_encode }}"
                      onclick="ibanToggle('{{ row.iban|default('')|e('js') }}', this)">
                      <i class="fas {{ row.abilitato is defined and row.abilitato ? 'fa-ban' : 'fa-check' }}"></i>
                    </button>
                  </td>
                  {% endif %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% endif %}

  </div>
</div>

{# ── Aggiungi / Modifica ──────────────────────────────────────────────────── #}
{% if is_superadmin %}
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white py-3">
    <h2 class="h5 mb-0" id="iban-form-title"><i class="fas fa-plus me-2 text-success"></i>Aggiungi IBAN</h2>
  </div>
  <div class="card-body">
    <form id="form-iban" onsubmit="return false;">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

      <div class="row g-3 mb-3">
        <div class="col-md-5">
          <label class="form-label">IBAN <span class="text-danger">*</span></label>
          <input type="text" class="form-control font-monospace text-uppercase" name="iban" id="iban-field"
            placeholder="IT60X0542811101000000123456" maxlength="34"
            pattern="[A-Za-z]{2}[0-9]{2}[A-Za-z0-9]{1,30}" required autocomplete="off">
          <div class="form-text">Formato: 2 lettere + 2 cifre + fino a 30 alfanumerici (ISO 13616).</div>
        </div>
        <div class="col-md-3">
          <label class="form-label">BIC</label>
          <input type="text" class="form-control font-monospace" name="bic" id="iban-bic"
            placeholder="BICXXXXX" maxlength="11" autocomplete="off">
        </div>
        <div class="col-md-4">
          <label class="form-label">Intestatario</label>
          <input type="text" class="form-control" name="intestatario" id="iban-intestatario"
            placeholder="Comune di …" maxlength="255">
        </div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label">Descrizione</label>
          <input type="text" class="form-control" name="descrizione" id="iban-descrizione"
            placeholder="Conto principale ente" maxlength="255">
        </div>
        <div class="col-md-6">
          <label class="form-label">Autorizzazione stampa Poste Italiane</label>
          <input type="text" class="form-control" name="aut_stampa_poste_italiane" id="iban-aut-stampa"
            placeholder="Codice autorizzazione (opzionale)" maxlength="35">
        </div>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-auto">
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch"
              name="postale_cb" id="iban-postale"
              onchange="document.querySelector('[name=postale]').value = this.checked ? 'true' : 'false'">
            <label class="form-check-label" for="iban-postale">Postale</label>
            <input type="hidden" name="postale" value="false">
          </div>
        </div>
        <div class="col-auto">
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch"
              name="mybank_cb" id="iban-mybank"
              onchange="document.querySelector('[name=mybank]').value = this.checked ? 'true' : 'false'">
            <label class="form-check-label" for="iban-mybank">MyBank</label>
            <input type="hidden" name="mybank" value="false">
          </div>
        </div>
        <div class="col-auto">
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch"
              name="abilitato_cb" id="iban-abilitato" checked
              onchange="document.querySelector('[name=abilitato]').value = this.checked ? 'true' : 'false'">
            <label class="form-check-label" for="iban-abilitato">Abilitato</label>
            <input type="hidden" name="abilitato" value="true">
          </div>
        </div>
      </div>

      <div id="iban-save-error" class="alert alert-danger py-2 d-none mt-3"></div>
      <div class="d-flex gap-2 justify-content-end border-top pt-3">
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="ibanClearForm()">
          <i class="fas fa-times me-1"></i>Annulla
        </button>
        <button type="button" class="btn btn-primary btn-sm" id="btn-iban-save"
          onclick="ibanSave(this)">
          <i class="fas fa-save me-1"></i>Salva
        </button>
      </div>
    </form>
  </div>
</div>
{% endif %}

{# ── Debug (solo se app_debug attivo) ───────────────────────────────────── #}
{% if app_debug and iban_json is defined %}
  <hr>
  <div class="d-flex justify-content-between align-items-center">
    <div class="text-muted small">Backoffice: /domini/{{ entity.id_dominio|default('?') }}/contiAccredito</div>
    <div class="d-flex align-items-center gap-2">
      <span class="badge bg-warning text-dark">Debug</span>
      <button class="btn btn-sm btn-outline-secondary" type="button"
        data-bs-toggle="collapse" data-bs-target="#rawIban">Mostra JSON</button>
    </div>
  </div>
  <div class="collapse mt-2" id="rawIban">
    <pre class="mb-0">{{ iban_json }}</pre>
  </div>
{% endif %}

{% if not app_debug and iban_error is same as(null) and iban_list is defined and iban_list|length == 0 %}
  <hr>
  <div class="d-flex justify-content-between align-items-center">
    <div class="text-muted small">
      Diagnostica: <code>/domini/{{ entity.id_dominio|default('?') }}/contiAccredito</code>
      &mdash; Lista vuota, nessun errore PHP.
    </div>
    <button class="btn btn-sm btn-outline-secondary" type="button"
      data-bs-toggle="collapse" data-bs-target="#rawIban">Mostra risposta raw</button>
  </div>
  <div class="collapse mt-2" id="rawIban">
    <pre class="mb-0 small">{{ iban_json|default('(nessun JSON disponibile)') }}</pre>
  </div>
{% endif %}

<script>
(function () {
  'use strict';

  const csrf = document.querySelector('#form-iban input[name="csrf_token"]')?.value || '';

  window.ibanReload = async function (btn) {
    btn.disabled = true;
    const orig = btn.innerHTML;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>…';
    try {
      const res  = await fetch('/impostazioni/iban/list');
      const json = await res.json();
      if (!json.success) {
        impToast(json.message || 'Errore caricamento lista.', false);
        return;
      }
      const list = json.data || [];
      const area = document.getElementById('iban-list-area');
      if (!area) { window.location.reload(); return; }
      if (list.length === 0) {
        area.innerHTML = '<p class="text-muted small px-3 py-3 mb-0">Nessun conto di accredito configurato.</p>';
        return;
      }
      area.innerHTML = `
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0 small">
            <thead class="table-light">
              <tr>
                <th>IBAN</th><th>BIC</th><th>Intestatario</th><th>Descrizione</th>
                <th class="text-center">Postale</th><th class="text-center">MyBank</th>
                <th class="text-center">Stato</th>
                {% if is_superadmin %}<th class="text-end">Azioni</th>{% endif %}
              </tr>
            </thead>
            <tbody>${list.map(row => ibanRowHtml(row)).join('')}</tbody>
          </table>
        </div>`;
    } catch (e) {
      impToast('Errore di rete: ' + e.message, false);
    } finally {
      btn.disabled = false;
      btn.innerHTML = orig;
    }
  };

  function ibanRowHtml(row) {
    const badge = (v) => v
      ? '<span class="badge text-bg-success">Sì</span>'
      : '<span class="badge bg-light text-muted border">No</span>';
    const statoBadge = row.abilitato
      ? '<span class="badge text-bg-success">Abilitato</span>'
      : '<span class="badge text-bg-danger">Disabilitato</span>';
    const esc = (s) => String(s||'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]);
    const enc = encodeURIComponent(row.iban||'');
    {% if is_superadmin %}
    const actions = `
      <td class="text-end text-nowrap">
        <button class="btn btn-xs btn-outline-primary me-1" title="Modifica"
          onclick='ibanFillForm(${JSON.stringify(row)})'>
          <i class="fas fa-edit"></i>
        </button>
        <button class="btn btn-xs ${row.abilitato ? 'btn-outline-warning' : 'btn-outline-success'}"
          title="${row.abilitato ? 'Disabilita' : 'Abilita'}"
          id="btn-toggle-${enc}"
          onclick="ibanToggle('${esc(row.iban||'')}', this)">
          <i class="fas ${row.abilitato ? 'fa-ban' : 'fa-check'}"></i>
        </button>
      </td>`;
    {% else %}
    const actions = '';
    {% endif %}
    return `<tr id="iban-row-${enc}">
      <td class="font-monospace fw-semibold">${esc(row.iban||'—')}</td>
      <td class="font-monospace">${esc(row.bic||'—')}</td>
      <td>${esc(row.intestatario||'—')}</td>
      <td>${esc(row.descrizione||'—')}</td>
      <td class="text-center">${badge(row.postale)}</td>
      <td class="text-center">${badge(row.mybank)}</td>
      <td class="text-center" id="iban-stato-${enc}">${statoBadge}</td>
      ${actions}
    </tr>`;
  }

  window.ibanFillForm = function (data) {
    const ibanField = document.getElementById('iban-field');
    ibanField.value   = data.iban || '';
    ibanField.readOnly = true;
    ibanField.classList.add('bg-light');

    document.getElementById('iban-bic').value          = data.bic || '';
    document.getElementById('iban-intestatario').value = data.intestatario || '';
    document.getElementById('iban-descrizione').value  = data.descrizione || '';
    document.getElementById('iban-aut-stampa').value   = data.autStampaPosteItaliane || data.aut_stampa_poste_italiane || '';

    const postale   = document.getElementById('iban-postale');
    const mybank    = document.getElementById('iban-mybank');
    const abilitato = document.getElementById('iban-abilitato');
    postale.checked   = !!data.postale;
    mybank.checked    = !!data.mybank;
    abilitato.checked = data.abilitato !== false;

    document.querySelector('[name=postale]').value   = postale.checked   ? 'true' : 'false';
    document.querySelector('[name=mybank]').value    = mybank.checked    ? 'true' : 'false';
    document.querySelector('[name=abilitato]').value = abilitato.checked ? 'true' : 'false';

    document.getElementById('iban-form-title').innerHTML =
      '<i class="fas fa-edit me-2 text-primary"></i>Modifica IBAN ' + (data.iban || '');
    ibanField.scrollIntoView({ behavior: 'smooth', block: 'center' });
  };

  window.ibanClearForm = function () {
    const f = document.getElementById('form-iban');
    if (!f) return;
    f.reset();
    const ibanField = document.getElementById('iban-field');
    ibanField.readOnly = false;
    ibanField.classList.remove('bg-light');
    document.querySelector('[name=postale]').value   = 'false';
    document.querySelector('[name=mybank]').value    = 'false';
    document.querySelector('[name=abilitato]').value = 'true';
    document.getElementById('iban-abilitato').checked = true;
    document.getElementById('iban-form-title').innerHTML =
      '<i class="fas fa-plus me-2 text-success"></i>Aggiungi IBAN';
  };

  function ibanShowError(msg) {
    const el = document.getElementById('iban-save-error');
    if (!el) return;
    el.innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i>' + msg;
    el.classList.remove('d-none');
  }

  function ibanHideError() {
    const el = document.getElementById('iban-save-error');
    if (el) el.classList.add('d-none');
  }

  window.ibanSave = async function (btn) {
    ibanHideError();
    const form = document.getElementById('form-iban');
    if (!form || !form.reportValidity()) return;
    const ibanVal = document.getElementById('iban-field').value.toUpperCase().trim();
    if (!/^[A-Z]{2}[0-9]{2}[A-Z0-9]{1,30}$/.test(ibanVal)) {
      ibanShowError('IBAN non valido — 2 lettere + 2 cifre + 1–30 alfanumerici.');
      return;
    }
    const data = new URLSearchParams(new FormData(form)).toString();
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Salvataggio…';
    try {
      const res  = await fetch('/impostazioni/iban/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: data,
      });
      let json;
      const text = await res.text();
      try { json = JSON.parse(text); } catch (_) {
        ibanShowError('Risposta non valida dal server (HTTP ' + res.status + '): ' + text.slice(0, 200));
        return;
      }
      if (json.success) {
        impToast(json.message || 'Salvato.', true);
        ibanClearForm();
        window.location.reload();
      } else {
        ibanShowError(json.message || 'Errore sconosciuto (HTTP ' + res.status + ').');
      }
    } catch (e) {
      ibanShowError('Errore di rete: ' + e.message);
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-save me-1"></i>Salva';
    }
  };

  window.ibanToggle = async function (iban, btn) {
    btn.disabled = true;
    const orig = btn.innerHTML;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
    try {
      const res  = await fetch('/impostazioni/iban/toggle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({ iban, csrf_token: csrf }).toString(),
      });
      const json = await res.json();
      impToast(json.message || (json.success ? 'OK.' : 'Errore.'), !!json.success);
      if (json.success) {
        const statoEl = document.getElementById('iban-stato-' + encodeURIComponent(iban));
        if (statoEl) {
          statoEl.innerHTML = json.abilitato
            ? '<span class="badge text-bg-success">Abilitato</span>'
            : '<span class="badge text-bg-danger">Disabilitato</span>';
        }
        btn.className = 'btn btn-xs ' + (json.abilitato ? 'btn-outline-warning' : 'btn-outline-success');
        btn.innerHTML = '<i class="fas ' + (json.abilitato ? 'fa-ban' : 'fa-check') + '"></i>';
        btn.title = json.abilitato ? 'Disabilita' : 'Abilita';
      } else {
        btn.innerHTML = orig;
      }
    } catch (e) {
      impToast('Errore di rete toggle: ' + e.message, false);
      btn.innerHTML = orig;
    } finally {
      btn.disabled = false;
    }
  };
})();
</script>
