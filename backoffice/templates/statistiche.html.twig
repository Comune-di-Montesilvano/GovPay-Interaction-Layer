{% extends 'base.html.twig' %}

{% block title %}Statistiche - GovPay{% endblock %}

{% block content %}
  {# 1. Title Section #}
  <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-2 mb-4">
    <div>
      <h1 class="h4 mb-1"><i class="fas fa-chart-pie me-2 text-primary"></i>Statistiche dei Pagamenti</h1>
      <p class="text-muted mb-0">Analisi delle entrate complessive dell'Ente basata sul database locale arricchito (FDR, Biz Events, TEFA, Mappings)</p>
    </div>
  </div>

  {# 2. Error Alerts #}
  {% if errors is defined and errors %}
    <div class="alert alert-danger shadow-sm" role="alert">
      <ul class="mb-0">
        {% for e in errors %}<li>{{ e }}</li>{% endfor %}
      </ul>
    </div>
  {% endif %}

  {# 3. Filters Form #}
  {% set f = filters ?? {} %}
  <form method="get" action="/statistiche" class="card shadow-sm mb-4">
    <div class="card-header bg-light border-bottom py-2">
      <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
        <div class="d-flex align-items-center gap-2">
          <i class="fas fa-filter text-primary" aria-hidden="true"></i>
          <h2 class="h6 mb-0 fw-bold">Filtri di Analisi</h2>
          <span class="text-muted small d-none d-md-inline">| Seleziona periodo temporale e tipo di aggregazione</span>
        </div>
        <button type="submit" class="btn btn-primary btn-sm px-3 shadow-sm">
          <i class="fas fa-sync me-1" aria-hidden="true"></i> Aggiorna Dati
        </button>
      </div>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label fw-semibold text-muted small">Intervallo date</label>
          <div class="d-flex gap-1 align-items-center">
            <input type="text" id="statsDaVis" class="form-control bo-cursor-pointer" placeholder="Da" autocomplete="off">
            <span class="text-muted small">–</span>
            <input type="text" id="statsAVis" class="form-control bo-cursor-pointer" placeholder="A" autocomplete="off">
          </div>
          <div class="bo-datepicker-quick-selects mt-2">
            <button type="button" class="bo-datepicker-quick-btn" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('thisMonth')">Mese Corrente</button>
            <button type="button" class="bo-datepicker-quick-btn" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('lastMonth')">Mese Precedente</button>
            <button type="button" class="bo-datepicker-quick-btn" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('thisYear')">Anno Corrente</button>
            <button type="button" class="bo-datepicker-quick-btn" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('lastYear')">Anno Precedente</button>
            <button type="button" class="bo-datepicker-quick-btn btn-clear text-danger" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('clear')">Azzera</button>
          </div>
          <input type="hidden" id="dataDa" name="dataDa" value="{{ f.dataDa|default('') }}">
          <input type="hidden" id="dataA" name="dataA" value="{{ f.dataA|default('') }}">
        </div>
        <div class="col-md-3">
          <label for="raggruppamento" class="form-label fw-semibold text-muted small">Raggruppa per</label>
          <select id="raggruppamento" name="raggruppamento" class="form-select">
            {% for value,label in group_options %}
              <option value="{{ value }}" {% if f.raggruppamento|default('TIPO_PENDENZA') == value %}selected{% endif %}>{{ label }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="col-md-3">
          <label for="idDominio" class="form-label fw-semibold text-muted small">ID Dominio (Ente)</label>
          <input type="text" class="form-control" id="idDominio" name="idDominio" value="{{ f.idDominio|default('') }}" placeholder="(opzionale)">
        </div>
      </div>
    </div>
  </form>

  {# 4. Statistics Results #}
  {% set has_data = stats is defined and stats %}
  {% if has_data %}
    {# 4.1 Hero Metrics Cards Grid (Aligned with Dashboard style) #}
    <div class="row g-3 mb-4">
      {# Card 1: Importo complessivo #}
      <div class="col-md-6">
        <div class="card bo-hero-card shadow-sm" style="--accent-color: var(--ms-gold-500);">
          <div class="card-body">
            <div class="bo-hero-card-icon" style="--bg-light: var(--ms-gold-100); --color: var(--ms-gold-700);">
              <i class="fas fa-wallet" aria-hidden="true"></i>
            </div>
            <span class="bo-hero-card-label">Importo complessivo incassato</span>
            <div class="bo-hero-card-value">€ {{ totals.amount|default(0)|number_format(2, ',', '.') }}</div>
            <div class="bo-hero-card-meta">
              <i class="fas fa-calendar-check text-success" aria-hidden="true"></i>
              <span>Dati aggregati per il periodo selezionato</span>
            </div>
          </div>
        </div>
      </div>

      {# Card 2: Numero pagamenti #}
      <div class="col-md-6">
        <div class="card bo-hero-card shadow-sm" style="--accent-color: var(--bi-primary);">
          <div class="card-body">
            <div class="bo-hero-card-icon" style="--bg-light: var(--bi-primary-a8); --color: var(--bi-primary);">
              <i class="fas fa-receipt" aria-hidden="true"></i>
            </div>
            <span class="bo-hero-card-label">Numero transazioni totali</span>
            <div class="bo-hero-card-value">{{ totals.count|default(0)|number_format(0, ',', '.') }}</div>
            <div class="bo-hero-card-meta">
              <i class="fas fa-circle-check text-success" aria-hidden="true"></i>
              <span>Transazioni riconciliate con successo</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    {# 4.2 Main Distribution Charts #}
    <div class="row g-3 mb-4">
      <div class="col-lg-6">
        <div class="card shadow-sm h-100">
          <div class="card-header bg-light border-bottom py-2">
            <div class="d-flex align-items-center gap-2">
              <i class="fas fa-chart-bar text-primary" aria-hidden="true"></i>
              <h3 class="h6 mb-0 fw-bold">Distribuzione Importi (€)</h3>
            </div>
          </div>
          <div class="card-body">
            <div style="position: relative; height: 300px; width: 100%;">
              <canvas id="statsAmountChart"></canvas>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-6">
        <div class="card shadow-sm h-100">
          <div class="card-header bg-light border-bottom py-2">
            <div class="d-flex align-items-center gap-2">
              <i class="fas fa-chart-bar text-primary" aria-hidden="true"></i>
              <h3 class="h6 mb-0 fw-bold">Numero Pagamenti</h3>
            </div>
          </div>
          <div class="card-body">
            <div style="position: relative; height: 300px; width: 100%;">
              <canvas id="statsCountChart"></canvas>
            </div>
          </div>
        </div>
      </div>
    </div>

    {# 4.3 Pie Breakdown Charts #}
    <div class="row g-3 mb-4">
      <div class="col-lg-6">
        <div class="card shadow-sm h-100">
          <div class="card-header bg-light border-bottom py-2">
            <div class="d-flex align-items-center gap-2">
              <i class="fas fa-chart-pie text-primary" aria-hidden="true"></i>
              <h3 class="h6 mb-0 fw-bold">Ripartizione Quote Incassi (Percentuale)</h3>
            </div>
          </div>
          <div class="card-body d-flex flex-column align-items-center justify-content-center" style="height: 320px;">
            <div style="position: relative; height: 260px; width: 100%;">
              <canvas id="statsAmountPie"></canvas>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-6">
        <div class="card shadow-sm h-100">
          <div class="card-header bg-light border-bottom py-2">
            <div class="d-flex align-items-center gap-2">
              <i class="fas fa-chart-pie text-primary" aria-hidden="true"></i>
              <h3 class="h6 mb-0 fw-bold">Ripartizione Volume Transazioni (Percentuale)</h3>
            </div>
          </div>
          <div class="card-body d-flex flex-column align-items-center justify-content-center" style="height: 320px;">
            <div style="position: relative; height: 260px; width: 100%;">
              <canvas id="statsCountPie"></canvas>
            </div>
          </div>
        </div>
      </div>
    </div>

    {# 4.4 Data Detail Table #}
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-light border-bottom py-3 d-flex align-items-center justify-content-between gap-2 flex-wrap">
        <div class="d-flex align-items-center gap-2">
          <i class="fas fa-list text-primary" aria-hidden="true"></i>
          <h3 class="h6 mb-0 fw-bold">Tabella di Riepilogo Analitico</h3>
          <span class="text-muted small d-none d-md-inline">| Clicca sulle colonne per ordinare o sui grafici per filtrare</span>
        </div>
        <div id="statsTableFilter" class="d-none">
          <span class="badge bg-primary px-2 py-1 fs-7" id="statsFilterLabel"></span>
          <button type="button" class="btn btn-sm btn-link text-danger p-0 ms-1" id="statsFilterReset" title="Rimuovi filtro">
            <i class="fas fa-times-circle" aria-hidden="true"></i>
          </button>
        </div>
      </div>
      <div class="table-responsive">
        <table id="statsDetailTable" class="table table-striped align-middle mb-0" style="font-size: 0.9rem;">
          <thead>
            <tr>
              <th scope="col" class="stats-sort bo-cursor-pointer py-3" data-col="0" title="Ordina">Categoria / Raggruppamento <i class="fas fa-sort text-muted ms-1 small"></i></th>
              <th scope="col" class="stats-sort text-end bo-cursor-pointer py-3" data-col="1" title="Ordina">Numero pagamenti <i class="fas fa-sort text-muted ms-1 small"></i></th>
              <th scope="col" class="stats-sort text-end bo-cursor-pointer py-3" data-col="2" title="Ordina">Importo complessivo <i class="fas fa-sort text-muted ms-1 small"></i></th>
            </tr>
          </thead>
          <tbody>
            {% for row in stats %}
              <tr data-label="{{ row.label|e('html_attr') }}">
                <td class="fw-semibold">{{ row.label }}</td>
                <td class="text-end fw-semibold">{{ row.numero_pagamenti|number_format(0, ',', '.') }}</td>
                <td class="text-end fw-bold text-dark">€ {{ row.importo|number_format(2, ',', '.') }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  {% else %}
    <div class="alert alert-info shadow-sm d-flex align-items-center gap-2" role="alert">
      <i class="fas fa-info-circle fs-5" aria-hidden="true"></i>
      <span>Nessun dato disponibile nel database locale per i filtri selezionati. Modifica l'intervallo temporale o controlla che i demoni di sincronizzazione flussi siano attivi.</span>
    </div>
  {% endif %}

  {# 5. Chart.js Implementation scripts #}
  {% if chart_payload_json %}
    <script src="/assets/chartjs/chart.umd.min.js"></script>
    <script>
      (function(){
        const payload = {{ chart_payload_json|raw }};
        // Premium corporate dashboard color palette (harmonized with blue/purple/gold theme)
        const palette = ['#0066CC', '#4A2A6E', '#C9A13B', '#107c41', '#d83b01', '#8a2be2', '#008080', '#ff4500'];
        const colors = payload.labels.map((_, idx) => palette[idx % palette.length]);

        function getCanvasContext(canvasId) {
          const canvas = document.getElementById(canvasId);
          if(!canvas || typeof Chart === 'undefined') {
            return null;
          }
          return canvas.getContext('2d');
        }

        // ── Drill-down functionality ──────────────────────────────────────────
        function filterTable(label) {
          const table = document.getElementById('statsDetailTable');
          const filterBar = document.getElementById('statsTableFilter');
          const filterLabel = document.getElementById('statsFilterLabel');
          if (!table) return;
          table.querySelectorAll('tbody tr').forEach(tr => {
            tr.style.display = label === null || tr.dataset.label === label ? '' : 'none';
          });
          if (filterBar && filterLabel) {
            if (label) {
              filterLabel.textContent = "Filtro: " + label;
              filterBar.classList.remove('d-none');
            } else {
              filterBar.classList.add('d-none');
            }
          }
        }

        const resetBtn = document.getElementById('statsFilterReset');
        if (resetBtn) resetBtn.addEventListener('click', () => filterTable(null));

        const drillClick = (event, elements) => {
          if (!elements.length) return;
          const idx = elements[0].index;
          filterTable(payload.labels[idx]);
          document.getElementById('statsDetailTable')?.closest('.card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        };

        // ── Build Bar Charts ──────────────────────────────────────────────────
        function buildChart(canvasId, dataset, label){
          const ctx = getCanvasContext(canvasId);
          if(!ctx){ return; }
          new Chart(ctx, {
            type: 'bar',
            data: {
              labels: payload.labels,
              datasets: [{
                label,
                data: dataset,
                backgroundColor: colors,
                borderColor: '#ffffff',
                borderWidth: 1,
                borderRadius: 4
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              onClick: drillClick,
              plugins: {
                legend: { display: false },
                tooltip: {
                  mode: 'index',
                  intersect: false,
                  callbacks: {
                    label: (ctx) => {
                      const value = ctx.parsed.y;
                      if(canvasId === 'statsAmountChart') {
                        return ' ' + new Intl.NumberFormat('it-IT', { style: 'currency', currency: 'EUR' }).format(value);
                      }
                      return ' ' + new Intl.NumberFormat('it-IT').format(value) + ' pagamenti';
                    }
                  }
                }
              },
              scales: {
                x: {
                  grid: { display: false }
                },
                y: {
                  beginAtZero: true,
                  grid: { color: "#f1f5f9" },
                  ticks: {
                    callback: function(value){
                      if(canvasId === 'statsAmountChart') {
                        return new Intl.NumberFormat('it-IT', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(value);
                      }
                      return new Intl.NumberFormat('it-IT').format(value);
                    }
                  }
                }
              }
            }
          });
        }

        buildChart('statsAmountChart', payload.amounts, 'Importo complessivo (€)');
        buildChart('statsCountChart', payload.counts, 'Transazioni');

        // ── Build Pie/Doughnut Charts ─────────────────────────────────────────
        function buildPieChart(canvasId, dataset, isAmount){
          const ctx = getCanvasContext(canvasId);
          if(!ctx){ return; }
          new Chart(ctx, {
            type: 'doughnut',
            data: {
              labels: payload.labels,
              datasets: [{
                data: dataset,
                backgroundColor: colors,
                borderColor: '#ffffff',
                borderWidth: 2,
              }],
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              cutout: "60%",
              onClick: drillClick,
              plugins: {
                legend: { display: false },
                tooltip: {
                  callbacks: {
                    label: (ctx) => {
                      const value = ctx.parsed;
                      if (isAmount) {
                        return ' ' + new Intl.NumberFormat('it-IT', { style: 'currency', currency: 'EUR' }).format(value);
                      }
                      return ' ' + new Intl.NumberFormat('it-IT').format(value) + ' pagamenti';
                    },
                  },
                },
              },
            },
          });
        }

        buildPieChart('statsAmountPie', payload.amounts, true);
        buildPieChart('statsCountPie', payload.counts, false);

        // ── Sortable table ────────────────────────────────────────────────────
        const table = document.getElementById('statsDetailTable');
        if (table) {
          let sortCol = -1, sortAsc = true;
          table.querySelectorAll('th.stats-sort').forEach(th => {
            th.addEventListener('click', () => {
              const col = parseInt(th.dataset.col);
              sortAsc = sortCol === col ? !sortAsc : true;
              sortCol = col;
              const tbody = table.querySelector('tbody');
              const rows = Array.from(tbody.querySelectorAll('tr'));
              rows.sort((a, b) => {
                const rawA = a.cells[col]?.textContent ?? '';
                const rawB = b.cells[col]?.textContent ?? '';
                const norm = s => s.trim().replace(/[^0-9,.]/g, '').replace(/\./g, '').replace(',', '.');
                const av = norm(rawA), bv = norm(rawB);
                const an = parseFloat(av), bn = parseFloat(bv);
                const cmp = isNaN(an) || isNaN(bn) ? rawA.localeCompare(rawB, 'it') : an - bn;
                return sortAsc ? cmp : -cmp;
              });
              rows.forEach(r => tbody.appendChild(r));
              table.querySelectorAll('th.stats-sort i').forEach(i => { i.className = 'fas fa-sort text-muted ms-1 small'; });
              th.querySelector('i').className = `fas fa-sort-${sortAsc ? 'up' : 'down'} text-primary ms-1 small`;
            });
          });
        }
      })();
    </script>
  {% endif %}

{% block scripts %}
<script>
(function(){
  const daEl  = document.getElementById('statsDaVis');
  const aEl   = document.getElementById('statsAVis');
  const daHid = document.getElementById('dataDa');
  const aHid  = document.getElementById('dataA');
  if (daEl && aEl && daHid && aHid && typeof window.initBackofficeDatePicker !== 'undefined') {
    window.initBackofficeDatePicker(daEl, aEl, daHid, aHid);
  }
})();
</script>
{% endblock %}
{% endblock %}
