{% extends 'base.html.twig' %}

{% block title %}Rateizzazione pendenza{% endblock %}

{% block content %}
  <h1 class="it-title">Rateizzazione</h1>

  <form method="post" action="/pendenze/preview">
    <input type="hidden" name="original_params" value="{{ params|json_encode|e }}">
    {# Reincludi i principali campi originali come hidden per sicurezza (soggettoPagatore, idTipoPendenza, ecc.) #}
    {% for k,v in params %}
      {% if v is iterable and k == 'voci' %}
        {# Include anche le voci originali come hidden così il Preview le può mostrare se torni indietro #}
        {% for idx, vv in v %}
          <input type="hidden" name="voci[{{ idx }}][idVocePendenza]" value="{{ vv.idVocePendenza|e }}">
          <input type="hidden" name="voci[{{ idx }}][descrizione]" value="{{ vv.descrizione|e }}">
          <input type="hidden" name="voci[{{ idx }}][importo]" value="{{ vv.importo|e }}">
        {% endfor %}
      {% elseif v is iterable %}
        {% for sk, sv in v %}
          {% if sv is iterable %}
            <input type="hidden" name="{{ k|e }}[{{ sk|e }}]" value="{{ sv|json_encode|e }}">
          {% else %}
            <input type="hidden" name="{{ k|e }}[{{ sk|e }}]" value="{{ sv|e }}">
          {% endif %}
        {% endfor %}
      {% else %}
        <input type="hidden" name="{{ k|e }}" value="{{ v|e }}">
      {% endif %}
    {% endfor %}
    {% if errors is defined and errors %}
    <div class="alert alert-danger">
      <ul class="mb-0">
        {% for e in errors %}
          <li>{{ e }}</li>
        {% endfor %}
      </ul>
      {# Show only sanitized errors in UI. For full HTTP exchange, enable APP_DEBUG and check logs. #}
    </div>
  {% endif %}
    <div class="card mb-3">
      <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-2">
          <div class="d-flex gap-2 align-items-center">
            <label for="rateCount" class="mb-0 small text-muted">Numero rate</label>
            <input id="rateCount" name="rate" type="number" min="1" value="{{ parts|length }}" class="form-control form-control-sm" style="width:80px">
          </div>
          <div class="d-flex gap-2 align-items-center">
            <label for="validitaFrequency" class="mb-0 small text-muted">Intervallo validità</label>
            <select id="validitaFrequency" class="form-select form-select-sm" style="width:140px">
              <option value="1">Mensile</option>
              <option value="2">Bimestrale</option>
              <option value="6">Semestrale</option>
              <option value="12">Annuale</option>
            </select>
          </div>
        </div>

        <table class="table table-sm align-middle">
          <thead>
            <tr><th>#</th><th class="w-50">Importo</th><th>Validità</th><th>Scadenza <button id="copyDatesBtnHeader" type="button" class="btn btn-link btn-sm p-0 ms-2" title="Copia validità → scadenza">Copia</button><button id="clearDatesBtnHeader" type="button" class="btn btn-link btn-sm p-0 ms-2 text-danger" title="Azzera scadenze">Azzera</button></th></tr>
          </thead>
          <tbody id="rateRows">
            {% for p in parts %}
              <tr>
                <td>{{ p.indice }}</td>
                <td><input type="number" step="0.01" name="parts[{{ loop.index0 }}][importo]" value="{{ p.importo }}" class="form-control"></td>
                <td><input type="date" name="parts[{{ loop.index0 }}][dataValidita]" value="{{ p.dataValidita|default(p.data_validita|default('')) }}" class="form-control"></td>
                <td><input type="date" name="parts[{{ loop.index0 }}][dataScadenza]" value="{{ params.parts is defined ? (p.dataScadenza|default(p.data_scadenza|default(''))) : '' }}" class="form-control"></td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
          <div class="d-flex justify-content-end mt-2">
            <div id="partsSum" class="fw-semibold">Totale rate: €<span id="partsSumValue">0.00</span></div>
          </div>
      </div>
    </div>

    <div class="d-flex gap-2">
    <div class="me-auto d-flex gap-2 align-items-center">
    </div>
      <!-- Invia a preview/conferma includendo le "parts" modificate -->
      <button type="submit" class="btn btn-primary">Aggiungi rate</button>
      <!-- Annulla: costruisce e invia esplicitamente un form POST verso /pendenze/preview -->
      <button type="button" id="btnAnnulla" class="btn btn-outline-secondary">Annulla</button>
    </div>
  </form>

  <script>
  (function(){
    function splitAmount(total, n) {
      if (n <= 1) return [Math.round(total*100)/100];
      const base = Math.floor((total / n) * 100) / 100.0;
      const parts = [Math.round((total - base*(n-1))*100)/100];
      for (let i=1;i<n;i++) parts.push(base);
      return parts;
    }
    
    function lastDayOfMonth(y, m){ return new Date(y, m+1, 0).getDate(); }
    function detectAnchorMode(date){
      const y = date.getFullYear(); const m = date.getMonth(); const d = date.getDate();
      const last = lastDayOfMonth(y, m);
      const isFeb = (m === 1);
      if (d === 31) return 'EOM';
      if (d === 30) return 'D30';
      if (isFeb && (d === 28 || d === 29)) return 'EOM';
      if (d === last) return 'EOM';
      return 'NORMAL';
    }
    function addMonthsWithAnchor(baseDate, monthsToAdd){
      const mode = detectAnchorMode(baseDate);
      const bY = baseDate.getFullYear(); const bM = baseDate.getMonth(); const bD = baseDate.getDate();
      const tmp = new Date(bY, bM + monthsToAdd, 1);
      const y = tmp.getFullYear(); const m = tmp.getMonth();
      const last = lastDayOfMonth(y, m);
      let day;
      if (mode === 'EOM') day = last;
      else if (mode === 'D30') day = (m === 1 ? last : Math.min(30, last));
      else day = Math.min(bD, last);
      return new Date(y, m, day);
    }

    function formatDate(date) {
      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, '0');
      const d = String(date.getDate()).padStart(2, '0');
      return y + '-' + m + '-' + d;
    }

    const form = document.querySelector('form');
    form.addEventListener('submit', function(e){
      const total = {{ importo }};
      const totalCents = Math.round((parseFloat(total) || 0) * 100);
      let sumCents = 0;
      document.querySelectorAll('#rateRows input[name$="[importo]"]').forEach(function(inp){
        const v = parseFloat(inp.value.replace(',', '.'));
        if (!isNaN(v)) {
          sumCents += Math.round(v * 100);
        }
      });
      if (sumCents !== totalCents) {
        e.preventDefault();
        const diff = (sumCents - totalCents) / 100;
        const sum = (sumCents/100).toFixed(2);
        alert('La somma delle rate (' + sum + ') non corrisponde esattamente all\'importo totale (' + (totalCents/100).toFixed(2) + '). Differenza: ' + diff.toFixed(2) + ' €. Correggi gli importi prima di procedere.');
        return;
      }
      var submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Invio in corso\u2026'; }
    });

    function recalculateDates() {
      const tbody = document.getElementById('rateRows');
      const rows = Array.from(tbody.querySelectorAll('tr'));
      if (rows.length === 0) return;

      const freq = parseInt(document.getElementById('validitaFrequency').value || '1', 10);

      // Recalculate Validity Dates
      const firstValiditaInput = rows[0].querySelector('input[name$="[dataValidita]"]');
      if (firstValiditaInput && firstValiditaInput.value) {
        const firstDate = new Date(firstValiditaInput.value + 'T00:00:00');
        rows.forEach(function(tr, idx) {
          if (idx === 0) return; // skip first
          const monthsToAdd = freq * idx;
          const d = addMonthsWithAnchor(firstDate, monthsToAdd);
          const input = tr.querySelector('input[name$="[dataValidita]"]');
          if (input) input.value = formatDate(d);
        });
      }

      // Recalculate Deadline Dates
      const firstScadenzaInput = rows[0].querySelector('input[name$="[dataScadenza]"]');
      if (firstScadenzaInput && firstScadenzaInput.value) {
        const firstDate = new Date(firstScadenzaInput.value + 'T00:00:00');
        rows.forEach(function(tr, idx) {
          if (idx === 0) return; // skip first
          const monthsToAdd = freq * idx;
          const d = addMonthsWithAnchor(firstDate, monthsToAdd);
          const input = tr.querySelector('input[name$="[dataScadenza]"]');
          if (input) input.value = formatDate(d);
        });
      } else {
        rows.forEach(function(tr, idx) {
          if (idx === 0) return; // skip first
          const input = tr.querySelector('input[name$="[dataScadenza]"]');
          if (input) input.value = '';
        });
      }
    }

    function rebuildRows() {
      const count = Math.max(1, parseInt(document.getElementById('rateCount').value || '3', 10));
      const freq = parseInt(document.getElementById('validitaFrequency').value || '1', 10);
      const total = {{ importo }};
      
      const tbody = document.getElementById('rateRows');
      const oldRows = Array.from(tbody.querySelectorAll('tr'));
      const oldInputs = oldRows.map(function(tr) {
        return {
          importo: tr.querySelector('input[name$="[importo]"]').value,
          dataValidita: tr.querySelector('input[name$="[dataValidita]"]').value,
          dataScadenza: tr.querySelector('input[name$="[dataScadenza]"]').value
        };
      });

      tbody.innerHTML = '';
      
      // Determine the first validity date
      let firstValidita = '';
      if (oldInputs.length > 0 && oldInputs[0].dataValidita) {
        firstValidita = oldInputs[0].dataValidita;
      } else {
        const today = new Date();
        const firstDate = addMonthsWithAnchor(today, 1);
        firstValidita = formatDate(firstDate);
      }

      // Determine the first deadline date
      let firstScadenza = '';
      if (oldInputs.length > 0 && oldInputs[0].dataScadenza) {
        firstScadenza = oldInputs[0].dataScadenza;
      }

      const firstDateObj = new Date(firstValidita + 'T00:00:00');
      const firstScadDateObj = firstScadenza ? new Date(firstScadenza + 'T00:00:00') : null;

      // Build the new rows
      for (let idx = 0; idx < count; idx++) {
        let importo = '0.00';
        let dataValidita = '';
        let dataScadenza = '';

        // If we have an existing row for this index, preserve its values
        if (idx < oldInputs.length) {
          importo = oldInputs[idx].importo;
          dataValidita = oldInputs[idx].dataValidita;
          dataScadenza = oldInputs[idx].dataScadenza;
        } else {
          // Calculate dates for new row
          const monthsToAdd = freq * idx;
          const valDate = addMonthsWithAnchor(firstDateObj, monthsToAdd);
          dataValidita = formatDate(valDate);
          
          if (firstScadDateObj) {
            const scadDate = addMonthsWithAnchor(firstScadDateObj, monthsToAdd);
            dataScadenza = formatDate(scadDate);
          }
        }

        const tr = document.createElement('tr');
        tr.innerHTML = `<td>${idx + 1}</td>
          <td><input type="number" step="0.01" name="parts[${idx}][importo]" value="${importo}" class="form-control"></td>
          <td><input type="date" name="parts[${idx}][dataValidita]" value="${dataValidita}" class="form-control"></td>
          <td><input type="date" name="parts[${idx}][dataScadenza]" value="${dataScadenza}" class="form-control"></td>`;
        tbody.appendChild(tr);
      }

      // If the rate count changed, redistribute the total amount equally among the new inputs
      if (count !== oldInputs.length) {
        const parts = splitAmount(total, count);
        const inputs = Array.from(tbody.querySelectorAll('input[name$="[importo]"]'));
        for (let idx = 0; idx < count; idx++) {
          inputs[idx].value = parts[idx].toFixed(2);
        }
      }

      updatePartsSum();
    }

    document.getElementById('rateCount').addEventListener('input', rebuildRows);
    document.getElementById('validitaFrequency').addEventListener('change', function() {
      recalculateDates();
    });

    function redistributeFrom(index) {
      const total = {{ importo }};
      const tbody = document.getElementById('rateRows');
      const inputs = Array.from(tbody.querySelectorAll('input[name$="[importo]"]'));
      const N = inputs.length;
      if (index >= N - 1) return;

      let fixedSum = 0;
      for (let k = 0; k <= index; k++) {
        const val = parseFloat(inputs[k].value.replace(',', '.'));
        fixedSum += isNaN(val) ? 0 : val;
      }

      const remainingAmount = total - fixedSum;
      const remCount = N - (index + 1);

      if (remCount > 0) {
        const parts = splitAmount(remainingAmount, remCount);
        for (let k = 0; k < remCount; k++) {
          const targetIndex = index + 1 + k;
          inputs[targetIndex].value = parts[k].toFixed(2);
        }
      }
    }

    function updatePartsSum(){
      const inputs = Array.from(document.querySelectorAll('#rateRows input[name$="[importo]"]'));
      let sumCents = 0;
      inputs.forEach(function(i){
        const v = parseFloat((i.value||'').replace(',', '.'));
        if(!isNaN(v)) sumCents += Math.round(v*100);
      });
      const el = document.getElementById('partsSumValue');
      if (el) el.textContent = (sumCents/100).toFixed(2);
      try {
        const totalCents = Math.round(({{ importo }} || 0) * 100);
        const container = document.getElementById('partsSum');
        if (sumCents !== totalCents) {
          if (container) container.classList.add('text-danger');
        } else {
          if (container) container.classList.remove('text-danger');
        }
      } catch(e) { /* ignore */ }
    }

    const rateRowsEl = document.getElementById('rateRows');
    if (rateRowsEl) {
      rateRowsEl.addEventListener('input', function(e){
        if (!e.target) return;
        
        // If an amount is changed:
        if (e.target.name && e.target.name.indexOf('[importo]') !== -1) {
          const match = e.target.name.match(/parts\[(\d+)\]/);
          if (match) {
            const index = parseInt(match[1], 10);
            redistributeFrom(index);
          }
          updatePartsSum();
        }

        // If a validity date is changed and it is the first row:
        if (e.target.name && e.target.name.indexOf('[dataValidita]') !== -1) {
          const match = e.target.name.match(/parts\[(\d+)\]/);
          if (match && parseInt(match[1], 10) === 0) {
            recalculateDates();
          }
        }

        // If a deadline date is changed and it is the first row:
        if (e.target.name && e.target.name.indexOf('[dataScadenza]') !== -1) {
          const match = e.target.name.match(/parts\[(\d+)\]/);
          if (match && parseInt(match[1], 10) === 0) {
            recalculateDates();
          }
        }
      });
    }

    updatePartsSum();

    const copyBtn = document.getElementById('copyDatesBtnHeader');
    if (copyBtn) {
      copyBtn.addEventListener('click', function(){
        const tbody = document.getElementById('rateRows');
        const rows = Array.from(tbody.querySelectorAll('tr'));
        rows.forEach(function(tr, idx){
          const validita = tr.querySelector('input[name$="[dataValidita]"]');
          let scadenza = tr.querySelector('input[name$="[dataScadenza]"]');
          if (validita && scadenza) {
            scadenza.value = validita.value || '';
          }
        });
        recalculateDates();
      });
    }

    const clearBtn = document.getElementById('clearDatesBtnHeader');
    if (clearBtn) {
      clearBtn.addEventListener('click', function(){
        const tbody = document.getElementById('rateRows');
        const rows = Array.from(tbody.querySelectorAll('tr'));
        rows.forEach(function(tr, idx){
          let scadenza = tr.querySelector('input[name$="[dataScadenza]"]');
          if (scadenza) {
            scadenza.value = '';
          }
        });
      });
    }

    const annullaBtn = document.getElementById('btnAnnulla');
    if (annullaBtn) {
      annullaBtn.addEventListener('click', function(){
        const origForm = document.querySelector('form');
        if (!origForm) return;
        const f = document.createElement('form');
        f.method = 'post';
        f.action = '/pendenze/preview';
        Array.from(origForm.elements).forEach(function(el){
          if (!el.name) return;                        
          if (el.name.indexOf('parts[') === 0) return;
          if (el.name === 'rate') return;
          if (el.type === 'button' || el.type === 'submit' || el.disabled) return;
          if ((el.type === 'checkbox' || el.type === 'radio') && !el.checked) return;
          if (el.tagName === 'SELECT') {
            const val = el.value;
            const inp = document.createElement('input'); inp.type = 'hidden'; inp.name = el.name; inp.value = val; f.appendChild(inp);
            return;
          }
          if (el.type === 'file') return;
          const inp = document.createElement('input'); inp.type = 'hidden'; inp.name = el.name; inp.value = el.value; f.appendChild(inp);
        });
        document.body.appendChild(f);
        f.submit();
      });
    }
  })();
  </script>
{% endblock %}
