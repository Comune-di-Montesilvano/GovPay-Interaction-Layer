{% extends 'base.html.twig' %}

{% block title %}Pendenza {{ idPendenza }}{% endblock %}

{% block content %}
  {% set target_return = return_url|default('/pendenze/ricerca') %}
  {% set return_origin = return_origin|default('') %}
  {% set from_flow = (return_origin == 'flusso') %}
  {% if not from_flow and 'pagamenti/ricerca-flussi/dettaglio' in target_return %}
    {% set from_flow = true %}
  {% endif %}
  {% set is_bollo = pendenza is defined and pendenza and (
      (pendenza.tipoPendenza is defined and pendenza.tipoPendenza.idTipoPendenza is defined and pendenza.tipoPendenza.idTipoPendenza == 'BOLLOT')
      or (pendenza.voci is defined and pendenza.voci|length > 0 and pendenza.voci[0].tipoBollo is defined and pendenza.voci[0].tipoBollo is not null and pendenza.voci[0].tipoBollo != '')
  ) %}
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="h4 mb-0">Dettaglio pendenza <span class="text-muted">{{ idPendenza }}</span></h2>
    <div class="d-flex gap-2">
      {% if pendenza and pendenza.stato == 'NON_ESEGUITA' %}
        {% if not is_bollo %}
          <a class="btn btn-warning" href="/pendenze/modifica/{{ idPendenza }}?return={{ target_return|url_encode }}">Modifica</a>
        {% endif %}
        <form method="post" action="/pendenze/annulla/{{ idPendenza }}" style="display:inline;">
          <button type="submit" class="btn btn-danger" onclick="return confirm('Sei sicuro di voler annullare questa pendenza?')">Annulla</button>
        </form>
      {% elseif pendenza and pendenza.stato == 'ANNULLATA' %}
        <form method="post" action="/pendenze/riattiva/{{ idPendenza }}" style="display:inline;">
          <button type="submit" class="btn btn-success" onclick="return confirm('Sei sicuro di voler riattivare questa pendenza?')">Riattiva</button>
        </form>
      {% endif %}
      {% if is_bollo and pendenza.numeroAvviso is defined and pendenza.numeroAvviso and id_dominio %}
        {% set _burl = '/avviso-bollo?iuv=' ~ pendenza.numeroAvviso|url_encode
            ~ '&ente=' ~ id_dominio|url_encode
            ~ '&importo=' ~ (pendenza.importo * 100)|round
            ~ '&causale=' ~ pendenza.causale|default('')|url_encode
            ~ '&cf=' ~ (pendenza.soggettoPagatore is defined and pendenza.soggettoPagatore.identificativo is defined ? pendenza.soggettoPagatore.identificativo : '')|url_encode
            ~ '&scadenza=' ~ pendenza.dataScadenza|default('')|url_encode %}
        {% for v in (pendenza.voci is defined ? pendenza.voci : []) %}
          {% set _burl = _burl ~ '&desc[]=' ~ v.descrizione|default('')|url_encode %}
        {% endfor %}
        <a class="btn btn-outline-info btn-sm" href="{{ _burl }}" target="_blank" rel="noopener">
          <i class="fas fa-print me-1" aria-hidden="true"></i> Bollettino
        </a>
      {% endif %}
      {% if came_from_insert %}
        <a class="btn btn-primary" href="/pendenze/inserimento">Inserisci nuova pendenza</a>
      {% else %}
        <a class="btn btn-outline-secondary" href="{{ target_return }}">&laquo; {{ from_flow ? 'Torna al dettaglio flusso' : 'Torna alla ricerca' }}</a>
      {% endif %}
    </div>

    {# voci spostate dinamicamente per ordine visuale (vedi sotto) #}
  </div>

  {% if error %}
    <div class="alert alert-danger">{{ error }}</div>
  {% endif %}

  {% if pendenza %}
    {% set r = pendenza %}

    {# Rilevamento marca da bollo: sopprime avviso PDF e rate (GovPay non genera avvisi per MBT) #}
    {% set is_bollo = (r.tipoPendenza is defined and r.tipoPendenza.idTipoPendenza is defined and r.tipoPendenza.idTipoPendenza == 'BOLLOT')
        or (r.voci is defined and r.voci|length > 0 and r.voci[0].tipoBollo is defined and r.voci[0].tipoBollo is not null and r.voci[0].tipoBollo != '') %}

    {% if is_bollo %}
      {% set _voci_list = r.voci is defined ? r.voci : [] %}
      <div class="alert alert-info d-flex align-items-start gap-2 mt-3 mb-2">
        <i class="fas fa-stamp fa-lg flex-shrink-0 mt-1" aria-hidden="true"></i>
        <div>
          <strong>Marca da Bollo Telematica</strong> — {{ _voci_list|length }} voce/i da € 16,00 ciascuna.
          {% set _prov = (_voci_list|length > 0 and _voci_list[0].provinciaResidenza is defined) ? _voci_list[0].provinciaResidenza : '' %}
          {% if _prov %}Provincia di residenza: <strong>{{ _prov }}</strong>.{% endif %}
          Avviso PDF e rateizzazione non applicabili.
        </div>
      </div>
    {% endif %}

    {# Raccogli il piano di rateizzazione e normalizza a lista 'rate_info' #}
    {# Normalizziamo la sorgente dei dati delle rate: preferiamo documento.rata, altrimenti proprieta.rate #}
    {% set possible = (r.documento is defined and r.documento.rata is defined) ? r.documento.rata : ((r.proprieta is defined and r.proprieta.rate is defined) ? r.proprieta.rate : []) %}
    {% if possible is iterable %}
      {% set rate_info = possible %}
    {% elseif possible is defined and possible is not empty %}
      {% set rate_info = [possible] %}
    {% else %}
      {% set rate_info = [] %}
    {% endif %}

    {# Calcola displayed_rates se necessario per rateizzazione o bottoni #}
    {% if rate_info|length > 0 or (related_pendenze is defined and related_pendenze|length > 0) %}
      {# Costruisci la lista visibile delle rate aggregando piano + pendenze correlate #}
      {% set selected_rate = (current_rate is defined and current_rate) ? current_rate : null %}
      {% if selected_rate is null %}
        {% if r.documento is defined and r.documento.rata is defined and not (r.documento.rata is iterable) %}
          {% set selected_rate = r.documento.rata %}
        {% endif %}
      {% endif %}

      {% set displayed_rates = [] %}
      {# Aggiungi il piano esplicito (se presente) normalizzando l'indice #}
      {% for rt in rate_info %}
        {# Calcola indice in modo robusto:
           - se rt è oggetto e contiene 'indice' usalo
           - altrimenti se rt è oggetto e contiene 'rata' usalo
           - se rt è scalare (es. "1") usalo come indice
           - fallback su loop.index per conservare ordine se non troviamo altro #}
        {% if rt is iterable %}
          {% if rt.indice is defined %}
            {% set idx = rt.indice %}
          {% elseif rt.rata is defined %}
            {% set idx = rt.rata %}
          {% else %}
            {% set idx = loop.index %}
          {% endif %}
          {% set normalized = rt|merge({'indice': idx}) %}
        {% else %}
          {% set idx = (rt is not null and rt != '') ? (rt|default(0) + 0) : loop.index %}
          {% set normalized = {'indice': idx} %}
        {% endif %}
        {# Riempiamo campi mancanti con valori della pendenza principale quando sensato #}
        {% if (normalized.importo is not defined or not normalized.importo) and r.importo is defined %}
          {% set normalized = normalized|merge({'importo': r.importo}) %}
        {% endif %}
        {% if (normalized.dataValidita is not defined or not normalized.dataValidita) and r.dataValidita is defined %}
          {% set normalized = normalized|merge({'dataValidita': r.dataValidita}) %}
        {% endif %}
        {% if (normalized.dataScadenza is not defined or not normalized.dataScadenza) and r.dataScadenza is defined %}
          {% set normalized = normalized|merge({'dataScadenza': r.dataScadenza}) %}
        {% endif %}
        {% if (normalized.stato is not defined or not normalized.stato) and r.stato is defined %}
          {% set normalized = normalized|merge({'stato': r.stato}) %}
        {% endif %}
        {% if (normalized.numeroAvviso is not defined or not normalized.numeroAvviso) and r.numeroAvviso is defined %}
          {% set normalized = normalized|merge({'numeroAvviso': r.numeroAvviso}) %}
        {% endif %}
        {# Normalizza id pendenza (diverse convenzioni: idPendenza / id_pendenza) #}
        {% if (normalized.idPendenza is not defined or not normalized.idPendenza) %}
          {% if rt.idPendenza is defined and rt.idPendenza %}
            {% set normalized = normalized|merge({'idPendenza': rt.idPendenza}) %}
          {% elseif rt.id_pendenza is defined and rt.id_pendenza %}
            {% set normalized = normalized|merge({'idPendenza': rt.id_pendenza}) %}
          {% elseif r.idPendenza is defined and r.idPendenza %}
            {% set normalized = normalized|merge({'idPendenza': r.idPendenza}) %}
          {% elseif r.id_pendenza is defined and r.id_pendenza %}
            {% set normalized = normalized|merge({'idPendenza': r.id_pendenza}) %}
          {% endif %}
        {% endif %}
        {% if (normalized.iuv is not defined or not normalized.iuv) and (r.identificativoUnivocoVersamento is defined or r.iuv is defined) %}
          {% set iuvFallback = r.identificativoUnivocoVersamento is defined ? r.identificativoUnivocoVersamento : (r.iuv|default('')) %}
          {% if iuvFallback %}{% set normalized = normalized|merge({'iuv': iuvFallback}) %}{% endif %}
        {% endif %}
        {% if (normalized.ccp is not defined or not normalized.ccp) and (r.codiceContestoPagamento is defined or r.ccp is defined) %}
          {% set ccpFallback = r.codiceContestoPagamento is defined ? r.codiceContestoPagamento : (r.ccp|default('')) %}
          {% if ccpFallback %}{% set normalized = normalized|merge({'ccp': ccpFallback}) %}{% endif %}
        {% endif %}
        {% set displayed_rates = displayed_rates|merge([normalized]) %}
      {% endfor %}

      {# Integra rate estratte dalle pendenze correlate (se disponibili) #}
      {% if related_pendenze is defined and related_pendenze|length > 0 %}
        {% for rp in related_pendenze %}
          {% set rp_idx = null %}
          {# Considera la pendenza correlata parte del piano solo se ha valore 'rata' esplicito (non vuoto) #}
          {% if rp.documento is defined and rp.documento.rata is defined %}
            {% if rp.documento.rata is iterable %}
              {% if rp.documento.rata|length > 0 and rp.documento.rata[0] is defined and rp.documento.rata[0].indice is defined %}
                {% set rp_idx = rp.documento.rata[0].indice %}
              {% endif %}
            {% else %}
              {% if rp.documento.rata is not null and rp.documento.rata != '' %}
                {% set rp_idx = rp.documento.rata %}
              {% endif %}
            {% endif %}
          {% endif %}
          {% if rp_idx is null and rp.proprieta is defined and rp.proprieta.rate is defined %}
            {% if rp.proprieta.rate is iterable and rp.proprieta.rate|length > 0 and rp.proprieta.rate[0] is defined and rp.proprieta.rate[0].indice is defined %}
              {% set rp_idx = rp.proprieta.rate[0].indice %}
            {% elseif rp.proprieta.rate.indice is defined and rp.proprieta.rate is not null and rp.proprieta.rate != '' %}
              {% set rp_idx = rp.proprieta.rate.indice %}
            {% endif %}
          {% endif %}
          {% if rp_idx is not null %}
            {% set found = false %}
            {% for dr in displayed_rates %}
              {% if not found and dr.indice is defined and (dr.indice|default(0) + 0) == (rp_idx|default(0) + 0) %}
                {% set found = true %}
              {% endif %}
            {% endfor %}
            {% if not found %}
              {% set entry = {'indice': rp_idx} %}
              {% if rp.importo is defined %} {% set entry = entry|merge({'importo': rp.importo}) %} {% endif %}
              {% if rp.dataValidita is defined %} {% set entry = entry|merge({'dataValidita': rp.dataValidita}) %} {% endif %}
              {% if rp.dataScadenza is defined %} {% set entry = entry|merge({'dataScadenza': rp.dataScadenza}) %} {% endif %}
              {% if rp.stato is defined %} {% set entry = entry|merge({'stato': rp.stato}) %} {% endif %}
              {% if rp.numeroAvviso is defined %} {% set entry = entry|merge({'numeroAvviso': rp.numeroAvviso}) %} {% endif %}
              {% if rp.identificativoUnivocoVersamento is defined %} {% set entry = entry|merge({'iuv': rp.identificativoUnivocoVersamento}) %} {% endif %}
              {% if rp.codiceContestoPagamento is defined %} {% set entry = entry|merge({'ccp': rp.codiceContestoPagamento}) %} {% endif %}
              {# Aggiungi idPendenza dalle pendenze correlate se presente (idPendenza o id_pendenza) #}
              {% if rp.idPendenza is defined and rp.idPendenza %}
                {% set entry = entry|merge({'idPendenza': rp.idPendenza}) %}
              {% elseif rp.id_pendenza is defined and rp.id_pendenza %}
                {% set entry = entry|merge({'idPendenza': rp.id_pendenza}) %}
              {% endif %}
              {% set displayed_rates = displayed_rates|merge([entry]) %}
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endif %}

      {# Determina l'indice massimo per ordinare la stampa (fallback: lunghezza lista) #}
      {% set maxIndex = 0 %}
      {% for dr in displayed_rates %}
        {% set cand = (dr.indice|default(0) + 0) %}
        {% if cand > maxIndex %}{% set maxIndex = cand %}{% endif %}
      {% endfor %}
      {% if maxIndex == 0 %}{% set maxIndex = displayed_rates|length %}{% endif %}

    {% else %}
      {% set displayed_rates = [] %}
      {% set selected_rate = null %}
      {% set maxIndex = 0 %}
    {% endif %}

    <div class="card mb-3">
      <div class="card-body">
        {# Prepara dominio e identificativi per i bottoni in alto #}
        {% set idDom = id_dominio|default(pendenza.idDominio|default('')) %}
        {# Link ricevuta in alto: cerca il primo RPP con esito OK, poi trova riscossione corrispondente per iur #}
        {% set topRppPath = '' %}
        {% if r.rpp is defined and r.rpp is iterable and r.voci is defined and r.voci is iterable %}
          {% for rr in r.rpp %}
            {% if topRppPath == '' %}
              {% set rt = rr.rt is defined ? rr.rt : null %}
              {# Esito OK: struttura piatta (outcome) o annidato (codiceEsitoPagamento/esitoSingoloPagamento) #}
              {% set rrOk = false %}
              {% if rt and rt.outcome is defined and rt.outcome == 'OK' %}
                {% set rrOk = true %}
              {% elseif rt and rt.datiPagamento is defined %}
                {% if rt.datiPagamento.codiceEsitoPagamento is defined and rt.datiPagamento.codiceEsitoPagamento == '0' %}
                  {% set rrOk = true %}
                {% elseif rt.datiPagamento.datiSingoloPagamento is defined and rt.datiPagamento.datiSingoloPagamento|length > 0 and rt.datiPagamento.datiSingoloPagamento[0].esitoSingoloPagamento is defined and rt.datiPagamento.datiSingoloPagamento[0].esitoSingoloPagamento == 'ESEGUITO' %}
                  {% set rrOk = true %}
                {% endif %}
              {% endif %}
              {% if rrOk %}
                {% set matchId = (rt and rt.receiptId is defined and rt.receiptId) ? rt.receiptId : (rr.rpt is defined and rr.rpt.datiVersamento is defined and rr.rpt.datiVersamento.codiceContestoPagamento is defined ? rr.rpt.datiVersamento.codiceContestoPagamento : '') %}
                {% if matchId %}
                  {% for voce in r.voci %}
                    {% if voce.riscossioni is defined and voce.riscossioni is iterable %}
                      {% for risc in voce.riscossioni %}
                        {% if topRppPath == '' and risc.rpp is defined and risc.rpp and risc.iur is defined and risc.iur == matchId %}
                          {% set topRppPath = risc.rpp %}
                        {% endif %}
                      {% endfor %}
                    {% endif %}
                  {% endfor %}
                {% endif %}
              {% endif %}
            {% endif %}
          {% endfor %}
        {% endif %}

        {# Cerca allegato XML bollo MBT (tipo riscossione 'MBT') #}
        {% set bolloXmlTesto = '' %}
        {% set bolloXmlIuv   = '' %}
        {% if r.voci is defined and r.voci is iterable %}
          {% for voce in r.voci %}
            {% if voce.riscossioni is defined and voce.riscossioni is iterable %}
              {% for risc in voce.riscossioni %}
                {% if bolloXmlTesto == ''
                    and risc.tipo is defined and risc.tipo == 'MBT'
                    and risc.allegato is defined
                    and risc.allegato.testo is defined
                    and risc.allegato.testo %}
                  {% set bolloXmlTesto = risc.allegato.testo %}
                  {% set bolloXmlIuv   = risc.iuv|default('bollo') %}
                {% endif %}
              {% endfor %}
            {% endif %}
          {% endfor %}
        {% endif %}

        <div class="d-flex flex-wrap align-items-center gap-3">
          <div>
            <div class="text-muted small">Stato</div>
            {% include 'partials/state_badge.html.twig' with { state: r.stato|default(''), pill: false } %}
          </div>
          <div>
            <div class="text-muted small">Importo</div>
            <div class="h5 mb-0">{{ r.importo is defined ? (r.importo|number_format(2, ',', '.')) ~ ' €' : '—' }}</div>
          </div>
          <div>
            <div class="text-muted small">Data avviso</div>
            {% set da = r.dataCaricamento|default('') %}
            <div class="mb-0">{{ da ? (da|date('d/m/Y')) : '—' }}</div>
          </div>
          <div>
            <div class="text-muted small">Scadenza</div>
            {% set ds = r.dataScadenza|default('') %}
            <div class="mb-0">{{ ds ? (ds|date('d/m/Y')) : '—' }}</div>
          </div>
          <div>
            <div class="text-muted small">Validità</div>
            {% set dv = r.dataValidita|default('') %}
            <div class="mb-0">{{ dv ? (dv|date('d/m/Y')) : '—' }}</div>
          </div>
          <div>
            <div class="text-muted small">Pagamento</div>
            {% set dp = r.dataPagamento|default('') %}
            <div class="mb-0">{{ dp ? (dp|date('d/m/Y')) : '—' }}</div>
          </div>
          {# Bottoni in alto, accanto alla zona pagamento #}
          {% if idDom and (r.numeroAvviso or topRppPath or bolloXmlTesto or (displayed_rates|length > 0)) %}
          <div class="d-flex align-items-center gap-2 ms-auto">
            {% if idDom and r.numeroAvviso and not is_bollo %}
              <a class="btn btn-primary btn-sm" href="/avvisi/{{ idDom|url_encode }}/{{ r.numeroAvviso|url_encode }}" target="_blank" rel="noopener" title="Scarica avviso (PDF)">
                <i class="fas fa-file-pdf me-1"></i> Avviso
              </a>
            {% endif %}
            {% if topRppPath %}
              <a class="btn btn-outline-success btn-sm" href="/pendenze{{ topRppPath }}/rt" target="_blank" rel="noopener" title="Scarica ricevuta">
                <i class="fas fa-file-invoice-dollar me-1"></i> Ricevuta
              </a>
            {% endif %}
            {% if bolloXmlTesto %}
              <button type="button"
                class="btn btn-outline-secondary btn-sm download-voce-bollo-xml-btn"
                id="download-bollo-xml-btn"
                data-testo="{{ bolloXmlTesto }}"
                data-iuv="{{ bolloXmlIuv }}"
                title="Scarica XML Marca da Bollo Telematica">
                <i class="fas fa-stamp me-1"></i> Marca da Bollo
              </button>
              <script>
              (function(){
                document.addEventListener('click', function(e) {
                  const btn = e.target.closest('.download-voce-bollo-xml-btn');
                  if (!btn) return;
                  const b64      = btn.dataset.testo;
                  const iuv      = btn.dataset.iuv || 'bollo';
                  const filename = 'marca-da-bollo-' + iuv + '.xml';
                  try {
                    const binary = atob(b64);
                    const bytes  = new Uint8Array(binary.length);
                    for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
                    const blob = new Blob([bytes], { type: 'application/xml' });
                    const url  = URL.createObjectURL(blob);
                    const a    = document.createElement('a');
                    a.href = url; a.download = filename;
                    document.body.appendChild(a); a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                  } catch(err) {
                    alert('Errore download marca da bollo: ' + err.message);
                  }
                });
              })();
              </script>
            {% endif %}
            {# Bottone Rate: solo se abbiamo rate con numeriAvviso #}
            {% set numeri = [] %}
            {% if displayed_rates is defined %}
              {% for dr in displayed_rates %}
                {% if dr.numeroAvviso is defined and dr.numeroAvviso %}
                  {% set numeri = numeri|merge([dr.numeroAvviso]) %}
                {% endif %}
              {% endfor %}
            {% endif %}
            {% if numeri|length > 0 and not is_bollo %}
              <button id="stampa-rate-btn" class="btn btn-success btn-sm" title="Scarica l'avviso multirata (PDF)">
                <i class="fas fa-clipboard-list me-1"></i> Rate
              </button>
              <script>
                (function(){
                  const btn = document.getElementById('stampa-rate-btn');
                  const numeri = {{ numeri|json_encode|raw }};
                  const docId = '{{ r.documento.identificativo|e('js') }}';
                  btn.addEventListener('click', async function(e){
                    e.preventDefault();
                    if (!numeri || numeri.length === 0) {
                      alert('Nessun avviso disponibile per il download');
                      return;
                    }
                    // Verifica che docId sia valorizzato
                    if (!docId || docId === '') {
                      alert('Identificativo documento mancante; impossibile procedere con la stampa.');
                      console.error('stampa: docId mancante', { docId, numeri });
                      return;
                    }
                    // Log per capire eventuali 404
                    console.debug('Chiamata stampa avvisi', { url: '/documenti/' + docId + '/avvisi', numeri });
                    btn.disabled = true;
                    const origHtml = btn.innerHTML;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Preparazione...';
                    try {
                      const resp = await fetch('/documenti/' + encodeURIComponent(docId) + '/avvisi', {
                        method: 'POST',
                        headers: {'Accept':'application/pdf','Content-Type':'application/json'},
                        body: JSON.stringify({ numeriAvviso: numeri })
                      });
                      if (!resp.ok) throw new Error('Errore server: ' + resp.status);
                      const blob = await resp.blob();
                      const url = URL.createObjectURL(blob);
                      window.open(url, '_blank');
                    } catch (err) {
                      alert('Errore durante la chiamata API: ' + err.message);
                      console.error(err);
                    } finally {
                      btn.disabled = false;
                      btn.innerHTML = origHtml;
                    }
                  });
                })();
              </script>
            {% endif %}
          </div>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-md-6">
        <div class="card h-100">
          {% set sogg = r.soggettoPagatore|default({}) %}
          {% set tipo = sogg.tipo|default('') %}
          {% if tipo != 'F' and tipo != 'G' %}
            {% set tipo = sogg.denominazione ? 'G' : 'F' %}
          {% endif %}
          <div class="card-header d-flex align-items-center gap-2">
            <span class="text-secondary" title="{{ tipo == 'F' ? 'Persona fisica' : 'Persona giuridica' }}">
              <i class="fas {{ tipo == 'F' ? 'fa-user' : 'fa-building' }}"></i>
            </span>
            <span>Soggetto pagatore</span>
          </div>
          <div class="card-body">
            <div>
              <span class="text-muted">Identificativo:</span> <strong>{{ sogg.identificativo|default('—') }}</strong>
            </div>
            <div><span class="text-muted">Anagrafica:</span> {{ sogg.anagrafica|default(sogg.denominazione|default('—')) }}</div>
            {% if sogg.email %}<div><span class="text-muted">Email:</span> {{ sogg.email }}</div>{% endif %}
            {% set parti = [] %}
            {% if sogg.indirizzo %}{% set parti = parti|merge([sogg.indirizzo]) %}{% endif %}
            {% if sogg.civico %}{% set parti = parti|merge([sogg.civico]) %}{% endif %}
            {% if sogg.localita %}{% set parti = parti|merge([sogg.localita]) %}{% endif %}
            {% if sogg.provincia %}{% set parti = parti|merge([sogg.provincia]) %}{% endif %}
            {% if sogg.nazione %}{% set parti = parti|merge([sogg.nazione]) %}{% endif %}
            {% if parti|length > 0 %}<div><span class="text-muted">Indirizzo:</span> {{ parti|join(', ') }}</div>{% endif %}
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-header">Dettagli pendenza</div>
          <div class="card-body">
            <div><span class="text-muted">Causale:</span> {{ r.causale|default(r.nome|default('—')) }}</div>
            {% if r.numeroAvviso %}
              <div><span class="text-muted">Numero avviso:</span> <span class="font-monospace">{{ r.numeroAvviso }}</span></div>
            {% endif %}
            {% set iuv_display = r.iuv|default(r.identificativoUnivocoVersamento|default('')) %}
            {% if iuv_display %}
              <div><span class="text-muted">IUV:</span> <span class="font-monospace">{{ iuv_display }}</span></div>
            {% endif %}
            {% set anno_ref = r.annoRiferimento is defined ? r.annoRiferimento : (r.anno_riferimento|default('')) %}
            {% if anno_ref %}
              <div><span class="text-muted">Anno di riferimento:</span> {{ anno_ref }}</div>
            {% endif %}
            {% set tipo_key = r.tipoPendenza.idTipoPendenza|default('') %}
            {# tipologie è un array di oggetti {id_entrata, descrizione, ...} -> cerchiamo la corrispondenza #}
            {% set tipo_descr = null %}
            {% if tipologie is iterable %}
              {% for t in tipologie %}
                {% if t.id_entrata is defined and t.id_entrata == tipo_key %}
                  {% set tipo_descr = t.descrizione|default(tipo_descr) %}
                {% endif %}
              {% endfor %}
            {% endif %}
            <div><span class="text-muted">Tipo:</span> {{ tipo_descr|default(r.tipoPendenza.descrizione | default(tipo_key | default('—'))) }}</div>
            {% if r.idPagamento %}<div><span class="text-muted">ID Pagamento:</span> {{ r.idPagamento }}</div>{% endif %}

          </div>
        </div>
      </div>
    </div>

    {# Mostra la sezione Rateizzazione: se abbiamo il piano lo includiamo qui.
      L'evidenziazione è deterministica: usiamo prima la variabile controller-provided
      `current_rate` se presente, altrimenti solo il valore scalare `documento.rata`.
      Non applichiamo inferenze o fallback automatici lato template. #}
      {% if numeri|length > 0 %}

        <div class="card mt-3">
          <div class="card-header d-flex align-items-center justify-content-between">
            <h3 class="h6 mb-0">Rateizzazione <span class="badge bg-secondary ms-2">{{ displayed_rates|length }} rate</span> - Doc. {{ r.documento.identificativo|default('—') }}{% if selected_rate %} - Rata #{{ selected_rate }}{% endif %}</h3>
          </div>
          <div class="card-body">

            <div class="table-responsive">
              <table class="table table-sm align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>#</th>
                    <th class="text-nowrap">Importo</th>
                    <th>Validità</th>
                    <th>Scadenza</th>
                    <th>Stato</th>
                    <th>Descrizione</th>
                    <th>ID pendenza</th>
                    <th>Azioni</th>
                  </tr>
                </thead>
                <tbody>
                  {% for i in 1..maxIndex %}
                    {# Cerca un'eventuale voce normalizzata per questo indice #}
                    {% set rt = null %}
                    {% for dr in displayed_rates %}
                      {% if rt is null and (dr.indice|default(0) + 0) == i %}
                        {% set rt = dr %}
                      {% endif %}
                    {% endfor %}
                    <tr class="{{ (selected_rate is defined and selected_rate is not null and (i == (selected_rate|default(0) + 0))) ? 'table-info' : '' }}">
                      <td>{{ i }}</td>
                      <td class="text-end text-nowrap">{% if rt is not null and rt.importo is defined %}{{ rt.importo|number_format(2, ',', '.') }} €{% else %}—{% endif %}</td>
                      <td>{% if rt is not null and rt.dataValidita is defined and rt.dataValidita %}{{ rt.dataValidita|date('d/m/Y') }}{% else %}—{% endif %}</td>
                      <td>{% if rt is not null and rt.dataScadenza is defined and rt.dataScadenza %}{{ rt.dataScadenza|date('d/m/Y') }}{% else %}—{% endif %}</td>
                      {# Stato: mostra badge colorato usando pendenza_states quando possibile #}
                      {% set st_rt = (rt is not null and rt.stato is defined) ? rt.stato : '' %}
                      {% if st_rt %}
                        <td>{% include 'partials/state_badge.html.twig' with { state: st_rt, pill: true, small: false } %}</td>
                      {% else %}
                        <td>—</td>
                      {% endif %}
                      <td>{% if rt is not null and rt.descrizione is defined and rt.descrizione %}{{ rt.descrizione }}{% elseif rt is not null and rt.causale is defined and rt.causale %}{{ rt.causale }}{% else %}—{% endif %}</td>
                      <td>{{ rt is not null and rt.idPendenza is defined ? rt.idPendenza : (rt is not null and rt.id_pendenza is defined ? rt.id_pendenza : '—') }}</td>
                      <td class="text-nowrap">
                        {# Link al dettaglio della pendenza (occhio) #}
                        {% set rowId = rt is not null and rt.idPendenza is defined and rt.idPendenza ? rt.idPendenza : (rt is not null and rt.id_pendenza is defined and rt.id_pendenza ? rt.id_pendenza : '') %}
                        {% if rowId %}
                          <a class="btn btn-outline-secondary btn-sm px-2 py-0" href="/pendenze/dettaglio/{{ rowId|url_encode }}" title="Apri dettaglio pendenza {{ rowId }}" aria-label="Apri dettaglio pendenza {{ rowId }}">
                            <i class="fas fa-eye" aria-hidden="true"></i>
                          </a>
                        {% else %}
                          <span class="text-muted">—</span>
                        {% endif %}
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      {% elseif r.proprieta is defined and r.proprieta.numeroRate is defined %}
        <div class="card mt-3">
          <div class="card-header">
            <h3 class="h6 mb-0">Rateizzazione</h3>
          </div>
          <div class="card-body">
            <div class="text-muted small">Numero di rate</div>
            <div class="h5 mb-0">{{ r.proprieta.numeroRate }}</div>
          </div>
        </div>
      {% elseif r.documento is defined and r.documento.rata is defined and not (r.documento.rata is iterable) and r.documento.rata != 0 %}
        <div class="card mt-3">
          <div class="card-header">
            <h3 class="h6 mb-0">Rateizzazione</h3>
          </div>
          <div class="card-body">
            <div class="text-muted small">Rata</div>
            <div class="h5 mb-0">#{{ r.documento.rata }}</div>
            <div class="text-muted">Documento: {{ r.documento.identificativo|default('—') }}</div>
          </div>
        </div>
      {% endif %}

      {# Voci di pendenza: elenco dettagliato delle singole voci (posizionato prima dei tentativi RPP) #}
    {% set voci_list = (r.voci is iterable) ? r.voci : (r.voci is defined and r.voci ? [r.voci] : []) %}
    <div class="card mt-3">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h3 class="h6 mb-0">Voci di pendenza <span class="badge bg-secondary ms-2">{{ voci_list|length }}</span></h3>
      </div>
      <div class="card-body">
        {% if voci_list|length > 0 %}
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th scope="col">#</th>
                  <th scope="col">ID voce</th>
                  <th scope="col">Descrizione</th>
                  <th scope="col" class="text-end text-nowrap">Importo</th>
                  <th scope="col">Stato</th>
                  {% if is_bollo %}
                    <th scope="col">Tipo bollo</th>
                    <th scope="col">Provincia</th>
                    <th scope="col">Impronta documento</th>
                    <th scope="col" class="text-center">Azioni</th>
                  {% else %}
                    <th scope="col">Descrizione tipologia</th>
                    <th scope="col">IBAN</th>
                    <th scope="col">Tipo cont.</th>
                    <th scope="col">Contabilità</th>
                  {% endif %}
                </tr>
              </thead>
              <tbody>
                {% for voce in voci_list %}
                  <tr>
                    <td>{{ voce.indice|default(loop.index) }}</td>
                    <td>{{ voce.idVocePendenza|default('—') }}</td>
                    <td>{{ voce.descrizione|default('—') }}</td>
                    <td class="text-end text-nowrap">{% if voce.importo is defined %}{{ voce.importo|number_format(2, ',', '.') }} €{% else %}—{% endif %}</td>
                    <td>
                      {% set st_voce = voce.stato|default('') %}
                      {% include 'partials/state_badge.html.twig' with { state: st_voce, pill: false, small: true } %}
                    </td>
                    {% if is_bollo %}
                      <td>{{ voce.tipoBollo|default('—') }}</td>
                      <td>{{ voce.provinciaResidenza|default('—') }}</td>
                      <td>
                        {% if voce.hashDocumento is defined and voce.hashDocumento %}
                          <code class="small user-select-all" title="{{ voce.hashDocumento }}">{{ voce.hashDocumento|slice(0,24) }}&hellip;</code>
                        {% else %}—{% endif %}
                      </td>
                      <td class="text-center">
                        {% set voceBolloXmlTesto = '' %}
                        {% set voceBolloXmlIuv = '' %}
                        {% if voce.riscossioni is defined and voce.riscossioni is iterable %}
                          {% for risc in voce.riscossioni %}
                            {% if voceBolloXmlTesto == ''
                                and risc.tipo is defined and risc.tipo == 'MBT'
                                and risc.allegato is defined
                                and risc.allegato.testo is defined
                                and risc.allegato.testo %}
                              {% set voceBolloXmlTesto = risc.allegato.testo %}
                              {% set voceBolloXmlIuv = risc.iuv|default('bollo') %}
                            {% endif %}
                          {% endfor %}
                        {% endif %}
                        {% if voceBolloXmlTesto %}
                          <button type="button"
                            class="btn btn-outline-secondary btn-sm px-2 py-0 download-voce-bollo-xml-btn"
                            data-testo="{{ voceBolloXmlTesto }}"
                            data-iuv="{{ voceBolloXmlIuv }}"
                            title="Scarica XML Marca da Bollo Telematica">
                            <i class="fas fa-stamp" aria-hidden="true"></i>
                          </button>
                        {% else %}
                          <span class="text-muted">—</span>
                        {% endif %}
                      </td>
                    {% else %}
                      <td class="text-break small">
                        {% set codice = voce.codiceContabilita|default('') %}
                        {% set desc_tipologia = null %}
                        {% if tipologie is iterable %}
                          {% for t in tipologie %}
                            {% if t.id_entrata is defined and t.id_entrata == codice %}
                              {% set desc_tipologia = t.descrizione|default(desc_tipologia) %}
                            {% endif %}
                          {% endfor %}
                        {% endif %}
                        {{ desc_tipologia|default(voce.codiceContabilita | default('—')) }}
                      </td>
                      <td class="text-break small">{{ voce.ibanAccredito|default('—') }}</td>
                      <td class="text-nowrap">{{ voce.tipoContabilita|default('—') }}</td>
                      <td>
                        {% if voce.contabilita is defined and voce.contabilita.quote is iterable and voce.contabilita.quote|length > 0 %}
                          {% for q in voce.contabilita.quote %}
                            <div class="small text-muted">
                              {% set capitolo = q.capitolo|default('') %}
                              {% set anno = q.anno_esercizio is defined ? q.anno_esercizio : (q.annoEsercizio|default('')) %}
                              {% if capitolo %}<strong>Cap:</strong> {{ capitolo }}{% endif %}
                              {% if anno %} <span class="ms-1"><strong>Anno:</strong> {{ anno }}</span>{% endif %}
                              {% if q.importo is defined %} <div class="text-end">{{ q.importo|number_format(2, ',', '.') }} €</div>{% endif %}
                            </div>
                          {% endfor %}
                        {% else %}
                          —
                        {% endif %}
                      </td>
                    {% endif %}
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% else %}
          <div class="text-muted">Nessuna voce disponibile per questa pendenza.</div>
        {% endif %}
      </div>
    </div>

    {# Info incasso da tabella ragioneria (flussi_rendicontazioni) #}
    {% if incasso_rows is defined and incasso_rows|length > 0 %}
      <div class="card mt-3">
        <div class="card-header d-flex align-items-center gap-2">
          <i class="fas fa-landmark text-success" aria-hidden="true"></i>
          <h3 class="h6 mb-0">Info incasso <span class="badge bg-success ms-1">{{ incasso_rows|length }}</span></h3>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Data pagamento</th>
                  <th>Data regolamento</th>
                  <th class="text-end text-nowrap">Importo</th>
                  <th>IUR</th>
                  <th>PSP</th>
                  <th>Flusso</th>
                  <th>Stato rend.</th>
                  <th>Esito</th>
                </tr>
              </thead>
              <tbody>
                {% for row in incasso_rows %}
                  <tr>
                    <td class="text-nowrap">{{ row.data_pagamento ? row.data_pagamento|date('d/m/Y') : '—' }}</td>
                    <td class="text-nowrap">{{ row.data_regolamento ? row.data_regolamento|date('d/m/Y') : '—' }}</td>
                    <td class="text-end text-nowrap">{{ row.importo is not null ? row.importo|number_format(2, ',', '.') ~ ' €' : '—' }}</td>
                    <td><code class="small">{{ row.iur|default('—') }}</code></td>
                    <td class="small">{{ row.ragione_psp|default(row.id_psp|default('—')) }}</td>
                    <td class="small text-nowrap">
                      {% if row.id_flusso %}
                        <a href="/pagamenti/ricerca-flussi/dettaglio/{{ row.id_flusso|url_encode }}?return={{ ('/pendenze/dettaglio/' ~ idPendenza)|url_encode }}"
                           class="text-muted" title="Apri dettaglio flusso">
                          <i class="fas fa-external-link-alt me-1" style="font-size:.65rem;"></i>{{ row.id_flusso }}
                        </a>
                      {% else %}
                        —
                      {% endif %}
                    </td>
                    <td>
                      {% if row.stato_rend %}
                        {% if row.stato_rend in ['INCASSATO','RENDICONTATO'] %}
                          <span class="badge" style="background:#d1e7dd;color:#0a3622;border:1px solid #a3cfbb;">{{ row.stato_rend }}</span>
                        {% elseif row.stato_rend in ['ANOMALO','ERRORE'] %}
                          <span class="badge" style="background:#f8d7da;color:#58151c;border:1px solid #f1aeb5;">{{ row.stato_rend }}</span>
                        {% else %}
                          <span class="badge bg-secondary">{{ row.stato_rend }}</span>
                        {% endif %}
                      {% else %}
                        —
                      {% endif %}
                    </td>
                    <td>
                      {% if row.esito is not null %}
                        {% if row.esito == 0 %}
                          <span class="badge" style="background:#d1e7dd;color:#0a3622;border:1px solid #a3cfbb;">OK</span>
                        {% else %}
                          <span class="badge" style="background:#f8d7da;color:#58151c;border:1px solid #f1aeb5;">{{ row.esito }}</span>
                        {% endif %}
                      {% else %}
                        —
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    {% endif %}

    {# Collapse Ricevute Telematiche (RT) sotto ciascun tentativo RPP #}
    {% set attempt_list = payment_attempts|default([]) %}
    {% set rppCount = attempt_list|length %}
    <div class="card mt-3">
      <div class="card-header d-flex justify-content-start align-items-center">
        <button class="btn btn-sm btn-outline-secondary me-2 mr-2" type="button"
          {% if rppCount == 0 %}disabled aria-disabled="true"{% else %}data-bs-toggle="collapse" data-bs-target="#rtCollapse" aria-expanded="false" aria-controls="rtCollapse"{% endif %}>
          Mostra tentativi di pagamento <span class="badge bg-secondary">{{ rppCount }}</span>
        </button>
        {% set hasHistory = (r.datiAllegati is defined and (r.datiAllegati.sorgente is defined or r.datiAllegati.operatore is defined or (r.datiAllegati.storico is defined and r.datiAllegati.storico is iterable))) %}
        <button class="btn btn-sm btn-outline-secondary me-2 mr-2" type="button" 
          {% if not hasHistory %}disabled aria-disabled="true"{% else %}data-bs-toggle="collapse" data-bs-target="#historyCollapse" aria-expanded="false" aria-controls="historyCollapse"{% endif %}>
          Sorgente e storico
        </button>
        {% set hasNotifiche = (r.datiAllegati is defined and r.datiAllegati.notifiche is defined and r.datiAllegati.notifiche is iterable and r.datiAllegati.notifiche|length > 0) %}
        <button class="btn btn-sm btn-outline-secondary" type="button" 
          {% if not hasNotifiche %}disabled aria-disabled="true"{% else %}data-bs-toggle="collapse" data-bs-target="#notificheCollapse" aria-expanded="false" aria-controls="notificheCollapse"{% endif %}>
          Notifiche <span class="badge bg-secondary">{{ hasNotifiche ? r.datiAllegati.notifiche|length : 0 }}</span>
        </button>
      </div>
      <div class="collapse" id="historyCollapse">
        <div class="card-body border-bottom">
            <h5 class="card-title h6">Sorgente</h5>
            {% if r.datiAllegati is defined and r.datiAllegati.sorgente is defined %}
                <div><span class="text-muted">Origine:</span> {{ r.datiAllegati.sorgente }}</div>
            {% endif %}
            {% if r.datiAllegati is defined and r.datiAllegati.batchId is defined %}
                <div><span class="text-muted">Batch ID:</span> {{ r.datiAllegati.batchId }}</div>
            {% endif %}
            {% if r.datiAllegati is defined and r.datiAllegati.operatore is defined %}
                <div><span class="text-muted">Operatore:</span> {{ r.datiAllegati.operatore }}</div>
            {% endif %}
            {% if r.datiAllegati is defined and r.datiAllegati.utente_autenticato is defined and r.datiAllegati.utente_autenticato %}
                <div class="mt-2 pt-2 border-top" style="border-top-style: dashed !important; border-top-color: var(--border-color) !important;">
                    <strong class="text-secondary"><i class="fas fa-user-check me-1"></i> Utente Autenticato Frontoffice:</strong>
                    <div class="ms-3 ps-1 mt-1">
                        <div><span class="text-muted">Nome e Cognome:</span> {{ r.datiAllegati.utente_nome|default('—') }} {{ r.datiAllegati.utente_cognome|default('—') }}</div>
                        <div><span class="text-muted">Codice Fiscale:</span> <span class="font-monospace small">{{ r.datiAllegati.utente_cf|default('—') }}</span></div>
                        {% if r.datiAllegati.utente_email is defined and r.datiAllegati.utente_email %}
                            <div><span class="text-muted">Email:</span> {{ r.datiAllegati.utente_email }}</div>
                        {% endif %}
                        {% if r.datiAllegati.utente_provider is defined and r.datiAllegati.utente_provider %}
                            <div><span class="text-muted">Provider di accesso:</span> {{ r.datiAllegati.utente_provider }}</div>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
            {% if r.datiAllegati is defined and r.datiAllegati.storico is defined and r.datiAllegati.storico is iterable %}
                <div class="mt-2">
                <strong>Storico Modifiche:</strong>
                <ul class="list-unstyled pl-2 border-left ml-2 mb-0">
                {% for h in r.datiAllegati.storico|reverse %}
                    <li><small class="text-muted">{{ h.data|date('d/m/Y H:i') }}</small> - {{ h.operatore|default('') }} ({{ h.operazione|default('Modifica') }})</li>
                {% endfor %}
                </ul>
                </div>
            {% endif %}
        </div>
      </div>
      {% if hasNotifiche %}
      <div class="collapse" id="notificheCollapse">
        <div class="card-body border-bottom">
            <h5 class="card-title h6">Notifiche Inviate</h5>
            <div class="table-responsive">
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th>Data/Ora</th>
                            <th>Tipo</th>
                            <th>Canale</th>
                            <th>Destinatario</th>
                            <th>Esito</th>
                        <th class="text-end">Azioni</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% set canResendNotifiche = (r.stato|default('') not in ['ESEGUITA','ESEGUITO','RISCOSSA','INCASSATA','INCASSATO','RENDICONTATA','RENDICONTATO']) %}
                    {% for notifica in r.datiAllegati.notifiche|reverse %}
                        <tr>
                            <td><small>{{ notifica.timestamp|date('d/m/Y H:i:s') }}</small></td>
                            <td>{{ notifica.tipo|default('N/A')|replace({'_': ' '})|title }}</td>
                            <td>
                                {% if notifica.canale == 'email' %}
                                    <i class="bi bi-envelope"></i> Email
                                {% elseif notifica.canale == 'app_io' %}
                                    <i class="bi bi-phone"></i> App IO
                                {% else %}
                                    {{ notifica.canale|default('N/A') }}
                                {% endif %}
                            </td>
                              <td><small>{{ notifica.destinatario|default(notifica.message_id|default('N/A')) }}</small></td>
                            <td>
                                {% if notifica.esito == 'OK' %}
                                    <span class="badge bg-success">OK</span>
                                {% else %}
                                    <span class="badge bg-danger">{{ notifica.esito|default('ERRORE') }}</span>
                                {% endif %}
                            </td>
                              <td class="text-end">
                                {% set canaleNotifica = notifica.canale|default('') %}
                                {% if canResendNotifiche and (canaleNotifica == 'email' or canaleNotifica == 'app_io') %}
                                  <form method="post" action="/pendenze/notifiche/reinvia/{{ idPendenza|url_encode }}" class="d-inline">
                                    <input type="hidden" name="canale" value="{{ canaleNotifica }}">
                                    <button type="submit" class="btn btn-outline-primary btn-sm" onclick="return confirm('Confermi il reinvio della notifica su {{ canaleNotifica == 'app_io' ? 'App IO' : 'Email' }}?')">Reinvia</button>
                                  </form>
                                {% else %}
                                  <button type="button" class="btn btn-outline-secondary btn-sm" disabled>Reinvia</button>
                                {% endif %}
                              </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
      </div>
      {% endif %}
      {% if rppCount > 0 %}
      <div class="collapse" id="rtCollapse">
        <div class="card-body">
              <div class="table-responsive small">
                <table class="table table-striped table-sm align-middle">
                  <thead>
                    <tr>
                      <th>Identificativo pagamento</th>
                      <th>Data e ora</th>
                      <th>Stato</th>
                      <th class="text-end text-nowrap">Importo</th>
                      <th>ABI</th>
                      <th>Istituto</th>
                      <th class="text-center">Ricevuta</th>
                    </tr>
                  </thead>
                  <tbody>
                  {% for attempt in attempt_list %}
                    <tr>
                      <td>{{ attempt.display_id ?: '—' }}</td>
                      <td class="text-nowrap">{% if attempt.timestamp %}{{ attempt.timestamp|date('d/m/Y H:i:s') }}{% else %}—{% endif %}</td>
                      <td>
                        {% if attempt.state %}
                          {% include 'partials/state_badge.html.twig' with { state: attempt.state, pill: true, small: true } %}
                        {% else %}
                          —
                        {% endif %}
                        {% if attempt.state_detail %}
                          <div class="small text-muted mt-1" style="max-width: 250px; font-size: 0.75rem; line-height: 1.2;">
                            {{ attempt.state_detail }}
                          </div>
                        {% endif %}
                      </td>
                      <td class="text-end text-nowrap">{% if attempt.amount is not null %}{{ attempt.amount|number_format(2, ',', '.') }} €{% else %}—{% endif %}</td>
                      <td>{{ attempt.abi ?: '—' }}</td>
                      <td>{{ attempt.institution ?: '—' }}</td>
                      <td class="text-center">
                        {% if attempt.receipt_path %}
                          <a class="btn btn-success btn-sm px-2 py-0" href="/pendenze{{ attempt.receipt_path }}/rt" title="Scarica ricevuta" aria-label="Scarica ricevuta">
                            <i class="fas fa-file-pdf"></i>
                          </a>
                        {% else %}
                          —
                        {% endif %}
                      </td>
                    </tr>
                  {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
      {% endif %}
    </div>

          {# Rate plan is displayed inside the 'Rateizzazione' card above. #}

    {% if app_debug %}
      <div class="card mt-3">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span class="badge bg-warning text-dark">Debug</span>
          <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#rawCollapse" aria-expanded="false" aria-controls="rawCollapse">Mostra/Nascondi</button>
        </div>
        <div class="collapse" id="rawCollapse">
          <div class="card-body">
            <pre class="mb-0">{{ pendenza|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_SLASHES')) }}</pre>
          </div>
        </div>
      </div>
      {# Removed related_pendenze view: all rates are shown in the Rateizzazione section above. #}
    {% endif %}
  {% else %}
    {% if not error %}
      <div class="alert alert-warning">Nessun dato pendenza disponibile.</div>
    {% endif %}
  {% endif %}

  <div class="mt-3">
    {% if came_from_insert %}
      <a class="btn btn-primary" href="/pendenze/inserimento">Inserisci nuova pendenza</a>
    {% else %}
      <a class="btn btn-outline-secondary" href="{{ target_return }}">&laquo; {{ from_flow ? 'Torna al dettaglio flusso' : 'Torna alla ricerca' }}</a>
    {% endif %}
  </div>

<script>
// (Funzioni JS rimosse: ora usiamo form POST per annulla/riattiva)
</script>
{% endblock %}
