{% extends 'base.html.twig' %}
{% block content %}
<div class="container my-5" style="max-width:720px;">
  <h1 class="h4 mb-3">Modifica utente</h1>
  {% if error %}<div class="alert alert-danger">{{ error }}</div>{% endif %}
  {% if edit_user.is_disabled %}
    <div class="alert alert-warning py-2 small">
      Utente disabilitato. Usa l'elenco utenti per riabilitarlo.
    </div>
  {% endif %}

  <form method="post" action="/users/{{ edit_user.id }}/edit" autocomplete="off">
    <input type="text" name="fakeusernameremembered" autocomplete="username"
           style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;"
           aria-hidden="true" tabindex="-1">
    <input type="password" name="fakepasswordremembered" autocomplete="current-password"
           style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;"
           aria-hidden="true" tabindex="-1">

    <div class="row g-3 mb-3">
      <div class="col-12">
        <label class="form-label">Email</label>
        <input class="form-control" type="email" name="email"
               value="{{ edit_user.email }}" required autocomplete="off"
               readonly onfocus="this.removeAttribute('readonly')">
      </div>
      <div class="col-md-6">
        <label class="form-label">Nome</label>
        <input class="form-control" type="text" name="first_name"
               value="{{ edit_user.first_name|default('') }}">
      </div>
      <div class="col-md-6">
        <label class="form-label">Cognome</label>
        <input class="form-control" type="text" name="last_name"
               value="{{ edit_user.last_name|default('') }}">
      </div>
      <div class="col-md-6">
        <label class="form-label">Ruolo</label>
        {% set is_self = current_user is defined and current_user.id == edit_user.id %}
        {% set can_demote_self = attribute(_context, 'can_demote_self') is defined ? can_demote_self : true %}
        <select name="role" class="form-control"
                {% if current_user.role == 'admin' and is_self %}disabled{% endif %}>
          <option value="user" {% if edit_user.role == 'user' %}selected{% endif %}
                  {% if is_self and not can_demote_self %}disabled{% endif %}>User</option>
          <option value="admin" {% if edit_user.role == 'admin' %}selected{% endif %}
                  {% if is_self and not can_demote_self %}disabled{% endif %}>Admin</option>
          <option value="superadmin" {% if edit_user.role == 'superadmin' %}selected{% endif %}>Superadmin</option>
        </select>
        {% if is_self and not can_demote_self %}
          <div class="form-text text-warning">Almeno un altro superadmin richiesto prima di declassarti.</div>
        {% endif %}
      </div>

      {% if all_tipologie is defined and all_tipologie|length > 0 %}
      <div class="col-md-6">
        <label for="default_id_entrata" class="form-label">Tipologia di default</label>
        <select class="form-select" id="default_id_entrata" name="default_id_entrata">
          <option value="">-- Nessuna --</option>
          {% for tip in all_tipologie %}
            <option value="{{ tip.id_entrata }}"
                    {% if edit_user.default_id_entrata == tip.id_entrata %}selected{% endif %}>
              {{ tip.descrizione }}
            </option>
          {% endfor %}
        </select>
        <div class="form-text">Pre-selezionata nei form di creazione pendenze.</div>
      </div>
      {% endif %}
    </div>

    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <div class="border rounded p-3 h-100 bg-light">
          <div class="small text-muted mb-1">Ultimo accesso</div>
          <div class="fw-semibold">
            {% if edit_user.last_login_at|default(null) %}
              {{ edit_user.last_login_at|date('d/m/Y H:i') }}
            {% else %}
              Mai registrato
            {% endif %}
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="border rounded p-3 h-100 bg-light">
          <div class="small text-muted mb-1">Ultimo cambio password</div>
          <div class="fw-semibold">
            {% if edit_user.last_password_change_at|default(null) %}
              {{ edit_user.last_password_change_at|date('d/m/Y H:i') }}
            {% else %}
              Mai registrato
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    {% if current_user is defined and current_user.role in ['admin', 'superadmin']
          and all_tipologie is defined and all_tipologie|length > 0 %}
      {% set active_count = user_tipologie_ids|default([])|length %}
      <div class="mb-3">
        <label class="form-label d-flex align-items-center gap-2">
          Tipologie abilitate
          {% if active_count > 0 %}
            <span class="badge bg-primary">{{ active_count }} attive</span>
          {% else %}
            <span class="badge bg-secondary">tutte visibili</span>
          {% endif %}
        </label>
        <div class="border rounded p-2" style="max-height:180px;overflow-y:auto;">
          {% for tip in all_tipologie %}
            <div class="form-check form-check-sm">
              <input class="form-check-input" type="checkbox"
                     id="tip_{{ tip.id_entrata }}" name="enabled_tipologie[]"
                     value="{{ tip.id_entrata }}"
                     {% if tip.id_entrata in user_tipologie_ids|default([]) %}checked{% endif %}>
              <label class="form-check-label small" for="tip_{{ tip.id_entrata }}">
                {{ tip.descrizione }}
              </label>
            </div>
          {% endfor %}
        </div>
        <div class="form-text">Se nessuna selezionata, l'utente vede tutte le tipologie del dominio.</div>
      </div>
    {% endif %}

    {% if current_user is defined and current_user.role in ['admin', 'superadmin']
          and all_groups is defined and all_groups|length > 0 %}
      <div class="mb-3">
        <label class="form-label d-flex align-items-center gap-2">
          Gruppi
          {% set grp_count = user_group_ids|default([])|length %}
          {% if grp_count > 0 %}
            <span class="badge bg-info">{{ grp_count }} assegnati</span>
          {% endif %}
        </label>
        <div class="border rounded p-2" style="max-height:150px;overflow-y:auto;">
          {% for g in all_groups %}
            <div class="form-check form-check-sm">
              <input class="form-check-input" type="checkbox"
                     id="grp_{{ g.id }}" name="group_ids[]"
                     value="{{ g.id }}"
                     {% if g.id in user_group_ids|default([]) %}checked{% endif %}>
              <label class="form-check-label small" for="grp_{{ g.id }}">
                <i class="fas fa-users-cog me-1 text-muted"></i>{{ g.nome }}
                {% if g.descrizione %}<span class="text-muted">({{ g.descrizione }})</span>{% endif %}
              </label>
            </div>
          {% endfor %}
        </div>
        <div class="form-text">I gruppi determinano tipologie e template ereditati dall'utente.</div>
      </div>
    {% endif %}

    <div class="d-flex gap-2">
      <button class="btn btn-primary" type="submit">Salva</button>
      <a class="btn btn-outline-secondary" href="/impostazioni?tab=utenti">Annulla</a>
    </div>
  </form>
</div>
{% endblock %}
