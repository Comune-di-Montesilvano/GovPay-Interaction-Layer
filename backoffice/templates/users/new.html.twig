{% extends 'base.html.twig' %}
{% block content %}
<div class="bo-form-shell bo-form-shell-md">
  <h1 class="h4 mb-3">Nuovo utente</h1>
  {% if error %}<div class="alert alert-danger">{{ error }}</div>{% endif %}
  <form method="post" action="/users/new" autocomplete="off">
    {# Hidden dummy fields to discourage browser autofill #}
    <input type="text" name="fakeusernameremembered" autocomplete="username" class="bo-autofill-trap" aria-hidden="true" tabindex="-1">
    <input type="password" name="fakepasswordremembered" autocomplete="new-password" class="bo-autofill-trap" aria-hidden="true" tabindex="-1">
    <div class="mb-3">
      <label class="form-label">Email</label>
  <input class="form-control" type="email" name="email" required autocomplete="email">
    </div>
    <div class="mb-3">
      <label class="form-label">Nome</label>
      <input class="form-control" type="text" name="first_name">
    </div>
    <div class="mb-3">
      <label class="form-label">Cognome</label>
      <input class="form-control" type="text" name="last_name">
    </div>
    <div class="mb-3">
      <label class="form-label">Ruolo</label>
      <select class="form-select" name="role">
        <option value="user">user</option>
        <option value="admin">admin</option>
        <option value="superadmin">superadmin</option>
      </select>
    </div>
    <div class="alert alert-info py-2 small">
      Dopo la creazione invieremo automaticamente una email all'utente per impostare la password.
    </div>
    <button class="btn btn-primary" type="submit">Crea</button>
    <a class="btn btn-outline-secondary" href="/impostazioni?tab=utenti">Annulla</a>
  </form>
</div>
{% endblock %}
