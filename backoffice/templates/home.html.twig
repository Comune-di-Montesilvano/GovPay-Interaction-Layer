{% extends 'base.html.twig' %}

{% block title %}Dashboard - GovPay{% endblock %}

{% block content %}
  {# 1. Welcome Section #}
  {% set first = current_user ? current_user.first_name|default('') : '' %}
  {% set last = current_user ? current_user.last_name|default('') : '' %}
  {% set display_name = (first != '' or last != '') ? (first ~ (last != '' ? ' ' ~ last|upper : '')) : (current_user ? current_user.email : 'Utente') %}
  <div class="bo-home-welcome">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
      <div class="d-flex align-items-center gap-3">
        <div class="bo-brand-logo-mark" aria-hidden="true" style="font-size: 2.2rem; color: var(--ms-gold-500); flex-shrink: 0;">
          {% if app_logo.type == 'img' %}
            <img src="{{ app_logo.src }}" alt="" style="height: 54px; width: auto; object-fit: contain;">
          {% else %}
            <i class="fas fa-building" aria-hidden="true"></i>
          {% endif %}
        </div>
        <div>
          <h1 style="font-size: 1.6rem; margin-bottom: 2px;">Ciao, {{ display_name }}! 👋</h1>
          <p class="mb-0 text-muted" style="font-size: 0.92rem;">
            Sei connesso come <strong class="text-primary">{{ current_user.role|upper }}</strong>. Questa è la dashboard operativa di <strong>{{ app_entity.name }}</strong> (ID Dominio: <code>{{ id_dominio }}</code>).
            <br>
            <span style="font-size: 0.86rem; display: inline-block; margin-top: 4px;">
              <i class="fas fa-info-circle text-info me-1" aria-hidden="true"></i>
              {% if current_user.role == 'superadmin' %}
                <strong>Consiglio operativo</strong>: Puoi attivare o arrestare i servizi di background direttamente dal pannello <em>GIL Services Hub</em> a destra.
              {% else %}
                <strong>Stato sistema</strong>: Tutti i servizi di sincronizzazione e integrazione flussi sono monitorati in tempo reale nel pannello a destra.
              {% endif %}
            </span>
          </p>
        </div>
      </div>
      
      {# Dedicated sync box badge in top-right, inline with heading #}
      <div class="bo-sync-date-badge shadow-sm" style="background: rgba(255, 255, 255, 0.12); border: 1px solid rgba(255, 255, 255, 0.22); border-radius: 8px; padding: 0.55rem 0.9rem; color: #fff; flex-shrink: 0; min-width: 190px; backdrop-filter: blur(4px);">
        <div class="small fw-semibold text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.05em; opacity: 0.8;">Sincronizzazione Flussi</div>
        <div class="d-flex align-items-center gap-2 mt-1">
          <i class="fas fa-calendar-alt text-warning" aria-hidden="true" style="font-size: 0.95rem;"></i>
          <span class="fw-bold" style="font-size: 1.0rem;">dal {{ ragioneria_scan_da_formatted }}</span>
        </div>
      </div>
    </div>
  </div>

  {# 2. Backlog Warning Bar #}
  <div class="bo-backlog-bar shadow-sm d-none" id="bo-backlog-bar" style="margin-bottom: 1.5rem;">
    <div class="d-flex align-items-center gap-2">
      <i class="fas fa-triangle-exclamation text-warning" style="font-size: 1.1rem;" aria-hidden="true"></i>
      <span id="bo-backlog-text">Caricamento stato coda...</span>
    </div>
    <div class="d-flex gap-2" id="bo-backlog-actions">
    </div>
  </div>

  {# 3. Hero Metric Cards Grid #}
  <div class="row g-3 mb-4">
    {# Card 1: Incassi Complessivi #}
    <div class="col-sm-6 {{ tefa_enabled|default(false) ? 'col-lg-3' : 'col-lg-4' }}">
      <div class="card bo-hero-card shadow-sm" style="--accent-color: var(--ms-gold-500);">
        <div class="card-body">
          <div class="bo-hero-card-icon" style="--bg-light: var(--ms-gold-100); --color: var(--ms-gold-700);">
            <i class="fas fa-wallet" aria-hidden="true"></i>
          </div>
          <span class="bo-hero-card-label">Incassi Complessivi</span>
          <div class="bo-hero-card-value" id="stats-totals-amount">
            <i class="fas fa-spinner fa-spin text-muted" style="font-size: 1.2rem;"></i>
          </div>
          <div class="bo-hero-card-meta" id="stats-totals-meta">
            <span>Caricamento...</span>
          </div>
        </div>
      </div>
    </div>

    {# Card 2: Sincronizzazione Ragioneria #}
    <div class="col-sm-6 {{ tefa_enabled|default(false) ? 'col-lg-3' : 'col-lg-4' }}">
      <div class="card bo-hero-card shadow-sm" style="--accent-color: var(--ms-green-600);">
        <div class="card-body">
          <div class="bo-hero-card-icon" style="--bg-light: var(--ms-green-100); --color: var(--ms-green-700);">
            <i class="fas fa-database" aria-hidden="true"></i>
          </div>
          <span class="bo-hero-card-label">Sincronizzazione Ragioneria</span>
          <div class="bo-hero-card-value">{{ daemons.ragioneria.running ? 'Attivo' : 'Arrestato' }}</div>
          <div class="bo-hero-card-meta">
            <span class="status-dot {{ daemons.ragioneria.running ? 'active' : 'stopped' }}" aria-hidden="true"></span>
            <span>Sincronizza dal: <strong>{{ ragioneria_scan_da_formatted }}</strong></span>
          </div>
        </div>
      </div>
    </div>

    {# Card 3: Biz Events Scanner #}
    <div class="col-sm-6 {{ tefa_enabled|default(false) ? 'col-lg-3' : 'col-lg-4' }}">
      <div class="card bo-hero-card shadow-sm" style="--accent-color: var(--bi-primary);">
        <div class="card-body">
          <div class="bo-hero-card-icon" style="--bg-light: var(--bi-primary-a8); --color: var(--bi-primary);">
            <i class="fas fa-receipt" aria-hidden="true"></i>
          </div>
          <span class="bo-hero-card-label">Ricevute Flussi Esterni</span>
          <div class="bo-hero-card-value" id="stats-biz-processed">
            <i class="fas fa-spinner fa-spin text-muted" style="font-size: 1.2rem;"></i>
          </div>
          <div class="bo-hero-card-meta" id="stats-biz-meta">
            <span>Caricamento...</span>
          </div>
        </div>
      </div>
    </div>

    {# Card 4: Classificatore TEFA #}
    {% if tefa_enabled|default(false) %}
    <div class="col-sm-6 col-lg-3">
      <div class="card bo-hero-card shadow-sm" style="--accent-color: var(--ms-purple-600);">
        <div class="card-body">
          <div class="bo-hero-card-icon" style="--bg-light: var(--ms-purple-100); --color: var(--ms-purple-600);">
            <i class="fas fa-building-columns" aria-hidden="true"></i>
          </div>
          <span class="bo-hero-card-label">Classificazione TEFA</span>
          <div class="bo-hero-card-value" id="stats-tefa-processed">
            <i class="fas fa-spinner fa-spin text-muted" style="font-size: 1.2rem;"></i>
          </div>
          <div class="bo-hero-card-meta" id="stats-tefa-meta">
            <span>Caricamento...</span>
          </div>
        </div>
      </div>
    </div>
    {% endif %}
  </div>

  {# 4. Interactive Charts Section #}
  <div class="row g-3 mb-4">
    {# Chart 1: Combined trend of last 6 months #}
    <div class="col-lg-8">
      <div class="card shadow-sm h-100">
        <div class="card-header bg-light border-bottom py-2">
          <div class="d-flex align-items-center gap-2">
            <h3 class="h6 mb-0">Andamento Incassi (Ultimi 6 Mesi)</h3>
            <span class="text-muted small">| Totale mensile riscosso ed esito pagamenti</span>
          </div>
        </div>
        <div class="card-body position-relative">
          <div id="monthly-trend-loading" class="position-absolute top-50 start-50 translate-middle text-center" style="z-index: 10;">
            <i class="fas fa-spinner fa-spin fa-2x text-primary mb-2"></i>
            <div class="text-muted small">Caricamento grafico...</div>
          </div>
          <div style="position: relative; height: 300px; width: 100%;">
            <canvas id="monthlyTrendChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    {# Chart 2: Distribution by Channel #}
    <div class="col-lg-4">
      <div class="card shadow-sm h-100">
        <div class="card-header bg-light border-bottom py-2">
          <div class="d-flex align-items-center gap-2">
            <h3 class="h6 mb-0">Ripartizione Canale</h3>
            <span class="text-muted small">| Incassi reali</span>
          </div>
        </div>
        <div class="card-body d-flex flex-column align-items-center justify-content-center position-relative">
          <div id="channel-dist-loading" class="position-absolute top-50 start-50 translate-middle text-center" style="z-index: 10;">
            <i class="fas fa-spinner fa-spin fa-2x text-primary mb-2"></i>
            <div class="text-muted small">Caricamento...</div>
          </div>
          <div style="position: relative; height: 200px; width: 100%;">
            <canvas id="channelDistributionChart"></canvas>
          </div>
          <div class="mt-3 text-center w-100" id="channel-dist-legend" style="display: none;">
            <div class="d-flex justify-content-center gap-4 text-muted small">
              <div>
                <span class="badge" style="background-color: var(--bi-primary); width: 12px; height: 12px; display: inline-block; padding: 0; margin-right: 6px; vertical-align: middle;"></span>
                Pendenze Interne: <strong id="channel-govpay-count">0</strong>
              </div>
              <div>
                <span class="badge" style="background-color: var(--ms-purple-600); width: 12px; height: 12px; display: inline-block; padding: 0; margin-right: 6px; vertical-align: middle;"></span>
                Pendenze Esterne: <strong id="channel-external-count">0</strong>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# 5. Daemons control & Activity Hub #}
  <div class="row g-3">
    {# Recent flussi synchronized #}
    <div class="col-lg-7">
      <div class="card shadow-sm h-100">
        <div class="card-header bg-light border-bottom py-2">
          <div class="d-flex align-items-center gap-2">
            <h3 class="h6 mb-0">Ultimi Flussi Rendicontati</h3>
            <span class="text-muted small">| Aggiornamenti ragioneria</span>
          </div>
        </div>
        <div class="card-body p-0" id="recent-flussi-container">
          <div class="p-5 text-center text-muted">
            <i class="fas fa-spinner fa-spin fa-2x text-primary mb-2"></i>
            <p class="mb-0">Caricamento flussi recenti...</p>
          </div>
        </div>
      </div>
    </div>

    {# Daemon Controller Hub #}
    <div class="col-lg-5">
      <div class="card shadow-sm h-100">
        <div class="card-header bg-light border-bottom py-2">
          <div class="d-flex align-items-center gap-2">
            <h3 class="h6 mb-0">GIL Services Hub</h3>
            <span class="text-muted small">| Stato dei servizi di integrazione</span>
          </div>
        </div>
        <div class="card-body">
          <div class="d-flex flex-column gap-3">
            {% set is_superadmin = current_user.role == 'superadmin' %}
            
            {# Daemon: Ragioneria Sync #}
            <div class="daemon-service-item">
              <div class="d-flex align-items-center justify-content-between">
                <span class="daemon-service-name">
                  <i class="fas fa-database" aria-hidden="true"></i> Sincronizzazione Flussi Interni
                </span>
                <span class="badge {{ daemons.ragioneria.running ? 'bg-success' : 'bg-secondary' }}">
                  {{ daemons.ragioneria.running ? 'Attivo' : 'Arrestato' }}
                </span>
              </div>
              <p class="daemon-service-desc">Scarica e sincronizza i flussi FDR ragioneria da GovPay nel database locale.</p>
              {% if is_superadmin %}
                <div class="daemon-service-controls">
                  {% if daemons.ragioneria.running %}
                    <button type="button" class="btn btn-danger btn-sm py-1" onclick="toggleDaemon('ragioneria', 'stop')">
                      <i class="fas fa-stop me-1" aria-hidden="true"></i> Arresta
                    </button>
                  {% else %}
                    <button type="button" class="btn btn-success btn-sm py-1" onclick="toggleDaemon('ragioneria', 'run')">
                      <i class="fas fa-play me-1" aria-hidden="true"></i> Avvia
                    </button>
                  {% endif %}
                </div>
              {% endif %}
            </div>

            {# Daemon: Biz Scanner #}
            <div class="daemon-service-item">
              <div class="d-flex align-items-center justify-content-between">
                <span class="daemon-service-name">
                  <i class="fas fa-receipt" aria-hidden="true"></i> Scanner Flussi Esterni (pagoPA)
                </span>
                <span class="badge {{ daemons.biz.running ? 'bg-success' : 'bg-secondary' }}">
                  {{ daemons.biz.running ? 'Attivo' : 'Arrestato' }}
                </span>
              </div>
              <p class="daemon-service-desc">Accoda pendenze non-GovPay e arricchisce i dati leggendo da Biz Events pagoPA.</p>
              {% if is_superadmin %}
                <div class="daemon-service-controls">
                  {% if daemons.biz.running %}
                    <button type="button" class="btn btn-danger btn-sm py-1" onclick="toggleDaemon('biz', 'stop')">
                      <i class="fas fa-stop me-1" aria-hidden="true"></i> Arresta
                    </button>
                  {% else %}
                    <button type="button" class="btn btn-success btn-sm py-1" onclick="toggleDaemon('biz', 'run')">
                      <i class="fas fa-play me-1" aria-hidden="true"></i> Avvia
                    </button>
                  {% endif %}
                </div>
              {% endif %}
            </div>

            {# Daemon: TEFA Classificator #}
            {% if tefa_enabled|default(false) %}
            <div class="daemon-service-item">
              <div class="d-flex align-items-center justify-content-between">
                <span class="daemon-service-name">
                  <i class="fas fa-building-columns" aria-hidden="true"></i> Classificatore TEFA
                </span>
                <span class="badge {{ daemons.tefa.running ? 'bg-success' : 'bg-secondary' }}">
                  {{ daemons.tefa.running ? 'Attivo' : 'Arrestato' }}
                </span>
              </div>
              <p class="daemon-service-desc">Classifica i flussi Biz Events identificando la quota provinciale TEFA.</p>
              {% if is_superadmin %}
                <div class="daemon-service-controls">
                  {% if daemons.tefa.running %}
                    <button type="button" class="btn btn-danger btn-sm py-1" onclick="toggleDaemon('tefa', 'stop')">
                      <i class="fas fa-stop me-1" aria-hidden="true"></i> Arresta
                    </button>
                  {% else %}
                    <button type="button" class="btn btn-success btn-sm py-1" onclick="toggleDaemon('tefa', 'run')">
                      <i class="fas fa-play me-1" aria-hidden="true"></i> Avvia
                    </button>
                  {% endif %}
                </div>
              {% endif %}
            </div>
            {% endif %}
            
          </div>
        </div>
      </div>
    </div>
  </div>

  {# 6. Breakdown by Noticing Type (Tipologie Pendenze) #}
  <div class="row g-3 mt-3 mb-4">
    <div class="col-12">
      <div class="card shadow-sm">
        <div class="card-header bg-light border-bottom py-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
          <div class="d-flex align-items-center gap-2">
            <h3 class="h6 mb-0">Ripartizione per Tipologia di Pendenza</h3>
            <span class="text-muted small d-none d-md-inline">| Analisi dei maggiori flussi di entrata dell'Ente</span>
          </div>
          <div class="d-flex align-items-center flex-wrap gap-3">
            {# Period selector pills #}
            <div class="btn-group btn-group-sm" role="group" aria-label="Periodo tipologie" id="bo-tipologie-periodo">
              <button type="button" class="btn btn-outline-primary" data-periodo="30d">Ultimi 30 gg</button>
              <button type="button" class="btn btn-outline-primary" data-periodo="last_month">Mese scorso</button>
              <button type="button" class="btn btn-outline-primary" data-periodo="this_year">Anno corrente</button>
              <button type="button" class="btn btn-outline-primary" data-periodo="last_year">Anno precedente</button>
              <button type="button" class="btn btn-primary" data-periodo="12m">Ultimi 12 mesi</button>
            </div>
            <div class="small text-muted fw-semibold" style="font-size: 0.84rem;">
              Totale periodo: <span id="bo-tipologie-total" class="text-primary fs-6 fw-bold">€ 0,00</span>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div id="bo-tipologie-grid-wrap">
            <div class="p-5 text-center text-muted">
              <i class="fas fa-spinner fa-spin fa-2x text-primary mb-2"></i>
              <p class="mb-0">Caricamento tipologie...</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# 7. Custom Scripts for Chart.js & Ajax Daemon toggling #}
  <script src="/assets/chartjs/chart.umd.min.js"></script>
  <script>
    // Global format helpers
    function fmtEur(val) {
      let num = parseFloat(val);
      if (isNaN(num)) return '€\u00a00,00';
      let parts = num.toFixed(2).split('.');
      parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ".");
      return '€\u00a0' + parts.join(',');
    }

    function fmtNum(val) {
      let num = parseInt(val, 10);
      if (isNaN(num)) return '0';
      return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", function() {
        loadDashboardStats();
      });
    } else {
      loadDashboardStats();
    }

    async function loadDashboardStats() {
      try {
        const response = await fetch('/api/dashboard/stats');
        if (!response.ok) throw new Error('Errore nel caricamento delle statistiche');
        const stats = await response.json();

        // ── 1. Popola barra backlog transazioni ──
        const tefaEnabled = {{ tefa_enabled|default(false) ? 'true' : 'false' }};
        const totalBacklog = stats.biz_queue_remaining + (tefaEnabled ? stats.tefa_queue_remaining : 0);
        const backlogBar = document.getElementById('bo-backlog-bar');
        
        if (totalBacklog > 0) {
          document.getElementById('bo-backlog-text').innerHTML = `
            Ci sono <strong>${fmtNum(totalBacklog)}</strong> transazioni in attesa di elaborazione
            (${stats.biz_queue_remaining > 0 ? `<strong>${fmtNum(stats.biz_queue_remaining)}</strong> Flussi Esterni` : ''}
            ${stats.biz_queue_remaining > 0 && stats.tefa_queue_remaining > 0 && tefaEnabled ? ' e ' : ''}
            ${stats.tefa_queue_remaining > 0 && tefaEnabled ? `<strong>${fmtNum(stats.tefa_queue_remaining)}</strong> TEFA` : ''}).
          `;
          
          let actionsHtml = '';
          if (stats.biz_queue_remaining > 0) {
            actionsHtml += `
              <a href="/pagamenti/report-ragioneria?q=1" class="btn btn-warning btn-sm" style="color: var(--ms-ink) !important; border: 1px solid rgba(0,0,0,0.15) !important;">
                <i class="fas fa-arrow-right me-1" aria-hidden="true"></i> Flussi Esterni
              </a>
            `;
          }
          if (stats.tefa_queue_remaining > 0 && tefaEnabled) {
            actionsHtml += `
              <a href="/pagamenti/report-tefa?q=1" class="btn btn-warning btn-sm" style="color: var(--ms-ink) !important; border: 1px solid rgba(0,0,0,0.15) !important;">
                <i class="fas fa-arrow-right me-1" aria-hidden="true"></i> Quota TEFA
              </a>
            `;
          }
          document.getElementById('bo-backlog-actions').innerHTML = actionsHtml;
          backlogBar.classList.remove('d-none');
        }

        // ── 2. Popola Eroi metriche ──
        document.getElementById('stats-totals-amount').textContent = fmtEur(stats.totals.amount);
        document.getElementById('stats-totals-meta').innerHTML = `
          <i class="fas fa-circle-check text-success" aria-hidden="true"></i>
          <span><strong>${fmtNum(stats.totals.count)}</strong> transazioni totali</span>
        `;

        document.getElementById('stats-biz-processed').textContent = fmtNum(stats.biz_counts.PROCESSED);
        let bizMetaHtml = '<span>';
        if (stats.biz_counts.PENDING > 0) {
          bizMetaHtml += `<strong class="text-warning">${stats.biz_counts.PENDING}</strong> in attesa · `;
        }
        if (stats.biz_counts.ERROR > 0) {
          bizMetaHtml += `<strong class="text-danger">${stats.biz_counts.ERROR}</strong> errori`;
        } else {
          bizMetaHtml += 'Elaborate con successo';
        }
        bizMetaHtml += '</span>';
        document.getElementById('stats-biz-meta').innerHTML = bizMetaHtml;

        const statsTefaProcessed = document.getElementById('stats-tefa-processed');
        const statsTefaMeta = document.getElementById('stats-tefa-meta');
        if (statsTefaProcessed && statsTefaMeta) {
          statsTefaProcessed.textContent = fmtNum(stats.tefa_counts.PROCESSED);
          let tefaMetaHtml = '<span>';
          if (stats.tefa_counts.PENDING > 0) {
            tefaMetaHtml += `<strong class="text-warning">${stats.tefa_counts.PENDING}</strong> in attesa · `;
          }
          if (stats.tefa_counts.ERROR > 0) {
            tefaMetaHtml += `<strong class="text-danger">${stats.tefa_counts.ERROR}</strong> errori`;
          } else {
            tefaMetaHtml += 'Analizzate correttamente';
          }
          tefaMetaHtml += '</span>';
          statsTefaMeta.innerHTML = tefaMetaHtml;
        }

        // ── 3. Disegna Chart 1 (Andamento Incassi) ──
        const ctxTrend = document.getElementById("monthlyTrendChart");
        const monthlyTrendLoading = document.getElementById("monthly-trend-loading");
        if (monthlyTrendLoading) monthlyTrendLoading.style.display = 'none';
        if (ctxTrend && typeof Chart !== 'undefined') {
          new Chart(ctxTrend.getContext("2d"), {
            type: "bar",
            data: {
              labels: stats.monthly_trend.map(item => item.label),
              datasets: [
                {
                  type: "line",
                  label: "Numero Transazioni",
                  borderColor: "#C9A13B", // crown gold
                  borderWidth: 3,
                  fill: false,
                  tension: 0.35,
                  yAxisID: "y-count",
                  data: stats.monthly_trend.map(item => item.count)
                },
                {
                  type: "bar",
                  label: "Pendenze Interne (€)",
                  backgroundColor: "#0066CC", 
                  hoverBackgroundColor: "#0052a3",
                  borderRadius: 4,
                  yAxisID: "y-amount",
                  data: stats.monthly_trend.map(item => item.amount_internal || 0)
                },
                {
                  type: "bar",
                  label: "Pendenze Esterne (€)",
                  backgroundColor: "#4A2A6E", 
                  hoverBackgroundColor: "#382054",
                  borderRadius: 4,
                  yAxisID: "y-amount",
                  data: stats.monthly_trend.map(item => item.amount_external || 0)
                }
              ]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: {
                legend: {
                  position: 'top',
                  labels: {
                    boxWidth: 12,
                    font: { family: 'Titillium Web', size: 12 }
                  }
                },
                tooltip: {
                  mode: 'index',
                  intersect: false
                }
              },
              scales: {
                x: {
                  stacked: true,
                  grid: { display: false }
                },
                "y-amount": {
                  stacked: true,
                  type: "linear",
                  position: "left",
                  ticks: {
                    callback: function(value) { return '€ ' + value.toLocaleString('it-IT'); }
                  },
                  grid: { color: "#f1f5f9" }
                },
                "y-count": {
                  stacked: false,
                  type: "linear",
                  position: "right",
                  grid: { drawOnChartArea: false },
                  ticks: {
                    precision: 0
                  }
                }
              }
            }
          });
        }

        // ── 4. Disegna Chart 2 (Ripartizione Canale) ──
        const ctxChannel = document.getElementById("channelDistributionChart");
        const channelDistLoading = document.getElementById("channel-dist-loading");
        if (channelDistLoading) channelDistLoading.style.display = 'none';
        if (ctxChannel && typeof Chart !== 'undefined') {
          new Chart(ctxChannel.getContext("2d"), {
            type: "doughnut",
            data: {
              labels: ["Pendenze Interne", "Pendenze Esterne"],
              datasets: [{
                data: [stats.channels_data.govpay, stats.channels_data.external],
                backgroundColor: ["#0066CC", "#4A2A6E"],
                borderWidth: 2,
                borderColor: "#fff"
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: {
                legend: { display: false }
              },
              cutout: "70%"
            }
          });
          
          document.getElementById('channel-govpay-count').textContent = fmtNum(stats.channels_data.govpay);
          document.getElementById('channel-external-count').textContent = fmtNum(stats.channels_data.external);
          document.getElementById('channel-dist-legend').style.display = 'block';
        }

        // ── 5. Popola tabella flussi recenti ──
        const recentFlussiContainer = document.getElementById('recent-flussi-container');
        if (!stats.recent_flussi || stats.recent_flussi.length === 0) {
          recentFlussiContainer.innerHTML = `
            <div class="p-4 text-center text-muted">
              <i class="fas fa-info-circle mb-2" style="font-size: 1.5rem;" aria-hidden="true"></i>
              <p class="mb-0">Nessun flusso sincronizzato presente in archivio.</p>
            </div>
          `;
        } else {
          let rowsHtml = '';
          stats.recent_flussi.forEach(flusso => {
            const isGovpayBadge = flusso.is_govpay == 1 
              ? '<span class="badge bg-primary">Flussi Interni</span>' 
              : '<span class="badge" style="background-color: var(--ms-purple-600); color: #fff;">Flussi Esterni</span>';
            const idFlusso = flusso.id_flusso || '';
            const escapedIdFlusso = encodeURIComponent(idFlusso);
            const slicedIdFlusso = idFlusso.length > 30 ? idFlusso.slice(0, 30) + '...' : idFlusso;

            rowsHtml += `
              <tr>
                <td class="fw-semibold">${flusso.data_regolamento}</td>
                <td>
                  <a href="/pagamenti/ricerca-flussi?q=1&idFlusso=${escapedIdFlusso}&idDominio=${encodeURIComponent('{{ id_dominio }}')}" class="text-decoration-none">
                    <code>${slicedIdFlusso}</code>
                  </a>
                </td>
                <td>${isGovpayBadge}</td>
                <td class="text-end">${fmtNum(flusso.transazioni)}</td>
                <td class="text-end fw-bold">€ ${parseFloat(flusso.importo_totale).toLocaleString('it-IT', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
              </tr>
            `;
          });

          recentFlussiContainer.innerHTML = `
            <div class="table-responsive">
              <table class="table table-striped align-middle mb-0" style="font-size: 0.88rem;">
                <thead>
                  <tr>
                    <th scope="col">Data Regolamento</th>
                    <th scope="col">ID Flusso</th>
                    <th scope="col">Sorgente</th>
                    <th scope="col" class="text-end">Transazioni</th>
                    <th scope="col" class="text-end">Importo Totale</th>
                  </tr>
                </thead>
                <tbody>
                  ${rowsHtml}
                </tbody>
              </table>
            </div>
          `;
        }

        // ── 6. Popola tipologie pendenze (12 mesi) ──
        const boTipologieTotal = document.getElementById('bo-tipologie-total');
        if (boTipologieTotal) {
          boTipologieTotal.textContent = fmtEur(stats.tipologie_total);
        }
        buildGrid(stats.tipologie_stats, stats.tipologie_total);

      } catch (e) {
        console.error('Errore caricamento statistiche dashboard', e);
        const containerIds = ['stats-totals-amount', 'stats-biz-processed', 'stats-tefa-processed', 'recent-flussi-container'];
        containerIds.forEach(id => {
          const el = document.getElementById(id);
          if (el) el.innerHTML = '<span class="text-danger small"><i class="fas fa-exclamation-triangle"></i> Errore</span>';
        });
        // Nascondi la barra backlog in caso di errore (evita che rimanga con il testo di caricamento)
        const backlogBarErr = document.getElementById('bo-backlog-bar');
        if (backlogBarErr) backlogBarErr.classList.add('d-none');
      }
    }

    // ── Daemon Controller AJAX ───────────────────────────────────────
    async function toggleDaemon(job, action) {
      if (!confirm(`Sei sicuro di voler ${action === 'run' ? 'avviare' : 'arrestare'} il servizio ${job}?`)) {
        return;
      }
      
      const btn = event?.currentTarget;
      if (btn) {
        btn.disabled = true;
        btn.innerHTML = `<i class="fas fa-spinner fa-spin me-1"></i> Attendi...`;
      }
      
      try {
        const response = await fetch(`/funzioni-avanzate/cron/${job}/${action}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" }
        });
        const result = await response.json();
        if (result.ok) {
          window.location.reload();
        } else {
          alert("Errore: " + (result.error || "Impossibile completare l'azione."));
          if (btn) btn.disabled = false;
        }
      } catch (e) {
        alert("Errore di rete: " + e.message);
        if (btn) btn.disabled = false;
      }
    }

    // ── Ripartizione Tipologie: period selector + AJAX reload ────────
    const periodoGroup  = document.getElementById('bo-tipologie-periodo');
    const gridWrap      = document.getElementById('bo-tipologie-grid-wrap');
    const totalSpan     = document.getElementById('bo-tipologie-total');
    let expanded        = false;

    function buildGrid(tipologie, total) {
      if (!tipologie || tipologie.length === 0) {
        gridWrap.innerHTML = `
          <div class="p-4 text-center text-muted" id="bo-tipologie-empty">
            <i class="fas fa-info-circle mb-2" style="font-size:1.5rem" aria-hidden="true"></i>
            <p class="mb-0">Nessun dato nel periodo selezionato.</p>
          </div>`;
        return;
      }

      let cardsHtml = '';
      tipologie.forEach(function (item, idx) {
        const percent = total > 0 ? (item.importo_totale / total * 100) : 0;
        const isExtra = idx >= 6;
        cardsHtml += `
          <div class="col-md-6 col-xl-4${isExtra && !expanded ? ' d-none bo-extra-tipologia' : (isExtra ? ' bo-extra-tipologia' : '')}">
            <div class="p-3 border rounded bg-light h-100 d-flex flex-column justify-content-between">
              <div>
                <div class="mb-2">
                  <h4 class="h6 mb-0 text-dark fw-bold" style="font-size:0.92rem;line-height:1.35">${item.tipologia_desc}</h4>
                </div>
                <div class="text-muted small mb-3">
                  <i class="fas fa-circle-check text-success me-1" aria-hidden="true"></i>
                  <strong>${fmtNum(item.transazioni)}</strong> transazioni
                </div>
              </div>
              <div>
                <div class="d-flex justify-content-between align-items-end mb-1">
                  <span class="fw-bold text-dark" style="font-size:1.1rem">${fmtEur(item.importo_totale)}</span>
                  <span class="small fw-semibold text-primary" style="font-size:0.8rem">${percent.toFixed(1)}%</span>
                </div>
                <div class="progress" style="height:6px" title="Quota del ${percent.toFixed(2)}% sul totale">
                  <div class="progress-bar progress-bar-striped bg-primary" role="progressbar"
                       style="width:${percent}%" aria-valuenow="${percent}" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
              </div>
            </div>
          </div>`;
      });

      const toggleWrapHtml = tipologie.length > 6 ? `
        <div class="text-center mt-4" id="bo-tipologie-toggle-wrap">
          <button type="button" id="bo-btn-toggle-tipologie" class="btn btn-outline-primary px-4 py-2">
            <i class="fas fa-chevron-${expanded ? 'up' : 'down'} me-2" id="bo-toggle-icon"></i>
            <span id="bo-toggle-text">${expanded ? 'Mostra meno' : 'Mostra tutte le tipologie (' + tipologie.length + ')'}</span>
          </button>
        </div>` : '';

      gridWrap.innerHTML = `<div class="row g-3" id="bo-tipologie-grid">${cardsHtml}</div>${toggleWrapHtml}`;

      // Re-bind the toggle button
      const toggleBtn = document.getElementById('bo-btn-toggle-tipologie');
      if (toggleBtn) toggleBtn.addEventListener('click', toggleExtraTipologie);
    }

    function toggleExtraTipologie() {
      const extraCards = document.querySelectorAll('.bo-extra-tipologia');
      const btnText    = document.getElementById('bo-toggle-text');
      const btnIcon    = document.getElementById('bo-toggle-icon');
      expanded = !expanded;
      extraCards.forEach(card => {
        card.classList.toggle('d-none', !expanded);
      });
      if (expanded) {
        btnText.textContent = 'Mostra meno';
        btnIcon.className   = 'fas fa-chevron-up me-2';
      } else {
        btnText.textContent = 'Mostra tutte le tipologie (' + (6 + extraCards.length) + ')';
        btnIcon.className   = 'fas fa-chevron-down me-2';
      }
    }

    async function loadTipologie(periodo) {
      gridWrap.innerHTML = `
        <div class="p-5 text-center text-muted">
          <i class="fas fa-spinner fa-spin fa-2x"></i>
        </div>`;
      try {
        const res  = await fetch('/api/dashboard/tipologie?periodo=' + encodeURIComponent(periodo));
        const data = await res.json();
        if (totalSpan) totalSpan.textContent = fmtEur(data.total);
        expanded = false;
        buildGrid(data.tipologie, data.total);
      } catch (e) {
        gridWrap.innerHTML = '<div class="p-4 text-center text-danger">Errore nel caricamento dei dati.</div>';
      }
    }

    // Wire up period buttons
    if (periodoGroup) {
      periodoGroup.addEventListener('click', function (e) {
        const btn = e.target.closest('[data-periodo]');
        if (!btn) return;
        // Update active state
        periodoGroup.querySelectorAll('button').forEach(b => {
          b.classList.toggle('btn-primary', b === btn);
          b.classList.toggle('btn-outline-primary', b !== btn);
        });
        loadTipologie(btn.dataset.periodo);
      });
    }
  </script>
{% endblock %}