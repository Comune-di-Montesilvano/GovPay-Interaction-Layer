<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Configurazione iniziale — GovPay Interaction Layer{% endblock %}</title>
  <link rel="stylesheet" href="/assets/fontawesome/css/all.min.css">
  <link rel="stylesheet" href="/assets/css/no-bootstrap-compat.css">
  <link rel="stylesheet" href="/assets/css/app.css">
  <link rel="stylesheet" href="/assets/css/backoffice-shell.css">
</head>
<body class="bo-setup-body">

<header class="wizard-header">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div class="brand">
        <i class="fa fa-cog me-2"></i>GovPay Interaction Layer — Configurazione guidata
      </div>
      <div class="small opacity-75">
        {% if app_ref_url %}
          <a href="{{ app_ref_url }}" target="_blank" rel="noopener noreferrer"
             class="text-white text-decoration-none" title="Vai al repository GitHub">
            <i class="fab fa-github me-1"></i>{{ app_version_label }}
          </a>
        {% else %}
          <span><i class="fab fa-github me-1"></i>{{ app_version_label }}</span>
        {% endif %}
      </div>
    </div>
  </div>
</header>

<main class="container py-4 bo-setup-main">
  {% block content %}{% endblock %}
</main>
<script src="/assets/js/app.js"></script>
{% block scripts %}{% endblock %}
</body>
</html>
