{% set cp = current_path|default('') %}
{% set is_auth = current_user ? true : false %}
{% set is_admin = is_auth and current_user.role in ['admin','superadmin'] %}
{% set first = is_auth ? current_user.first_name|default('') : '' %}
{% set last = is_auth ? current_user.last_name|default('') : '' %}
{% set display_name = (first != '' or last != '') ? (first ~ (last != '' ? ' ' ~ last|upper : '')) : (is_auth ? current_user.email : 'Utente') %}
{% set initials = ((first|slice(0,1)) ~ (last|slice(0,1)))|upper %}
{% if initials == '' and is_auth %}
  {% set initials = current_user.email|slice(0,2)|upper %}
{% endif %}

{% if is_auth %}
  <button type="button" class="bo-sidebar-backdrop" data-bo-sidebar-close aria-label="Chiudi menu laterale"></button>

  <aside class="bo-sidebar" id="boSidebar" aria-label="Navigazione principale backoffice">
    <a class="bo-sidebar-brand" href="/" aria-label="Vai alla dashboard">
      <span class="bo-sidebar-brand-mark" aria-hidden="true">
        {% if app_logo.type == 'img' %}
          <img src="{{ app_logo.src }}" alt="" class="bo-brand-logo-img">
        {% else %}
          <i class="fas fa-building bo-brand-logo-fallback" aria-hidden="true"></i>
        {% endif %}
      </span>
      <span class="bo-sidebar-brand-copy">
        <span class="bo-sidebar-brand-title">{{ app_entity.name }}</span>
        <span class="bo-sidebar-brand-subtitle">Sportello pagamenti</span>
      </span>
    </a>

    <nav class="bo-nav" aria-label="Menu backoffice">
      <div class="bo-nav-section-title">Operativo</div>

      <a class="bo-nav-item {{ cp == '/' ? 'is-active' : '' }}" href="/">
        <i class="fas fa-chart-line" aria-hidden="true"></i>
        <span>Dashboard</span>
      </a>

      <a class="bo-nav-item" href="/pendenze/ricerca">
        <i class="fas fa-file-invoice-dollar" aria-hidden="true"></i>
        <span>Pendenze</span>
      </a>
      <a class="bo-nav-subitem {{ cp starts with '/pendenze/ricerca' ? 'is-active' : '' }}" href="/pendenze/ricerca">
        <i class="fas fa-search" aria-hidden="true"></i>
        <span>Ricerca pendenze</span>
      </a>
      <a class="bo-nav-subitem {{ cp == '/pendenze/inserimento' ? 'is-active' : '' }}" href="/pendenze/inserimento">
        <i class="fas fa-plus-circle" aria-hidden="true"></i>
        <span>Nuova Pendenza</span>
      </a>
      {% if bollot_attivo is defined and bollot_attivo %}
        <a class="bo-nav-subitem {{ cp == '/pendenze/nuova-bollo' ? 'is-active' : '' }}" href="/pendenze/nuova-bollo">
          <i class="fas fa-stamp" aria-hidden="true"></i>
          <span>Nuova marca da bollo</span>
        </a>
      {% endif %}
      <a class="bo-nav-subitem {{ cp == '/pendenze/massivo/inserimento' ? 'is-active' : '' }}" href="/pendenze/massivo/inserimento">
        <i class="fas fa-file-upload" aria-hidden="true"></i>
        <span>Pendenze Massive</span>
      </a>
      <a class="bo-nav-subitem {{ cp == '/pendenze/massivo/storico' ? 'is-active' : '' }}" href="/pendenze/massivo/storico">
        <i class="fas fa-history" aria-hidden="true"></i>
        <span>Storico Massivo</span>
      </a>
      
      <a class="bo-nav-item" href="/pagamenti/ricerca-flussi">
        <i class="fas fa-landmark" aria-hidden="true"></i>
        <span>Ragioneria</span>
      </a>
      <a class="bo-nav-subitem {{ cp starts with '/pagamenti/ricerca-flussi' ? 'is-active' : '' }}" href="/pagamenti/ricerca-flussi">
        <i class="fas fa-search" aria-hidden="true"></i>
        <span>Ricerca flussi</span>
      </a>
      <a class="bo-nav-subitem {{ cp starts with '/pagamenti/incassi-tassonomia' ? 'is-active' : '' }}" href="/pagamenti/incassi-tassonomia">
        <i class="fas fa-receipt" aria-hidden="true"></i>
        <span>Report incassi</span>
      </a>
      <a class="bo-nav-subitem {{ cp starts with '/pagamenti/report-ragioneria' ? 'is-active' : '' }}" href="/pagamenti/report-ragioneria">
        <i class="fas fa-book" aria-hidden="true"></i>
        <span>Report ragioneria</span>
      </a>
      {% if tefa_enabled is defined and tefa_enabled %}
        <a class="bo-nav-subitem {{ cp starts with '/pagamenti/report-tefa' ? 'is-active' : '' }}" href="/pagamenti/report-tefa">
          <i class="fas fa-university" aria-hidden="true"></i>
          <span>Report TEFA</span>
        </a>
      {% endif %}
      <a class="bo-nav-item {{ cp starts with '/statistiche' ? 'is-active' : '' }}" href="/statistiche">
        <i class="fas fa-chart-pie" aria-hidden="true"></i>
        <span>Statistiche</span>
      </a>

      <div class="bo-nav-section-title">Funzioni avanzate</div>
      <a class="bo-nav-item {{ cp starts with '/funzioni-avanzate/cron' ? 'is-active' : '' }}" href="/funzioni-avanzate/cron">
        <i class="fas fa-clock" aria-hidden="true"></i>
        <span>Cron / Servizi</span>
      </a>
      <a class="bo-nav-item {{ cp starts with '/funzioni-avanzate/mapping-pendenze' ? 'is-active' : '' }}" href="/funzioni-avanzate/mapping-pendenze">
        <i class="fas fa-route" aria-hidden="true"></i>
        <span>Mapping pendenze est.</span>
      </a>

      <div class="bo-nav-section-title">Sistema</div>

      {% if is_admin %}
        {% set in_impostazioni = cp starts with '/impostazioni' or cp starts with '/configurazione' %}
        <a class="bo-nav-item {{ in_impostazioni ? 'is-active' : '' }}" href="/impostazioni">
          <i class="fas fa-sliders-h" aria-hidden="true"></i>
          <span>Impostazioni</span>
        </a>
      {% endif %}

      <a class="bo-nav-item {{ cp == '/guida' ? 'is-active' : '' }}" href="/guida">
        <i class="fas fa-question-circle" aria-hidden="true"></i>
        <span>Guida</span>
      </a>
    </nav>

    <div class="bo-sidebar-meta">
      <span class="bo-sidebar-status-dot" aria-hidden="true"></span>
      <span>Online</span>
      {% if app_ref_url %}
        <a class="bo-sidebar-version" href="{{ app_ref_url }}" target="_blank" rel="noopener noreferrer" title="Vai al repository GitHub ({{ app_version_label }})">
          <i class="fab fa-github me-1" aria-hidden="true"></i>{{ app_version_label }}
        </a>
      {% elseif app_repo_url %}
        <a class="bo-sidebar-version" href="{{ app_repo_url }}" target="_blank" rel="noopener noreferrer" title="Vai al repository GitHub ({{ app_version_label }})">
          <i class="fab fa-github me-1" aria-hidden="true"></i>{{ app_version_label }}
        </a>
      {% else %}
        <span class="bo-sidebar-version">{{ app_version_label }}</span>
      {% endif %}
    </div>
  </aside>

  <header class="bo-topbar" role="banner">
    <button type="button" class="bo-topbar-icon-btn" id="boSidebarToggle" aria-controls="boSidebar" aria-label="Apri o chiudi menu laterale" aria-expanded="false">
      <i class="fas fa-bars" aria-hidden="true"></i>
    </button>

    <form class="bo-topbar-search" id="bo-smart-search" method="get" action="/pendenze/ricerca" role="search">
      <i class="fas fa-search" aria-hidden="true"></i>
      <input type="search" id="bo-smart-search-input" name="q" placeholder="Cerca CF, P.IVA, IUV o ID flusso" autocomplete="off">
      <span id="bo-search-badge" class="bo-search-badge" aria-hidden="true"></span>
    </form>

    <div class="bo-topbar-actions">
      <a href="/guida" class="bo-topbar-icon-btn" aria-label="Apri guida">
        <i class="fas fa-question-circle" aria-hidden="true"></i>
      </a>

      <details class="bo-user-menu">
        <summary aria-label="Apri menu utente">
          <span class="bo-user-avatar">{{ initials }}</span>
          <span class="bo-user-copy">
            <strong>{{ display_name }}</strong>
            <small>{{ current_user.role|upper }}</small>
          </span>
          <i class="fas fa-chevron-down" aria-hidden="true"></i>
        </summary>
        <div class="bo-user-dropdown" role="menu">
          <a href="/profile" class="{{ cp == '/profile' ? 'is-active' : '' }}" role="menuitem">Profilo</a>
          <a href="/logout" class="is-danger" role="menuitem">Logout</a>
        </div>
      </details>
    </div>
  </header>
{% else %}
  <header class="bo-guest-topbar" role="banner">
    <a class="bo-guest-brand" href="/login">{{ app_entity.name }}</a>
    <nav class="bo-guest-nav" aria-label="Menu pubblico backoffice">
      <a class="{{ cp == '/guida' ? 'is-active' : '' }}" href="/guida">Guida</a>
      <a class="{{ cp == '/login' ? 'is-active' : '' }}" href="/login">Login</a>
    </nav>
  </header>
{% endif %}