{% extends 'base.html.twig' %}
{% block content %}
<div class="container-fluid py-4">
  <h1 class="h4 mb-3"><i class="fas fa-scale-balanced me-2"></i>Rendicontazione — Da confermare</h1>

  {% for f in flash %}
    <div class="alert alert-{{ f.type == 'error' ? 'danger' : f.type }}">{{ f.text }}</div>
  {% endfor %}

  {% if righe|length == 0 %}
    <div class="alert alert-info">Nessun pagamento in attesa di conferma.</div>
  {% else %}
    <form method="post" action="/rendicontazione/conferma">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
          <thead>
            <tr>
              <th><input type="checkbox" onclick="document.querySelectorAll('.riga-check:not([disabled])').forEach(c=>c.checked=this.checked)"></th>
              <th>IUV</th>
              <th>Debitore</th>
              <th>Tipologia</th>
              <th>Causale</th>
              <th class="text-end">Importo</th>
              <th>Data pagamento</th>
            </tr>
          </thead>
          <tbody>
            {% for r in righe %}
              <tr>
                <td>
                  {% if r.cod_entrata in action_entrate %}
                    <input class="form-check-input riga-check" type="checkbox" name="riga_ids[]" value="{{ r.id }}">
                  {% else %}
                    <input class="form-check-input riga-check" type="checkbox" disabled title="Permessi insufficienti per smarcare questa tipologia">
                  {% endif %}
                </td>
                <td class="font-monospace small">
                  {% if r.id_pendenza %}
                    <a href="/pendenze/dettaglio/{{ r.id_pendenza|url_encode }}?return={{ '/rendicontazione/da-confermare'|url_encode }}">{{ r.iuv_completo }}</a>
                  {% else %}
                    {{ r.iuv_completo }}
                  {% endif %}
                </td>
                <td>
                  <div class="fw-semibold">{{ r.debitore_nome }}</div>
                  <div class="small text-muted font-monospace">{{ r.debitore_cf }}</div>
                </td>
                <td><span class="badge bg-light text-dark border">{{ r.cod_entrata }}</span></td>
                <td class="small text-muted">{{ r.descrizione_entrata }}</td>
                <td class="text-end">&euro; {{ r.importo|number_format(2, ',', '.') }}</td>
                <td>{{ r.data_pagamento }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <button type="submit" class="btn btn-primary">Conferma selezionate</button>
    </form>

    {% set totalPages = (totale / per_page)|round(0, 'ceil') %}
    {% if totalPages > 1 %}
      <nav class="mt-3">
        <ul class="pagination">
          {% for p in 1..totalPages %}
            <li class="page-item {{ p == page ? 'active' : '' }}">
              <a class="page-link" href="?page={{ p }}">{{ p }}</a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}
  {% endif %}
</div>
{% endblock %}
