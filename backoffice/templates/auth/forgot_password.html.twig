{% extends 'base.html.twig' %}

{% block title %}Password dimenticata — {{ parent() }}{% endblock %}

{% block content %}
<section class="bo-login-wrap bo-login-wrap-auth">
  <div class="bo-login-grid">
    <aside class="bo-login-hero">
      <div class="bo-login-brand">
        <span class="bo-login-brand-mark" aria-hidden="true">
          {% if app_logo.type == 'img' %}
            <img src="{{ app_logo.src }}" alt="" class="bo-login-brand-logo-img">
          {% else %}
            <i class="fas fa-building bo-login-brand-logo-fallback" aria-hidden="true"></i>
          {% endif %}
        </span>
        <div class="bo-login-brand-copy">
          <strong>{{ app_entity.name }}</strong>
          <small>{{ app_entity.suffix }}</small>
        </div>
      </div>

      <p class="bo-login-kicker">Recupero accesso</p>
      <h1>Password dimenticata</h1>
      <p class="bo-login-lead">
        Inserisci l'email associata al tuo account: riceverai un link temporaneo per impostare una nuova password.
      </p>
      <ul class="bo-login-points">
        <li><i class="fas fa-envelope-open-text" aria-hidden="true"></i>Link inviato solo se l'account esiste</li>
        <li><i class="fas fa-clock" aria-hidden="true"></i>Validita del link: 60 minuti</li>
        <li><i class="fas fa-user-shield" aria-hidden="true"></i>Nessuna informazione sensibile mostrata</li>
      </ul>
      <div class="bo-login-meta">
        <span class="bo-login-dot" aria-hidden="true"></span>
        <span>Procedura sicura di reset</span>
      </div>
    </aside>

    <div class="bo-login-card">
      <h2>Recupera password</h2>
      <p>Compila il campo email per continuare.</p>

      {% if success %}
        <div class="alert alert-success">
          <strong>Controlla la tua email.</strong><br>
          Se esiste un account associato a quell'indirizzo, riceverai un link entro pochi minuti.<br>
          <small class="text-muted">Il link scade dopo 60 minuti.</small>
        </div>
        <a href="/login" class="btn btn-outline-primary mt-2">Torna al login</a>
      {% else %}
        {% if error %}
          <div class="alert alert-danger">{{ error }}</div>
        {% endif %}

        <form method="post" action="/password-dimenticata" class="bo-login-form">
          <div class="mb-3">
            <label for="email" class="form-label">Indirizzo email</label>
            <input type="email" class="form-control" id="email" name="email" required autofocus placeholder="nome@esempio.it" autocomplete="email">
          </div>
          <button type="submit" class="btn btn-primary w-100 bo-login-submit">Invia link di reset</button>
          <div class="bo-login-links mt-3">
            <a href="/login" class="small">Torna al login</a>
            <a href="/guida" class="small text-muted">Guida operativa</a>
          </div>
        </form>
      {% endif %}
    </div>
  </div>
</section>
{% endblock %}
