{% extends 'base.html.twig' %}

{% block title %}Reimposta password — {{ parent() }}{% endblock %}

{% block content %}
<section class="bo-login-wrap bo-login-wrap-auth">
  <div class="bo-login-grid">
    <aside class="bo-login-hero">
      <div class="bo-login-brand">
        <span class="bo-login-brand-mark" aria-hidden="true">
          {% if app_logo.type == 'img' %}
            <img src="{{ app_logo.src }}" alt="" class="bo-login-brand-logo-img">
          {% else %}
            <i class="fas fa-building bo-login-brand-logo-fallback" aria-hidden="true"></i>
          {% endif %}
        </span>
        <div class="bo-login-brand-copy">
          <strong>{{ app_entity.name }}</strong>
          <small>{{ app_entity.suffix }}</small>
        </div>
      </div>

      <p class="bo-login-kicker">Aggiornamento credenziali</p>
      <h1>Reimposta password</h1>
      <p class="bo-login-lead">
        Imposta una nuova password robusta per il tuo account operatore backoffice.
      </p>
      <ul class="bo-login-points">
        <li><i class="fas fa-lock" aria-hidden="true"></i>Password minima di 8 caratteri</li>
        <li><i class="fas fa-key" aria-hidden="true"></i>Token monouso e a scadenza</li>
        <li><i class="fas fa-shield-check" aria-hidden="true"></i>Aggiornamento immediato delle credenziali</li>
      </ul>
      <div class="bo-login-meta">
        <span class="bo-login-dot" aria-hidden="true"></span>
        <span>Canale protetto</span>
      </div>
    </aside>

    <div class="bo-login-card">
      <h2>Nuova password</h2>
      <p>Compila i campi per completare il reset.</p>

      {% if token_error is defined and token_error %}
        <div class="alert alert-danger">
          <strong>Link non valido.</strong><br>
          {{ error }}
        </div>
        <a href="/password-dimenticata" class="btn btn-primary mt-2">Richiedi un nuovo link</a>
      {% else %}
        {% if error %}
          <div class="alert alert-danger">{{ error }}</div>
        {% endif %}

        <form method="post" action="/reset-password" class="bo-login-form">
          <input type="hidden" name="token" value="{{ token|e }}">

          <div class="mb-3">
            <label for="password" class="form-label">Nuova password</label>
            <input type="password" class="form-control" id="password" name="password" required minlength="8" autofocus autocomplete="new-password">
          </div>

          <div class="mb-3">
            <label for="password_confirm" class="form-label">Conferma password</label>
            <input type="password" class="form-control" id="password_confirm" name="password_confirm" required minlength="8" autocomplete="new-password">
          </div>

          <button type="submit" class="btn btn-primary w-100 bo-login-submit">Salva nuova password</button>

          <div class="bo-login-links mt-3">
            <a href="/login" class="small">Torna al login</a>
            <a href="/guida" class="small text-muted">Guida operativa</a>
          </div>
        </form>
      {% endif %}
    </div>
  </div>
</section>
{% endblock %}
