{% extends 'base.html.twig' %}

{% block title %}Report Ragioneria{% endblock %}

{% block content %}
  <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-2 mb-4">
    <div>
      <h1 class="h4 mb-1">Report ragioneria</h1>
      <p class="text-muted mb-0">Incassi reali da flussi di rendicontazione pagoPA, per tipologia e data flusso</p>
    </div>
    <div class="d-flex gap-2">
      {% if csv_link %}
        <a href="{{ csv_link }}" class="btn btn-outline-primary">Export CSV</a>
      {% endif %}
      {% if refresh_cache_url %}
        <a href="{{ refresh_cache_url }}" class="btn btn-outline-warning">Rigenera cache</a>
      {% endif %}
      <a href="/" class="btn btn-outline-secondary">Home</a>
    </div>
  </div>

  {% if errors is defined and errors %}
    <div class="alert alert-danger" role="alert">
      <ul class="mb-0">
        {% for e in errors %}<li>{{ e }}</li>{% endfor %}
      </ul>
    </div>
  {% endif %}

  {% set f = filters ?? {} %}
  {% set biz = biz_counts|default({'PENDING': 0, 'PROCESSED': 0, 'ERROR': 0, 'SKIPPED': 0, 'total': 0}) %}
  <div class="card shadow-sm mb-4 border-danger-subtle">
    <div class="card-header bg-danger bg-opacity-10 border-bottom py-3 d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-2">
      <div>
        <h2 class="h6 mb-0">Stato pendenze Biz</h2>
        <p class="small text-muted mb-0">Contatori globali su tabella biz_ricevute per il dominio selezionato</p>
      </div>
      <form method="post" action="/pagamenti/report-ragioneria/biz-reset-errors" class="m-0">
        <input type="hidden" name="idDominio" value="{{ f.idDominio|default('') }}">
        <input type="hidden" name="return_url" value="/pagamenti/report-ragioneria?q=1&idDominio={{ f.idDominio|default('')|url_encode }}">
        <button type="submit" class="btn btn-outline-danger" {% if (biz.ERROR|default(0)) <= 0 %}disabled{% endif %}>
          Reset errori Biz ({{ biz.ERROR|default(0) }})
        </button>
      </form>
    </div>
    <div class="card-body">
      <div class="row g-3 text-center">
        <div class="col-6 col-md-2">
          <div class="small text-muted text-uppercase">Totali</div>
          <div class="h4 mb-0">{{ biz.total|default(0) }}</div>
        </div>
        <div class="col-6 col-md-2">
          <div class="small text-muted text-uppercase">Pending</div>
          <div class="h4 mb-0 text-primary">{{ biz.PENDING|default(0) }}</div>
        </div>
        <div class="col-6 col-md-2">
          <div class="small text-muted text-uppercase">Processed</div>
          <div class="h4 mb-0 text-success">{{ biz.PROCESSED|default(0) }}</div>
        </div>
        <div class="col-6 col-md-2">
          <div class="small text-muted text-uppercase">Error</div>
          <div class="h4 mb-0 text-danger">{{ biz.ERROR|default(0) }}</div>
        </div>
        <div class="col-6 col-md-2">
          <div class="small text-muted text-uppercase">Skipped</div>
          <div class="h4 mb-0 text-secondary">{{ biz.SKIPPED|default(0) }}</div>
        </div>
      </div>
    </div>
  </div>

  {# ── Filtri ──────────────────────────────────────────────────────────── #}
  <form method="get" action="/pagamenti/report-ragioneria" class="card shadow-sm mb-4" id="reportRagioneriaForm">
    <input type="hidden" name="q" value="1">
    <div class="card-header bg-light border-bottom py-3">
      <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-lg-between gap-2">
        <div>
          <h2 class="h6 mb-0">Filtri</h2>
          <p class="small text-muted mb-0">Il periodo si riferisce alla <strong>data flusso</strong> (data emissione flusso bancario)</p>
        </div>
        <button type="submit" class="btn btn-primary" id="reportRagioneriaSubmit">Aggiorna</button>
      </div>
    </div>
    <div class="card-body">
      <div id="reportRagioneriaLoading" class="alert alert-info d-none" role="status" aria-live="polite">
        <div class="d-flex align-items-center gap-2 mb-2">
          <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
          <span id="reportRagioneriaLoadingText">Elaborazione backend in corso...</span>
        </div>
        <div class="progress" style="height: 1.5rem;">
          <div id="reportRagioneriaProgressBar" class="progress-bar progress-bar-striped progress-bar-animated fw-semibold" role="progressbar" style="width: 0%; min-width: 4.5rem;">0%</div>
        </div>
      </div>
      <div class="row g-3">
        <div class="col-md-5">
          <label for="dataDaVis" class="form-label">Intervallo data flusso</label>
          <div class="d-flex gap-1 align-items-center">
            <input type="text" id="dataDaVis" class="form-control form-control-sm" placeholder="Da" autocomplete="off" readonly style="cursor:pointer;">
            <span class="text-muted small">-</span>
            <input type="text" id="dataAVis" class="form-control form-control-sm" placeholder="A" autocomplete="off" readonly style="cursor:pointer;">
          </div>
          <input type="hidden" id="dataDa" name="dataDa" value="{{ f.dataDa|default('') }}">
          <input type="hidden" id="dataA" name="dataA" value="{{ f.dataA|default('') }}">
        </div>
        <div class="col-md-7">
          <label for="tassonomie" class="form-label">Tipologie (lascia vuoto = tutte)</label>
          <select class="form-select" id="tassonomie" name="tassonomie[]" multiple aria-label="Seleziona tassonomie">
            {% for tipo in tipologie_censite|default([]) %}
              {% set tid = tipo.id_entrata|default('') %}
              <option value="{{ tid }}" {% if tid in (f.tassonomie|default([])) %}selected{% endif %}>{{ tipo.descrizione|default(tid) }}</option>
            {% endfor %}
          </select>
          <div class="form-text">Ricerca e selezione multipla.</div>
        </div>
      </div>

      <div class="row g-3 mt-2">
        <div class="col-12">
          <button class="btn btn-link px-0" type="button" data-bs-toggle="collapse" data-bs-target="#advancedFiltersRagioneria" aria-expanded="false" aria-controls="advancedFiltersRagioneria">
            Filtri avanzati
          </button>
        </div>
      </div>

      <div class="collapse mt-2" id="advancedFiltersRagioneria">
        <fieldset class="row g-3">
          <legend class="visually-hidden">Filtri avanzati report ragioneria</legend>
          <div class="col-md-3">
            <label for="idDominio" class="form-label">ID Dominio</label>
            <input type="text" class="form-control" id="idDominio" name="idDominio" value="{{ f.idDominio|default('') }}" placeholder="(opzionale)">
          </div>
        </fieldset>
      </div>
    </div>
  </form>

  {% if query_made and cache_info %}
    <div class="alert alert-secondary small">
      <strong>Sorgente dati:</strong> {{ cache_info.source|default('n/d')|upper }}
      {% if cache_info.stored_at %}
        <span class="ms-3"><strong>Creata:</strong> {{ cache_info.stored_at }}</span>
      {% endif %}
      {% if cache_info.expires_at %}
        <span class="ms-3"><strong>Scadenza:</strong> {{ cache_info.expires_at }}</span>
      {% endif %}
    </div>
  {% endif %}

  {# ── KPI ──────────────────────────────────────────────────────────────── #}
  {% set has_data = query_made and rows is defined and rows %}
  {% if has_data %}
    <div class="row g-3 mb-4">
      <div class="col-md-4">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="text-muted text-uppercase small mb-1">Importo totale rendicontato</div>
            <div class="display-6 fw-bold">€ {{ totals.amount|default(0)|number_format(2, ',', '.') }}</div>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="text-muted text-uppercase small mb-1">Rendicontazioni</div>
            <div class="display-6 fw-bold">{{ totals.count|default(0)|number_format(0, ',', '.') }}</div>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="text-muted text-uppercase small mb-1">Flussi processati</div>
            <div class="display-6 fw-bold">{{ meta.flussi_processati|default(0) }}</div>
          </div>
        </div>
      </div>
    </div>

    {# ── Riepilogo per tipologia ───────────────────────────────────────── #}
    {% if by_tipologia is defined and by_tipologia %}
      <h3 class="h6 mb-2">Riepilogo per tipologia</h3>
      <div class="card shadow-sm mb-4">
        <div class="table-responsive">
          <table id="tableTipologia" class="table table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th scope="col" class="stats-sort" data-col="0" style="cursor:pointer;" title="Ordina">Tipologia (cod. entrata) <i class="fas fa-sort text-muted ms-1 small"></i></th>
                <th scope="col" class="stats-sort text-end" data-col="1" style="cursor:pointer;" title="Ordina">N. rendicontazioni <i class="fas fa-sort text-muted ms-1 small"></i></th>
                <th scope="col" class="stats-sort text-end" data-col="2" style="cursor:pointer;" title="Ordina">Importo totale <i class="fas fa-sort text-muted ms-1 small"></i></th>
              </tr>
            </thead>
            <tbody>
              {% for agg in by_tipologia %}
                <tr>
                  <td><strong>{{ agg.tassonomia_label|default(agg.tassonomia) }}</strong></td>
                  <td class="text-end">{{ agg.count|number_format(0, ',', '.') }}</td>
                  <td class="text-end">€ {{ agg.amount|number_format(2, ',', '.') }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% endif %}

    {# ── Dettaglio righe ──────────────────────────────────────────────── #}
    <h3 class="h6 mb-2">Dettaglio rendicontazioni</h3>
    <div class="card shadow-sm mb-4">
      <div class="table-responsive">
        <table class="table table-striped align-middle mb-0 small">
          <thead>
            <tr>
              <th scope="col">Data flusso</th>
              <th scope="col">Data regolamento</th>
              <th scope="col">Tipologia</th>
              <th scope="col">IUV</th>
              <th scope="col">IUR</th>
              <th scope="col">Stato</th>
              <th scope="col" title="0=pagato, 3=revocato, 9=senza RPT">Esito</th>
              <th scope="col" class="text-end">Importo</th>
              <th scope="col"></th>
            </tr>
          </thead>
          <tbody>
            {% for row in rows %}
              <tr>
                <td>{{ row.data_flusso|default('')|slice(0, 10) }}</td>
                <td>{{ row.data_regolamento|default('')|slice(0, 10) }}</td>
                <td>{{ row.tassonomia_label|default(row.tassonomia|default('N/D')) }}</td>
                <td class="text-nowrap">{{ row.iuv|default('') }}</td>
                <td>{{ row.iur|default('') }}</td>
                <td>{{ row.stato_rend|default('') }}</td>
                <td>
                  {% if row.esito == 0 %}
                    <span class="badge bg-success">Pagato</span>
                  {% elseif row.esito == 3 %}
                    <span class="badge bg-warning text-dark">Revocato</span>
                  {% elseif row.esito == 9 %}
                    <span class="badge bg-secondary">Senza RPT</span>
                  {% else %}
                    {{ row.esito }}
                  {% endif %}
                </td>
                <td class="text-end">€ {{ row.importo|default(0)|number_format(2, ',', '.') }}</td>
                <td class="text-center">
                  {% if row.id_pendenza|default('') %}
                    <a href="/pendenze/dettaglio/{{ row.id_pendenza|url_encode }}" class="btn btn-outline-secondary btn-sm py-0 px-1" title="Apri dettaglio pendenza" target="_blank">
                      <i class="fas fa-external-link-alt fa-xs"></i>
                    </a>
                  {% elseif row.iuv|default('') %}
                    <a href="/pendenze/ricerca?iuv={{ row.iuv|url_encode }}&q=1" class="btn btn-outline-secondary btn-sm py-0 px-1" title="Cerca pendenza per IUV" target="_blank">
                      <i class="fas fa-external-link-alt fa-xs"></i>
                    </a>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      {% if num_pagine is defined and num_pagine > 1 %}
        <div class="card-footer bg-white border-top py-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
          <div class="small text-muted">
            Pagina {{ filters.page|default(1) }} di {{ num_pagine }} · {{ page_size|default(50) }} righe per pagina
          </div>
          <div class="btn-group" role="group" aria-label="Paginazione report ragioneria">
            {% if prev_url %}
              <a class="btn btn-outline-primary" href="{{ prev_url }}">&laquo; Precedente</a>
            {% else %}
              <button class="btn btn-outline-secondary" disabled>&laquo; Precedente</button>
            {% endif %}
            {% if next_url %}
              <a class="btn btn-outline-primary" href="{{ next_url }}">Successiva &raquo;</a>
            {% else %}
              <button class="btn btn-outline-secondary" disabled>Successiva &raquo;</button>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>

  {% elseif query_made and (errors is not defined or not errors) %}
    <div class="alert alert-info">Nessun dato: avvia il daemon Ragioneria da Impostazioni -> Cron</div>
  {% endif %}

  {# ── Debug ────────────────────────────────────────────────────────────── #}
  {% if app_debug and meta %}
    <div class="card shadow-sm mb-4 border-warning">
      <div class="card-header bg-warning bg-opacity-10 py-2">
        <span class="badge bg-warning text-dark me-2">Debug</span>Metadati chiamata
      </div>
      <div class="card-body small">
        <ul class="mb-0">
          <li>Flussi processati: {{ meta.flussi_processati|default(0) }}</li>
          <li>Rendicontazioni totali (post-filtro): {{ meta.rendicontazioni_totali|default(0) }}</li>
          <li>Tassonomie filtrate: {{ (meta.tassonomie_filtrate|default([]))|join(', ') ?: '(tutte)' }}</li>
        </ul>
      </div>
    </div>
  {% endif %}

  {% if app_debug %}
    <div class="card shadow-sm mb-4 border-warning">
      <div class="card-header bg-warning bg-opacity-10 py-2 d-flex align-items-center gap-2">
        <span class="badge bg-warning text-dark">Debug</span>
        <span>Raw payload API</span>
        <button class="btn btn-sm btn-outline-secondary ms-auto" type="button"
                data-bs-toggle="collapse" data-bs-target="#rawPayload"
                aria-expanded="false" aria-controls="rawPayload">Mostra/Nascondi</button>
      </div>
      <div id="rawPayload" class="collapse">
        <div class="card-body">
          {% if raw_payload_json %}
            <pre class="small text-break mb-0" style="max-height:400px;overflow-y:auto">{{ raw_payload_json }}</pre>
          {% else %}
            <div class="small text-muted">Dati raw non disponibili.</div>
          {% endif %}
        </div>
      </div>
    </div>
  {% endif %}
{% endblock %}

{% block scripts %}
<script>
(function () {
  const form = document.getElementById('reportRagioneriaForm');
  const submitButton = document.getElementById('reportRagioneriaSubmit');
  const loadingBox = document.getElementById('reportRagioneriaLoading');
  if (form && submitButton && loadingBox) {
    form.addEventListener('submit', function (evt) {
      submitButton.disabled = true;
      loadingBox.classList.remove('d-none');
    });
  }

  const tipologieEl = document.getElementById('tassonomie');
  if (tipologieEl && typeof TomSelect !== 'undefined') {
    new TomSelect(tipologieEl, {
      create: false,
      sortField: { field: 'text', direction: 'asc' },
      maxOptions: 10000,
      placeholder: 'Cerca tipologia...'
    });
  }

  const elDa  = document.getElementById('dataDaVis');
  const elA   = document.getElementById('dataAVis');
  const hidDa = document.getElementById('dataDa');
  const hidA  = document.getElementById('dataA');

  if (elDa && elA && hidDa && hidA && typeof Litepicker !== 'undefined') {
    const toIt = (iso) => {
      if (!iso) return '';
      const parts = iso.split('-');
      if (parts.length !== 3) return iso;
      return parts[2] + '/' + parts[1] + '/' + parts[0];
    };

    if (hidDa.value) elDa.value = toIt(hidDa.value);
    if (hidA.value)  elA.value  = toIt(hidA.value);

    new Litepicker({
      element: elDa,
      elementEnd: elA,
      singleMode: false,
      format: 'DD/MM/YYYY',
      lang: 'it-IT',
      autoApply: true,
      resetButton: true,
      numberOfMonths: 1,
      numberOfColumns: 1,
      tooltipText: { one: 'giorno', other: 'giorni' },
      setup(p) {
        p.on('selected', (d1, d2) => {
          hidDa.value = d1.format('YYYY-MM-DD');
          hidA.value = d2.format('YYYY-MM-DD');
        });
        p.on('clear:selection', () => {
          hidDa.value = '';
          hidA.value = '';
          elDa.value = '';
          elA.value = '';
        });
      }
    });
  }

  const tipologiaTable = document.getElementById('tableTipologia');
  if (tipologiaTable) {
    let sortCol = -1;
    let sortAsc = true;
    const numericColumns = [1, 2];
    tipologiaTable.querySelectorAll('th.stats-sort').forEach(function (th) {
      th.addEventListener('click', function () {
        const col = parseInt(th.dataset.col || '-1', 10);
        if (col < 0) return;
        sortAsc = sortCol === col ? !sortAsc : true;
        sortCol = col;

        const tbody = tipologiaTable.querySelector('tbody');
        if (!tbody) return;
        const rows = Array.from(tbody.querySelectorAll('tr'));
        rows.sort(function (a, b) {
          const rawA = (a.cells[col] && a.cells[col].textContent) ? a.cells[col].textContent : '';
          const rawB = (b.cells[col] && b.cells[col].textContent) ? b.cells[col].textContent : '';
          let cmp = 0;
          if (numericColumns.indexOf(col) !== -1) {
            const norm = function (s) {
              return s.trim().replace(/[^0-9,.-]/g, '').replace(/\./g, '').replace(',', '.');
            };
            const an = parseFloat(norm(rawA));
            const bn = parseFloat(norm(rawB));
            if (isNaN(an) || isNaN(bn)) {
              cmp = rawA.localeCompare(rawB, 'it');
            } else {
              cmp = an - bn;
            }
          } else {
            cmp = rawA.localeCompare(rawB, 'it');
          }
          return sortAsc ? cmp : -cmp;
        });

        rows.forEach(function (r) { tbody.appendChild(r); });
        tipologiaTable.querySelectorAll('th.stats-sort i').forEach(function (i) {
          i.className = 'fas fa-sort text-muted ms-1 small';
        });
        const icon = th.querySelector('i');
        if (icon) {
          icon.className = 'fas fa-sort-' + (sortAsc ? 'up' : 'down') + ' text-primary ms-1 small';
        }
      });
    });
  }
})();
</script>
{% endblock %}
