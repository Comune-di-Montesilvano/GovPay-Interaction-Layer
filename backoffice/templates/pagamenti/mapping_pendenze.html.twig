{% extends 'base.html.twig' %}

{% block title %}Mapping Pendenze Esterne - GovPay{% endblock %}

{% block content %}
  {% set is_admin = current_user.role in ['admin', 'superadmin'] %}

  {# ── Read-only Warning for Operator Roles ── #}
  {% if not is_admin %}
    <div class="alert alert-info shadow-sm d-flex align-items-center gap-2 mb-4" role="alert" style="border-radius: 8px;">
      <i class="fas fa-info-circle fs-5 text-primary" aria-hidden="true"></i>
      <span>Sei connesso come <strong>{{ current_user.role|upper }}</strong> (Sola Lettura). Le funzioni avanzate di configurazione e reset del mapping pendenze esterne sono riservate agli amministratori.</span>
    </div>
  {% endif %}

  {# ── Page header ── #}
  <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-2 mb-4">
    <div>
      <h1 class="h4 mb-1">Mapping Pendenze Esterne</h1>
      <p class="text-muted mb-0">Associa fornitori e tipologie contabili alle transazioni PagoPA esterne in due fasi: <strong>L1</strong> identifica il fornitore tramite prefisso IUV, <strong>L2</strong> classifica la tipologia tramite vocabolario keyword.</p>
    </div>
  </div>

  {# ── Flash alerts ── #}
  {% if flash is defined and flash is not empty %}
    {% for message in flash %}
      <div class="alert alert-{{ message.type }} alert-dismissible fade show shadow-sm" role="alert" style="border-radius: 8px;">
        {% if message.type == 'success' %}
          <i class="fas fa-circle-check me-2"></i>
        {% else %}
          <i class="fas fa-circle-exclamation me-2"></i>
        {% endif %}
        {{ message.text }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    {% endfor %}
  {% endif %}

  {# ── Stats & Remap ── #}
  <div class="card shadow-sm border-0 mb-4 bg-white" style="border-radius: var(--bo-radius, 10px);">
    <div class="card-header bg-light py-3 border-bottom d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div class="d-flex align-items-center gap-2">
        <i class="fas fa-chart-pie text-primary fs-5"></i>
        <h3 class="h6 mb-0 fw-bold">Statistiche Copertura Mapping</h3>
      </div>
      <div class="d-flex align-items-center gap-3">
        <span class="small text-muted d-none d-sm-inline">
          Gestisci i demoni nella scheda <a href="/funzioni-avanzate/cron" class="fw-semibold text-primary"><i class="fas fa-clock me-1"></i>Cron/Servizi</a>
        </span>
        {% if is_admin %}
        <form method="post" action="/funzioni-avanzate/mapping-pendenze/applica" class="m-0">
          <button type="submit" class="btn btn-primary btn-sm fw-semibold shadow-sm">
            <i class="fas fa-play me-1"></i>Applica ora (L1+L2)
          </button>
        </form>
        <form method="post" action="/funzioni-avanzate/mapping-pendenze/reset" onsubmit="return confirm('Forzare rielaborazione completa L1 + L2? Tutte le pendenze esterne verranno rimappate.');" class="m-0">
          <button type="submit" class="btn btn-warning btn-sm fw-semibold text-dark shadow-sm">
            <i class="fas fa-arrows-rotate me-1"></i>Reset e Rielabora
          </button>
        </form>
        {% endif %}
      </div>
    </div>
    <div class="card-body py-4">
      <div class="mb-3">
        <span class="badge bg-primary me-2" style="font-size: 0.75rem;"><i class="fas fa-route me-1"></i>Livello 1 — Fornitore (IUV prefix)</span>
      </div>
      <div class="row g-3 text-center mb-4">
        <div class="col-md-4">
          <div class="p-3 border rounded bg-light">
            <span class="d-block small text-muted text-uppercase fw-semibold mb-1" style="font-size: 0.7rem; letter-spacing: 0.5px;">Identificate L1</span>
            <span class="d-block fs-4 fw-bold text-success mb-1">{{ stats.PROCESSED.count|number_format(0, ',', '.') }}</span>
            <span class="d-block text-muted small" style="font-size: 0.85rem;">€ {{ stats.PROCESSED.amount|number_format(2, ',', '.') }}</span>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-3 border rounded bg-light">
            <span class="d-block small text-muted text-uppercase fw-semibold mb-1" style="font-size: 0.7rem; letter-spacing: 0.5px;">Senza match L1</span>
            <span class="d-block fs-4 fw-bold text-danger mb-1">{{ stats.NO_MATCH.count|number_format(0, ',', '.') }}</span>
            <span class="d-block text-muted small" style="font-size: 0.85rem;">€ {{ stats.NO_MATCH.amount|number_format(2, ',', '.') }}</span>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-3 border rounded bg-light">
            <span class="d-block small text-muted text-uppercase fw-semibold mb-1" style="font-size: 0.7rem; letter-spacing: 0.5px;">In coda L1 (Pending)</span>
            <span class="d-block fs-4 fw-bold text-warning mb-1">{{ stats.PENDING.count|number_format(0, ',', '.') }}</span>
            <span class="d-block text-muted small" style="font-size: 0.85rem;">€ {{ stats.PENDING.amount|number_format(2, ',', '.') }}</span>
          </div>
        </div>
      </div>

      <div class="mb-3">
        <span class="badge bg-success me-2" style="font-size: 0.75rem;"><i class="fas fa-book-open me-1"></i>Livello 2 — Tipologia (vocabolario keyword)</span>
      </div>
      <div class="row g-3 text-center">
        <div class="col-md-4">
          <div class="p-3 border rounded" style="background: #f0fff4;">
            <span class="d-block small text-muted text-uppercase fw-semibold mb-1" style="font-size: 0.7rem; letter-spacing: 0.5px;">Classificate L2</span>
            <span class="d-block fs-4 fw-bold text-success mb-1">{{ stats.vocab.PROCESSED.count|number_format(0, ',', '.') }}</span>
            <span class="d-block text-muted small" style="font-size: 0.85rem;">€ {{ stats.vocab.PROCESSED.amount|number_format(2, ',', '.') }}</span>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-3 border rounded" style="background: #fff5f5;">
            <span class="d-block small text-muted text-uppercase fw-semibold mb-1" style="font-size: 0.7rem; letter-spacing: 0.5px;">Senza match vocab L2</span>
            <span class="d-block fs-4 fw-bold text-danger mb-1">{{ stats.vocab.NO_MATCH.count|number_format(0, ',', '.') }}</span>
            <span class="d-block text-muted small" style="font-size: 0.85rem;">€ {{ stats.vocab.NO_MATCH.amount|number_format(2, ',', '.') }}</span>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-3 border rounded" style="background: #fffbf0;">
            <span class="d-block small text-muted text-uppercase fw-semibold mb-1" style="font-size: 0.7rem; letter-spacing: 0.5px;">In attesa L2</span>
            <span class="d-block fs-4 fw-bold text-warning mb-1">{{ stats.vocab.PENDING.count|number_format(0, ',', '.') }}</span>
            <span class="d-block text-muted small" style="font-size: 0.85rem;">—</span>
          </div>
        </div>
      </div>

      <div class="mt-4 text-start small text-muted border-top pt-3">
        <i class="fas fa-info-circle me-1 text-primary"></i> Totale pendenze esterne: <strong>{{ stats.total.count|number_format(0, ',', '.') }}</strong> (€ <strong>{{ stats.total.amount|number_format(2, ',', '.') }}</strong>).
      </div>
    </div>
  </div>

  {# ── Gestione Tipologie Personalizzate ── #}
  {% if is_admin %}
  <div class="card shadow-sm mb-4" style="border-radius: var(--bo-radius, 10px); border: 1px solid #e2e8f0; overflow:hidden;">
    <div class="card-header py-2 px-3 d-flex align-items-center justify-content-between" style="background: linear-gradient(90deg,#f8fafc 0%,#f1f5f9 100%); border-bottom: 1px solid #e2e8f0;">
      <div class="d-flex align-items-center gap-2">
        <span class="d-inline-flex align-items-center justify-content-center rounded-2 bg-secondary bg-opacity-10" style="width:28px;height:28px;">
          <i class="fas fa-tags text-secondary" style="font-size:0.8rem;"></i>
        </span>
        <div>
          <h3 class="h6 mb-0 fw-semibold" style="font-size:0.85rem;">Tipologie Personalizzate</h3>
          <div class="text-muted" style="font-size:0.7rem;">Codici tipologia custom usati nei mapping L1/L2</div>
        </div>
      </div>
      {% if tipologie_custom is defined and tipologie_custom is not empty %}
        <span class="badge bg-secondary bg-opacity-75 rounded-pill" style="font-size:0.72rem;">{{ tipologie_custom|length }}</span>
      {% endif %}
    </div>

    <div class="card-body p-0">
      {% if tipologie_custom is defined and tipologie_custom is not empty %}
      <div class="px-3 pt-3 pb-1">
        <div class="d-flex flex-wrap gap-2">
          {% for tc in tipologie_custom %}
          <div class="d-inline-flex align-items-center gap-1 rounded-3 px-2 py-1 border" style="background:#f8fafc; font-size:0.8rem; border-color:#e2e8f0 !important;">
            <code class="text-primary fw-semibold" style="font-size:0.78rem; background:none; padding:0;">{{ tc.cod_entrata }}</code>
            <span class="text-muted mx-1" style="font-size:0.75rem;">{{ tc.descrizione }}</span>
            <a href="/funzioni-avanzate/mapping-pendenze/tipologie-custom/delete?id={{ tc.id }}"
               class="text-danger ms-1 d-inline-flex align-items-center"
               onclick="return confirm('Eliminare \'{{ tc.cod_entrata }}\'?')"
               title="Elimina tipologia"
               style="opacity:0.6; text-decoration:none; font-size:0.75rem; line-height:1;">
              <i class="fas fa-times-circle"></i>
            </a>
          </div>
          {% endfor %}
        </div>
      </div>
      {% else %}
      <div class="d-flex align-items-center gap-2 px-3 py-3 text-muted" style="font-size:0.8rem;">
        <i class="fas fa-circle-info"></i>
        <span>Nessuna tipologia personalizzata. Aggiungine una con il modulo qui sotto.</span>
      </div>
      {% endif %}

      <form method="post" action="/funzioni-avanzate/mapping-pendenze/tipologie-custom/add"
            class="px-3 pb-3 pt-2 mt-1 border-top d-flex align-items-end gap-2 flex-wrap" style="background:#fafafa;">
        <div style="flex: 0 0 160px;">
          <label class="form-label form-label-sm text-muted mb-1" style="font-size:0.72rem; text-transform:uppercase; letter-spacing:.3px;">Codice <span class="text-danger">*</span></label>
          <input type="text" name="cod_entrata" class="form-control form-control-sm" placeholder="Es. TARI" required maxlength="100" style="text-transform:uppercase; font-family:monospace; font-size:0.82rem;">
        </div>
        <div style="flex: 1 1 260px;">
          <label class="form-label form-label-sm text-muted mb-1" style="font-size:0.72rem; text-transform:uppercase; letter-spacing:.3px;">Descrizione <span class="text-danger">*</span></label>
          <input type="text" name="descrizione" class="form-control form-control-sm" placeholder="Es. Tassa Rifiuti" required maxlength="255" style="font-size:0.82rem;">
        </div>
        <div style="flex: 0 0 auto;">
          <button type="submit" class="btn btn-sm btn-primary px-3" style="font-size:0.82rem;">
            <i class="fas fa-plus me-1"></i>Aggiungi
          </button>
        </div>
      </form>
    </div>
  </div>
  {% endif %}

  {# ── Form aggiunta regola L1 ── #}
  {% if is_admin %}
  <div class="card shadow-sm border-0 mb-4 bg-white" style="border-radius: var(--bo-radius, 10px);">
    <div class="card-header bg-light py-3 border-bottom">
      <h3 class="h6 mb-0 fw-bold"><i class="fas fa-plus-circle text-primary me-2"></i>Nuova Regola Livello 1 — Prefisso IUV → Fornitore</h3>
    </div>
    <div class="card-body">
      <form method="post" action="/funzioni-avanzate/mapping-pendenze/add" id="mappingRuleForm">
        <div class="row g-3">
          {# Prefisso IUV #}
          <div class="col-md-4">
            <label for="pattern_iuv" class="form-label small fw-bold">Prefisso IUV<span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="pattern_iuv" name="pattern_iuv" required placeholder="Es. 0622" style="text-transform: uppercase;">
            <div class="form-text small" style="font-size: 0.75rem;">Primi caratteri numerici dell'IUV.</div>
          </div>

          {# Fornitore #}
          <div class="col-md-4">
            <label for="fornitore" class="form-label small fw-bold">Fornitore (Partner Tecnologico)<span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="fornitore" name="fornitore" required placeholder="Es. Maggioli S.p.A.">
            <div class="form-text small" style="font-size: 0.75rem;">Soggetto o applicazione sorgente.</div>
          </div>

          {# Tipologia Fallback L2 #}
          <div class="col-md-4">
            <label for="cod_entrata_select" class="form-label small fw-bold">Tipologia Fallback L2</label>
            <select class="form-select" id="cod_entrata_select" name="cod_entrata">
              <option value="">-- Nessuna / Generica --</option>
              {% if tipologie_list is not empty %}
              <optgroup label="Standard">
                {% for ent in tipologie_list %}
                  <option value="{{ ent.id_entrata }}">{{ ent.descrizione }}</option>
                {% endfor %}
              </optgroup>
              {% endif %}
              {% if tipologie_custom is defined and tipologie_custom is not empty %}
              <optgroup label="Personalizzate">
                {% for tc in tipologie_custom %}
                  <option value="{{ tc.cod_entrata }}">{{ tc.descrizione }} [{{ tc.cod_entrata }}]</option>
                {% endfor %}
              </optgroup>
              {% endif %}
            </select>
            <div class="form-text small" style="font-size: 0.75rem;">Usata da L2 se nessuna keyword vocab matcha.</div>
          </div>
        </div>
        <div class="mt-3 text-end border-top pt-3">
          <button type="submit" class="btn btn-primary px-4 shadow-sm">
            <i class="fas fa-save me-2"></i>Salva Regola L1
          </button>
        </div>
      </form>
    </div>
  </div>
  {% endif %}

  {# ── Form aggiunta keyword vocabolario L2 (mostrato on-demand) ── #}
  {% if is_admin %}
  <div class="card shadow-sm border-0 mb-4 bg-white" id="vocabKeywordCard" style="display:none; border-radius: var(--bo-radius, 10px); border-left: 4px solid #198754 !important;">
    <div class="card-header py-3 border-bottom d-flex align-items-center justify-content-between" style="background: #f0fff4;">
      <h3 class="h6 mb-0 fw-bold"><i class="fas fa-book-open text-success me-2"></i>Aggiungi Keyword Vocabolario — Livello 2</h3>
      <button type="button" class="btn-close btn-sm" onclick="hideVocabForm()" aria-label="Chiudi"></button>
    </div>
    <div class="card-body">
      <form method="post" action="/funzioni-avanzate/mapping-pendenze/vocab/add" id="vocabKeywordForm">
        <div class="row g-3">
          <div class="col-md-3">
            <label class="form-label small fw-bold">Pattern IUV</label>
            <input type="text" class="form-control bg-light" id="vocab_pattern_iuv" name="pattern_iuv" readonly required>
            <div class="form-text small" style="font-size: 0.75rem;">Pre-compilato dal pattern selezionato.</div>
          </div>
          <div class="col-md-3">
            <label class="form-label small fw-bold">Keyword <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="vocab_keyword" name="keyword" required placeholder="Es. TARI">
            <div class="form-text small" style="font-size: 0.75rem;">Ricerca case-insensitive nella causale.</div>
          </div>
          <div class="col-md-4">
            <label class="form-label small fw-bold">Tipologia Entrata <span class="text-danger">*</span></label>
            <select class="form-select" id="vocab_cod_entrata_select" name="cod_entrata" required>
              <option value="">-- Seleziona --</option>
              {% if tipologie_list is not empty %}
              <optgroup label="Standard">
                {% for ent in tipologie_list %}
                  <option value="{{ ent.id_entrata }}">{{ ent.descrizione }}</option>
                {% endfor %}
              </optgroup>
              {% endif %}
              {% if tipologie_custom is defined and tipologie_custom is not empty %}
              <optgroup label="Personalizzate">
                {% for tc in tipologie_custom %}
                  <option value="{{ tc.cod_entrata }}">{{ tc.descrizione }} [{{ tc.cod_entrata }}]</option>
                {% endfor %}
              </optgroup>
              {% endif %}
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label small fw-bold">Priorità</label>
            <input type="number" class="form-control" name="priorita" value="10" min="0" max="255">
            <div class="form-text small" style="font-size: 0.75rem;">Più alto = testato prima.</div>
          </div>
        </div>
        <div class="mt-3 text-end border-top pt-3">
          <button type="button" class="btn btn-outline-secondary me-2" onclick="hideVocabForm()">Annulla</button>
          <button type="submit" class="btn btn-success px-4 shadow-sm">
            <i class="fas fa-plus me-2"></i>Aggiungi Keyword
          </button>
        </div>
      </form>
    </div>
  </div>
  {% endif %}

  {# ── Form accorpamento pattern L1 (mostrato on-demand) ── #}
  {% if is_admin %}
  <div class="card shadow-sm border-0 mb-4 bg-white" id="accorpaPatternCard" style="display:none; border-radius: var(--bo-radius, 10px); border-left: 4px solid var(--ms-gold-500, #ffc107) !important;">
    <div class="card-header py-3 border-bottom d-flex align-items-center justify-content-between" style="background: #fffdf0;">
      <h3 class="h6 mb-0 fw-bold"><i class="fas fa-compress-arrows-alt text-warning me-2"></i>Accorpa Pattern IUV</h3>
      <button type="button" class="btn-close btn-sm" onclick="hideAccorpaForm()" aria-label="Chiudi"></button>
    </div>
    <div class="card-body">
      <form method="post" action="/funzioni-avanzate/mapping-pendenze/accorpa" id="accorpaPatternForm">
        <div class="row g-3 align-items-end">
          <div class="col-md-4">
            <label class="form-label small fw-bold">Pattern da accorpare (Sorgente)</label>
            <input type="text" class="form-control bg-light" id="accorpa_pattern_sorgente" name="pattern_iuv" readonly required>
          </div>
          <div class="col-md-5">
            <label class="form-label small fw-bold">Accorpa a (Pattern di destinazione / Target)<span class="text-danger">*</span></label>
            <select class="form-select" id="accorpa_pattern_target" name="accorpato_a" required>
              <option value="">-- Seleziona il pattern di destinazione --</option>
              {% for other in patterns %}
                {# Solo pattern battezzati e diversi da se stessi e non a loro volta accorpati #}
                {% if other.fornitore is not empty and other.accorpato_a is empty %}
                  <option value="{{ other.pattern_iuv }}">{{ other.pattern_iuv }} ({{ other.fornitore }})</option>
                {% endif %}
              {% endfor %}
            </select>
          </div>
          <div class="col-md-3">
            <button type="submit" class="btn btn-warning w-100 fw-semibold text-dark shadow-sm">
              <i class="fas fa-compress-arrows-alt me-2"></i>Accorpa ora
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
  {% endif %}

  {# ── Macro helper: riga pattern (riusata in entrambe le tabelle) ── #}
  {# Nota: Twig non ha macro inline; il blocco row è duplicato. #}

  {# ── Tabella 1: Regole L1 Attive (battezzate) ── #}
  {% if patterns|filter(p => p.fornitore is not empty)|length > 0 %}
  <div class="card shadow-sm border-0 bg-white mb-4" style="border-radius: var(--bo-radius, 10px);">
    <div class="card-header py-3 border-bottom d-flex align-items-center gap-2" style="background: linear-gradient(90deg,#f0fff4 0%,#f8fafc 100%); border-left: 4px solid #198754;">
      <i class="fas fa-circle-check text-success fs-5"></i>
      <h3 class="h6 mb-0 fw-bold">Regole L1 Attive</h3>
      <span class="badge bg-success rounded-pill ms-1" style="font-size: 0.72rem;">{{ patterns|filter(p => p.fornitore is not empty)|length }}</span>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0" style="font-size: 0.88rem;">
          <thead>
            <tr class="table-dark">
              <th scope="col" style="width: 18%;">Prefisso IUV</th>
              <th scope="col" style="width: 22%;">Fornitore</th>
              <th scope="col" style="width: 20%;">Tipologia Fallback L2</th>
              <th scope="col" style="width: 30%;">Vocabolario L2 (keyword → tipologia)</th>
              <th scope="col" class="text-end" style="width: 10%;">Azioni</th>
            </tr>
          </thead>
          <tbody>
            {% for pat in patterns|filter(p => p.fornitore is not empty) %}
              {% set is_covered = false %}
              {% set coverer = '' %}
              {% for other in patterns %}
                {% if other.pattern_iuv != pat.pattern_iuv and other.fornitore is not empty and pat.pattern_iuv starts with other.pattern_iuv %}
                  {% set is_covered = true %}
                  {% set coverer = other.pattern_iuv %}
                {% endif %}
              {% endfor %}
              <tr style="{% if pat.accorpato_a is not empty %}border-left: 4px dashed #94a3b8; background-color: #f8fafc;{% else %}border-left: 4px solid {% if pat.insufficiente %}#adb5bd{% else %}var(--bi-primary, #0d6efd){% endif %};{% endif %}">
                <td {% if pat.accorpato_a is not empty %}class="ps-4"{% endif %}>
                  {% if pat.accorpato_a is not empty %}
                    <div class="d-flex align-items-center mb-1">
                      <i class="fas fa-level-up-alt fa-rotate-90 text-muted me-2" style="font-size: 0.95rem;"></i>
                      <span class="fw-bold mono fs-6 text-dark">{{ pat.pattern_iuv }}</span>
                    </div>
                  {% else %}
                    <span class="fw-bold mono fs-6 text-dark">{{ pat.pattern_iuv }}</span>
                  {% endif %}
                  {% if pat.is_custom == 1 %}
                    <span class="badge bg-primary d-block mt-1" style="font-size: 0.65rem; width: max-content;">CUSTOM</span>
                  {% else %}
                    <span class="badge bg-secondary d-block mt-1" style="font-size: 0.65rem; width: max-content;">SCOPERTO</span>
                  {% endif %}
                  {% if pat.insufficiente %}
                    <span class="badge d-block mt-1" style="font-size: 0.63rem; width: max-content; background: #adb5bd; color: #fff;">⚠ &lt;5 trans. — inattivo</span>
                  {% endif %}
                  <div class="small text-muted mt-2 mb-2" style="font-size: 0.75rem;">
                    {{ pat.transazioni_count }} trans.<br/>
                    <strong>€ {{ pat.importo_totale|number_format(2, ',', '.') }}</strong>
                  </div>
                  {% set ex_id = 'ex-' ~ pat.pattern_iuv|replace({'%': '', ' ': '', '.': ''}) %}
                  {% if pat.vocab_rules is not empty and pat.stats_uncovered is not null %}
                    <button class="btn btn-link btn-sm p-0 mt-2 text-decoration-none {{ pat.stats_uncovered > 0 ? 'text-danger' : 'text-success' }}"
                            type="button" data-bs-toggle="collapse" data-bs-target="#{{ ex_id }}" aria-expanded="false">
                      <i class="fas fa-eye me-1"></i>{{ pat.stats_uncovered }} non coperte da L2
                    </button>
                  {% elseif pat.examples is not empty %}
                    <button class="btn btn-link btn-sm p-0 mt-2 text-decoration-none text-secondary"
                            type="button" data-bs-toggle="collapse" data-bs-target="#{{ ex_id }}" aria-expanded="false">
                      <i class="fas fa-eye me-1"></i>{{ pat.examples|length }} esempi
                    </button>
                  {% endif %}
                </td>
                <td>
                  {% if pat.accorpato_a is not empty %}
                    <div class="d-flex flex-column">
                      <span class="badge bg-success-subtle text-success border border-success-subtle mb-1" style="font-size: 0.7rem; width: max-content;">
                        <i class="fas fa-compress-arrows-alt me-1"></i>Accorpato a <strong>{{ pat.accorpato_a }}</strong>
                      </span>
                      {% if pat.fornitore is not empty %}
                        <span class="small text-muted">Eredita: <strong>{{ pat.fornitore }}</strong></span>
                      {% endif %}
                    </div>
                  {% else %}
                    <strong class="text-dark">{{ pat.fornitore }}</strong>
                    {% if is_admin %}
                    <button type="button" class="btn btn-link btn-sm p-0 d-block mt-1 text-decoration-none text-secondary" onclick="setupModificaFornitore('{{ pat.pattern_iuv }}', '{{ pat.fornitore|e('js') }}', '{{ pat.cod_entrata|default('')|e('js') }}')">
                      <i class="fas fa-pen me-1"></i>Modifica
                    </button>
                    {% endif %}
                    {% if is_covered %}
                      <div class="small text-info mt-1" style="font-size: 0.72rem;">
                        <i class="fas fa-info-circle me-1"></i>Accorpato sotto <code>{{ coverer }}</code>
                      </div>
                    {% endif %}
                  {% endif %}
                </td>
                <td>
                  {% if pat.cod_entrata is not empty %}
                    {% set found_desc = pat.cod_entrata %}
                    {% for ent in tipologie_list %}
                      {% if ent.id_entrata == pat.cod_entrata %}{% set found_desc = ent.descrizione %}{% endif %}
                    {% endfor %}
                    <span class="badge bg-info text-dark" style="font-size: 0.8rem; font-weight: 500;">{{ found_desc }}</span>
                    <div class="small text-muted mt-1" style="font-size: 0.7rem;">usata se nessun vocab match</div>
                  {% else %}
                    <span class="text-muted small">Nessun fallback</span>
                  {% endif %}
                </td>
                <td>
                  {% if pat.accorpato_a is not empty %}
                    <div class="text-muted small mb-2"><i class="fas fa-info-circle me-1"></i>Ereditato da <code>{{ pat.accorpato_a }}</code>:</div>
                  {% endif %}
                  {% if pat.vocab_rules is not empty %}
                    <ul class="list-unstyled mb-1 d-flex flex-column gap-1">
                      {% for vk in pat.vocab_rules %}
                        {% set vk_desc = vk.cod_entrata %}
                        {% for ent in tipologie_list %}
                          {% if ent.id_entrata == vk.cod_entrata %}{% set vk_desc = ent.descrizione %}{% endif %}
                        {% endfor %}
                        <li class="p-1 border rounded {% if pat.accorpato_a is not empty %}bg-light text-muted{% else %}bg-light{% endif %} d-flex justify-content-between align-items-center">
                          <span style="font-size: 0.79rem;">
                            <code class="text-success {% if pat.accorpato_a is not empty %}text-opacity-50{% endif %}">{{ vk.keyword }}</code>
                            <span class="text-muted mx-1">→</span>
                            <strong>{{ vk_desc }}</strong>
                            <span class="badge bg-light text-muted border ms-1" style="font-size: 0.62rem;">p:{{ vk.priorita }}</span>
                            {% if pat.stats_by_keyword[vk.keyword] is defined %}
                              <span class="badge bg-success-subtle text-success border border-success-subtle ms-1" style="font-size: 0.62rem;">{{ pat.stats_by_keyword[vk.keyword] }} coperte</span>
                            {% endif %}
                          </span>
                          {% if is_admin and pat.accorpato_a is empty %}
                          <a href="/funzioni-avanzate/mapping-pendenze/delete?type=vocab&id={{ vk.id }}"
                             class="text-danger p-0 ms-2" title="Elimina keyword"
                             onclick="return confirm('Eliminare la keyword \'{{ vk.keyword|e('js') }}\'?');">
                             <i class="fas fa-times-circle"></i>
                          </a>
                          {% endif %}
                        </li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                  {% if is_admin and pat.accorpato_a is empty %}
                    <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none text-success" onclick="setupVocabKeyword('{{ pat.pattern_iuv }}')">
                      <i class="fas fa-plus me-1"></i>Aggiungi keyword
                    </button>
                  {% elseif not is_admin %}
                    <span class="text-muted small">—</span>
                  {% endif %}
                </td>
                <td class="text-end">
                  {% if is_admin %}
                    <div class="d-flex justify-content-end gap-1">
                      {% if pat.accorpato_a is not empty %}
                        <a href="/funzioni-avanzate/mapping-pendenze/disunisci?pattern_iuv={{ pat.pattern_iuv|url_encode }}"
                           class="btn btn-outline-warning btn-sm px-3" title="Rimuovi accorpamento">
                          <i class="fas fa-unlink"></i>
                        </a>
                      {% endif %}
                      <a href="/funzioni-avanzate/mapping-pendenze/delete?type=pattern&pattern_iuv={{ pat.pattern_iuv|url_encode }}"
                         class="btn btn-outline-danger btn-sm px-3"
                         onclick="return confirm('Eliminare il pattern IUV \'{{ pat.pattern_iuv }}\' e tutto il suo vocabolario L2?');"
                         title="Elimina pattern e vocab">
                        <i class="fas fa-trash-can"></i>
                      </a>
                    </div>
                  {% else %}
                    <span class="text-muted small">—</span>
                  {% endif %}
                </td>
              </tr>
              {% if pat.examples is not empty %}
              {% set ex_id = 'ex-' ~ pat.pattern_iuv|replace({'%': '', ' ': '', '.': ''}) %}
              <tr class="border-0" {% if pat.accorpato_a is not empty %}style="background-color: #f8fafc;"{% endif %}>
                <td colspan="5" class="p-0 border-0">
                  <div class="collapse" id="{{ ex_id }}">
                    <div class="px-3 py-2 border-top border-bottom {% if pat.accorpato_a is not empty %}ps-5 bg-transparent{% else %}bg-light{% endif %}">
                      <div class="text-muted fw-semibold mb-2" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.4px;">
                        <i class="fas fa-eye me-1"></i>
                        {% if pat.vocab_rules is not empty %}Pendenze non coperte da L2{% else %}Esempi pendenze reali{% endif %}
                      </div>
                      <div class="row g-2">
                        {% for ex in pat.examples %}
                          <div class="col-12 col-md-4">
                            <div class="p-2 rounded border {{ pat.vocab_rules is not empty ? 'bg-danger-subtle border-danger' : 'bg-white' }}" style="font-size: 0.78rem;">
                              <div class="d-flex align-items-center gap-1 flex-wrap mb-1">
                                <code class="text-secondary" style="font-size: 0.73rem;">{{ ex.iuv }}</code>
                                <strong>€{{ ex.importo|number_format(2, ',', '.') }}</strong>
                              </div>
                              <div class="text-muted" style="font-style: italic; font-size: 0.73rem;">"{{ ex.descrizione_entrata|default('(in attesa scansione)') }}"</div>
                              {% if ex.id_flusso is not empty %}
                                <a href="/pagamenti/ricerca-flussi/dettaglio/{{ ex.id_flusso|url_encode }}" target="_blank" class="d-block mt-1 text-primary" style="font-size: 0.7rem; word-break: break-all;">
                                  <i class="fas fa-file-invoice me-1"></i>{{ ex.id_flusso }}
                                </a>
                              {% endif %}
                            </div>
                          </div>
                        {% endfor %}
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
              {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  {% endif %}

  {# ── Tabella 2: Pattern Scoperti (da battezzare) — con filtro char ── #}
  <div class="card shadow-sm border-0 bg-white mb-5" style="border-radius: var(--bo-radius, 10px);">
    <div class="card-header bg-light py-3 border-bottom d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div class="d-flex align-items-center gap-2">
        <i class="fas fa-magnifying-glass text-warning fs-5"></i>
        <h3 class="h6 mb-0 fw-bold">Pattern Scoperti — da battezzare</h3>
        {% set unmapped_count = patterns|filter(p => p.fornitore is empty)|length %}
        {% if unmapped_count > 0 %}
          <span class="badge bg-warning text-dark rounded-pill ms-1" style="font-size: 0.72rem;">{{ unmapped_count }}</span>
        {% endif %}
      </div>
      <div class="btn-group btn-group-sm" role="group" aria-label="Filtra per lunghezza prefisso">
        <button type="button" class="btn btn-dark pattern-filter-btn" data-filter="all" onclick="filterPatterns('all')">Tutti</button>
        <button type="button" class="btn btn-outline-dark pattern-filter-btn" data-filter="5" onclick="filterPatterns('5')">5 char</button>
        <button type="button" class="btn btn-outline-dark pattern-filter-btn" data-filter="4" onclick="filterPatterns('4')">4 char</button>
        <button type="button" class="btn btn-outline-dark pattern-filter-btn" data-filter="3" onclick="filterPatterns('3')">3 char</button>
      </div>
    </div>
    <div class="card-body p-0">
      {% if patterns|filter(p => p.fornitore is empty)|length == 0 %}
        <div class="p-5 text-center text-muted">
          <i class="fas fa-circle-check mb-3 fs-3 text-success" aria-hidden="true"></i>
          <p class="mb-0 fs-6">Tutti i pattern scoperti sono stati battezzati.</p>
        </div>
      {% elseif patterns is empty %}
        <div class="p-5 text-center text-muted">
          <i class="fas fa-info-circle mb-3 fs-3" aria-hidden="true"></i>
          <p class="mb-0 fs-6">Nessun pattern IUV rilevato. Avvia il demone Mapping L1 per scansionare la cache.</p>
        </div>
      {% else %}
        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle mb-0" style="font-size: 0.88rem;">
            <thead>
              <tr class="table-dark">
                <th scope="col" style="width: 18%;">Prefisso IUV</th>
                <th scope="col" style="width: 22%;">Fornitore</th>
                <th scope="col" style="width: 20%;">Tipologia Fallback L2</th>
                <th scope="col" style="width: 30%;">Vocabolario L2 (keyword → tipologia)</th>
                <th scope="col" class="text-end" style="width: 10%;">Azioni</th>
              </tr>
            </thead>
            <tbody>
              {% for pat in patterns|filter(p => p.fornitore is empty) %}
                <tr data-len="{{ pat.pattern_iuv|length }}" style="border-left: 4px solid {% if pat.insufficiente %}#adb5bd{% else %}var(--ms-gold-500, #ffc107){% endif %};">
                  <td>
                    <span class="fw-bold mono fs-6 text-dark">{{ pat.pattern_iuv }}</span>
                    {% if pat.is_custom == 1 %}
                      <span class="badge bg-primary d-block mt-1" style="font-size: 0.65rem; width: max-content;">CUSTOM</span>
                    {% else %}
                      <span class="badge bg-secondary d-block mt-1" style="font-size: 0.65rem; width: max-content;">SCOPERTO</span>
                    {% endif %}
                    {% if pat.insufficiente %}
                      <span class="badge d-block mt-1" style="font-size: 0.63rem; width: max-content; background: #adb5bd; color: #fff;">⚠ &lt;5 trans. — inattivo</span>
                    {% endif %}
                    <div class="small text-muted mt-2 mb-2" style="font-size: 0.75rem;">
                      {{ pat.transazioni_count }} trans.<br/>
                      <strong>€ {{ pat.importo_totale|number_format(2, ',', '.') }}</strong>
                    </div>
                    {% set ex_id = 'ex-' ~ pat.pattern_iuv|replace({'%': '', ' ': '', '.': ''}) %}
                    {% if pat.examples is not empty %}
                      <button class="btn btn-link btn-sm p-0 mt-2 text-decoration-none text-secondary"
                              type="button" data-bs-toggle="collapse" data-bs-target="#{{ ex_id }}" aria-expanded="false">
                        <i class="fas fa-eye me-1"></i>{{ pat.examples|length }} esempi
                      </button>
                    {% endif %}
                  </td>
                  <td>
                    <span class="text-warning fw-semibold"><i class="fas fa-triangle-exclamation me-1"></i>Non battezzato</span>
                    {% if is_admin %}
                    <div class="d-flex flex-column gap-1 mt-1">
                      <button type="button" class="btn btn-link btn-sm p-0 text-start text-decoration-none" onclick="setupBattezza('{{ pat.pattern_iuv }}')">
                        <i class="fas fa-arrow-right me-1"></i>Battezza ora
                      </button>
                      <button type="button" class="btn btn-link btn-sm p-0 text-start text-decoration-none text-success" onclick="setupAccorpa('{{ pat.pattern_iuv }}')">
                        <i class="fas fa-compress-arrows-alt me-1"></i>Accorpa a...
                      </button>
                    </div>
                    {% endif %}
                  </td>
                  <td><span class="text-muted small">Nessun fallback</span></td>
                  <td><span class="text-muted small">Battezza prima il fornitore.</span></td>
                  <td class="text-end">
                    {% if is_admin %}
                      <span class="text-muted small">—</span>
                    {% else %}
                      <span class="text-muted small">—</span>
                    {% endif %}
                  </td>
                </tr>
                {% if pat.examples is not empty %}
                {% set ex_id = 'ex-' ~ pat.pattern_iuv|replace({'%': '', ' ': '', '.': ''}) %}
                <tr class="border-0 pattern-discovery-row">
                  <td colspan="5" class="p-0 border-0">
                    <div class="collapse" id="{{ ex_id }}">
                      <div class="px-3 py-2 bg-light border-top border-bottom">
                        <div class="text-muted fw-semibold mb-2" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.4px;">
                          <i class="fas fa-eye me-1"></i>Esempi pendenze reali
                        </div>
                        <div class="row g-2">
                          {% for ex in pat.examples %}
                            <div class="col-12 col-md-4">
                              <div class="p-2 rounded border bg-white" style="font-size: 0.78rem;">
                                <div class="d-flex align-items-center gap-1 flex-wrap mb-1">
                                  <code class="text-secondary" style="font-size: 0.73rem;">{{ ex.iuv }}</code>
                                  <strong>€{{ ex.importo|number_format(2, ',', '.') }}</strong>
                                </div>
                                <div class="text-muted" style="font-style: italic; font-size: 0.73rem;">"{{ ex.descrizione_entrata|default('(in attesa scansione)') }}"</div>
                                {% if ex.id_flusso is not empty %}
                                  <a href="/pagamenti/ricerca-flussi/dettaglio/{{ ex.id_flusso|url_encode }}" target="_blank" class="d-block mt-1 text-primary" style="font-size: 0.7rem; word-break: break-all;">
                                    <i class="fas fa-file-invoice me-1"></i>{{ ex.id_flusso }}
                                  </a>
                                {% endif %}
                              </div>
                            </div>
                          {% endfor %}
                        </div>
                      </div>
                    </div>
                  </td>
                </tr>
                {% endif %}
              {% else %}
                <tr><td colspan="5" class="text-center text-muted p-4">Tutti i pattern scoperti sono stati battezzati.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% endif %}
    </div>
  </div>

  {# ── Riquadro esempi NO_MATCH (dopo discovery) ── #}
  {% if no_match_examples is defined and no_match_examples is not empty %}
  <div class="card shadow-sm mb-5" style="border-radius: var(--bo-radius, 10px); border: 1px solid #f5c6cb;">
    <div class="card-header py-2 px-3 d-flex align-items-center gap-2" style="background: #fff5f5; border-bottom: 1px solid #f5c6cb;">
      <i class="fas fa-triangle-exclamation text-danger"></i>
      <span class="fw-semibold" style="font-size: 0.85rem;">Esempi di pendenze senza match L1 (NO_MATCH)</span>
      {% if stats.NO_MATCH.count > 0 %}
        <span class="badge bg-danger rounded-pill ms-auto" style="font-size: 0.72rem;">{{ stats.NO_MATCH.count|number_format(0, ',', '.') }} totali</span>
      {% endif %}
    </div>
    <div class="card-body p-3">
      <div class="row g-2">
        {% for ex in no_match_examples %}
          <div class="col-12 col-md-4">
            <div class="p-2 rounded border bg-danger-subtle border-danger" style="font-size: 0.78rem;">
              <div class="d-flex align-items-center gap-1 flex-wrap mb-1">
                <code class="text-secondary" style="font-size: 0.73rem;">{{ ex.iuv }}</code>
                <strong>€{{ ex.importo|number_format(2, ',', '.') }}</strong>
              </div>
              <div class="text-muted" style="font-style: italic; font-size: 0.73rem;">"{{ ex.descrizione_entrata|default('(descrizione non disponibile)') }}"</div>
              {% if ex.id_flusso is not empty %}
                <a href="/pagamenti/ricerca-flussi/dettaglio/{{ ex.id_flusso|url_encode }}" target="_blank" class="d-block mt-1 text-primary" style="font-size: 0.7rem; word-break: break-all;">
                  <i class="fas fa-file-invoice me-1"></i>{{ ex.id_flusso }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
  {% endif %}

{% endblock %}

{% block scripts %}
  {{ parent() }}
  <script>
    // ── L1 form helpers ──────────────────────────────────────────────────────
    function setupBattezza(prefix) {
      document.getElementById('pattern_iuv').value = prefix;
      document.getElementById('fornitore').value = '';
      document.getElementById('fornitore').focus();
      document.getElementById('mappingRuleForm').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function setupModificaFornitore(prefix, currentFornitore, currentCodEntrata) {
      document.getElementById('pattern_iuv').value = prefix;
      document.getElementById('fornitore').value = currentFornitore;

      const sel = document.getElementById('cod_entrata_select');
      sel.value = currentCodEntrata;
      // If value not in list (old custom code), add a temporary option
      if (currentCodEntrata !== '' && sel.value !== currentCodEntrata) {
        const opt = document.createElement('option');
        opt.value = currentCodEntrata;
        opt.textContent = currentCodEntrata + ' (non registrato)';
        sel.appendChild(opt);
        sel.value = currentCodEntrata;
      }

      document.getElementById('mappingRuleForm').scrollIntoView({ behavior: 'smooth', block: 'start' });
      document.getElementById('fornitore').focus();
      document.getElementById('fornitore').select();
    }

    // ── L1 accorpa form helpers ──────────────────────────────────────────────
    function setupAccorpa(patternIuv) {
      document.getElementById('accorpa_pattern_sorgente').value = patternIuv;
      
      // Update options to exclude the pattern itself
      const select = document.getElementById('accorpa_pattern_target');
      for (let i = 0; i < select.options.length; i++) {
        const option = select.options[i];
        if (option.value === patternIuv) {
          option.disabled = true;
          option.style.display = 'none';
        } else {
          option.disabled = false;
          option.style.display = '';
        }
      }
      
      select.value = '';
      
      const card = document.getElementById('accorpaPatternCard');
      card.style.display = 'block';
      card.scrollIntoView({ behavior: 'smooth', block: 'start' });
      select.focus();
    }

    function hideAccorpaForm() {
      document.getElementById('accorpaPatternCard').style.display = 'none';
    }

    // ── L2 vocab form helpers ────────────────────────────────────────────────
    function setupVocabKeyword(patternIuv) {
      document.getElementById('vocab_pattern_iuv').value = patternIuv;
      document.getElementById('vocab_keyword').value = '';
      document.getElementById('vocab_cod_entrata_select').value = '';
      const card = document.getElementById('vocabKeywordCard');
      card.style.display = 'block';
      card.scrollIntoView({ behavior: 'smooth', block: 'start' });
      document.getElementById('vocab_keyword').focus();
    }

    function hideVocabForm() {
      document.getElementById('vocabKeywordCard').style.display = 'none';
    }

    // ── Filtro lunghezza prefisso ────────────────────────────────────────────
    function filterPatterns(len) {
      document.querySelectorAll('.pattern-filter-btn').forEach(function(b) {
        var isActive = b.dataset.filter === String(len);
        b.classList.toggle('btn-dark', isActive);
        b.classList.toggle('btn-outline-dark', !isActive);
      });
      document.querySelectorAll('tr[data-len]').forEach(function(tr) {
        var show = (len === 'all' || tr.dataset.len === String(len));
        tr.style.display = show ? '' : 'none';
        var next = tr.nextElementSibling;
        if (next && !next.dataset.len && next.querySelector && next.querySelector('.collapse')) {
          next.style.display = show ? '' : 'none';
        }
      });
    }
  </script>
{% endblock %}
