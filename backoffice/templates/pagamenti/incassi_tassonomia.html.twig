{% extends 'base.html.twig' %}

{% block title %}Report Incassi per Tassonomia{% endblock %}

{% block content %}
  <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-2 mb-4">
    <div>
      <h1 class="h4 mb-1">Report incassi per tassonomia</h1>
      <p class="text-muted mb-0">Pagamenti riscossi nel periodo selezionato, indipendentemente dalla data di creazione della pendenza</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/statistiche" class="btn btn-outline-secondary">Vai a Statistiche</a>
    </div>
  </div>

  {% if errors is defined and errors %}
    <div class="alert alert-danger" role="alert">
      <ul class="mb-0">
        {% for e in errors %}<li>{{ e }}</li>{% endfor %}
      </ul>
    </div>
  {% endif %}

  {% set f = filters ?? {} %}
  <form method="get" action="/pagamenti/incassi-tassonomia" class="card shadow-sm mb-4" id="incassiTassonomiaForm">
    <input type="hidden" name="q" value="1">
    <div class="card-header bg-light border-bottom py-2">
      <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
        <div class="d-flex align-items-center gap-2">
          <h2 class="h6 mb-0">Filtri</h2>
          <span class="text-muted small d-none d-md-inline">| Filtra per finestra di incasso e tassonomia</span>
        </div>
        <button type="submit" class="btn btn-primary btn-sm" id="incassiTassonomiaSubmit">Aggiorna</button>
      </div>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-5">
          <label for="dataDaVis" class="form-label">Intervallo date incasso</label>
          <div class="d-flex gap-1 align-items-center">
            <input type="text" id="dataDaVis" class="form-control form-control-sm bo-cursor-pointer" placeholder="Da" autocomplete="off">
            <span class="text-muted small">-</span>
            <input type="text" id="dataAVis" class="form-control form-control-sm bo-cursor-pointer" placeholder="A" autocomplete="off">
          </div>
          <div class="bo-datepicker-quick-selects">
            <button type="button" class="bo-datepicker-quick-btn" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('thisMonth')">Mese Corrente</button>
            <button type="button" class="bo-datepicker-quick-btn" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('lastMonth')">Mese Precedente</button>
            <button type="button" class="bo-datepicker-quick-btn" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('thisYear')">Anno Corrente</button>
            <button type="button" class="bo-datepicker-quick-btn" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('lastYear')">Anno Precedente</button>
            <button type="button" class="bo-datepicker-quick-btn btn-clear" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('clear')">Azzera</button>
          </div>
          <input type="hidden" id="dataDa" name="dataDa" value="{{ f.dataDa|default('') }}">
          <input type="hidden" id="dataA" name="dataA" value="{{ f.dataA|default('') }}">
        </div>
        <div class="col-md-7">
          <label for="tassonomie" class="form-label">Tipologie (tipologie censite)</label>
          <select class="form-select" id="tassonomie" name="tassonomie[]" multiple aria-label="Seleziona tassonomie">
            {% for tipo in tipologie_censite|default([]) %}
              {% set tid = tipo.id_entrata|default('') %}
              <option value="{{ tid }}" {% if tid in (f.tassonomie|default([])) %}selected{% endif %}>{{ tipo.descrizione|default(tid) }}</option>
            {% endfor %}
          </select>
          <div class="form-text">Ricerca e selezione multipla.</div>
        </div>
      </div>

      <div class="row g-3 mt-2">
        <div class="col-12">
          <button class="btn btn-link px-0" type="button" data-bs-toggle="collapse" data-bs-target="#advancedFiltersIncassi" aria-expanded="false" aria-controls="advancedFiltersIncassi">
            Filtri avanzati
          </button>
        </div>
      </div>

      <div class="collapse mt-2" id="advancedFiltersIncassi">
        <fieldset class="row g-3">
          <legend class="visually-hidden">Filtri avanzati report incassi</legend>
          <div class="col-md-3">
            <label for="idDominio" class="form-label">ID Dominio</label>
            <input type="text" class="form-control" id="idDominio" name="idDominio" value="{{ f.idDominio|default('') }}" placeholder="(opzionale)">
          </div>
        </fieldset>
      </div>
    </div>
  </form>

  {% set has_data = query_made and rows is defined and rows %}
  {% if has_data %}
    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="text-muted text-uppercase small">Importo complessivo</div>
            <div class="display-6">€ {{ totals.amount|default(0)|number_format(2, ',', '.') }}</div>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="text-muted text-uppercase small">Numero pagamenti</div>
            <div class="display-6">{{ totals.count|default(0)|number_format(0, ',', '.') }}</div>
          </div>
        </div>
      </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
      <h3 class="h6 mb-0">Dettaglio riscossioni</h3>
      {% if csv_link %}
        <a href="{{ csv_link }}" class="btn btn-sm btn-outline-primary">Export CSV</a>
      {% endif %}
    </div>

    <div class="card shadow-sm mb-4">
      <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
          <thead>
            <tr>
              <th scope="col">Data</th>
              <th scope="col">Tassonomia</th>
              <th scope="col">IUV</th>
              <th scope="col">IUR</th>
              <th scope="col">Stato</th>
              <th scope="col">Tipo</th>
              <th scope="col" class="text-end">Importo</th>
              <th scope="col"></th>
            </tr>
          </thead>
          <tbody>
            {% for row in rows %}
              <tr>
                <td>{{ row.data|default('')|slice(0, 10) }}</td>
                <td>{{ row.tassonomia_label|default(row.tassonomia|default('N/D')) }}</td>
                <td class="small">{{ row.iuv|default('') }}</td>
                <td class="small">{{ row.iur|default('') }}</td>
                <td>{{ row.stato|default('') }}</td>
                <td>{{ row.tipo|default('') }}</td>
                <td class="text-end">€ {{ row.importo|default(0)|number_format(2, ',', '.') }}</td>
                <td class="text-center">
                  {% if row.id_pendenza|default('') %}
                    <a href="/pendenze/dettaglio/{{ row.id_pendenza|url_encode }}" class="btn btn-outline-secondary btn-sm py-0 px-1" title="Apri dettaglio pendenza" target="_blank">
                      <i class="fas fa-external-link-alt fa-xs"></i>
                    </a>
                  {% elseif row.iuv|default('') %}
                    <a href="/pendenze/ricerca?iuv={{ row.iuv|url_encode }}&q=1" class="btn btn-outline-secondary btn-sm py-0 px-1" title="Cerca pendenza per IUV" target="_blank">
                      <i class="fas fa-external-link-alt fa-xs"></i>
                    </a>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  {% elseif query_made and (errors is not defined or not errors) %}
    <div class="alert alert-info">Nessun risultato trovato per i filtri selezionati.</div>
  {% endif %}

  {% if app_debug and meta %}
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-light border-bottom py-3">
        <span class="badge bg-warning text-dark">Debug</span>
        Parametri applicati
      </div>
      <div class="card-body">
        <ul class="mb-0">
          <li>Pagine API lette: {{ meta.pages_fetched|default(0) }}</li>
          <li>Chiamate API eseguite: {{ meta.raw_calls|default(0) }}</li>
          <li>Stati inclusi: {{ (meta.states|default([]))|join(', ') }}</li>
          <li>Tipi inclusi: {{ (meta.types|default([]))|join(', ') }}</li>
          <li>Tassonomie richieste: {{ (meta.taxonomies|default([]))|join(', ') }}</li>
        </ul>
      </div>
    </div>
  {% endif %}

  {% if app_debug %}
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-light border-bottom py-3 d-flex align-items-center gap-2">
        <span class="badge bg-warning text-dark">Debug</span>
        <span>Dati raw API /riscossioni</span>
        <button class="btn btn-sm btn-outline-secondary ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#rawPayload" aria-expanded="false" aria-controls="rawPayload">Mostra/Nascondi</button>
      </div>
      <div id="rawPayload" class="collapse">
        <div class="card-body">
          {% if raw_payload_json %}
            <pre class="small text-break mb-0">{{ raw_payload_json }}</pre>
          {% else %}
            <div class="small text-muted mb-0">Dati raw non disponibili (nessuna risposta API utile da mostrare).</div>
          {% endif %}
        </div>
      </div>
    </div>
  {% endif %}
{% endblock %}

{% block scripts %}
<script>
(function () {
  const tipologieEl = document.getElementById('tassonomie');
  if (tipologieEl && typeof TomSelect !== 'undefined') {
    new TomSelect(tipologieEl, {
      create: false,
      sortField: { field: 'text', direction: 'asc' },
      maxOptions: 10000,
      placeholder: 'Cerca tipologia...'
    });
  }

  const elDa = document.getElementById('dataDaVis');
  const elA = document.getElementById('dataAVis');
  const hidDa = document.getElementById('dataDa');
  const hidA = document.getElementById('dataA');

  if (elDa && elA && hidDa && hidA && typeof window.initBackofficeDatePicker !== 'undefined') {
    window.initBackofficeDatePicker(elDa, elA, hidDa, hidA);
  }
})();
</script>
{% endblock %}
