{% extends 'base.html.twig' %}

{% block title %}Report TEFA - GovPay{% endblock %}

{% block head %}
<style>
  .tefa-stat-card { border-left: 4px solid; }
  .tefa-stat-card.pending   { border-left-color: #ffc107; }
  .tefa-stat-card.processed { border-left-color: #198754; }
  .tefa-stat-card.error     { border-left-color: #dc3545; }
  .tefa-stat-card.skipped   { border-left-color: #6c757d; }
</style>
{% endblock %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-3">
  <h1 class="h4 mb-0"><i class="fas fa-building-columns me-2 text-primary"></i>Report TEFA</h1>
</div>

{% set is_admin = current_user.role in ['admin', 'superadmin'] %}

{# ── Contatori stato ──────────────────────────────────────────────────────── #}
<div class="row g-2 mb-3" id="tefa-counts">
  <div class="col-6 col-md-3">
    <div class="card tefa-stat-card pending shadow-sm px-3 py-2">
      <div class="small text-muted fw-semibold" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;">In attesa</div>
      <div class="fs-4 fw-bold text-warning" id="cnt-pending">{{ counts.PENDING }}</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card tefa-stat-card processed shadow-sm px-3 py-2">
      <div class="small text-muted fw-semibold" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;">Elaborati</div>
      <div class="fs-4 fw-bold text-success" id="cnt-processed">{{ counts.PROCESSED }}</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card tefa-stat-card error shadow-sm px-3 py-2">
      <div class="small text-muted fw-semibold" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;">Errori</div>
      <div class="fs-4 fw-bold text-danger" id="cnt-error">{{ counts.ERROR }}</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card tefa-stat-card skipped shadow-sm px-3 py-2">
      <div class="small text-muted fw-semibold" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;">Non TEFA</div>
      <div class="fs-4 fw-bold text-secondary" id="cnt-skipped">{{ counts.SKIPPED }}</div>
    </div>
  </div>
</div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3 bg-light p-2 rounded border" style="border-color: var(--border-color) !important;">
  <div class="text-muted small" id="poll-status" style="font-size: 13px;">
    {% if scanner_running %}
      {% if counts.PENDING > 0 %}
        <span class="text-success fw-semibold"><i class="fas fa-circle-play me-1"></i>Servizio TEFA attivo</span> — <i class="fas fa-circle-notch fa-spin me-1"></i>Elaborazione in corso ({{ counts.PENDING }} in attesa)...
      {% else %}
        <span class="text-success fw-semibold"><i class="fas fa-circle-check me-1"></i>Servizio TEFA attivo</span> — Nessun record in attesa.
      {% endif %}
    {% else %}
      {% if counts.PENDING > 0 %}
        <span class="text-danger fw-semibold"><i class="fas fa-circle-stop me-1"></i>Servizio TEFA arrestato</span> — {{ counts.PENDING }} record in attesa. <a href="/funzioni-avanzate/cron" class="fw-semibold text-decoration-underline" style="color:inherit;">Avvia il servizio nel pannello Cron</a> per elaborarli.
      {% else %}
        <span class="text-muted fw-semibold"><i class="fas fa-circle-minus me-1"></i>Servizio TEFA spento</span> — Nessun record in attesa.
      {% endif %}
    {% endif %}
  </div>
  {% if counts.SKIPPED > 0 and is_admin %}
    <button type="button" class="btn btn-xs btn-outline-secondary py-1" onclick="retrySkipped()">
      <i class="fas fa-rotate-right me-1"></i>Riprocessa non-TEFA ({{ counts.SKIPPED }})
    </button>
  {% endif %}
</div>

{# ── Anomalie ratio TEFA/Comune ───────────────────────────────────────────── #}
{% if anomaly_rows is defined and anomaly_rows|length > 0 %}
<div class="card shadow-sm mb-4" style="border: 1px solid #f0ad4e; border-left: 4px solid #f0ad4e;">
  <div class="card-header d-flex align-items-center justify-content-between py-2"
       style="background: linear-gradient(90deg, #fff8ec 0%, #fff 100%); border-bottom: 1px solid #f0e0b0;">
    <div class="d-flex align-items-center gap-2">
      <i class="fas fa-triangle-exclamation text-warning fs-5"></i>
      <span class="fw-semibold" style="color:#b45309;">Anomalie ratio TEFA/Comune</span>
      <span class="badge rounded-pill text-bg-warning ms-1">{{ anomaly_rows|length }}</span>
      <span class="text-muted small d-none d-md-inline ms-1">| Multibeneficiario con ratio fuori intervallo 1%–10%</span>
    </div>
    <button class="btn btn-sm btn-outline-warning" type="button"
            data-bs-toggle="collapse" data-bs-target="#anomalyPanel" aria-expanded="false"
            id="anomalyToggleBtn">
      <i class="fas fa-chevron-down me-1" id="anomalyToggleIcon"></i><span id="anomalyToggleLabel">Mostra</span>
    </button>
  </div>
  <div class="collapse" id="anomalyPanel">
    <div class="px-3 py-2 border-bottom small text-muted" style="background:#fff8ec;">
      Verificare caso per caso: <strong>Sì TEFA</strong> accetta il pagamento, <strong>Non TEFA</strong> conferma l'esclusione definitiva.
    </div>
    <div class="table-responsive">
      <table class="table table-sm table-hover align-middle mb-0" style="font-size: 0.875rem;">
        <thead style="background:#fef3c7; font-size:0.78rem; text-transform:uppercase; letter-spacing:.04em;">
          <tr>
            <th class="ps-3">Data</th>
            <th>Causale</th>
            <th class="text-end">Imp. TEFA (€)</th>
            <th class="text-end">Imp. Comune (€)</th>
            <th>Comune</th>
            <th class="text-end">Ratio</th>
            {% if is_admin %}<th class="text-center pe-3">Azione</th>{% endif %}
          </tr>
        </thead>
        <tbody id="anomalyTableBody">
          {% for row in anomaly_rows %}
          {% set ratio_val = (row.importo_comune is not null and row.importo_comune > 0 and row.importo_tefa is not null) ? (row.importo_tefa / row.importo_comune * 100) : null %}
          {% set nome_comune = row.denominazione_comune|default(row.cf_comune|default('')) %}
          {% set biz_data = {
              iur: row.iur,
              iuv: row.iuv|default(''),
              data_pagamento: row.data_pagamento|default(''),
              nominativo_debitore: row.nominativo_debitore|default(''),
              cf_debitore: row.cf_debitore|default(''),
              nominativo_pagante: row.nominativo_pagante|default(''),
              cf_pagante: row.cf_pagante|default(''),
              causale: row.causale|default(''),
              biz_company: row.biz_company|default(''),
              importo_tefa: row.importo_tefa,
              importo_comune: row.importo_comune,
              cf_comune: row.cf_comune|default(''),
              denom_comune: row.denominazione_comune|default(''),
              trasferimenti_json: row.trasferimenti_json|default('[]')
          } %}
          <tr id="anomaly-row-{{ row.id }}">
            <td class="ps-3 text-nowrap text-muted small">{{ row.data_pagamento|default('—') }}</td>
            <td style="max-width:220px;white-space:normal;font-size:.82rem;">
              <span class="text-muted">{{ row.causale|default('—') }}</span>
              <button type="button" class="btn btn-link p-0 ms-1 text-info js-anomaly-biz"
                      data-row="{{ biz_data|json_encode|e('html_attr') }}"
                      title="Visualizza dati Biz Events"
                      style="font-size:.75rem;vertical-align:baseline;line-height:1;">
                <i class="fas fa-search"></i>
              </button>
              <div class="text-muted" style="font-size:.7rem;margin-top:1px;"><code>{{ row.iur|slice(0, 18) }}…</code></div>
            </td>
            <td class="text-end fw-semibold">{{ row.importo_tefa is not null ? row.importo_tefa|number_format(2, ',', '.') : '—' }}</td>
            <td class="text-end fw-semibold">{{ row.importo_comune is not null ? row.importo_comune|number_format(2, ',', '.') : '—' }}</td>
            <td style="font-size:.82rem;">
              <div class="fw-semibold">{{ nome_comune != '' ? nome_comune : (row.cf_comune|default('—')) }}</div>
              {% if row.cf_comune and nome_comune != row.cf_comune %}<div class="text-muted" style="font-size:.72rem;">{{ row.cf_comune }}</div>{% endif %}
            </td>
            <td class="text-end">
              {% if ratio_val is not null %}
                {% if ratio_val < 2 or ratio_val > 8 %}
                  <span class="badge text-bg-danger">{{ ratio_val|number_format(1, ',', '.') }}%</span>
                {% else %}
                  <span class="badge text-bg-warning text-dark">{{ ratio_val|number_format(1, ',', '.') }}%</span>
                {% endif %}
              {% else %}—{% endif %}
            </td>
            {% if is_admin %}
            <td class="text-center pe-3 text-nowrap">
              <button class="btn btn-xs btn-outline-secondary me-1"
                      onclick="anomalyAction({{ row.id }}, 'skip')"
                      title="Conferma come non TEFA — esclusione definitiva">
                <i class="fas fa-ban me-1"></i>Non TEFA
              </button>
              <button class="btn btn-xs btn-success"
                      onclick="anomalyAction({{ row.id }}, 'accept')"
                      title="Accetta come TEFA nonostante il ratio anomalo">
                <i class="fas fa-check me-1"></i>Sì TEFA
              </button>
            </td>
            {% endif %}
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
<script>
(function(){
  var panel = document.getElementById('anomalyPanel');
  if (panel) {
    panel.addEventListener('show.bs.collapse', function(){
      document.getElementById('anomalyToggleIcon').classList.replace('fa-chevron-down','fa-chevron-up');
      document.getElementById('anomalyToggleLabel').textContent = 'Nascondi';
    });
    panel.addEventListener('hide.bs.collapse', function(){
      document.getElementById('anomalyToggleIcon').classList.replace('fa-chevron-up','fa-chevron-down');
      document.getElementById('anomalyToggleLabel').textContent = 'Mostra';
    });
  }

})();
</script>
{% endif %}

{# ── Tabella errori ───────────────────────────────────────────────────────── #}
{% if error_rows|length > 0 %}
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white d-flex align-items-center justify-content-between">
    <h6 class="mb-0 text-danger"><i class="fas fa-triangle-exclamation me-2"></i>Errori ({{ error_rows|length }})</h6>
    {% if is_admin %}
    <button type="button" class="btn btn-sm btn-outline-warning" onclick="retryErrors()">
      <i class="fas fa-rotate-right me-1"></i>Riprova tutti
    </button>
    {% endif %}
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-sm mb-0">
        <thead class="table-light"><tr>
          <th>IUR</th><th>IUV</th><th>Data pagamento</th><th>Importo</th><th>Motivo errore</th><th>Data errore</th>
        </tr></thead>
        <tbody>
        {% for r in error_rows %}
          <tr>
            <td class="font-monospace small">{{ r.iur }}</td>
            <td class="font-monospace small">{{ r.iuv }}</td>
            <td>{{ r.data_pagamento }}</td>
            <td>{{ r.importo_tefa ? '€ ' ~ r.importo_tefa|number_format(2, ',', '.') : '-' }}</td>
            <td class="text-danger small">{{ r.error_msg }}</td>
            <td class="small text-muted">{{ r.updated_at }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
{% endif %}

{# ── Report per Comune ────────────────────────────────────────────────────── #}
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white">
    <h5 class="mb-0"><i class="fas fa-chart-bar me-2 text-primary"></i>Report per Comune</h5>
  </div>
  <div class="card-body">
    <form method="GET" action="/pagamenti/report-tefa" class="mb-3">
      <input type="hidden" name="q" value="1">
      <div class="row g-2 align-items-center">
        <!-- Date fields column -->
        <div class="col-12 col-md-auto">
          <label class="form-label small fw-semibold mb-1">Intervallo date</label>
          <div class="d-flex gap-1 align-items-center" style="max-width: 290px;">
            <input type="text" id="rDaVis" class="form-control form-control-sm bo-cursor-pointer" placeholder="Da" autocomplete="off" style="width: 130px;">
            <span class="text-muted small">–</span>
            <input type="text" id="rAVis"  class="form-control form-control-sm bo-cursor-pointer" placeholder="A"  autocomplete="off" style="width: 130px;">
          </div>
          <input type="hidden" id="rDa" name="dataDa" value="{{ filters.dataDa }}">
          <input type="hidden" id="rA"  name="dataA"  value="{{ filters.dataA }}">
        </div>
        
        <!-- Quick selectors column -->
        <div class="col-12 col-md flex-grow-1 align-self-end mt-2 mt-md-0">
          <div class="bo-datepicker-quick-selects m-0" style="display: flex; gap: 4px; flex-wrap: wrap;">
            <button type="button" class="bo-datepicker-quick-btn" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('thisMonth')">Mese Corrente</button>
            <button type="button" class="bo-datepicker-quick-btn" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('lastMonth')">Mese Precedente</button>
            <button type="button" class="bo-datepicker-quick-btn" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('thisYear')">Anno Corrente</button>
            <button type="button" class="bo-datepicker-quick-btn" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('lastYear')">Anno Precedente</button>
            <button type="button" class="bo-datepicker-quick-btn btn-clear" onclick="if(typeof window.setBackofficeQuickRange!=='undefined') window.setBackofficeQuickRange('clear')">Azzera</button>
          </div>
        </div>
        
        <!-- Action buttons column -->
        <div class="col-12 col-md-auto align-self-end d-flex gap-2 mt-2 mt-md-0">
          <button type="submit" class="btn btn-primary btn-sm px-3"><i class="fas fa-search me-1"></i>Cerca</button>
          {% if query_made and report_rows|length > 0 %}
          <a href="/pagamenti/report-tefa?q=1&dataDa={{ filters.dataDa }}&dataA={{ filters.dataA }}&export=csv"
             class="btn btn-sm btn-outline-secondary px-3"><i class="fas fa-file-csv me-1"></i>CSV</a>
          {% endif %}
        </div>
      </div>
    </form>

    {% if query_made %}
      {# ── Copertura mensile e Legenda ───────────────────────────────────── #}
      {% set mesi_nomi = ['Gen','Feb','Mar','Apr','Mag','Giu','Lug','Ago','Set','Ott','Nov','Dic'] %}
      {% if coverage|length > 0 or (mancanti_periodi is defined and mancanti_periodi|length > 0) %}
      <div class="mb-3 bg-light p-2 rounded border" style="border-color: var(--border-color) !important;">
        <div class="d-flex flex-column gap-2">
          
          <!-- Row 1: Month status badges -->
          {% if coverage|length > 0 %}
          <div class="d-flex flex-wrap gap-1 align-items-center">
            <span class="fw-semibold text-muted me-1" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;">Scansione:</span>
            {% for c in coverage %}
              {% set pct_ok = c.n_total > 0 ? (c.n_processed / c.n_total * 100)|round : 0 %}
              {% if c.n_pending > 0 %}
                {% set cls = 'text-bg-warning' %}
                {% set tip = 'In attesa: ' ~ c.n_pending ~ '/' ~ c.n_total %}
              {% elseif c.n_error > 0 %}
                {% set cls = 'text-bg-danger' %}
                {% set tip = 'Errori: ' ~ c.n_error ~ '/' ~ c.n_total %}
              {% elseif c.n_processed > 0 %}
                {% set cls = 'text-bg-success' %}
                {% set tip = 'Elaborati: ' ~ c.n_processed ~ '/' ~ c.n_total %}
              {% else %}
                {% set cls = 'text-bg-secondary' %}
                {% set tip = 'Solo SKIPPED: ' ~ c.n_skipped %}
              {% endif %}
              <span class="badge {{ cls }}" title="{{ tip }}" style="font-size:.75rem;cursor:default;padding:2px 8px !important;">
                {{ mesi_nomi[c.mese - 1] }} {{ c.anno }}
              </span>
            {% endfor %}
          </div>
          {% endif %}
          
          <!-- Row 2: Warning periods & Legend inline -->
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 pt-2 border-top" style="border-top-color: var(--border-color) !important; font-size: 11px;">
            <!-- Non-scanned periods -->
            <div class="d-flex align-items-center">
              {% if mancanti_periodi is defined and mancanti_periodi|length > 0 %}
                <span class="text-warning-emphasis fw-semibold me-1">
                  <i class="fas fa-triangle-exclamation text-warning me-1"></i>
                  Mesi non scansionati:
                </span>
                <span class="text-muted">{{ mancanti_periodi|join(', ') }}</span>
              {% else %}
                <span class="text-success fw-semibold">
                  <i class="fas fa-circle-check me-1"></i>
                  Copertura scansione completa per il periodo selezionato.
                </span>
              {% endif %}
            </div>
            
            <!-- Legend (with states as badges directly) -->
            <div class="text-muted d-flex flex-wrap gap-2 align-items-center">
              <span class="fw-semibold text-muted">Legenda:</span>
              <span class="badge text-bg-success py-0.5 px-2" style="font-size: 10px; font-weight: 700; border-radius: 999px;">ELABORATO</span>
              <span class="badge text-bg-warning py-0.5 px-2" style="font-size: 10px; font-weight: 700; border-radius: 999px;">IN ATTESA</span>
              <span class="badge text-bg-danger py-0.5 px-2" style="font-size: 10px; font-weight: 700; border-radius: 999px;">ERRORI</span>
              <span class="badge text-bg-secondary py-0.5 px-2" style="font-size: 10px; font-weight: 700; border-radius: 999px;">SOLO SCARTATI</span>
            </div>
          </div>
          
        </div>
      </div>
      {% endif %}

      {% if report_rows|length == 0 %}
        <div class="alert alert-info py-2">Nessun dato TEFA elaborato per il periodo selezionato.</div>
      {% else %}
        <div class="table-responsive">
          <table class="table table-hover">
            <thead class="table-light">
              <tr>
                <th>Comune</th>
                <th>CF Comune</th>
                <th class="text-end">N. Pagamenti</th>
                <th class="text-end">Totale TEFA (€)</th>
                <th class="text-end">Totale Imp. Comune (€)</th>
              </tr>
            </thead>
            <tbody>
            {% for r in report_rows %}
              <tr>
                <td>{{ r.denominazione_comune ?: r.cf_comune }}</td>
                <td class="font-monospace small">{{ r.cf_comune }}</td>
                <td class="text-end">{{ r.n_pagamenti }}</td>
                <td class="text-end fw-semibold">{{ r.totale_tefa|number_format(2, ',', '.') }}</td>
                <td class="text-end">{{ r.totale_comune|number_format(2, ',', '.') }}</td>
              </tr>
            {% endfor %}
            </tbody>
            <tfoot class="table-light fw-bold">
              <tr>
                <td colspan="2">Totale</td>
                <td class="text-end">{{ report_rows|column('n_pagamenti')|reduce((a, b) => a + b, 0) }}</td>
                <td class="text-end">{{ totali_tefa|number_format(2, ',', '.') }}</td>
                <td class="text-end">{{ totali_comune|number_format(2, ',', '.') }}</td>
              </tr>
            </tfoot>
          </table>
        </div>
      {% endif %}
    {% endif %}
  </div>
</div>
{# ── Biz Events modal (anomalie) ──────────────────────────────────────────── #}
<div class="modal fade" id="bizAnomalyModal" tabindex="-1" aria-labelledby="bizAnomalyModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="bizAnomalyModalLabel"><i class="fas fa-receipt me-2"></i>Ricevuta Biz Events</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Chiudi"></button>
      </div>
      <div class="modal-body" id="bizAnomalyModalBody">
        <p class="text-center text-muted py-4"><i class="fas fa-spinner fa-spin me-2"></i>Caricamento...</p>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
(function () {
  // ── Litepicker report ─────────────────────────────────────────────────────
  const elDa  = document.getElementById('rDaVis');
  const elA   = document.getElementById('rAVis');
  const hidDa = document.getElementById('rDa');
  const hidA  = document.getElementById('rA');
  if (elDa && elA && hidDa && hidA && typeof window.initBackofficeDatePicker !== 'undefined') {
    window.initBackofficeDatePicker(elDa, elA, hidDa, hidA);
  }

  // ── Polling contatori ─────────────────────────────────────────────────────
  var pollInterval = null;
  var pendingCount = {{ counts.PENDING|default(0) }};

  function updateCounts(c, running) {
    document.getElementById('cnt-pending').textContent   = c.PENDING   ?? 0;
    document.getElementById('cnt-processed').textContent = c.PROCESSED ?? 0;
    document.getElementById('cnt-error').textContent     = c.ERROR     ?? 0;
    document.getElementById('cnt-skipped').textContent   = c.SKIPPED   ?? 0;
    
    var ps = document.getElementById('poll-status');
    var pending = c.PENDING ?? 0;
    
    if (running) {
      if (pending > 0) {
        ps.innerHTML = '<span class="text-success fw-semibold"><i class="fas fa-circle-play me-1"></i>Servizio TEFA attivo</span> — <i class="fas fa-circle-notch fa-spin me-1"></i>Elaborazione in corso (' + pending + ' in attesa)...';
      } else {
        ps.innerHTML = '<span class="text-success fw-semibold"><i class="fas fa-circle-check me-1"></i>Servizio TEFA attivo</span> — Nessun record in attesa.';
      }
    } else {
      if (pending > 0) {
        ps.innerHTML = '<span class="text-danger fw-semibold"><i class="fas fa-circle-stop me-1"></i>Servizio TEFA arrestato</span> — ' + pending + ' record in attesa. <a href="/funzioni-avanzate/cron" class="fw-semibold text-decoration-underline" style="color:inherit;">Avvia il servizio nel pannello Cron</a> per elabolarli.';
      } else {
        ps.innerHTML = '<span class="text-muted fw-semibold"><i class="fas fa-circle-minus me-1"></i>Servizio TEFA spento</span> — Nessun record in attesa.';
      }
    }
  }

  function pollStatus() {
    fetch('/pagamenti/report-tefa/status')
      .then(r => r.json())
      .then(d => { if (d.ok) updateCounts(d.counts, d.scanner_running); })
      .catch(() => {});
  }

  if (pendingCount > 0 || {{ scanner_running ? 'true' : 'false' }}) {
    pollInterval = setInterval(pollStatus, 15000);
  }

  window.retryErrors = function () {
    fetch('/pagamenti/report-tefa/retry-errors', { method: 'POST' })
      .then(r => r.json())
      .then(d => { if (d.ok) { alert(d.reset + ' errori reimpostati come PENDING.'); pollStatus(); } })
      .catch(() => {});
  };

  window.retrySkipped = function () {
    if (!confirm('Rimettere in coda tutti i record non-TEFA? Verranno ri-elaborati.')) return;
    fetch('/pagamenti/report-tefa/retry-skipped', { method: 'POST' })
      .then(r => r.json())
      .then(d => { if (d.ok) { alert(d.reset + ' record rimessi in coda.'); location.reload(); } })
      .catch(() => {});
  };

  window.anomalyAction = function (id, action) {
    var label = action === 'accept' ? 'Accettare questa pendenza come TEFA nonostante il ratio anomalo?' : 'Confermare questa pendenza come non TEFA?';
    if (!confirm(label)) return;
    fetch('/pagamenti/report-tefa/anomaly/' + id + '/' + action, { method: 'POST' })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (d.ok) {
          var row = document.getElementById('anomaly-row-' + id);
          if (row) row.remove();
          var tbody = document.getElementById('anomalyTableBody');
          if (tbody && tbody.rows.length === 0) {
            var panel = document.getElementById('anomalyPanel');
            if (panel) panel.closest('.card').remove();
          }
        } else {
          alert('Errore: ' + (d.error || 'sconosciuto'));
        }
      })
      .catch(function () { alert('Errore di rete.'); });
  };
})();
</script>

<script>
// ── Biz Events modal per anomalie TEFA (dati locali da biz_ricevute) ──────
(function () {
  function escHtml(str) {
    if (!str) return '';
    var d = document.createElement('div');
    d.appendChild(document.createTextNode(str));
    return d.innerHTML;
  }

  function dlRow(label, value) {
    return '<dt class="col-sm-5 text-muted">' + escHtml(label) + '</dt>'
      + '<dd class="col-sm-7 text-break">' + (value ? escHtml(String(value)) : '—') + '</dd>';
  }

  function fmtAmt(val) {
    var n = parseFloat(val);
    return isNaN(n) ? '—' : n.toLocaleString('it-IT', {minimumFractionDigits: 2}) + ' €';
  }

  function buildHtml(d) {
    var html = '<div class="row g-3">'
      + '<div class="col-12 col-md-6"><h6 class="text-secondary text-uppercase mb-2">Debitore</h6><dl class="row mb-0 small">'
      + dlRow('Nome', d.nominativo_debitore) + dlRow('Codice fiscale', d.cf_debitore)
      + '</dl></div>'
      + '<div class="col-12 col-md-6"><h6 class="text-secondary text-uppercase mb-2">Pagatore</h6><dl class="row mb-0 small">'
      + dlRow('Nome', d.nominativo_pagante) + dlRow('Codice fiscale', d.cf_pagante)
      + '</dl></div></div><hr>'
      + '<div class="row g-3"><div class="col-12 col-md-6"><h6 class="text-secondary text-uppercase mb-2">Dettagli pagamento</h6><dl class="row mb-0 small">'
      + dlRow('IUR', d.iur)
      + dlRow('IUV', d.iuv)
      + dlRow('Data', d.data_pagamento)
      + dlRow('Descrizione', d.causale)
      + (d.biz_company ? dlRow('Ente', d.biz_company) : '')
      + '</dl></div>'
      + '<div class="col-12 col-md-6"><h6 class="text-secondary text-uppercase mb-2">Trasferimenti</h6><dl class="row mb-0 small">'
      + dlRow('Imp. Provincia (TEFA)', fmtAmt(d.importo_tefa))
      + dlRow('Imp. Comune', fmtAmt(d.importo_comune))
      + dlRow('CF Comune', d.cf_comune)
      + dlRow('Comune', d.denom_comune)
      + '</dl></div></div>';

    try {
      var trs = JSON.parse(d.trasferimenti_json || '[]');
      if (trs.length > 0) {
        html += '<hr><h6 class="text-secondary text-uppercase mb-2">Dettaglio trasferimenti (' + trs.length + ')</h6>'
          + '<div class="table-responsive"><table class="table table-sm table-bordered small mb-0">'
          + '<thead class="table-light"><tr><th>#</th><th>CF Beneficiario</th><th class="text-end">Importo</th><th>Causale</th><th>IBAN</th></tr></thead><tbody>';
        for (var i = 0; i < trs.length; i++) {
          var tr = trs[i];
          html += '<tr><td>' + (i + 1) + '</td>'
            + '<td class="font-monospace small">' + escHtml(tr.fiscal_code_pa || '—') + '</td>'
            + '<td class="text-end text-nowrap">' + fmtAmt(tr.transfer_amount) + '</td>'
            + '<td>' + escHtml(tr.remittance_information || '—') + '</td>'
            + '<td class="text-break small">' + escHtml(tr.iban || '—') + '</td></tr>';
        }
        html += '</tbody></table></div>';
      }
    } catch (e) {}

    return html;
  }

  document.addEventListener('DOMContentLoaded', function () {
    var modalEl   = document.getElementById('bizAnomalyModal');
    var modalBody = document.getElementById('bizAnomalyModalBody');
    if (!modalEl || !modalBody) return;
    var bsModal = new bootstrap.Modal(modalEl);

    document.addEventListener('click', function (e) {
      var btn = e.target.closest('.js-anomaly-biz');
      if (!btn) return;
      try {
        var data = JSON.parse(btn.getAttribute('data-row') || '{}');
        modalBody.innerHTML = buildHtml(data);
      } catch (ex) {
        modalBody.innerHTML = '<div class="alert alert-warning">Dati non disponibili.</div>';
      }
      bsModal.show();
    });
  });
})();
</script>
{% endblock %}
