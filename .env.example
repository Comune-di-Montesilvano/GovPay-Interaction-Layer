# ─────────────────────────────────────────────────────────────────────────────
# GovPay Interaction Layer — variabili di bootstrap
#
# Queste sono le UNICHE variabili da configurare in .env (o in Portainer come
# Environment variables per lo stack). Tutto il resto si configura dall'interfaccia
# Backoffice → Impostazioni e viene salvato nel database.
#
# In Portainer: Stacks → <stack> → Editor → Environment variables
# In locale: copia in .env e personalizza i valori
# ─────────────────────────────────────────────────────────────────────────────

# Versione immagini Docker (tag su GHCR).
# Esempi: latest, v1.0.0-alpha, v1.1.0
APP_VERSION=latest

# ─────────────────────────────────────────────────────────────────────────────
# APACHE / SSL
# ─────────────────────────────────────────────────────────────────────────────
APACHE_SERVER_NAME=localhost
# SSL=on  abilita HTTPS su Apache (richiede certificati nel volume gil_ssl_certs)
# SSL=off disabilita SSL (utile dietro reverse proxy)
SSL=off
# Override opzionale dell'URL interno backoffice (usato da auth-proxy e frontoffice).
# Regola automatica: SSL=on → https://backoffice:80 | SSL!=on → http://backoffice
# Lasciare commentato nella maggior parte dei casi:
# BACKOFFICE_INTERNAL_URL=https://backoffice:80

# URL interno IDP metadata SAML2 usato dal frontoffice (default: HTTP).
# Con SSL=on auth-proxy-nginx serve HTTPS su porta 80 → impostare:
# AUTH_PROXY_SAML2_IDP_METADATA_URL_INTERNAL=https://auth-proxy-nginx:80/Saml2IDP/metadata

# Porte esposte sull'host
BACKOFFICE_HTTP_PORT=8443
FRONTOFFICE_HTTP_PORT=8444
#AUTH_PROXY_PORT=9445

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — OBBLIGATORIO impostare tutte le variabili prima del primo avvio
# ─────────────────────────────────────────────────────────────────────────────
DB_NAME=govpay
DB_ROOT_PASSWORD=cambia_con_password_sicura

# Utente backoffice (lettura/scrittura)
BACKOFFICE_DB_USER=govpay
BACKOFFICE_DB_PASSWORD=cambia_con_password_sicura

# Utente frontoffice (sola lettura)
FRONTOFFICE_DB_USER=govpay_cittadini
FRONTOFFICE_DB_PASSWORD=cambia_con_password_sicura

# ─────────────────────────────────────────────────────────────────────────────
# CHIAVE DI CIFRATURA — usata per cifrare segreti nel DB (app IO, chiavi SATOSA…)
# Deve essere esattamente 32 caratteri. Genera con: openssl rand -hex 16
# ─────────────────────────────────────────────────────────────────────────────
APP_ENCRYPTION_KEY=cambia_con_32_caratteri_esatti_ok

# ─────────────────────────────────────────────────────────────────────────────
# MASTER TOKEN — token condiviso per comunicazione interna backoffice ↔ auth-proxy
# Usato dagli endpoint /api/auth-proxy/env e /api/frontoffice/config del backoffice.
# Genera con: openssl rand -hex 24
# ─────────────────────────────────────────────────────────────────────────────
MASTER_TOKEN=cambia_con_token_sicuro_48_chars

# ─────────────────────────────────────────────────────────────────────────────
# VOLUME SPID (opzionale — default: govpay_spid_certs)
# ─────────────────────────────────────────────────────────────────────────────
# SPID_CERTS_DOCKER_VOLUME=govpay_spid_certs

# ─────────────────────────────────────────────────────────────────────────────
# AUTH PROXY (SATOSA) — tuning infrastrutturale
# Le variabili applicative (ENABLE_SPID, ENABLE_CIE_OIDC, URL pubblici SATOSA,
# dati organizzazione, ecc.) si configurano via Backoffice → Impostazioni → Login Proxy.
# ─────────────────────────────────────────────────────────────────────────────

# Intervallo (secondi) con cui auth-proxy verifica la config backoffice
# e gestisce avvio/stop di SATOSA. Default: 60.
#AUTH_PROXY_WATCHDOG_INTERVAL=60

# Intervallo (secondi) con cui frontoffice verifica la config backoffice
# e invia graceful reload ad Apache. Default: 300 (5 minuti).
#FRONTOFFICE_WATCHDOG_INTERVAL=300

# URL interno del metadata-builder (HTTP server sulla porta 8081).
# Usato dal backoffice per export-agid e export-cieoidc.
# Default automatico se lasciato commentato.
#METADATA_BUILDER_INTERNAL_URL=http://metadata-builder:8081

# Resolver DNS usato da auth-proxy-nginx per risolvere il servizio auth-proxy.
# Docker di default: 127.0.0.11. In Podman rootless impostare il DNS della rete podman
# (esempio frequente: 10.89.0.1) se nei log nginx compare "resolver 127.0.0.11".
#NGINX_DNS_RESOLVER=10.89.0.1

# ─────────────────────────────────────────────────────────────────────────────
# MONGODB — credenziali per auth-proxy-db (backend CIE OIDC)
# Necessario se ENABLE_CIE_OIDC=true (configurato via Backoffice → Login Proxy).
# Genera password sicura con: openssl rand -hex 16
# ─────────────────────────────────────────────────────────────────────────────
MONGODB_USERNAME=satosa_user
MONGODB_PASSWORD=cambia_con_password_sicura
MONGODB_DB=satosa
